{
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:lang(es|en|de|fr|it|nl)/real-estate",
      "destination": "/:lang/properties",
      "permanent": true
    },
    {
      "source": "/:lang(es|en|de|fr|it|nl)/real-estate/",
      "destination": "/:lang/properties/",
      "permanent": true
    }
  ]
}
