---
import BaseLayout from "@webapp/layouts/BaseLayout.astro";
import RichContent from "@webapp/components/RichContent.astro";
import PropertyHero from "@webapp/components/PropertyHero.astro";
import GallerySection from "@webapp/components/GallerySection.astro";
import MapboxCostaMap from "@webapp/components/MapboxCostaMap.astro";

import { SEO_LANDING_CITIES, SEO_LANDING_TYPES } from "@shared/config/seoSlugs";
import { formatPrice } from "@shared/presentation/common";
import {
  normalizeProperty,
  normalizePropertyCard,
} from "@shared/properties/public";
import { appendCatalogFiltersToSearchParams } from "@shared/properties/catalogFilters";
import { resolvePropertyLanding } from "@shared/seo/resolvePropertyLanding";
import { DEFAULT_LANG, isSupportedLang } from "@shared/i18n/languages";
import { getPublicPropertiesWithFallback } from "@shared/properties/public";
import { buildPropertyMapFeature } from "@shared/properties/compactMapFeatures";
import { buildPublicNavigation } from "@webapp/navigation/publicNavigation";
import "@webapp/styles/components/property-detail.css";

/* =========================
   PARAMS
========================= */
const { slug, lang: langParam } = Astro.params;
const lang = typeof langParam === "string" ? langParam : DEFAULT_LANG;
if (!isSupportedLang(lang)) {
  return Astro.redirect(`/${DEFAULT_LANG}/`, 302);
}
const requestedSlug = String(slug ?? "").trim();
const [{ properties: navPromotions }, { properties: propertyByLangMatches }] = await Promise.all([
  getPublicPropertiesWithFallback({
    query: {
      listingTypes: ["promotion"],
      onlyOwnProjects: true,
      selectProfile: "card",
    },
  }),
  getPublicPropertiesWithFallback({
    query: {
      slug: requestedSlug,
      slugLang: lang,
      limit: 1,
    },
  }),
]);
const navProjectIds = navPromotions
  .map((property) => String(property.id ?? "").trim())
  .filter(Boolean);
const { properties: navProjectUnits } = navProjectIds.length
  ? await getPublicPropertiesWithFallback({
      query: {
        listingTypes: ["unit"],
        parentIds: navProjectIds,
        selectProfile: "card",
      },
    })
  : { properties: [] };
const navigation = buildPublicNavigation({
  lang,
  family: "catalog",
  section: "property-detail",
  properties: [...navPromotions, ...navProjectUnits],
});

const agent = {
  phone: "+34 600 123 456",
  email: "info@blancareal.com",
};

/* =========================
   RESOLVE PROPERTY
========================= */
const propertyByLangSlug = propertyByLangMatches[0] ?? null;
let fallbackProperties = [] as any[];
if (!propertyByLangSlug) {
  const { properties } = await getPublicPropertiesWithFallback({});
  fallbackProperties = properties;
}

const propertyByAnySlug = propertyByLangSlug
  ? null
  : fallbackProperties.find((property) => Object.values(property.slugs ?? {}).includes(requestedSlug));

if (!propertyByLangSlug && propertyByAnySlug?.slugs?.[lang]) {
  return Astro.redirect(`/${lang}/property/${propertyByAnySlug.slugs[lang]}/`, 302);
}

const property = propertyByLangSlug ?? propertyByAnySlug;

if (!property) {
  throw new Error(`Property not found: ${lang}/${slug}`);
}
const propertyLegacyCode = String(property.legacy_code ?? property.id ?? slug).trim();

const [parentPropertyResult, projectUnitsResult] = await Promise.all([
  property.parent_id
    ? getPublicPropertiesWithFallback({
        query: {
          ids: [String(property.parent_id)],
          limit: 1,
        },
      })
    : Promise.resolve({ properties: [] }),
  property.listing_type === "promotion"
    ? getPublicPropertiesWithFallback({
        query: {
          listingTypes: ["unit"],
          parentIds: [String(property.id)],
        },
      })
    : Promise.resolve({ properties: [] }),
]);
const parentProperty = parentPropertyResult.properties[0] ?? null;
const propertyTranslations = property.translations ?? {};
const propertyLangTranslation = propertyTranslations?.[lang] ?? {};
const parentLangTranslation = parentProperty?.translations?.[lang] ?? {};
const hasOwnDescription =
  Array.isArray(propertyLangTranslation?.description) && propertyLangTranslation.description.length > 0;
const resolvedTranslations =
  !hasOwnDescription &&
  Array.isArray(parentLangTranslation?.description) &&
  parentLangTranslation.description.length > 0
    ? {
        ...propertyTranslations,
        [lang]: {
          ...parentLangTranslation,
          ...propertyLangTranslation,
          description: parentLangTranslation.description,
        },
      }
    : propertyTranslations;

const ownGallery = property.media?.gallery ?? {};
const galleryKeys = ["exterior", "interior", "views", "floorplan", "living", "bedroom", "kitchen", "bathroom"];
const getGalleryList = (source, key) => (Array.isArray(source?.[key]) ? source[key] : []);
const hasAnyOwnGallery = galleryKeys.some((key) => getGalleryList(ownGallery, key).length > 0);
const selectGalleryCategory = (key) =>
  hasAnyOwnGallery
    ? getGalleryList(property.media?.gallery, key)
    : getGalleryList(parentProperty?.media?.gallery, key);

const resolvedMedia = {
  ...(parentProperty?.media ?? {}),
  ...(property.media ?? {}),
  cover: property.media?.cover ?? parentProperty?.media?.cover ?? null,
  gallery: {
    ...(parentProperty?.media?.gallery ?? {}),
    ...(property.media?.gallery ?? {}),
    exterior: selectGalleryCategory("exterior"),
    interior: selectGalleryCategory("interior"),
    views: selectGalleryCategory("views"),
    floorplan: selectGalleryCategory("floorplan"),
    living: selectGalleryCategory("living"),
    bedroom: selectGalleryCategory("bedroom"),
    kitchen: selectGalleryCategory("kitchen"),
    bathroom: selectGalleryCategory("bathroom"),
  },
};

const propertyResolved = {
  ...property,
  translations: resolvedTranslations,
  media: resolvedMedia,
};

/* =========================
   NORMALIZATION
========================= */
const data = normalizeProperty(propertyResolved, lang);
const propertyCard = normalizePropertyCard(propertyResolved, lang);

if (!data || !data.visible) {
  throw new Error(`Property is private or not available: ${lang}/${slug}`);
}

/* =========================
   SAFE DERIVED DATA
========================= */
const canonicalUrl = `https://blancareal.com/${lang}/property/${slug}/`;
const propertyLangs = Array.isArray(property.languages) && property.languages.length
  ? property.languages
  : [lang];

const isPromotion = data.isPromotion ?? property.listing_type === "promotion";

const allProjectUnitsRaw = isPromotion
  ? projectUnitsResult.properties.filter((p) => (p.status ?? "available") !== "private")
  : [];

const unitsRaw = allProjectUnitsRaw.filter(
  (p) => (p.status ?? "available") === "available" && p.slugs?.[lang]
);

const units = unitsRaw
  .map((unit) => ({
    raw: unit,
    data: normalizeProperty(unit, lang),
  }))
  .filter((unit) => unit.data && unit.data.visible && unit.raw?.slugs?.[lang]);

const getUnitNumber = (unit) => {
  const id = unit?.raw?.id ?? "";
  if (id.includes("-")) return id.split("-").pop();
  return id || "-";
};

const getNumericRange = (values) => {
  if (!values.length) return null;
  const min = Math.min(...values);
  const max = Math.max(...values);
  return { min, max };
};

const projectSummary = (() => {
  if (!isPromotion || !allProjectUnitsRaw.length) return null;

  const soldCount = allProjectUnitsRaw.filter((unit) => unit.status === "sold").length;
  const availableCount = allProjectUnitsRaw.filter(
    (unit) => (unit.status ?? "available") === "available"
  ).length;

  const priceRange = getNumericRange(
    allProjectUnitsRaw
      .filter((unit) => (unit.status ?? "available") === "available")
      .map((unit) => unit.price)
      .filter((value) => typeof value === "number")
  );

  const bedroomsRange = getNumericRange(
    allProjectUnitsRaw
      .map((unit) => unit.property?.bedrooms)
      .filter((value) => typeof value === "number")
  );

  const areaRange = getNumericRange(
    allProjectUnitsRaw
      .map((unit) => unit.property?.area_m2)
      .filter((value) => typeof value === "number")
  );

  const terraceRange = getNumericRange(
    allProjectUnitsRaw
      .map((unit) => unit.property?.terrace_m2)
      .filter((value) => typeof value === "number")
  );

  return {
    unitsCount: allProjectUnitsRaw.length,
    soldCount,
    availableCount,
    priceRange,
    bedroomsRange,
    areaRange,
    terraceRange,
    deliveryYear: property.property?.year_built ?? null,
  };
})();
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN ?? "";
const mapboxStyle = import.meta.env.PUBLIC_MAPBOX_STYLE ?? "mapbox://styles/mapbox/streets-v12";
const propertyMapFeatureResult = buildPropertyMapFeature({
  property: propertyResolved,
  parentProperty,
  card: propertyCard,
  lang,
  availableUnitsCount: isPromotion ? units.length : null,
});
const propertyMapFeatures = propertyMapFeatureResult.feature ? [propertyMapFeatureResult.feature] : [];

const formatRangeValue = (range, decimals = 0) => {
  if (!range) return null;
  const min = decimals > 0 ? range.min.toFixed(decimals) : Math.round(range.min);
  const max = decimals > 0 ? range.max.toFixed(decimals) : Math.round(range.max);
  if (min === max) return String(min);
  return `${min}-${max}`;
};

const getUnitFloorLabel = (unit) => {
  const raw = unit?.raw?.property ?? {};
  if (typeof raw.floor_label === "string" && raw.floor_label.trim().length > 0) {
    return raw.floor_label;
  }
  if (typeof raw.floor_level === "number") {
    return `P${raw.floor_level}`;
  }
  return "-";
};

const getUnitFloorplanUrl = (unit) => {
  const plans = unit?.raw?.media?.gallery?.floorplan ?? [];
  const firstPdf = plans.find((item) =>
    typeof item?.url === "string" && item.url.toLowerCase().endsWith(".pdf")
  );
  return firstPdf?.url ?? null;
};

