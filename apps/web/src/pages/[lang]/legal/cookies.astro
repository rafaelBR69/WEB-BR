const t = copyByLang[lang] ?? copyByLang.en;
---

<BaseLayout title={t.title} description={t.description} lang={lang} availableLangs={SUPPORTED_LANGS} {...navigation}>
  <main class="legal-doc-page">
    <div class="legal-doc-shell">
      <section class="legal-doc-hero">
        <p class="legal-doc-eyebrow">{t.eyebrow}</p>
        <h1>{t.heading}</h1>
        <p>{t.intro}</p>
        <div class="legal-doc-meta">
          <span>{t.updated}</span>
          <span>{t.meta}</span>
        </div>
      </section>

      <div class="legal-doc-grid">
        {t.sections.map((section) => (
          <article class="legal-doc-card">
            <h2>{section.title}</h2>
            {Array.isArray(section.paragraphs) &&
              section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            {Array.isArray(section.items) && (
              <ul>
                {section.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
          </article>
        ))}

        <article class="legal-doc-card legal-doc-card-table">
          <h2>{t.tableTitle}</h2>
          <div class="legal-doc-table-wrap">
            <table class="legal-doc-table">
              <thead>
                <tr>
                  {t.tableColumns.map((column) => (
                    <th>{column}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {t.rows.map((row) => (
                  <tr>
                    {row.map((cell) => (
                      <td>{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </article>

        <article class="legal-doc-card">
          <h2>{t.manageTitle}</h2>
          {t.manageParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>

        <article class="legal-doc-card">
          <h2>{t.contactTitle}</h2>
          <p>{COMPANY.tradeName}</p>
          <p>{COMPANY.legalName}</p>
          <p>CIF {COMPANY.vatId}</p>
          <p>{COMPANY.address}</p>
          <p>{COMPANY.registry}</p>
          <div class="legal-doc-contact">
            <a href={`mailto:${COMPANY.email}`}>{COMPANY.email}</a>
            <a href={`tel:${COMPANY.phone.replace(/\s+/g, "")}`}>{COMPANY.phone}</a>
          </div>
        </article>
      </div>
    </div>
  </main>
</BaseLayout>
