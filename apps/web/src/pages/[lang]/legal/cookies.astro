---
export const prerender = false;

import BaseLayout from "@webapp/layouts/BaseLayout.astro";
import { DEFAULT_LANG, isSupportedLang, SUPPORTED_LANGS } from "@shared/i18n/languages";
import { buildPublicNavigation } from "@webapp/navigation/publicNavigation";
import "@webapp/styles/pages/legal-docs.css";

const langParam = Astro.params.lang ?? DEFAULT_LANG;

if (!isSupportedLang(langParam)) {
  return Astro.redirect(`/${DEFAULT_LANG}/legal/cookies/`, 302);
}

const lang = langParam;
const navigation = buildPublicNavigation({
  lang,
  family: "editorial",
  section: "legal",
});
const CONTACT_EMAIL = "info@blancareal.com";

const copyByLang = {
  es: {
    title: "Politica de cookies | BlancaReal",
    description:
      "Politica de cookies de BlancaReal con categorias, finalidades, base de consentimiento y gestion de preferencias.",
    eyebrow: "Legal",
    heading: "Politica de cookies",
    intro:
      "Esta politica describe las cookies y tecnologias similares que pueden utilizarse en la web de BlancaReal, la finalidad de cada categoria y la forma de aceptar, rechazar o revisar las preferencias de consentimiento.",
    updated: "Actualizado en marzo de 2026",
    meta: "BlancaReal · Mijas Costa · Costa del Sol",
    sections: [
      {
        title: "1. Que son las cookies",
        paragraphs: [
          "Las cookies son pequenos archivos de texto o identificadores similares que se almacenan en el navegador o dispositivo cuando visitas una web. Sirven para recordar preferencias, mantener funciones tecnicas, medir el uso del sitio o activar integraciones de terceros cuando el usuario lo permite.",
        ],
      },
      {
        title: "2. Como usamos las cookies",
        paragraphs: [
          "BlancaReal clasifica las cookies en necesarias, analiticas y de marketing. Las necesarias pueden ejecutarse para que la web funcione correctamente. Las cookies analiticas o de marketing no deben activarse hasta que el usuario haya otorgado su consentimiento a traves del gestor de consentimiento configurado en el sitio.",
        ],
      },
      {
        title: "3. Categorias de cookies",
        items: [
          "Necesarias: hacen posible funciones tecnicas basicas, seguridad, navegacion y almacenamiento del estado de consentimiento.",
          "Analiticas: permiten medir uso, rendimiento y comportamiento agregado del sitio para mejorar contenidos y conversion.",
          "Marketing: permiten activar etiquetas publicitarias, remarketing o medicion de campanas en plataformas de terceros.",
        ],
      },
    ],
    tableTitle: "Inventario y estado actual",
    tableColumns: ["Categoria", "Cookie / tecnologia", "Dominio", "Duracion", "Finalidad"],
    rows: [
      ["Necesaria", "cookieyes-consent", "blancareal.com", "12 meses", "Guardar las preferencias de consentimiento del usuario cuando el CMP este activo."],
      ["Necesaria", "Cookies tecnicas propias", "blancareal.com", "Sesion o variable", "Permitir la navegacion, formularios, seguridad basica y funcionamiento de la interfaz."],
      ["Analitica", "No activada sin consentimiento", "N/A", "N/A", "BlancaReal no debe disparar analitica hasta que exista consentimiento valido."],
      ["Marketing", "No activada sin consentimiento", "N/A", "N/A", "BlancaReal no debe disparar etiquetas publicitarias o remarketing sin consentimiento valido."],
    ],
    manageTitle: "4. Gestion de preferencias",
    manageParagraphs: [
      "Puedes aceptar, rechazar o revisar las categorias de cookies desde el banner o panel de preferencias del sitio cuando este disponible. Ademas, siempre puedes modificar la configuracion de cookies desde tu navegador.",
      "Si desactivas determinadas cookies necesarias, es posible que algunas funciones del sitio no se comporten correctamente.",
    ],
    contactTitle: "5. Contacto",
  },
  en: {
    title: "Cookie policy | BlancaReal",
    description:
      "BlancaReal cookie policy with categories, purposes, consent basis and preference management.",
    eyebrow: "Legal",
    heading: "Cookie policy",
    intro:
      "This policy describes the cookies and similar technologies that may be used on the BlancaReal website, the purpose of each category and how users can accept, reject or review their consent preferences.",
    updated: "Updated in March 2026",
    meta: "BlancaReal · Mijas Costa · Costa del Sol",
    sections: [
      {
        title: "1. What cookies are",
        paragraphs: [
          "Cookies are small text files or similar identifiers stored in the browser or device when a user visits a website. They can be used to remember preferences, maintain technical functions, measure site usage or activate third-party integrations where consent has been granted.",
        ],
      },
      {
        title: "2. How we use cookies",
        paragraphs: [
          "BlancaReal classifies cookies as necessary, analytics and marketing. Necessary cookies may run in order for the site to work correctly. Analytics and marketing cookies must not be activated until the user has granted consent through the consent manager configured on the site.",
        ],
      },
      {
        title: "3. Cookie categories",
        items: [
          "Necessary: support technical operation, security, navigation and storage of the user's consent status.",
          "Analytics: measure site usage, performance and aggregated behaviour in order to improve content and conversion.",
          "Marketing: enable advertising tags, remarketing or campaign measurement in third-party platforms.",
        ],
      },
    ],
    tableTitle: "Current inventory and status",
    tableColumns: ["Category", "Cookie / technology", "Domain", "Duration", "Purpose"],
    rows: [
      ["Necessary", "cookieyes-consent", "blancareal.com", "12 months", "Stores user consent preferences when the CMP is active."],
      ["Necessary", "First-party technical cookies", "blancareal.com", "Session or variable", "Enable navigation, forms, basic security and interface behaviour."],
      ["Analytics", "Not activated without consent", "N/A", "N/A", "BlancaReal must not trigger analytics until valid consent exists."],
      ["Marketing", "Not activated without consent", "N/A", "N/A", "BlancaReal must not trigger advertising or remarketing tags without valid consent."],
    ],
    manageTitle: "4. Preference management",
    manageParagraphs: [
      "Users may accept, reject or review cookie categories from the site banner or preferences panel when available. Cookie settings can also be modified directly in the browser.",
      "If some necessary cookies are disabled, parts of the site may stop working correctly.",
    ],
    contactTitle: "5. Contact",
  },
};

const t = copyByLang[lang] ?? copyByLang.en;
---

<BaseLayout title={t.title} description={t.description} lang={lang} availableLangs={SUPPORTED_LANGS} {...navigation}>
  <main class="legal-doc-page">
    <div class="legal-doc-shell">
      <section class="legal-doc-hero">
        <p class="legal-doc-eyebrow">{t.eyebrow}</p>
        <h1>{t.heading}</h1>
        <p>{t.intro}</p>
        <div class="legal-doc-meta">
          <span>{t.updated}</span>
          <span>{t.meta}</span>
        </div>
      </section>

      <div class="legal-doc-grid">
        {t.sections.map((section) => (
          <article class="legal-doc-card">
            <h2>{section.title}</h2>
            {Array.isArray(section.paragraphs) &&
              section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            {Array.isArray(section.items) && (
              <ul>
                {section.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
          </article>
        ))}

        <article class="legal-doc-card legal-doc-card-table">
          <h2>{t.tableTitle}</h2>
          <div class="legal-doc-table-wrap">
            <table class="legal-doc-table">
              <thead>
                <tr>
                  {t.tableColumns.map((column) => (
                    <th>{column}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {t.rows.map((row) => (
                  <tr>
                    {row.map((cell) => (
                      <td>{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </article>

        <article class="legal-doc-card">
          <h2>{t.manageTitle}</h2>
          {t.manageParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>

        <article class="legal-doc-card">
          <h2>{t.contactTitle}</h2>
          <p>{CONTACT_EMAIL}</p>
          <div class="legal-doc-contact">
            <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
          </div>
        </article>
      </div>
    </div>
  </main>
</BaseLayout>
