---
export const prerender = false;

import BaseLayout from "@webapp/layouts/BaseLayout.astro";
import PropertyCard from "@webapp/components/PropertyCard.astro";
import MapboxCostaMap from "@webapp/components/MapboxCostaMap.astro";
import { getPublicPropertiesWithFallback } from "@shared/properties/public";
import { normalizeVisiblePublicPropertyCards } from "@shared/properties/public";
import { applyFilters } from "@shared/properties/public";
import { buildCompactPropertyMapPayload } from "@shared/properties/compactMapFeatures";
import { INDEXABLE_CITIES } from "@shared/config/seoSlugs";
import {
  buildPropertyLandingCatalogUrl,
  resolvePropertyLanding,
} from "@shared/seo/resolvePropertyLanding";
import { buildPropertyLandingContent } from "@shared/seo/propertyLandingContent";
import { evaluatePropertyLandingEligibility } from "@shared/seo/propertyLandingEligibility";
import { buildPropertyLandingSchema } from "@shared/seo/buildPropertyLandingSchema";
import { buildPropertyLandingHubs } from "@shared/seo/propertyLandingHubs";
import { DEFAULT_LANG, isSupportedLang, SUPPORTED_LANGS } from "@shared/i18n/languages";
import { comparePromotionEditorialOrder } from "@shared/config/promotionOrder";
import { appendCatalogFiltersToSearchParams } from "@shared/properties/catalogFilters";
import { buildPublicNavigation } from "@webapp/navigation/publicNavigation";
import "@webapp/styles/components/filters.css";
import "@webapp/styles/components/properties-grid.css";
import "@webapp/styles/pages/properties.css";

const rawSlug = Array.isArray(Astro.params.slug)
  ? Astro.params.slug
  : Astro.params.slug
    ? [Astro.params.slug]
    : [];

const langParam = Astro.params.lang ?? DEFAULT_LANG;

if (!isSupportedLang(langParam)) {
  return Astro.redirect(`/${DEFAULT_LANG}/properties/`, 302);
}

const lang = langParam;
const normalizeLandingSegment = (value: string) =>
  String(value)
    .trim()
    .toLowerCase()
    .replace(/^\/+|\/+$/g, "");

const landing = resolvePropertyLanding({
  lang,
  slugSegments: rawSlug,
});

if (!landing) {
  const firstSegment = String(rawSlug[0] ?? "").toLowerCase();
  if (firstSegment && INDEXABLE_CITIES.includes(firstSegment)) {
    return Astro.redirect(`/${lang}/properties/${firstSegment}/`, 301);
  }

  return Astro.redirect(`/${lang}/properties/`, 301);
}
const requestedSeoKey = rawSlug.map(normalizeLandingSegment).filter(Boolean).join("/");
if (requestedSeoKey && requestedSeoKey !== landing.seoKey) {
  return Astro.redirect(landing.canonicalPath, 301);
}

const { properties } = await getPublicPropertiesWithFallback({
  query: {
    selectProfile: "card",
  },
});
const navigation = buildPublicNavigation({
  lang,
  family: "catalog",
  section: "properties",
  properties,
});

const cards = normalizeVisiblePublicPropertyCards(properties, lang);
const eligibleLandings = evaluatePropertyLandingEligibility({
  lang,
  cards,
});

const filteredCards = applyFilters(cards, landing.queryFilters);
const filteredUnitCards = applyFilters(cards, {
  ...landing.queryFilters,
  listingType: "unit",
});

const sortedCards = [...filteredCards].sort((a, b) => {
  if (a.isPromotion && b.isPromotion) {
    const byEditorial = comparePromotionEditorialOrder(a, b);
    if (byEditorial !== 0) return byEditorial;
  }

  const byPriority = (b.priority ?? 0) - (a.priority ?? 0);
  if (byPriority !== 0) return byPriority;

  return (b.priceDisplay ?? b.price ?? 0) - (a.priceDisplay ?? a.price ?? 0);
});
const sortedUnitCards = [...filteredUnitCards].sort((a, b) => {
  const byPriority = (b.priority ?? 0) - (a.priority ?? 0);
  if (byPriority !== 0) return byPriority;
  return (b.priceDisplay ?? b.price ?? 0) - (a.priceDisplay ?? a.price ?? 0);
});

const primaryMedia = sortedCards.find((card) => card.cover)?.cover ?? null;
const ogImage =
  typeof primaryMedia === "string"
    ? primaryMedia
    : primaryMedia?.url ?? null;

const content = buildPropertyLandingContent({
  lang,
  landing,
  resultCount: sortedCards.length,
  ogImage,
});

const structuredData = buildPropertyLandingSchema({
  lang,
  canonicalPath: landing.canonicalPath,
  content,
  cards: sortedCards,
});

const hubSections = buildPropertyLandingHubs({
  lang,
  eligibleLandings,
  landing,
});

const catalogUrl = buildPropertyLandingCatalogUrl(landing);
const buildCatalogSearchUrl = (overrides = {}) => {
  const params = new URLSearchParams();
  const merged = {
    city: landing.queryFilters.city,
    area: landing.queryFilters.area,
    type: landing.queryFilters.type,
    feature: landing.queryFilters.feature,
    market: landing.queryFilters.market,
    priceMin: landing.queryFilters.priceMin,
    ...overrides,
  };

  Object.entries(merged).forEach(([key, value]) => {
    if (value === null || value === undefined || value === "") return;
    if (Array.isArray(value)) {
      value.forEach((item) => {
        if (item !== null && item !== undefined && item !== "") {
          params.append(key, String(item));
        }
      });
      return;
    }
    params.set(key, String(value));
  });

  const query = params.toString();
  return query ? `/${lang}/properties/?${query}` : `/${lang}/properties/`;
};
const baseSearchLabel =
  landing.area?.label ??
  landing.city.label;
const baseIntentLabel =
  landing.type?.label ??
  landing.popular?.label ??
  landing.city.label;
const activeLandingChips = [
  {
    label: landing.city.label,
    href: `/${lang}/properties/${landing.city.slug}/`,
  },
  landing.area
    ? {
        label: landing.area.label,
        href: `/${lang}/properties/${landing.city.slug}/${landing.area.slug}/`,
      }
    : null,
  landing.type
    ? {
        label: landing.type.label,
        href: buildCatalogSearchUrl({ q: null }),
      }
    : null,
  landing.popular
    ? {
        label: landing.popular.label,
        href: buildCatalogSearchUrl({ q: null }),
      }
    : null,
].filter(Boolean);
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN ?? "";
const mapboxStyle = import.meta.env.PUBLIC_MAPBOX_STYLE ?? "mapbox://styles/mapbox/streets-v12";
const featuredShowcaseCard = sortedCards[0] ?? null;
const listingCards = featuredShowcaseCard
  ? sortedCards.filter((card) => String(card.id) !== String(featuredShowcaseCard.id))
  : sortedCards;
const compactMapPayload = buildCompactPropertyMapPayload(sortedCards, properties, lang);
const compactMapFeatureCount = compactMapPayload.diagnostics.renderedFeatures;
const buildMapFeaturesUrl = (filters) => {
  const params = new URLSearchParams();
  params.set("lang", lang);
  appendCatalogFiltersToSearchParams(params, filters);
  const query = params.toString();
  return `/api/v1/properties/map${query ? `?${query}` : ""}`;
};
const compactMapFeaturesUrl = buildMapFeaturesUrl(landing.queryFilters);

const copyByLang = {
  es: {
    eyebrow: "Costa del Sol",
    propertiesFound: "propiedades encontradas",
    searchAria: "Buscar propiedades dentro del catalogo",
    searchPlaceholder: "Buscar por zona, referencia o palabra clave",
    search: "Buscar",
    resultsFor: "Resultados para",
    mapEmpty: "No hay ubicaciones disponibles en el mapa.",
    mapReset: "Reiniciar mapa",
    browseCatalog: "Abrir catalogo interactivo",
    contactTeam: "Contactar con el equipo",
    faqTitle: "Preguntas frecuentes",
    emptyTitle: "No hay propiedades visibles para esta combinacion",
    emptyText:
      "Esta URL queda publicada como landing util, pero ahora mismo no tiene inventario suficiente para indexarse con fuerza.",
    backToProperties: "Ver todas las propiedades",
    footerTitle: "¿No encuentra lo que busca?",
    footerText:
      "Tenemos propiedad off-market para compradores exigentes, contacte con BlancaReal directamente para descubrirlas.",
  },
  en: {
    eyebrow: "Costa del Sol",
    propertiesFound: "properties found",
    searchAria: "Search properties inside the catalogue",
    searchPlaceholder: "Search by area, reference or keyword",
    search: "Search",
    resultsFor: "Results for",
    mapEmpty: "No map locations available.",
    mapReset: "Reset map",
    browseCatalog: "Open interactive catalogue",
    contactTeam: "Contact the team",
    faqTitle: "Frequently asked questions",
    emptyTitle: "No visible properties for this combination",
    emptyText:
      "This URL can still exist as a useful landing, but it currently does not have enough live stock to justify strong indexation.",
    backToProperties: "View all properties",
    footerTitle: "Did not find what you are looking for?",
    footerText:
      "We have off-market property for demanding buyers. Contact BlancaReal directly to discover it.",
  },
  de: {
    eyebrow: "Costa del Sol",
    propertiesFound: "immobilien gefunden",
    searchAria: "Immobilien im Katalog suchen",
    searchPlaceholder: "Nach Gebiet, Referenz oder Stichwort suchen",
    search: "Suchen",
    resultsFor: "Ergebnisse fuer",
    mapEmpty: "Keine Standorte auf der Karte verfuegbar.",
    mapReset: "Karte zuruecksetzen",
    browseCatalog: "Interaktiven Katalog oeffnen",
    contactTeam: "Mit dem Team sprechen",
    faqTitle: "Haeufige Fragen",
    emptyTitle: "Keine sichtbaren Immobilien fuer diese Kombination",
    emptyText:
      "Diese URL bleibt als nuetzliche Landingpage bestehen, hat aktuell aber nicht genug Live-Inventar fuer eine starke Indexierung.",
    backToProperties: "Alle Immobilien ansehen",
    footerTitle: "Haben Sie nicht gefunden, was Sie suchen?",
    footerText:
      "Wir haben Off-Market-Immobilien fuer anspruchsvolle Kaeufer. Kontaktieren Sie BlancaReal direkt, um sie zu entdecken.",
  },
  fr: {
    eyebrow: "Costa del Sol",
    propertiesFound: "proprietes trouvees",
    searchAria: "Rechercher des proprietes dans le catalogue",
    searchPlaceholder: "Rechercher par zone, reference ou mot-cle",
    search: "Rechercher",
    resultsFor: "Resultats pour",
    mapEmpty: "Aucun emplacement disponible sur la carte.",
    mapReset: "Reinitialiser la carte",
    browseCatalog: "Ouvrir le catalogue interactif",
    contactTeam: "Parler avec l equipe",
    faqTitle: "Questions frequentes",
    emptyTitle: "Aucune propriete visible pour cette combinaison",
    emptyText:
      "Cette URL peut rester une landing utile, mais elle ne dispose pas encore d un stock suffisant pour une forte indexation.",
    backToProperties: "Voir toutes les proprietes",
    footerTitle: "Vous ne trouvez pas ce que vous cherchez ?",
    footerText:
      "Nous disposons de biens off-market pour des acheteurs exigeants. Contactez directement BlancaReal pour les decouvrir.",
  },
  it: {
    eyebrow: "Costa del Sol",
    propertiesFound: "proprieta trovate",
    searchAria: "Cerca proprieta nel catalogo",
    searchPlaceholder: "Cerca per zona, riferimento o parola chiave",
    search: "Cerca",
    resultsFor: "Risultati per",
    mapEmpty: "Nessuna posizione disponibile sulla mappa.",
    mapReset: "Reimposta mappa",
    browseCatalog: "Apri catalogo interattivo",
    contactTeam: "Contatti il team",
    faqTitle: "Domande frequenti",
    emptyTitle: "Nessuna proprieta visibile per questa combinazione",
    emptyText:
      "Questa URL puo restare una landing utile, ma in questo momento non ha abbastanza stock live per una forte indicizzazione.",
    backToProperties: "Vedi tutte le proprieta",
    footerTitle: "Non trova quello che cerca?",
    footerText:
      "Abbiamo proprieta off-market per acquirenti esigenti. Contatti direttamente BlancaReal per scoprirle.",
  },
  nl: {
    eyebrow: "Costa del Sol",
    propertiesFound: "woningen gevonden",
    searchAria: "Zoek woningen in de catalogus",
    searchPlaceholder: "Zoek op zone, referentie of trefwoord",
    search: "Zoeken",
    resultsFor: "Resultaten voor",
    mapEmpty: "Geen locaties beschikbaar op de kaart.",
    mapReset: "Kaart resetten",
    browseCatalog: "Open interactieve catalogus",
    contactTeam: "Praat met het team",
    faqTitle: "Veelgestelde vragen",
    emptyTitle: "Geen zichtbare woningen voor deze combinatie",
    emptyText:
      "Deze URL kan nuttig blijven als landing, maar heeft nu niet genoeg live aanbod voor sterke indexatie.",
    backToProperties: "Bekijk alle woningen",
    footerTitle: "Vindt u niet wat u zoekt?",
    footerText:
      "Wij hebben off-market woningen voor veeleisende kopers. Neem rechtstreeks contact op met BlancaReal om ze te ontdekken.",
  },
};

const t = copyByLang[lang] ?? copyByLang.es;
---

<BaseLayout
  title={content.title}
  description={content.description}
  noindex={content.noindex}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  {...navigation}
  structuredData={structuredData}
  og={content.ogImage ? { image: content.ogImage } : undefined}
>
  <div class="properties-page properties-seo-page">
    <header class="properties-header properties-seo-header">
      <div class="header-content">
        <nav class="properties-breadcrumbs" aria-label="Breadcrumb">
          <ol>
            {content.breadcrumbs.map((crumb) => (
              <li>
                <a href={crumb.href}>{crumb.name}</a>
              </li>
            ))}
          </ol>
        </nav>
        <p class="subtitle">{t.eyebrow}</p>
        <h1>{content.h1}</h1>
      </div>
    </header>

    <div class="properties-layout properties-layout--seo">
      <main class="properties-content">
        <div class="content-header">
          <div class="results-summary">
            <p class="results-count" aria-live="polite" aria-atomic="true">
              <strong>{sortedUnitCards.length}</strong> {t.propertiesFound}
            </p>
            <p class="results-query">
              {t.resultsFor} "<span>{baseIntentLabel} · {baseSearchLabel}</span>"
            </p>
          </div>
        </div>

        <form class="search-bar" method="get" action={`/${lang}/properties/`} role="search">
          {landing.queryFilters.city?.map((city) => (
            <input type="hidden" name="city" value={city} />
          ))}
          {landing.queryFilters.area?.map((area) => (
            <input type="hidden" name="area" value={area} />
          ))}
          {landing.queryFilters.type?.map((type) => (
            <input type="hidden" name="type" value={type} />
          ))}
          {landing.queryFilters.feature?.map((feature) => (
            <input type="hidden" name="feature" value={feature} />
          ))}
          {landing.queryFilters.market && (
            <input type="hidden" name="market" value={landing.queryFilters.market} />
          )}
          {typeof landing.queryFilters.priceMin === "number" && (
            <input type="hidden" name="priceMin" value={String(landing.queryFilters.priceMin)} />
          )}
          <input
            type="search"
            name="q"
            placeholder={t.searchPlaceholder}
            aria-label={t.searchAria}
          />
          <button type="submit">{t.search}</button>
        </form>

        {activeLandingChips.length > 0 && (
          <section class="active-filters-bar" aria-label={t.propertiesFound}>
            {activeLandingChips.map((chip) => (
              <a href={chip.href} class="chip">
                <span>{chip.label}</span>
              </a>
            ))}
          </section>
        )}

        {(compactMapFeatureCount > 0 || featuredShowcaseCard) && (
          <section class="properties-showcase-row" aria-label="Landing catalogue showcase">
            {compactMapFeatureCount > 0 && (
              <div class="properties-showcase-map">
                <MapboxCostaMap
                  token={mapboxToken}
                  styleUrl={mapboxStyle}
                  featuresUrl={compactMapFeaturesUrl}
                  emptyMessage={t.mapEmpty}
                  resetViewLabel={t.mapReset}
                  mode="listing"
                  loadStrategy="visible"
                  allowExtrasLoad={true}
                  showPois={false}
                  showZones={false}
                  enableRouting={false}
                  compact={true}
                  fitToFeaturesOnLoad={true}
                />
              </div>
            )}
            {featuredShowcaseCard && (
              <div class="properties-showcase-featured">
                <PropertyCard data={featuredShowcaseCard} lang={lang} maxGallerySlides={1} />
              </div>
            )}
          </section>
        )}

        {sortedCards.length === 0 ? (
          <div class="empty-state">
            <div class="empty-icon"></div>
            <h3>{t.emptyTitle}</h3>
            <p>{t.emptyText}</p>
            <a href={`/${lang}/properties/`} class="btn btn-primary">{t.backToProperties}</a>
          </div>
        ) : (
          <section class="properties-grid">
            {listingCards.map((data) => (
              <PropertyCard data={data} lang={lang} maxGallerySlides={1} />
            ))}
          </section>
        )}

        {content.faqItems.length > 0 && (
          <section class="properties-seo-faq" aria-labelledby="landingFaqTitle">
            <div class="properties-seo-heading">
              <h2 id="landingFaqTitle">{t.faqTitle}</h2>
            </div>
            <div class="properties-seo-faq-list">
              {content.faqItems.map((item) => (
                <details class="properties-seo-faq-item">
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))}
            </div>
          </section>
        )}

        {hubSections.length > 0 && (
          <section class="properties-seo-hubs" aria-label="Related property searches">
            {hubSections.map((section) => (
              <article class="properties-hub-section">
                <h2>{section.title}</h2>
                <div class="properties-hub-links">
                  {section.links.map((link) => (
                    <a href={link.href} class="properties-hub-link">{link.label}</a>
                  ))}
                </div>
              </article>
            ))}
          </section>
        )}
      </main>
    </div>

    <div class="list-footer-cta">
      <h3>{t.footerTitle}</h3>
      <p>{t.footerText}</p>
      <a href={`/${lang}/contact/`} class="btn btn-outline">{t.contactTeam}</a>
    </div>
  </div>
</BaseLayout>
