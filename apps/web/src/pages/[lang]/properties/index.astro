                  styleUrl={mapboxStyle}
                  featuresUrl={compactMapFeaturesUrl}
                  emptyMessage={t.mapEmpty}
                  resetViewLabel={t.mapReset}
                  mode="listing"
                  loadStrategy="visible"
                  allowExtrasLoad={false}
