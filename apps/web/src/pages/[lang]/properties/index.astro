const t = copyByLang[lang] ?? copyByLang.es;

const renderText = (
  template,
  values: Record<string, string | number | null | undefined> = {}
) =>
  String(template).replace(/\{(\w+)\}/g, (_, key) =>
    String(values[key] ?? "")
  );

/* =========================
   FILTROS ACTIVOS (QUERY PARAMS)
========================= */
const { searchParams } = Astro.url;

const toggleMulti = (current, value) => {
  const next = new Set(current || []);
  if (next.has(value)) {
    next.delete(value);
  } else {
    next.add(value);
  }
  return Array.from(next);
};

const hasTechnicalFilters =
  searchParams.has("sort") ||
  searchParams.has("page");

/* =========================
   LISTADO NORMALIZADO
========================= */
const cards = normalizeVisiblePublicPropertyCards(properties, lang);
const allCardPrices = cards
  .map((card) => card.price)
  .filter((value): value is number => typeof value === "number" && Number.isFinite(value));
const catalogPriceBounds = {
  min: allCardPrices.length ? Math.min(...allCardPrices) : 0,
  max: allCardPrices.length ? Math.max(...allCardPrices) : 5000000,
};
const activeFilters = parseCatalogActiveFilters({
  searchParams,
  lang,
  priceBounds: catalogPriceBounds,
});

/* =========================
   APLICAR FILTROS
========================= */
const filteredCards = applyFilters(cards, activeFilters);
const filteredUnitCards = applyFilters(cards, {
  ...activeFilters,
  listingType: "unit",
});

/* =========================
   ORDENACIÃ“N
========================= */
const sort = searchParams.get("sort");
const sortApplied = sort ?? "priority";
const hasSearchIntent = Boolean(activeFilters.search || activeFilters.ref);

const sortedCards = [...filteredCards].sort((a, b) => {
  if (hasSearchIntent) {
    const bySearchScore = (b.searchScore ?? 0) - (a.searchScore ?? 0);
    if (bySearchScore !== 0) return bySearchScore;
  }
  if (sortApplied === "price_desc") return b.price - a.price;
  if (sortApplied === "price_asc") return a.price - b.price;
  if (a.isPromotion && b.isPromotion) {
    const byEditorial = comparePromotionEditorialOrder(a, b);
    if (byEditorial !== 0) return byEditorial;
  }
  const byPriority = (b.priority ?? 0) - (a.priority ?? 0);
  if (byPriority !== 0) return byPriority;
  return (b.price ?? 0) - (a.price ?? 0);
});
const sortCatalogCards = (a, b) => {
  if (hasSearchIntent) {
    const bySearchScore = (b.searchScore ?? 0) - (a.searchScore ?? 0);
    if (bySearchScore !== 0) return bySearchScore;
  }
  if (sortApplied === "price_desc") return (b.price ?? 0) - (a.price ?? 0);
  if (sortApplied === "price_asc") return (a.price ?? 0) - (b.price ?? 0);
  if (a.isPromotion && b.isPromotion) {
    const byEditorial = comparePromotionEditorialOrder(a, b);
    if (byEditorial !== 0) return byEditorial;
  }
  const byPriority = (b.priority ?? 0) - (a.priority ?? 0);
  if (byPriority !== 0) return byPriority;
  return (b.price ?? 0) - (a.price ?? 0);
};
const sortedUnitCards = [...filteredUnitCards].sort(sortCatalogCards);

/* =========================
   FILTROS DISPONIBLES (CONTEXTUALES)
========================= */
const filters = buildFilters(cards) as {
  cities: string[];
  areas: Record<string, string[]>;
  types: string[];
  markets: string[];
  bedrooms: number[];
  floors: string[];
  price: { min: number; max: number };
};

const formatFloorLabel = (floorValue) => floorValue;
const selectedCities = activeFilters.city ?? [];
const selectedAreas = activeFilters.area ?? [];
const primaryCity = selectedCities.length === 1 ? selectedCities[0] : null;
const primaryArea = selectedAreas.length === 1 ? selectedAreas[0] : null;
const formatFeatureLabel = (value) => {
  const def = FEATURES?.[value];
  return def?.[lang] ?? def?.es ?? value;
};
const formatPriceLabel = (min, max) => {
  const format = (value) =>
    new Intl.NumberFormat(lang === "es" ? "es-ES" : lang, {
      style: "currency",
      currency: "EUR",
      maximumFractionDigits: 0,
    }).format(value);

  if (typeof min === "number" && typeof max === "number") {
    return `${format(min)} - ${format(max)}`;
  }
  if (typeof min === "number") {
    return `${format(min)}+`;
  }
  if (typeof max === "number") {
    return `< ${format(max)}`;
  }
  return t.price;
};
const availableAreas = Array.from(
  new Set(
    (selectedCities.length > 0 ? selectedCities : Object.keys(filters.areas)).flatMap(
      (city) => filters.areas[city] ?? []
    )
  )
).sort((a, b) => a.localeCompare(b));
const availableFeatures = Array.from(
  new Set(
    cards.flatMap((card) => (Array.isArray(card.featureKeys) ? card.featureKeys : []))
  )
).sort((a, b) => formatFeatureLabel(a).localeCompare(formatFeatureLabel(b)));
const priceBounds = {
  min: Number.isFinite(Number(catalogPriceBounds.min)) ? Number(catalogPriceBounds.min) : 0,
  max: Number.isFinite(Number(catalogPriceBounds.max)) ? Number(catalogPriceBounds.max) : 5000000,
};
const priceStep = priceBounds.max > 2000000 ? 50000 : 25000;

const summarizeSelection = (selected, fallback, formatter = (value) => value) => {
  if (!Array.isArray(selected) || selected.length === 0) return fallback;
  if (selected.length === 1) return formatter(selected[0]);
  return `${fallback} (${selected.length})`;
};

const locationSummary = primaryArea
  ? displayLocation(primaryArea)
  : primaryCity
    ? displayLocation(primaryCity)
    : summarizeSelection(selectedCities, t.location, displayLocation);
const typeSummary = summarizeSelection(activeFilters.type, t.propertyType, (value) =>
  formatPropertyType(value, lang)
);
const bedroomsSummary = summarizeSelection(activeFilters.bedrooms, t.bedrooms, (value) =>
  `${value} ${t.bedroomsSuffix}`
);
const amenitiesSummary = summarizeSelection(activeFilters.feature, t.amenities, formatFeatureLabel);
const priceSummary =
  typeof activeFilters.priceMin === "number" || typeof activeFilters.priceMax === "number"
    ? formatPriceLabel(activeFilters.priceMin, activeFilters.priceMax)
    : t.price;
const locationButtonLabel = locationSummary === t.location ? t.location : `${t.location}: ${locationSummary}`;
const typeButtonLabel = typeSummary === t.propertyType ? t.propertyType : `${t.propertyType}: ${typeSummary}`;
const priceButtonLabel = priceSummary === t.price ? t.price : `${t.price}: ${priceSummary}`;
const bedroomsButtonLabel = bedroomsSummary === t.bedrooms ? t.bedrooms : `${t.bedrooms}: ${bedroomsSummary}`;
const amenitiesButtonLabel = amenitiesSummary === t.amenities ? t.amenities : `${t.amenities}: ${amenitiesSummary}`;

const pruneAreasForCities = (cities, areas) => {
  if (!Array.isArray(areas) || !areas.length) return null;
  if (!Array.isArray(cities) || !cities.length) return null;
  const allowed = new Set(cities.flatMap((city) => filters.areas[city] ?? []));
  const next = areas.filter((area) => allowed.has(area));
  return next.length ? next : null;
};

/* =========================
   SEO
========================= */
const listSeo = normalizePropertyList({
  lang,
  city: primaryCity,
  area: primaryArea,
  type: activeFilters.type,
  feature: activeFilters.feature,
  market: activeFilters.market,
  province: "Costa del Sol",
  hasTechnicalFilters,
});

/* =========================
   URL BUILDER
========================= */
function buildUrl(overrides = {}) {
  const params = new URLSearchParams();

  const merged = {
    city: activeFilters.city,
    area: activeFilters.area,
    type: activeFilters.type,
    feature: activeFilters.feature,
    market: activeFilters.market,
    bedrooms: activeFilters.bedrooms,
    floor: activeFilters.floor,
    priceMin: activeFilters.priceMin,
    priceMax: activeFilters.priceMax,
    q: activeFilters.search,
    ref: activeFilters.ref,
    sort,
    ...overrides,
  };

  Object.entries(merged).forEach(([key, value]) => {
    if (value === null || value === undefined) return;
    if (Array.isArray(value)) {
      value.filter((v) => v !== null && v !== undefined).forEach((v) => {
        params.append(key, String(v));
      });
      return;
    }
    params.set(key, String(value));
  });

  const qs = params.toString();
  return qs ? `?${qs}` : `/${lang}/properties/`;
}
const isFiltered = !!(
  activeFilters.city ||
  activeFilters.area ||
  (activeFilters.type && activeFilters.type.length) ||
  (activeFilters.feature && activeFilters.feature.length) ||
  (activeFilters.bedrooms && activeFilters.bedrooms.length) ||
  (activeFilters.floor && activeFilters.floor.length) ||
  activeFilters.market ||
  activeFilters.priceMin ||
  activeFilters.priceMax ||
  activeFilters.search ||
  activeFilters.ref
);
const shouldRenderSeoHubs = !isFiltered && !hasTechnicalFilters;
const eligibleLandings = shouldRenderSeoHubs
  ? evaluatePropertyLandingEligibility({
      lang,
      cards,
    })
  : [];
// formatFloorLabel defined above (identity)

const formatMarketLabel = (value) => {
  const def = MARKET_TYPE?.[value];
  return def?.label?.[lang] ?? value;
};

const activeFilterChips = [
  ...(activeFilters.city ?? []).map((city) => {
    const nextCities = toggleMulti(activeFilters.city, city);
    return {
      label: displayLocation(city),
      href: buildUrl({
        city: nextCities.length ? nextCities : null,
        area: pruneAreasForCities(nextCities, activeFilters.area),
      }),
    };
  }),
  ...(activeFilters.area ?? []).map((area) => ({
    label: displayLocation(area),
    href: buildUrl({ area: toggleMulti(activeFilters.area, area) }),
  })),
  ...(activeFilters.type ?? []).map((type) => ({
    label: formatPropertyType(type, lang),
    href: buildUrl({ type: toggleMulti(activeFilters.type, type) }),
  })),
  ...(activeFilters.feature ?? []).map((feature) => ({
    label: formatFeatureLabel(feature),
    href: buildUrl({ feature: toggleMulti(activeFilters.feature, feature) }),
  })),
  ...(activeFilters.market ? [{
    label: formatMarketLabel(activeFilters.market),
    href: buildUrl({ market: null }),
  }] : []),
  ...(activeFilters.bedrooms ?? []).map((bedrooms) => ({
    label: `${bedrooms} ${t.bedroomsSuffix}`,
    href: buildUrl({ bedrooms: toggleMulti(activeFilters.bedrooms, bedrooms) }),
  })),
  ...(activeFilters.floor ?? []).map((floor) => ({
    label: formatFloorLabel(floor),
    href: buildUrl({ floor: toggleMulti(activeFilters.floor, floor) }),
  })),
  ...((typeof activeFilters.priceMin === "number" || typeof activeFilters.priceMax === "number")
    ? [{
        label: formatPriceLabel(activeFilters.priceMin, activeFilters.priceMax),
        href: buildUrl({ priceMin: null, priceMax: null }),
      }]
    : []),
  ...(activeFilters.search ? [{
    label: `"${activeFilters.search}"`,
    href: buildUrl({ q: null }),
  }] : []),
  ...(activeFilters.ref ? [{
    label: `Ref ${activeFilters.ref}`,
    href: buildUrl({ ref: null }),
  }] : []),
];

const seoHubSections = shouldRenderSeoHubs
  ? buildPropertyLandingHubs({
      lang,
      eligibleLandings,
    })
  : [];
const pageNoindex = isFiltered || hasTechnicalFilters;
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN ?? "";
const mapboxStyle = import.meta.env.PUBLIC_MAPBOX_STYLE ?? "mapbox://styles/mapbox/streets-v12";
const featuredShowcaseCard = sortedCards[0] ?? null;
const listingCards = featuredShowcaseCard
  ? sortedCards.filter((card) => String(card.id) !== String(featuredShowcaseCard.id))
  : sortedCards;
const compactMapPayload = buildCompactPropertyMapPayload(sortedCards, properties, lang);
const compactMapFeatureCount = compactMapPayload.diagnostics.renderedFeatures;
const buildMapFeaturesUrl = (filters) => {
  const params = new URLSearchParams();
  params.set("lang", lang);
  appendCatalogFiltersToSearchParams(params, filters);
  const query = params.toString();
  return `/api/v1/properties/map${query ? `?${query}` : ""}`;
};
const compactMapFeaturesUrl = buildMapFeaturesUrl(activeFilters);
---

<BaseLayout
  title={listSeo.title}
  description={listSeo.description}
  noindex={pageNoindex}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  {...navigation}
>
  <div class={`properties-page ${isFiltered ? 'is-filtered' : ''}`}>
    
    <!-- HEADER DE PAGINA -->
    <header class="properties-header">
      <div class="header-content">
        <h1>{listSeo.title}</h1>
        { !isFiltered && (
          <p class="subtitle">
            {renderText(t.headerSubtitle, {
              location: displayLocation(primaryCity) || t.defaultLocation,
            })}
          </p>
        )}
      </div>
    </header>

    <div class="properties-layout">
      
      <!-- SIDEBAR FILTROS -->
