</BaseLayout>

<script>
  import { destroyMapboxRoots, initMapboxRoots } from "@webapp/scripts/mapbox-public";
  import "@webapp/scripts/property-map-focus";

  const MOBILE_FILTERS_MEDIA = "(max-width: 1023px)";
  const filtersPanel = document.getElementById("propertiesFiltersPanel");
  let filtersLastFocus = null;

  const isMobileFiltersViewport = () => window.matchMedia(MOBILE_FILTERS_MEDIA).matches;
  const getFiltersOpenButton = () => document.querySelector("[data-filters-open]");

  const getDrawerFocusable = () => {
    if (!(filtersPanel instanceof HTMLElement)) return [];
    return Array.from(
      filtersPanel.querySelectorAll('a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])')
    );
  };

  const syncDrawerA11yState = () => {
    const page = document.querySelector(".properties-page");
    const isOpen = page?.classList.contains("filters-drawer-open");
    if (filtersPanel instanceof HTMLElement) {
      filtersPanel.setAttribute("aria-hidden", isOpen ? "false" : "true");
    }
    const filtersOpenButton = getFiltersOpenButton();
    if (filtersOpenButton instanceof HTMLButtonElement) {
      filtersOpenButton.setAttribute("aria-expanded", isOpen ? "true" : "false");
    }
  };

  const handleDrawerKeydown = (event) => {
    if (event.key !== "Tab") return;
    const focusable = getDrawerFocusable();
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];

    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
      return;
    }

    if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  };

  const closeFiltersDrawer = () => {
    const page = document.querySelector(".properties-page");
    if (!page) return;
    page.classList.remove("filters-drawer-open");
    document.body.classList.remove("filters-drawer-lock");
    syncDrawerA11yState();
    document.removeEventListener("keydown", handleDrawerKeydown);
    if (filtersLastFocus instanceof HTMLElement && filtersLastFocus.isConnected) {
      filtersLastFocus.focus();
    }
  };

  const openFiltersDrawer = () => {
    if (!isMobileFiltersViewport()) return;
    const page = document.querySelector(".properties-page");
    if (!page) return;
    filtersLastFocus = document.activeElement;
    page.classList.add("filters-drawer-open");
    document.body.classList.add("filters-drawer-lock");
    syncDrawerA11yState();
    const focusable = getDrawerFocusable();
    if (focusable[0] instanceof HTMLElement) {
      focusable[0].focus();
    }
    document.addEventListener("keydown", handleDrawerKeydown);
  };

  const syncFiltersDrawerMode = () => {
    if (!isMobileFiltersViewport()) {
      closeFiltersDrawer();
      if (filtersPanel instanceof HTMLElement) {
        filtersPanel.setAttribute("aria-hidden", "false");
      }
      const filtersOpenButton = getFiltersOpenButton();
      if (filtersOpenButton instanceof HTMLButtonElement) {
        filtersOpenButton.setAttribute("aria-expanded", "false");
      }
      return;
    }
    syncDrawerA11yState();
  };

  const shouldHandleLink = (link) => {
    if (!link) return false;
    if (link.target && link.target !== "_self") return false;
    if (link.hasAttribute("download")) return false;
    const href = link.getAttribute("href");
    if (!href || href.startsWith("#")) return false;
    if (link.dataset.noAjax === "true") return false;
    if (href.startsWith("?")) return true;
    return href.includes("/properties");
  };

  const resolveHref = (href) => {
    if (href.startsWith("?")) {
      return `${window.location.pathname}${href}`;
    }
    return href;
  };

  const initPriceRange = (scope = document) => {
    scope.querySelectorAll("[data-price-range]").forEach((rangeRoot) => {
      const minRange = rangeRoot.querySelector("[data-price-min]");
      const maxRange = rangeRoot.querySelector("[data-price-max]");
      const minInput = rangeRoot.parentElement?.querySelector("[data-price-min-input]");
      const maxInput = rangeRoot.parentElement?.querySelector("[data-price-max-input]");
      const fill = rangeRoot.querySelector("[data-price-range-fill]");

      if (
        !(minRange instanceof HTMLInputElement) ||
        !(maxRange instanceof HTMLInputElement) ||
        !(minInput instanceof HTMLInputElement) ||
        !(maxInput instanceof HTMLInputElement)
      ) {
        return;
      }

      const absoluteMin = Number(rangeRoot.dataset.min || 0);
      const absoluteMax = Number(rangeRoot.dataset.max || 0);
      const step = Number(rangeRoot.dataset.step || 1);
      const parsePriceInputValue = (value, fallback) => {
        const normalized = String(value ?? "")
          .replace(/[^\d]/g, "")
          .trim();
        if (!normalized) return fallback;
        const parsed = Number(normalized);
        return Number.isFinite(parsed) ? parsed : fallback;
      };

      const clampValues = (source = "range") => {
        let minValue =
          source === "input"
            ? parsePriceInputValue(minInput.value, absoluteMin)
            : Number(minRange.value);
        let maxValue =
          source === "input"
            ? parsePriceInputValue(maxInput.value, absoluteMax)
            : Number(maxRange.value);

        minValue = Math.max(absoluteMin, Math.min(minValue, absoluteMax));
        maxValue = Math.max(absoluteMin, Math.min(maxValue, absoluteMax));

        if (maxValue < minValue) {
          if (source === "input") {
            if (document.activeElement === minInput) {
              maxValue = minValue;
            } else {
              minValue = maxValue;
            }
          } else if (document.activeElement === minRange) {
            maxValue = minValue;
          } else {
            minValue = maxValue;
          }
        }

        minValue = Math.round(minValue / step) * step;
        maxValue = Math.round(maxValue / step) * step;

        minRange.value = String(minValue);
        maxRange.value = String(maxValue);
        minInput.value = String(minValue);
        maxInput.value = String(maxValue);

        const start = ((minValue - absoluteMin) / (absoluteMax - absoluteMin)) * 100;
        const end = ((maxValue - absoluteMin) / (absoluteMax - absoluteMin)) * 100;
        if (fill instanceof HTMLElement) {
          fill.style.left = `${start}%`;
          fill.style.width = `${Math.max(end - start, 0)}%`;
        }
      };

      minRange.addEventListener("input", () => clampValues("range"));
      maxRange.addEventListener("input", () => clampValues("range"));
      minInput.addEventListener("input", () => clampValues("input"));
      maxInput.addEventListener("input", () => clampValues("input"));
      clampValues("range");
    });
  };

  const closeToolbarDropdowns = () => {
    document.querySelectorAll(".catalog-filter-dropdown.is-open").forEach((node) => {
      node.classList.remove("is-open");
      const toggle = node.querySelector("[data-filter-dropdown-toggle]");
      if (toggle instanceof HTMLButtonElement) {
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  };

  const handleNavigation = async (href, options = {}) => {
    const targetHref = resolveHref(href);
    const currentContent = document.querySelector(".properties-content");
    currentContent?.classList.add("is-loading");
    currentContent?.setAttribute("aria-busy", "true");
    closeToolbarDropdowns();

    try {
      const response = await fetch(targetHref, { headers: { "X-Requested-With": "fetch" } });
      if (!response.ok) {
        window.location.href = targetHref;
        return;
      }

      const html = await response.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, "text/html");

      const currentSidebarBody = document.querySelector(".filters-body");
      const nextSidebarBody = doc.querySelector(".filters-body");
      const nextContent = doc.querySelector(".properties-content");
      const currentFooter = document.querySelector(".list-footer-cta");
      const nextFooter = doc.querySelector(".list-footer-cta");

      if (currentSidebarBody && nextSidebarBody) {
        currentSidebarBody.replaceWith(nextSidebarBody);
      }

      if (currentContent && nextContent) {
        destroyMapboxRoots(currentContent);
        currentContent.replaceWith(nextContent);
        initMapboxRoots(nextContent, { eager: true });
      }

      if (currentFooter && nextFooter) {
        currentFooter.replaceWith(nextFooter);
      }

      document.title = doc.title;
      initPriceRange(document);
      if (options.pushState !== false) {
        history.pushState({}, "", targetHref);
      }
      closeFiltersDrawer();
      syncFiltersDrawerMode();
    } finally {
      document.querySelector(".properties-content")?.classList.remove("is-loading");
      document.querySelector(".properties-content")?.setAttribute("aria-busy", "false");
    }
  };

  document.addEventListener("click", (event) => {
    const dropdownToggle = event.target.closest("[data-filter-dropdown-toggle]");
    if (dropdownToggle) {
      event.preventDefault();
      const dropdown = dropdownToggle.closest(".catalog-filter-dropdown");
      const willOpen = !dropdown?.classList.contains("is-open");
      closeToolbarDropdowns();
      if (dropdown && willOpen) {
        dropdown.classList.add("is-open");
        if (dropdownToggle instanceof HTMLButtonElement) {
          dropdownToggle.setAttribute("aria-expanded", "true");
        }
      }
      return;
    }

    if (!event.target.closest(".catalog-filter-dropdown")) {
      closeToolbarDropdowns();
    }

    const openButton = event.target.closest("[data-filters-open]");
    if (openButton) {
      event.preventDefault();
      openFiltersDrawer();
      return;
    }

    const closeButton = event.target.closest("[data-filters-close]");
    if (closeButton) {
      event.preventDefault();
      closeFiltersDrawer();
      return;
    }

    const link = event.target.closest("a");
    if (!shouldHandleLink(link)) return;
    if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
    event.preventDefault();
    handleNavigation(link.getAttribute("href"));
  });

  document.addEventListener("submit", (event) => {
    const form = event.target;
    if (!(form instanceof HTMLFormElement)) return;
    if (!form.matches(".search-bar, .catalog-price-form")) return;
    event.preventDefault();
    const formData = new FormData(form);

    if (form.matches(".catalog-price-form")) {
      const priceRange = form.querySelector("[data-price-range]");
      const absoluteMin = Number(priceRange?.dataset.min || 0);
      const absoluteMax = Number(priceRange?.dataset.max || 0);
      const rawMin = Number(formData.get("priceMin"));
      const rawMax = Number(formData.get("priceMax"));

      if (!Number.isFinite(rawMin) || rawMin <= absoluteMin) {
        formData.delete("priceMin");
      }

      if (!Number.isFinite(rawMax) || rawMax >= absoluteMax) {
        formData.delete("priceMax");
      }
    }

    handleNavigation(
      form.action ? `${form.action}?${new URLSearchParams(formData).toString()}` : window.location.href
    );
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeToolbarDropdowns();
      closeFiltersDrawer();
    }
  });

  window.addEventListener("popstate", () => {
    handleNavigation(window.location.href, { pushState: false });
  });

  window.addEventListener("resize", syncFiltersDrawerMode);
  syncFiltersDrawerMode();
  initPriceRange(document);
</script>


