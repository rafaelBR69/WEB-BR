            <div class="catalog-filter-menu">
              <div class="catalog-filter-menu-group">
                <p>{t.propertyType}</p>
                <ul>
                  <li>
                    <a href={buildUrl({ type: null })} class="catalog-filter-menu-clear">
                      <span>{t.clearAll}</span>
