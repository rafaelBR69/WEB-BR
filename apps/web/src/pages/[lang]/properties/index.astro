          >
            <span>{t.newBuilds}</span>
          </a>

          <a
            href={buildUrl({ market: activeFilters.market === "segunda_mano" ? null : "segunda_mano" })}
            class={`catalog-filter-chip ${activeFilters.market === "segunda_mano" ? "is-active" : ""}`}
          >
            <span>{t.resale}</span>
          </a>
        </section>

        <!-- BARRA SUPERIOR (Resultados + Ordenar) -->
        <div class="content-header">
          <div class="results-summary">
            <p class="results-count" aria-live="polite" aria-atomic="true">
              <strong>{filteredUnitCards.length}</strong> {t.propertiesFound}
            </p>
            {activeFilters.search && (
              <p class="results-query">
                {t.resultsFor} "<span>{activeFilters.search}</span>"
              </p>
            )}
          </div>
          
          <div class="content-tools">
