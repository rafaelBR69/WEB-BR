                    {filters.cities.map((city: string) => (
                      <li class={activeFilters.city?.includes(city) ? "active" : ""}>
                        <a
                          href={buildUrl((() => {
                            const nextCities = toggleMulti(activeFilters.city, city);
                            return {
                              city: nextCities.length ? nextCities : null,
                              area: pruneAreasForCities(nextCities, activeFilters.area),
                            };
                          })())}
                        >
                          <span class="check-icon"></span>
                          {displayLocation(city)}
                          {activeFilters.city?.includes(city) && (
                            <span class="filter-clear">x</span>
