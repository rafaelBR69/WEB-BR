                        data-price-min-input
                      />
                    </label>
                    <label>
                      <span>{t.to}</span>
                      <input
                        type="text"
                        name="priceMax"
                        inputmode="numeric"
                        pattern="[0-9]*"
                        value={typeof activeFilters.priceMax === "number" ? activeFilters.priceMax : priceBounds.max}
                        data-price-max-input
                      />
