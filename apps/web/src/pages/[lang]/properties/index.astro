import "@webapp/styles/pages/properties.css";

const langParam = Astro.params.lang ?? DEFAULT_LANG;
if (!isSupportedLang(langParam)) {
  return Astro.redirect(`/${DEFAULT_LANG}/properties/`, 302);
}

const lang = langParam;
const ui = getUiCopy(lang);
const headerNavItems = [
  { href: `/${lang}/real-estate/`, label: ui.layout.navRealEstate },
  { href: `/${lang}/properties/`, label: ui.layout.navProperties },
  { href: `/${lang}/projects/`, label: ui.layout.navProjects },
  { href: `/${lang}/contact/`, label: ui.layout.navContact },
];
const { properties } = await getPublicPropertiesWithFallback({
  fallbackProperties,
});

