const t = copyByLang[lang] ?? copyByLang.es;

const renderText = (
  template,
  values: Record<string, string | number | null | undefined> = {}
) =>
  String(template).replace(/\{(\w+)\}/g, (_, key) =>
    String(values[key] ?? "")
  );

/* =========================
   FILTROS ACTIVOS (QUERY PARAMS)
========================= */
const { searchParams } = Astro.url;

const getMultiParam = (key) => {
  const values = searchParams.getAll(key)
    .map((v) => String(v).trim())
    .filter(Boolean);
  return values.length ? values : null;
};

const toggleMulti = (current, value) => {
  const next = new Set(current || []);
  if (next.has(value)) {
    next.delete(value);
  } else {
    next.add(value);
  }
  return Array.from(next);
};

const normalizeTypeParam = (value) => {
  if (!value) return null;
  const normalized = String(value).toLowerCase().trim();
  if (TYPES[normalized]) return normalized;

  for (const [key, def] of Object.entries(TYPES)) {
    if (def.label?.[lang]?.toLowerCase() === normalized) return key;
    if (def.label?.es?.toLowerCase() === normalized) return key;
  }

  return normalized;
};

const activeFilters = {
  city: getMultiParam("city")
    ? [...new Set(getMultiParam("city").map((v) => normalizeCity(v)).filter(Boolean))]
    : null,

  area: getMultiParam("area")
    ? [...new Set(getMultiParam("area").map((v) => normalizeArea(v)).filter(Boolean))]
    : null,

  type: getMultiParam("type")
    ? getMultiParam("type").map((v) => normalizeTypeParam(v))
    : null,
  market: searchParams.get("market") || null,

  bedrooms: getMultiParam("bedrooms")
    ? getMultiParam("bedrooms").map((v) => Number(v)).filter((v) => !Number.isNaN(v))
    : null,

  floor: getMultiParam("floor")
    ? [...new Set(
        getMultiParam("floor")
          .map((v) => normalizeFloorFilterLabel(v))
          .filter((v): v is string => typeof v === "string" && !isVillaFloorLabel(v))
      )]
    : null,

  priceMin: searchParams.get("priceMin")
    ? Number(searchParams.get("priceMin"))
    : null,

  priceMax: searchParams.get("priceMax")
    ? Number(searchParams.get("priceMax"))
    : null,
  search: searchParams.get("q")
    ? String(searchParams.get("q")).trim()
    : null,
  ref: searchParams.get("ref")
    ? String(searchParams.get("ref")).trim()
    : null,
};

const hasTechnicalFilters =
  searchParams.has("sort") ||
  searchParams.has("page");

/* =========================
   LISTADO NORMALIZADO
========================= */
const cards = properties
  .map((p) => normalizePropertyCard(p, lang))
  .filter(Boolean)
  .filter((p) => p.visible);

/* =========================
   APLICAR FILTROS
========================= */
const filteredCards = applyFilters(cards, activeFilters);

/* =========================
   ORDENACIÃ“N
========================= */
const sort = searchParams.get("sort");
const sortApplied = sort ?? "priority";
const hasSearchIntent = Boolean(activeFilters.search || activeFilters.ref);

const sortedCards = [...filteredCards].sort((a, b) => {
  if (hasSearchIntent) {
    const bySearchScore = (b.searchScore ?? 0) - (a.searchScore ?? 0);
    if (bySearchScore !== 0) return bySearchScore;
  }
  if (sortApplied === "price_desc") return b.price - a.price;
  if (sortApplied === "price_asc") return a.price - b.price;
  if (a.isPromotion && b.isPromotion) {
    const byEditorial = comparePromotionEditorialOrder(a, b);
    if (byEditorial !== 0) return byEditorial;
  }
  const byPriority = (b.priority ?? 0) - (a.priority ?? 0);
  if (byPriority !== 0) return byPriority;
  return (b.price ?? 0) - (a.price ?? 0);
});

/* =========================
   FILTROS DISPONIBLES (CONTEXTUALES)
========================= */
const filters = buildFilters(cards) as {
  cities: string[];
  areas: Record<string, string[]>;
  types: string[];
  markets: string[];
  bedrooms: number[];
  floors: string[];
  price: { min: number; max: number };
};

const formatFloorLabel = (floorValue) => floorValue;
const selectedCities = activeFilters.city ?? [];
const selectedAreas = activeFilters.area ?? [];
const primaryCity = selectedCities.length === 1 ? selectedCities[0] : null;
const primaryArea = selectedAreas.length === 1 ? selectedAreas[0] : null;
const availableAreas = Array.from(
  new Set(
    (selectedCities.length > 0 ? selectedCities : Object.keys(filters.areas)).flatMap(
      (city) => filters.areas[city] ?? []
    )
  )
).sort((a, b) => a.localeCompare(b));

const pruneAreasForCities = (cities, areas) => {
  if (!Array.isArray(areas) || !areas.length) return null;
  if (!Array.isArray(cities) || !cities.length) return null;
  const allowed = new Set(cities.flatMap((city) => filters.areas[city] ?? []));
  const next = areas.filter((area) => allowed.has(area));
  return next.length ? next : null;
};

/* =========================
   SEO
========================= */
const listSeo = normalizePropertyList({
  lang,
  city: primaryCity,
  area: primaryArea,
  type: activeFilters.type,
  market: activeFilters.market,
  province: "Costa del Sol",
  hasTechnicalFilters,
});

/* =========================
   URL BUILDER
========================= */
function buildUrl(overrides = {}) {
  const params = new URLSearchParams();

  const merged = {
    city: activeFilters.city,
    area: activeFilters.area,
    type: activeFilters.type,
    market: activeFilters.market,
    bedrooms: activeFilters.bedrooms,
    floor: activeFilters.floor,
    priceMin: activeFilters.priceMin,
    priceMax: activeFilters.priceMax,
    q: activeFilters.search,
    ref: activeFilters.ref,
    sort,
    ...overrides,
  };

  Object.entries(merged).forEach(([key, value]) => {
    if (value === null || value === undefined) return;
    if (Array.isArray(value)) {
      value.filter((v) => v !== null && v !== undefined).forEach((v) => {
        params.append(key, String(v));
      });
      return;
    }
    params.set(key, String(value));
  });

  const qs = params.toString();
  return qs ? `?${qs}` : `/${lang}/properties/`;
}
const isFiltered = !!(
  activeFilters.city ||
  activeFilters.area ||
  (activeFilters.type && activeFilters.type.length) ||
  (activeFilters.bedrooms && activeFilters.bedrooms.length) ||
  (activeFilters.floor && activeFilters.floor.length) ||
  activeFilters.market ||
  activeFilters.priceMin ||
  activeFilters.priceMax ||
  activeFilters.search ||
  activeFilters.ref
);
// formatFloorLabel defined above (identity)

const formatMarketLabel = (value) => {
  const def = MARKET_TYPE?.[value];
  return def?.label?.[lang] ?? value;
};

const activeFilterChips = [
  ...(activeFilters.city ?? []).map((city) => {
    const nextCities = toggleMulti(activeFilters.city, city);
    return {
      label: displayLocation(city),
      href: buildUrl({
        city: nextCities.length ? nextCities : null,
        area: pruneAreasForCities(nextCities, activeFilters.area),
      }),
    };
  }),
  ...(activeFilters.area ?? []).map((area) => ({
    label: displayLocation(area),
    href: buildUrl({ area: toggleMulti(activeFilters.area, area) }),
  })),
  ...(activeFilters.type ?? []).map((type) => ({
    label: formatPropertyType(type, lang),
    href: buildUrl({ type: toggleMulti(activeFilters.type, type) }),
  })),
  ...(activeFilters.market ? [{
    label: formatMarketLabel(activeFilters.market),
    href: buildUrl({ market: null }),
  }] : []),
  ...(activeFilters.bedrooms ?? []).map((bedrooms) => ({
    label: `${bedrooms} ${t.bedroomsSuffix}`,
    href: buildUrl({ bedrooms: toggleMulti(activeFilters.bedrooms, bedrooms) }),
  })),
  ...(activeFilters.floor ?? []).map((floor) => ({
    label: formatFloorLabel(floor),
    href: buildUrl({ floor: toggleMulti(activeFilters.floor, floor) }),
  })),
  ...(activeFilters.search ? [{
    label: `"${activeFilters.search}"`,
    href: buildUrl({ q: null }),
  }] : []),
  ...(activeFilters.ref ? [{
    label: `Ref ${activeFilters.ref}`,
    href: buildUrl({ ref: null }),
  }] : []),
];
---

<BaseLayout
  title={listSeo.title}
  description={listSeo.description}
  noindex={listSeo.noindex}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  headerNavItems={headerNavItems}
>
  <div class={`properties-page ${isFiltered ? 'is-filtered' : ''}`}>
    
    <!-- HEADER DE PÃGINA -->
    <header class="properties-header">
      <div class="header-content">
        <h1>{listSeo.title}</h1>
        { !isFiltered && (
          <p class="subtitle">
            {renderText(t.headerSubtitle, {
              location: displayLocation(primaryCity) || t.defaultLocation,
            })}
          </p>
        )}
      </div>
    </header>

    <div class="properties-layout">
      
      <!-- SIDEBAR FILTROS -->
      <aside class="properties-sidebar">
        <div class="filters-sticky">
          <section
            class="filters-panel"
            id="propertiesFiltersPanel"
            role="dialog"
            aria-modal="true"
            aria-labelledby="propertiesFiltersTitle"
            aria-hidden="true"
            tabindex="-1"
          >
            <div class="filters-panel-header mobile-only">
              <p class="filters-panel-title">{t.filterProperties}</p>
              <button type="button" class="filters-panel-close" data-filters-close aria-label={t.closeFilters}>
                <span aria-hidden="true">&times;</span>
              </button>
            </div>
            <div class="filters-body" id="filtersBody">
              <div class="filters-header">
                <h2 id="propertiesFiltersTitle">{t.filter}</h2>
                {((activeFilters.city && activeFilters.city.length) || (activeFilters.area && activeFilters.area.length) || (activeFilters.type && activeFilters.type.length) || (activeFilters.bedrooms && activeFilters.bedrooms.length) || (activeFilters.floor && activeFilters.floor.length) || activeFilters.market || activeFilters.search || activeFilters.ref) && (
                  <a href={`/${lang}/properties/`} class="reset-all">{t.clearAll}</a>
                )}
              </div>

              {filters.cities.length > 0 && (
                <div class="filter-group">
                  <h3>{t.location}</h3>
                  <ul class="filter-list vertical">
                    {filters.cities.map((city: string) => (
                      <li class={activeFilters.city?.includes(city) ? "active" : ""}>
                        <a
                          href={buildUrl((() => {
                            const nextCities = toggleMulti(activeFilters.city, city);
                            return {
                              city: nextCities.length ? nextCities : null,
                              area: pruneAreasForCities(nextCities, activeFilters.area),
                            };
                          })())}
                        >
                          <span class="check-icon"></span>
                          {displayLocation(city)}
                          {activeFilters.city?.includes(city) && (
                            <span class="filter-clear">x</span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {selectedCities.length > 0 && availableAreas.length > 0 && (
                <div class="filter-group">
                  <h3>{renderText(t.areasIn, { city: displayLocation(primaryCity) || t.defaultLocation })}</h3>
                  <ul class="filter-list vertical">
                    {availableAreas.map((area: string) => (
                      <li class={activeFilters.area?.includes(area) ? "active" : ""}>
                        <a href={buildUrl({ area: toggleMulti(activeFilters.area, area) })}>
                          <span class="check-icon"></span>
                          {displayLocation(area)}
                          {activeFilters.area?.includes(area) && (
                            <span class="filter-clear">x</span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {(filters.types.length > 1 || (activeFilters.type && activeFilters.type.length)) && (
                <div class="filter-group">
                  <h3>{t.propertyType}</h3>
                  <ul class="filter-list vertical">
                    {filters.types.map((type: string) => (
                      <li class={activeFilters.type?.includes(type) ? "active" : ""}>
                        <a href={buildUrl({ type: toggleMulti(activeFilters.type, type) })}>
                          <span class="check-icon"></span>
                          {formatPropertyType(type, lang)}
                          {activeFilters.type?.includes(type) && (
                            <span class="filter-clear">x</span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {filters.markets.length > 0 && (
                <div class="filter-group">
                  <h3>{t.status}</h3>
                  <ul class="filter-list vertical">
                    {filters.markets.map((market: string) => (
                      <li class={market === activeFilters.market ? "active" : ""}>
                        <a href={buildUrl({ market: market === activeFilters.market ? null : market })}>
                          <span class="check-icon"></span>
                          {formatMarketLabel(market)}
                          {market === activeFilters.market && (
                            <span class="filter-clear">x</span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {filters.bedrooms.length > 0 && (
                <div class="filter-group">
                  <h3>{t.bedrooms}</h3>
                  <ul class="filter-list vertical">
                    {filters.bedrooms.map((bedrooms: number) => (
                      <li class={activeFilters.bedrooms?.includes(bedrooms) ? "active" : ""}>
                        <a href={buildUrl({ bedrooms: toggleMulti(activeFilters.bedrooms, bedrooms) })}>
                          <span class="check-icon"></span>
                          {bedrooms} {t.bedroomsSuffix}
                          {activeFilters.bedrooms?.includes(bedrooms) && (
                            <span class="filter-clear">x</span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {filters.floors.length > 0 && (
                <div class="filter-group">
                  <h3>{t.floor}</h3>
                  <ul class="filter-list vertical">
                    {filters.floors.map((floor: string) => (
                      <li class={activeFilters.floor?.includes(floor) ? "active" : ""}>
                        <a href={buildUrl({ floor: toggleMulti(activeFilters.floor, floor) })}>
                          <span class="check-icon"></span>
                          {formatFloorLabel(floor)}
                          {activeFilters.floor?.includes(floor) && (
                            <span class="filter-clear">x</span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </section>
        </div>
      </aside>

      <!-- CONTENIDO PRINCIPAL -->
      <main class="properties-content">
        <!-- BARRA SUPERIOR (Resultados + Ordenar) -->
        <div class="content-header">
          <div class="results-summary">
            <p class="results-count" aria-live="polite" aria-atomic="true">
              <strong>{sortedCards.length}</strong> {t.propertiesFound}
            </p>
            {activeFilters.search && (
              <p class="results-query">
                {t.resultsFor} "<span>{activeFilters.search}</span>"
              </p>
            )}
          </div>
          
          <div class="content-tools">
            <div class="sort-dropdown" aria-label={t.sortBy}>
              <span class="sort-label">{t.sortBy}</span>
              <div class="sort-options" role="list">
                <a href={buildUrl({ sort: "priority" })} class={sortApplied === 'priority' ? 'active' : ''}>{t.relevance}</a>
                <a href={buildUrl({ sort: "price_asc" })} class={sortApplied === 'price_asc' ? 'active' : ''}>{t.priceAsc}</a>
                <a href={buildUrl({ sort: "price_desc" })} class={sortApplied === 'price_desc' ? 'active' : ''}>{t.priceDesc}</a>
              </div>
            </div>
          </div>
        </div>

        <form class="search-bar" method="get" action={`/${lang}/properties/`} role="search">
          <input
            type="search"
            name="q"
            placeholder={t.searchPlaceholder}
            value={activeFilters.search ?? ""}
            aria-label={t.searchAria}
          />
          {activeFilters.city?.map((city: string) => (
            <input type="hidden" name="city" value={city} />
          ))}
          {activeFilters.area?.map((area: string) => (
            <input type="hidden" name="area" value={area} />
          ))}
          {activeFilters.type?.map((type: string) => (
            <input type="hidden" name="type" value={type} />
          ))}
          {activeFilters.bedrooms?.map((bedroom: number) => (
            <input type="hidden" name="bedrooms" value={bedroom} />
          ))}
          {activeFilters.floor?.map((floor: string) => (
            <input type="hidden" name="floor" value={floor} />
          ))}
          {activeFilters.market && (
            <input type="hidden" name="market" value={activeFilters.market} />
          )}
          {typeof activeFilters.priceMin === "number" && (
            <input type="hidden" name="priceMin" value={activeFilters.priceMin} />
          )}
          {typeof activeFilters.priceMax === "number" && (
            <input type="hidden" name="priceMax" value={activeFilters.priceMax} />
          )}
          {sort && <input type="hidden" name="sort" value={sort} />}
          {activeFilters.ref && <input type="hidden" name="ref" value={activeFilters.ref} />}
          <button
            type="button"
            class="filters-toggle-mobile filters-toggle-inline"
            data-filters-open
            aria-label={t.openFiltersAria}
            aria-controls="propertiesFiltersPanel"
            aria-expanded="false"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 6h16" />
              <path d="M7 12h10" />
              <path d="M10 18h4" />
            </svg>
            <span>{t.openFilters}</span>
          </button>
          <button type="submit">{t.search}</button>
        </form>

        {activeFilterChips.length > 0 && (
          <section class="active-filters-bar" aria-label={t.filterProperties}>
            {activeFilterChips.map((chip) => (
              <a href={chip.href} class="chip">
                <span>{chip.label}</span>
                <span class="close" aria-hidden="true">&times;</span>
              </a>
            ))}
            <a href={`/${lang}/properties/`} class="chip chip--reset">{t.clearAll}</a>
          </section>
        )}

        {sortedCards.length === 0 ? (
          <div class="empty-state">
            <div class="empty-icon">ðŸ”</div>
            <h3>{t.emptyTitle}</h3>
            <p>{t.emptyText}</p>
            <a href={`/${lang}/properties/`} class="btn btn-primary">{t.viewAllProperties}</a>
          </div>
        ) : (
          <>
            <section class="properties-grid">
              {sortedCards.map((data) => (
                <PropertyCard data={data} lang={lang} />
              ))}
            </section>
          </>
        )}

      </main>
    </div>

    <button
      type="button"
      class="filters-drawer-backdrop"
      data-filters-close
      aria-label={t.closeFilters}
    ></button>

    <!-- CTA FOOTER (CENTRADOR) -->
    <div class="list-footer-cta">
      <h3>{t.footerTitle}</h3>
      <p>
        {activeFilters.city
          ? renderText(t.footerCityPrompt, { city: displayLocation(primaryCity) || t.defaultLocation })
          : t.footerDefaultPrompt}
      </p>
      <a href={`/${lang}/contact/`} class="btn btn-outline">{t.contactUs}</a>
    </div>

  </div>
</BaseLayout>

<script is:inline>
  const MOBILE_FILTERS_MEDIA = "(max-width: 1023px)";
  const filtersPanel = document.getElementById("propertiesFiltersPanel");
  let filtersLastFocus = null;

  const isMobileFiltersViewport = () => window.matchMedia(MOBILE_FILTERS_MEDIA).matches;
  const getFiltersOpenButton = () => document.querySelector("[data-filters-open]");

  const getDrawerFocusable = () => {
    if (!(filtersPanel instanceof HTMLElement)) return [];
    return Array.from(
      filtersPanel.querySelectorAll('a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])')
    );
  };

  const syncDrawerA11yState = () => {
    const page = document.querySelector(".properties-page");
    const isOpen = page?.classList.contains("filters-drawer-open");
    if (filtersPanel instanceof HTMLElement) {
      filtersPanel.setAttribute("aria-hidden", isOpen ? "false" : "true");
    }
    const filtersOpenButton = getFiltersOpenButton();
    if (filtersOpenButton instanceof HTMLButtonElement) {
      filtersOpenButton.setAttribute("aria-expanded", isOpen ? "true" : "false");
    }
  };

  const handleDrawerKeydown = (event) => {
    if (event.key !== "Tab") return;
    const focusable = getDrawerFocusable();
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];

    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
      return;
    }

    if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  };

  const closeFiltersDrawer = () => {
    const page = document.querySelector(".properties-page");
    if (!page) return;
    page.classList.remove("filters-drawer-open");
    document.body.classList.remove("filters-drawer-lock");
    syncDrawerA11yState();
    document.removeEventListener("keydown", handleDrawerKeydown);
    if (filtersLastFocus instanceof HTMLElement && filtersLastFocus.isConnected) {
      filtersLastFocus.focus();
    }
  };

  const openFiltersDrawer = () => {
    if (!isMobileFiltersViewport()) return;
    const page = document.querySelector(".properties-page");
    if (!page) return;
    filtersLastFocus = document.activeElement;
    page.classList.add("filters-drawer-open");
    document.body.classList.add("filters-drawer-lock");
    syncDrawerA11yState();
    const focusable = getDrawerFocusable();
    if (focusable[0] instanceof HTMLElement) {
      focusable[0].focus();
    }
    document.addEventListener("keydown", handleDrawerKeydown);
  };

  const syncFiltersDrawerMode = () => {
    if (!isMobileFiltersViewport()) {
      closeFiltersDrawer();
      if (filtersPanel instanceof HTMLElement) {
        filtersPanel.setAttribute("aria-hidden", "false");
      }
      const filtersOpenButton = getFiltersOpenButton();
      if (filtersOpenButton instanceof HTMLButtonElement) {
        filtersOpenButton.setAttribute("aria-expanded", "false");
      }
      return;
    }
    syncDrawerA11yState();
  };

  const shouldHandleLink = (link) => {
    if (!link) return false;
    if (link.target && link.target !== "_self") return false;
    if (link.hasAttribute("download")) return false;
    const href = link.getAttribute("href");
    if (!href || href.startsWith("#")) return false;
    if (link.dataset.noAjax === "true") return false;
    if (href.startsWith("?")) return true;
    return href.includes("/properties");
  };

  const resolveHref = (href) => {
    if (href.startsWith("?")) {
      return `${window.location.pathname}${href}`;
    }
    return href;
  };

  const handleNavigation = async (href, options = {}) => {
    const targetHref = resolveHref(href);
    const currentContent = document.querySelector(".properties-content");
    currentContent?.classList.add("is-loading");
    currentContent?.setAttribute("aria-busy", "true");

    try {
      const response = await fetch(targetHref, { headers: { "X-Requested-With": "fetch" } });
      if (!response.ok) {
        window.location.href = targetHref;
        return;
      }

      const html = await response.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, "text/html");

      const currentSidebarBody = document.querySelector(".filters-body");
      const nextSidebarBody = doc.querySelector(".filters-body");
      const nextContent = doc.querySelector(".properties-content");
      const currentFooter = document.querySelector(".list-footer-cta");
      const nextFooter = doc.querySelector(".list-footer-cta");

      if (currentSidebarBody && nextSidebarBody) {
        currentSidebarBody.replaceWith(nextSidebarBody);
      }

      if (currentContent && nextContent) {
        currentContent.replaceWith(nextContent);
      }

      if (currentFooter && nextFooter) {
        currentFooter.replaceWith(nextFooter);
      }

      document.title = doc.title;
      if (options.pushState !== false) {
        history.pushState({}, "", targetHref);
      }
      closeFiltersDrawer();
      syncFiltersDrawerMode();
    } finally {
      document.querySelector(".properties-content")?.classList.remove("is-loading");
      document.querySelector(".properties-content")?.setAttribute("aria-busy", "false");
    }
  };

  document.addEventListener("click", (event) => {
    const openButton = event.target.closest("[data-filters-open]");
    if (openButton) {
      event.preventDefault();
      openFiltersDrawer();
      return;
    }

    const closeButton = event.target.closest("[data-filters-close]");
    if (closeButton) {
      event.preventDefault();
      closeFiltersDrawer();
      return;
    }

    const link = event.target.closest("a");
    if (!shouldHandleLink(link)) return;
    if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
    event.preventDefault();
    handleNavigation(link.getAttribute("href"));
  });

  document.addEventListener("submit", (event) => {
    const form = event.target;
    if (!(form instanceof HTMLFormElement)) return;
    if (!form.matches(".search-bar")) return;
    event.preventDefault();
    handleNavigation(form.action ? `${form.action}?${new URLSearchParams(new FormData(form)).toString()}` : window.location.href);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeFiltersDrawer();
    }
  });

  window.addEventListener("popstate", () => {
    handleNavigation(window.location.href, { pushState: false });
  });

  window.addEventListener("resize", syncFiltersDrawerMode);
  syncFiltersDrawerMode();
</script>


