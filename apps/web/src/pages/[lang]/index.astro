    image:
      "https://scontent.cdninstagram.com/v/t51.82787-15/642461079_18305358940273221_6062423964266999021_n.webp?stp=c288.0.864.864a_dst-jpg_e35_s640x640_tt6&_nc_cat=101&ccb=7-5&_nc_sid=18de74&efg=eyJlZmdfdGFnIjoiQ0FST1VTRUxfSVRFTS5iZXN0X2ltYWdlX3VybGdlbi5DMyJ9&_nc_ohc=4Hz9EcT9ZRsQ7kNvwHDbYWZ&_nc_oc=Adka_TQAwPPn2m55OyXHLbp-RFhsmzwX6ZKPJpzYoa9vK6tDnn7mfqE2S4NhC7OwT9E&_nc_zt=23&_nc_ht=scontent.cdninstagram.com&_nc_gid=swp1KuY4pwAC33Dc7vfHIA&_nc_ss=8&oh=00_Afw-2Fqo3B0VII_KUUQvFCNWmLEMCIdaPIz0wTYNL322CA&oe=69C05D8A",
  },
  {
    url: "https://www.instagram.com/p/DTxImRpjNNE/",
    title: "Despertar cada dia frente al mar",
    image:
      "https://scontent.cdninstagram.com/v/t51.82787-15/619850521_18300872167273221_3675599708415453825_n.jpg?stp=cmp1_dst-jpg_e35_s640x640_tt6&_nc_cat=111&ccb=7-5&_nc_sid=18de74&efg=eyJlZmdfdGFnIjoiQ0xJUFMuYmVzdF9pbWFnZV91cmxnZW4uQzMifQ%3D%3D&_nc_ohc=K6A31Jn69KQQ7kNvwHlAIrH&_nc_oc=AdnlqHrvlV9KbMKB4m1xcxUssVy4QYfnaSQBFujH5OuP5Da3D2qZcsbznfuMw7TCeEU&_nc_zt=23&_nc_ht=scontent.cdninstagram.com&_nc_gid=GxA3HiS6GPhfjxmHRqnxZw&_nc_ss=8&oh=00_AfxSowEJlEBYSUg-RoxRhLKF8BNTjAfli2wQaT01c5vJQA&oe=69C052E0",
  },
  {
    url: "https://www.instagram.com/p/DTffWKyjM06/",
    title: "The future begins here",
    image:
      "https://scontent.cdninstagram.com/v/t51.82787-15/615399797_18300040270273221_1873871616694110556_n.jpg?stp=cmp1_dst-jpg_e35_s640x640_tt6&_nc_cat=111&ccb=7-5&_nc_sid=18de74&efg=eyJlZmdfdGFnIjoiQ0xJUFMuYmVzdF9pbWFnZV91cmxnZW4uQzMifQ%3D%3D&_nc_ohc=sMH0rnV-FOsQ7kNvwFNXfSH&_nc_oc=AdnvqWd9Om6Pj3VcUq6NEnkq31VreGH5C0n4brODm2mBIyOScAhrZAjIh5zCJG2hOjw&_nc_zt=23&_nc_ht=scontent.cdninstagram.com&_nc_gid=f7KKzXzILY5M8kuPYrBzTQ&_nc_ss=8&oh=00_AfzfMtDKOIaHk8jAcCi39I0FoMNOdY0JPiiFJELYrN6rkA&oe=69C052F4",
  },
];
const youtubeHubUrl = "https://www.youtube.com/watch?v=gKg4CPHCtL8";
const youtubeVideos = [
  {
    url: "https://youtu.be/gKg4CPHCtL8?si=4k2-FXuYdSBTVm_J",
    title: "Video destacado de BlancaReal",
    image: "https://i.ytimg.com/vi/gKg4CPHCtL8/maxresdefault.jpg",
  },
  {
    url: "https://youtu.be/Z5i1V_h4am4?si=xGe1ofwK-9g5a8-z",
    title: "Recorrido inmobiliario en Costa del Sol",
    image: "https://i.ytimg.com/vi/Z5i1V_h4am4/maxresdefault.jpg",
  },
  {
    url: "https://youtu.be/TRpcobBeRqw?si=IgdXs3nK6FPckP7u",
    title: "Promocion y estilo de vida BlancaReal",
    image: "https://i.ytimg.com/vi/TRpcobBeRqw/maxresdefault.jpg",
  },
  {
    url: "https://youtu.be/XEsSWWHKn28?si=QjTtYzBoBmC6dUX7",
    title: "Proyecto residencial en video",
    image: "https://i.ytimg.com/vi/XEsSWWHKn28/maxresdefault.jpg",
  },
  {
    url: "https://youtu.be/bSjWyx8wMfw?si=j7sGAwDcx4IGts0f",
    title: "Visita y presentacion de propiedad",
    image: "https://i.ytimg.com/vi/bSjWyx8wMfw/maxresdefault.jpg",
  },
];

const teamCards = teamMembers.map((member) => ({
  name: member.name,
  role: member.role?.[lang] ?? member.role?.es ?? "",
  email: member.email ?? member.emails?.[0]?.address ?? "",
  phone: member.phone ?? "",
  emailHref: member.email ?? member.emails?.[0]?.address ?? "",
  phoneHref: String(member.phone ?? "").replace(/\s+/g, ""),
  image: member.photo?.url ?? "",
  imageAlt: member.photo?.alt?.[lang] ?? member.photo?.alt?.es ?? member.name,
  languageBadges: Array.isArray(member.spoken_languages)
    ? member.spoken_languages
        .filter((code) => TEAM_LANGUAGE_BADGES[code])
        .map((code) => TEAM_LANGUAGE_BADGES[code])
    : [],
}));

const homePostsCopy = homeContent.postsByLang[lang] ?? homeContent.postsByLang.es;
const homePosts = posts
  .filter((post) => post.status === "published")
  .map((post) => {
    const translation = post.translations?.[lang] ?? post.translations?.es ?? null;
    const slug = post.slugs?.[lang] ?? post.slugs?.es ?? null;
    if (!translation || !slug || !translation.title) return null;

    return {
      slug,
      title: translation.title,
      excerpt: translation.excerpt ?? "",
      category: String(post.category ?? ""),
      featured: post.featured === true,
      publishedAt: post.published_at ?? "",
      readingTimeMin: Number(post.reading_time_min ?? 0) || 0,
      coverUrl: post.media?.cover?.url ?? "",
      coverAlt:
        post.media?.cover?.alt?.[lang] ??
        post.media?.cover?.alt?.es ??
        translation.title,
    };
  })
  .filter(Boolean)
  .sort((left, right) => {
    const featuredDelta = Number(right.featured) - Number(left.featured);
    if (featuredDelta !== 0) return featuredDelta;
    const leftTime = new Date(`${left.publishedAt}T00:00:00`).getTime();
    const rightTime = new Date(`${right.publishedAt}T00:00:00`).getTime();
    return rightTime - leftTime;
  })
  .slice(0, 4);

const homeLeadPost = homePosts[0] ?? null;
const homeSecondaryPosts = homePosts.slice(1, 4);

const collaboratorLoop = [...extra.collaborators, ...extra.collaborators];
const collaboratorLogoLoop = [...collaboratorLogos, ...collaboratorLogos];

const footerLinks = [
  { href: `/${lang}/properties/`, label: t.blocks.realEstate.title },
  { href: `/${lang}/legal-services/`, label: t.blocks.legal.title },
  { href: `/${lang}/commercialization/`, label: t.blocks.commercialization.title },
  { href: aboutPath, label: t.navAbout },
  { href: `/${lang}/contact/`, label: t.navContact },
];

const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "RealEstateAgent",
    name: "BlancaReal",
    url: `https://blancareal.com/${lang}/`,
    image: heroPosterUrl,
    telephone: "+34952599159",
    email: "info@blancareal.com",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Calle Monte Calahonda, 10",
      addressLocality: "Mijas Costa",
      postalCode: "29649",
      addressCountry: "ES",
    },
    areaServed: ["Costa del Sol", "Mijas Costa", "Fuengirola", "Malaga"],
    availableLanguage: ["es", "en", "de", "fr", "it", "nl"],
    numberOfEmployees: teamCount,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "BlancaReal",
        item: `https://blancareal.com/${lang}/`,
      },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<BaseLayout
  title={t.title}
  description={t.description}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  og={{ image: heroPosterUrl }}
  preloadImageUrl={heroPosterUrl}
  preloadImageType="image/webp"
  structuredData={homeStructuredData}
  {...navigation}
  showMobileStickyCta={false}
  preloadSmoothyFont={true}
>
  <HomeEditorialHero
    lang={lang}
    slides={heroSlides}
    stats={heroStats}
    projectsPath={`/${lang}/projects/`}
  />
  <HomeFeaturedServices lang={lang} />
  <HomeFeaturedUnits lang={lang} cards={featuredUnits} />

  <section class="landing-about-z container">
    {homeLeadPost ? (
      <article class="home-journal">
        <div class="home-journal-head">
          <div class="home-journal-heading">
            <p class="home-journal-eyebrow">{homePostsCopy.eyebrow}</p>
            <h2>{homePostsCopy.title}</h2>
            <p>{homePostsCopy.intro}</p>
          </div>
          <a href={`/${lang}/posts/`} class="home-journal-link">{homePostsCopy.viewAll}</a>
        </div>

        <div class="home-journal-grid">
          <article class="home-journal-lead">
            <a href={`/${lang}/post/${homeLeadPost.slug}/`} class="home-journal-card-link">
              {homeLeadPost.coverUrl ? (
                <img
                  src={homeLeadPost.coverUrl}
                  alt={homeLeadPost.coverAlt}
                  width="1280"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="home-journal-fallback"></div>
              )}
              <div class="home-journal-overlay"></div>
              <div class="home-journal-copy">
                <span>{homeLeadPost.category}</span>
                <h3>{homeLeadPost.title}</h3>
                <p>{homeLeadPost.excerpt}</p>
              </div>
            </a>
          </article>

          <div class="home-journal-stack">
            {homeSecondaryPosts.map((post) => (
              <article class="home-journal-secondary">
                <a href={`/${lang}/post/${post.slug}/`} class="home-journal-secondary-link">
                  {post.coverUrl ? (
                    <img
                      src={post.coverUrl}
                      alt={post.coverAlt}
                      width="960"
                      height="720"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="home-journal-fallback"></div>
                  )}
                  <div class="home-journal-secondary-copy">
                    <span>{post.category}</span>
                    <h3>{post.title}</h3>
                    <p>{post.excerpt}</p>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>
      </article>
    ) : null}

    <section class="home-instagram" aria-label={instagramCopy.ariaLabel}>
      <div class="home-instagram-head">
        <div class="home-instagram-heading">
          <h2>{instagramCopy.title}</h2>
          <p>{instagramCopy.intro}</p>
        </div>
        <a
          href={instagramProfileUrl}
          class="home-instagram-follow"
          target="_blank"
          rel="noreferrer"
        >
          <span>{instagramCopy.cta}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <div class="lightwidget home-instagram-widget" data-id="blancareal-instagram">
        <ul class="lightwidget__posts lightwidget__posts--hover-show-instagram-icon lightwidget__posts--image-format-square lightwidget__posts--grid">
        {instagramPosts.map((post) => (
          <li class="lightwidget__tile">
            <a
              href={post.url}
              class="lightwidget__link lightwidget__focus"
              target="_blank"
              rel="noreferrer"
              aria-label={post.title}
            >
              <figure class="lightwidget__photo">
                <picture class="lightwidget__image-wrapper">
                  <img
                    width="1080"
                    height="1080"
                    alt={post.title}
                    class="lightwidget__image"
                    sizes="(max-width: 1200px) 33vw, 17vw"
                    src={post.image}
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
                <span class="lightwidget__instagram-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="4" width="16" height="16" rx="3.75"></rect>
                    <circle cx="12" cy="12" r="3.4"></circle>
                    <circle cx="17.2" cy="6.9" r="0.9" fill="currentColor" stroke="none"></circle>
                  </svg>
                </span>
                <figcaption class="lightwidget__caption">{post.title}</figcaption>
              </figure>
            </a>
          </li>
        ))}
        </ul>
      </div>
    </section>

    <section class="home-media home-youtube" aria-label={youtubeCopy.ariaLabel}>
      <div class="home-media-head">
        <div class="home-media-heading">
          <h2>{youtubeCopy.title}</h2>
          <p>{youtubeCopy.intro}</p>
        </div>
        <a
          href={youtubeHubUrl}
          class="home-media-follow home-youtube-follow"
          target="_blank"
          rel="noreferrer"
        >
          <span>{youtubeCopy.cta}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <div class="home-media-widget" data-id="blancareal-youtube">
        <div class="home-media-list">
          {youtubeVideos.map((video) => (
            <article class="home-media-tile">
              <a
                href={video.url}
                class="home-media-link"
                target="_blank"
                rel="noreferrer"
                aria-label={video.title}
              >
                <figure class="home-media-photo">
                  <picture class="home-media-image-wrapper">
                    <img
                      width="480"
                      height="360"
                      alt={video.title}
                      class="home-media-image"
                      sizes="(max-width: 1200px) 33vw, 20vw"
                      src={video.image}
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                  <span class="home-media-video-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                      <path d="M21.8 7.2a2.9 2.9 0 0 0-2-2c-1.8-.5-7.8-.5-7.8-.5s-6 0-7.8.5a2.9 2.9 0 0 0-2 2A30.9 30.9 0 0 0 1.7 12a30.9 30.9 0 0 0 .5 4.8 2.9 2.9 0 0 0 2 2c1.8.5 7.8.5 7.8.5s6 0 7.8-.5a2.9 2.9 0 0 0 2-2 30.9 30.9 0 0 0 .5-4.8 30.9 30.9 0 0 0-.5-4.8Z"></path>
                      <path d="m10 15.5 5.2-3.5L10 8.5Z" fill="#fff"></path>
                    </svg>
                  </span>
                  <figcaption class="home-media-caption">{video.title}</figcaption>
                </figure>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <article class="z-team">
      <div class="z-team-head">
        <h2>{teamCopy.title}</h2>
      </div>
      <div class="z-team-carousel" data-team-carousel>
        <button
          class="z-team-arrow z-team-arrow-prev"
          type="button"
          aria-label={teamCopy.prev}
          data-carousel-prev
        >
          <span aria-hidden="true">&larr;</span>
        </button>
        <div class="z-team-viewport" data-carousel-viewport>
          <div class="z-team-track">
            {teamCards.map((member) => (
              <article class="z-team-card">
                <div class="z-team-photo">
                  <img
