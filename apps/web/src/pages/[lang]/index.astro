const landingNavGroups = landingNavGroupsByLang[lang] ?? landingNavGroupsByLang.es;

const homePostsByLang = {
  es: {
    eyebrow: "Revista BlancaReal",
    title: "Lecturas recientes sobre mercado, producto y asesoramiento",
    intro:
      "Una seleccion editorial de nuestro blog para poner contexto al mercado, explicar servicios y destacar operaciones o proyectos recientes.",
    viewAll: "Ver revista",
  },
  en: {
    eyebrow: "BlancaReal Journal",
    title: "Recent reads on market, product and advisory",
    intro:
      "An editorial selection from our journal to frame the market, explain services and highlight recent deals or developments.",
    viewAll: "View journal",
  },
  de: {
    eyebrow: "BlancaReal Magazin",
    title: "Aktuelle Inhalte zu Markt, Produkt und Beratung",
    intro:
      "Eine redaktionelle Auswahl aus unserem Magazin, um den Markt einzuordnen, Services zu erklaeren und aktuelle Projekte oder Transaktionen hervorzuheben.",
    viewAll: "Magazin ansehen",
