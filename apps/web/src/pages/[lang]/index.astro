          items: [
            { label: "Contracten opstellen en beoordelen", href: `/${lang}/legal-services/#coverage-contracts` },
            { label: "Due diligence vastgoed", href: `/${lang}/legal-services/#coverage-due` },
            { label: "Fiscaal advies", href: `/${lang}/legal-services/#coverage-tax` },
            { label: "Documentatie en afhandeling", href: `/${lang}/legal-services/#coverage-docs` },
