---
export const prerender = false;

import BaseLayout from "@webapp/layouts/BaseLayout.astro";
import HomeEditorialHero from "@webapp/components/HomeEditorialHero.astro";
import HomeFeaturedServices from "@webapp/components/HomeFeaturedServices.astro";
import HomeFeaturedUnits from "@webapp/components/HomeFeaturedUnits.astro";
import HomeSocialHub from "@webapp/components/HomeSocialHub.astro";
import { DEFAULT_LANG, isSupportedLang, SUPPORTED_LANGS } from "@shared/i18n/languages";
import { getUiCopy } from "@shared/i18n/ui";
import teamMembers from "@shared/data/team";
import posts from "@shared/data/posts";
import "@webapp/styles/pages/landing.css";
import "@webapp/styles/pages/home.css";
import "@webapp/styles/pages/home-editorial.css";
import { formatPrice } from "@shared/presentation/common";
import {
  buildFeaturedChildUnitCards,
  buildProjectShowcaseCards,
  getPublicPropertiesWithFallback,
} from "@shared/properties/public";
import { buildPublicNavigation } from "@webapp/navigation/publicNavigation";
import homePageContent from "@shared/data/pages/home.json";

const langParam = Astro.params.lang ?? DEFAULT_LANG;

if (!isSupportedLang(langParam)) {
  return Astro.redirect(`/${DEFAULT_LANG}/`, 302);
}

const lang = langParam;
const foundedYear = 1969;
const teamCount = teamMembers.length;
const contactPath = `/${lang}/contact/`;
const aboutPath = `/${lang}/about/`;
const legalNoticePath = `/${lang}/legal/notice/`;
const privacyPath = `/${lang}/legal/privacy/`;
const cookiesPath = `/${lang}/legal/cookies/`;
const HERO_POSTER_URL =
  "https://gslfgcqwmcircqaslzij.supabase.co/storage/v1/object/public/properties/PM0079/cover/1.webp";
const CONTACT_PREFILL_STORAGE_KEY = "blancareal-contact-prefill";

const collaboratorLogoModules = import.meta.glob(
  "../../../../../src/assets/collaborators/strategic/*.{avif,jpg,jpeg,png,svg,webp}",
  { eager: true, query: "?url", import: "default" },
);

const collaboratorFallbackAltByLang = {
  es: "Colaborador estrategico",
  en: "Strategic collaborator",
  de: "Strategischer Partner",
  fr: "Collaborateur strategique",
  it: "Collaboratore strategico",
  nl: "Strategische partner",
} as const;

const formatCollaboratorLogoName = (filePath) =>
  filePath
    .split("/")
    .pop()
    ?.replace(/\.[^.]+$/, "")
    .replace(/[-_]+/g, " ")
    .replace(/\s+/g, " ")
    .trim() ??
  collaboratorFallbackAltByLang[lang as keyof typeof collaboratorFallbackAltByLang] ??
  collaboratorFallbackAltByLang.es;

const collaboratorLogos = Object.entries(collaboratorLogoModules)
  .map(([filePath, src]) => ({
    src,
    alt: formatCollaboratorLogoName(filePath),
  }))
  .sort((left, right) => left.alt.localeCompare(right.alt, lang));

const homeContent = homePageContent as Record<string, any>;
const t = homeContent.pageByLang[lang] ?? homeContent.pageByLang.es;
const ui = getUiCopy(lang);
const navigation = buildPublicNavigation({
  lang,
  family: "home",
  section: "home",
});
const HOME_PROJECT_IDS = ["PM0079", "PM0074", "PM0011"];
const [
  { properties: homeProjects },
  { properties: homeProjectUnits },
  { count: availableHomesCountRaw },
] = await Promise.all([
  getPublicPropertiesWithFallback({
    query: {
      ids: HOME_PROJECT_IDS,
      listingTypes: ["promotion"],
      selectProfile: "card",
    },
  }),
  getPublicPropertiesWithFallback({
    query: {
      listingTypes: ["unit"],
      parentIds: HOME_PROJECT_IDS,
      selectProfile: "card",
    },
  }),
  getPublicPropertiesWithFallback({
    query: {
      listingTypes: ["unit"],
      statuses: ["available"],
      countOnly: true,
    },
  }),
]);
const properties = [...homeProjects, ...homeProjectUnits];

const projectCards = buildProjectShowcaseCards(properties, lang, {
  allowedIds: HOME_PROJECT_IDS,
  limit: 4,
});

const featuredUnits = buildFeaturedChildUnitCards(properties, lang, {
  limit: 20,
});

const availableHomesCount =
  typeof availableHomesCountRaw === "number" && Number.isFinite(availableHomesCountRaw)
    ? availableHomesCountRaw
    : 0;

const formattedAvailableHomesCount = new Intl.NumberFormat(lang).format(availableHomesCount);

const heroSlides = projectCards.map((card) => ({
  ...card,
  priceLabel: formatPrice(card.priceFrom, card.currency, lang),
}));
const heroStats = (homeContent.heroStatsByLang[lang] ?? homeContent.heroStatsByLang.es).map(
  (item: { value: string; label: string }) => ({
    ...item,
    value:
      item.value === "__AVAILABLE_HOMES_COUNT__" ? formattedAvailableHomesCount : item.value,
  }),
);
const heroPosterUrl = heroSlides[0]?.coverUrl ?? HERO_POSTER_URL;

const extra = homeContent.extraByLang[lang] ?? homeContent.extraByLang.es;
const formCopy = homeContent.formByLang[lang] ?? homeContent.formByLang.es;
const TEAM_LANGUAGE_BADGES = homeContent.teamLanguageBadges as Record<
  string,
  { label: string; flagUrl: string }
>;
const teamCopy = homeContent.teamByLang[lang] ?? homeContent.teamByLang.es;

const teamCards = teamMembers.map((member) => ({
  name: member.name,
  role: member.role?.[lang] ?? member.role?.es ?? "",
  email: member.email ?? member.emails?.[0]?.address ?? "",
  phone: member.phone ?? "",
  emailHref: member.email ?? member.emails?.[0]?.address ?? "",
  phoneHref: String(member.phone ?? "").replace(/\s+/g, ""),
  whatsappHref: String(member.phone ?? "").replace(/\D+/g, ""),
  image: member.photo?.url ?? "",
  imageAlt: member.photo?.alt?.[lang] ?? member.photo?.alt?.es ?? member.name,
  languageBadges: Array.isArray(member.spoken_languages)
    ? member.spoken_languages
        .filter((code) => TEAM_LANGUAGE_BADGES[code])
        .map((code) => TEAM_LANGUAGE_BADGES[code])
    : [],
}));

const homePostsCopy = homeContent.postsByLang[lang] ?? homeContent.postsByLang.es;
const homePosts = posts
  .filter((post) => post.status === "published")
  .map((post) => {
    const translation = post.translations?.[lang] ?? post.translations?.es ?? null;
    const slug = post.slugs?.[lang] ?? post.slugs?.es ?? null;
    if (!translation || !slug || !translation.title) return null;

    return {
      slug,
      title: translation.title,
      excerpt: translation.excerpt ?? "",
      category: String(post.category ?? ""),
      featured: post.featured === true,
      publishedAt: post.published_at ?? "",
      readingTimeMin: Number(post.reading_time_min ?? 0) || 0,
      coverUrl: post.media?.cover?.url ?? "",
      coverAlt:
        post.media?.cover?.alt?.[lang] ??
        post.media?.cover?.alt?.es ??
        translation.title,
    };
  })
  .filter(Boolean)
  .sort((left, right) => {
    const featuredDelta = Number(right.featured) - Number(left.featured);
    if (featuredDelta !== 0) return featuredDelta;
    const leftTime = new Date(`${left.publishedAt}T00:00:00`).getTime();
    const rightTime = new Date(`${right.publishedAt}T00:00:00`).getTime();
    return rightTime - leftTime;
  })
  .slice(0, 4);

const homeLeadPost = homePosts[0] ?? null;
const homeSecondaryPosts = homePosts.slice(1, 4);

const collaboratorLoop = [...extra.collaborators, ...extra.collaborators];
const collaboratorLogoLoop = [...collaboratorLogos, ...collaboratorLogos];

const footerLinks = [
  { href: `/${lang}/properties/`, label: t.blocks.realEstate.title },
  { href: `/${lang}/legal-services/`, label: t.blocks.legal.title },
  { href: `/${lang}/commercialization/`, label: t.blocks.commercialization.title },
  { href: aboutPath, label: t.navAbout },
  { href: `/${lang}/contact/`, label: t.navContact },
];

const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "RealEstateAgent",
    name: "BlancaReal",
    url: `https://blancareal.com/${lang}/`,
    image: heroPosterUrl,
    telephone: "+34952599159",
    email: "info@blancareal.com",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Calle Monte Calahonda, 10",
      addressLocality: "Mijas Costa",
      postalCode: "29649",
      addressCountry: "ES",
    },
    areaServed: ["Costa del Sol", "Mijas Costa", "Fuengirola", "Malaga"],
    availableLanguage: ["es", "en", "de", "fr", "it", "nl"],
    numberOfEmployees: teamCount,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "BlancaReal",
        item: `https://blancareal.com/${lang}/`,
      },
    ],
  },
];

const currentYear = new Date().getFullYear();
const mobileHomeCopyByLang = {
  es: {
    exploreProjects: "Explorar proyectos",
    quickActionsLabel: "Accesos directos",
    viewAllUnits: "Ver todas",
  },
  en: {
    exploreProjects: "Explore projects",
    quickActionsLabel: "Quick actions",
    viewAllUnits: "View all",
  },
  de: {
    exploreProjects: "Projekte entdecken",
    quickActionsLabel: "Schnellzugriff",
    viewAllUnits: "Alle ansehen",
  },
  fr: {
    exploreProjects: "Explorer les projets",
    quickActionsLabel: "Acces rapides",
    viewAllUnits: "Voir tout",
  },
  it: {
    exploreProjects: "Esplora i progetti",
    quickActionsLabel: "Accessi rapidi",
    viewAllUnits: "Vedi tutto",
  },
  nl: {
    exploreProjects: "Projecten ontdekken",
    quickActionsLabel: "Snelle acties",
    viewAllUnits: "Alles bekijken",
  },
};
const mobileHomeCopy =
  mobileHomeCopyByLang[lang as keyof typeof mobileHomeCopyByLang] ?? mobileHomeCopyByLang.es;
const projectsPath = `/${lang}/projects/`;
const propertiesPath = `/${lang}/properties/`;
const heroMobileQuickLinks = [
  { href: projectsPath, label: ui.layout.navProjects },
  { href: propertiesPath, label: ui.layout.navProperties },
  { href: `/${lang}/commercialization/`, label: ui.layout.navCommercialization },
  { href: `/${lang}/legal-services/`, label: ui.layout.navLegalServices },
];
---

<BaseLayout
  title={t.title}
  description={t.description}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  og={{ image: heroPosterUrl }}
  preloadImageUrl={heroPosterUrl}
  preloadImageType="image/webp"
  structuredData={homeStructuredData}
  {...navigation}
  showMobileStickyCta={false}
  mobileStickyCta={{
    primary: { href: projectsPath, label: mobileHomeCopy.exploreProjects, variant: "primary" },
    secondary: { href: "tel:+34952599159", label: ui.layout.call, variant: "call" },
  }}
  preloadSmoothyFont={true}
>
  <HomeEditorialHero
    lang={lang}
    slides={heroSlides}
    stats={heroStats}
    projectsPath={projectsPath}
    propertiesPath={propertiesPath}
    mobileQuickLinks={heroMobileQuickLinks}
    mobileQuickActionsLabel={mobileHomeCopy.quickActionsLabel}
  />
  <HomeFeaturedUnits
    lang={lang}
    cards={featuredUnits}
    viewAllHref={propertiesPath}
    viewAllLabel={mobileHomeCopy.viewAllUnits}
  />
  <HomeFeaturedServices lang={lang} />

  <section class="landing-about-z container">
    <article class="z-team">
      <div class="z-team-head">
        <h2>{teamCopy.title}</h2>
      </div>
      <div class="z-team-carousel" data-team-carousel>
        <button
          class="z-team-arrow z-team-arrow-prev"
          type="button"
          aria-label={teamCopy.prev}
          data-carousel-prev
        >
          <span aria-hidden="true">&larr;</span>
        </button>
        <div class="z-team-viewport" data-carousel-viewport>
          <div class="z-team-track">
            {teamCards.map((member) => (
              <article class="z-team-card">
                <div class="z-team-photo">
                  <img
                    src={member.image}
                    alt={member.imageAlt}
                    width="720"
                    height="900"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="z-team-copy">
                  <h3>{member.name}</h3>
                  {member.role && <p class="z-team-role">{member.role}</p>}
                  <dl class="z-team-meta">
                    <div>
                      <dt>{teamCopy.languages}</dt>
                      <dd>
                        {member.languageBadges.length > 0 ? (
                          <ul class="z-team-flags" aria-label={teamCopy.languages}>
                            {member.languageBadges.map((badge) => (
                              <li class="z-team-flag" title={badge.label}>
                                <img src={badge.flagUrl} alt={badge.label} loading="lazy" />
                              </li>
                            ))}
                          </ul>
                        ) : (
                          teamCopy.noLanguages
                        )}
                      </dd>
                    </div>
                  </dl>
                  <div class="z-team-actions">
                    {member.phone && member.whatsappHref && (
                      <a
                        class="z-team-action z-team-action-whatsapp"
                        href={`https://wa.me/${member.whatsappHref}`}
                        target="_blank"
                        rel="noreferrer"
                      >
                        {teamCopy.whatsappAction}
                      </a>
                    )}
                    {member.email && (
                      <a class="z-team-action z-team-action-email" href={`mailto:${member.emailHref}`}>
                        {teamCopy.emailAction}
                      </a>
                    )}
                    {member.phone && (
                      <a class="z-team-action z-team-action-phone" href={`tel:${member.phoneHref}`}>
                        {teamCopy.phoneAction}
                      </a>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
        <button
          class="z-team-arrow z-team-arrow-next"
          type="button"
          aria-label={teamCopy.next}
          data-carousel-next
        >
          <span aria-hidden="true">&rarr;</span>
        </button>
      </div>
    </article>

    {homeLeadPost ? (
      <article class="home-journal">
        <div class="home-journal-head">
          <div class="home-journal-heading">
            <p class="home-journal-eyebrow">{homePostsCopy.eyebrow}</p>
            <h2>{homePostsCopy.title}</h2>
            <p>{homePostsCopy.intro}</p>
          </div>
          <a href={`/${lang}/posts/`} class="home-journal-link">{homePostsCopy.viewAll}</a>
        </div>

        <div class="home-journal-grid">
          <article class="home-journal-lead">
            <a href={`/${lang}/post/${homeLeadPost.slug}/`} class="home-journal-card-link">
              {homeLeadPost.coverUrl ? (
                <img
                  src={homeLeadPost.coverUrl}
                  alt={homeLeadPost.coverAlt}
                  width="1280"
                  height="900"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="home-journal-fallback"></div>
              )}
              <div class="home-journal-overlay"></div>
              <div class="home-journal-copy">
                <span>{homeLeadPost.category}</span>
                <h3>{homeLeadPost.title}</h3>
                <p>{homeLeadPost.excerpt}</p>
              </div>
            </a>
          </article>

          <details class="home-journal-accordion" open>
            <summary class="home-journal-summary">
              <span>{homePostsCopy.viewAll}</span>
            </summary>

            <div class="home-journal-stack">
              {homeSecondaryPosts.map((post) => (
                <article class="home-journal-secondary">
                  <a href={`/${lang}/post/${post.slug}/`} class="home-journal-secondary-link">
                    {post.coverUrl ? (
                      <img
                        src={post.coverUrl}
                        alt={post.coverAlt}
                        width="960"
                        height="720"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="home-journal-fallback"></div>
                    )}
                    <div class="home-journal-secondary-copy">
                      <span>{post.category}</span>
                      <h3>{post.title}</h3>
                      <p>{post.excerpt}</p>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          </details>
        </div>
      </article>
    ) : null}

    <article class="z-row is-reverse" id="home-contact">
      <div class="z-media">
        <img
          src={extra.aboutRows[1].image}
          alt={extra.aboutRows[1].imageAlt}
          width="1280"
          height="960"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="z-copy z-copy-form">
        <h2>{formCopy.title}</h2>
        <p>{formCopy.intro}</p>
        <details class="z-form-disclosure" open>
          <summary class="z-form-summary">
            <span class="z-form-summary-open">{formCopy.toggleOpen}</span>
            <span class="z-form-summary-close">{formCopy.toggleClose}</span>
          </summary>
          <form class="z-form" method="get" action={contactPath} id="landingLeadForm">
            <div class="z-form-grid">
              <label class="z-form-field">
                <span>{formCopy.name}</span>
                <input type="text" name="name" required />
              </label>
              <label class="z-form-field">
                <span>{formCopy.email}</span>
                <input type="email" name="email" required />
              </label>
              <label class="z-form-field">
                <span>{formCopy.phone}</span>
                <input type="tel" name="phone" />
              </label>
              <label class="z-form-field">
                <span>{formCopy.service}</span>
                <select name="service" required>
                  <option value="">{formCopy.optionDefault}</option>
                  <option value="real-estate">{formCopy.optionRealEstate}</option>
                  <option value="legal-services">{formCopy.optionLegal}</option>
                  <option value="commercialization">{formCopy.optionCommercialization}</option>
                </select>
              </label>
            </div>

            <label class="z-form-field z-form-field-full">
              <span>{formCopy.message}</span>
              <textarea name="message" rows="4"></textarea>
            </label>

            <label class="z-form-consent">
              <input type="checkbox" name="consent" required />
              <span>
                {formCopy.consentPrefix}{" "}
                <a href={privacyPath}>{formCopy.consentLink}</a>{" "}
                {formCopy.consentSuffix}
              </span>
            </label>

            <p class="z-form-legal-note">{formCopy.legalNote}</p>

            <div class="z-form-actions">
              <button type="submit" class="z-form-submit">{formCopy.submit}</button>
              <p class="z-form-status" id="landingLeadStatus" aria-live="polite"></p>
            </div>
          </form>
        </details>
      </div>
    </article>

    <HomeSocialHub lang={lang} />
  </section>

  <section class="landing-collaborators" aria-label={extra.collaboratorsAria}>
    <div class="container">
      <h2>{extra.collaboratorsTitle}</h2>
    </div>
    <div class="collaborators-marquee">
      <div class="collaborators-track">
        {collaboratorLogos.length > 0
          ? collaboratorLogoLoop.map((logo, index) => (
              <article
                class="collab-pill collab-pill-logo"
                aria-hidden={index >= collaboratorLogos.length ? "true" : undefined}
              >
                <img src={logo.src} alt={logo.alt} loading="lazy" decoding="async" />
              </article>
            ))
          : collaboratorLoop.map((item, index) => (
              <article class="collab-pill" aria-hidden={index >= extra.collaborators.length ? "true" : undefined}>
                <span class="collab-dot"></span>
                <p>{item}</p>
              </article>
            ))}
      </div>
    </div>
  </section>

  <footer class="landing-footer">
    <div class="container landing-footer-grid">
      <section class="footer-brand">
        <a href={`/${lang}/`} class="footer-brand-logo" aria-label="BlancaReal">
          <img
            src="/logos/blanca_real_logo_secundario_blanco.png"
            alt="BlancaReal"
            width="150"
            height="145"
            loading="lazy"
          />
        </a>
        <p>{extra.footerTagline}</p>
      </section>

      <section class="footer-nav">
        <h3>{extra.footerSections}</h3>
        <ul>
          {footerLinks.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </section>

      <section class="footer-contact">
        <h3>{extra.footerContact}</h3>
        <ul>
          <li><a href="tel:+34952599159">+34 952 599 159</a></li>
          <li><a href="mailto:info@blancareal.com">info@blancareal.com</a></li>
          <li>Calle Monte Calahonda, 10 - 29649 Mijas Costa, Malaga</li>
        </ul>
      </section>

      <section class="footer-legal">
        <h3>{extra.footerLegal}</h3>
        <ul>
          <li><a href={legalNoticePath}>{extra.legalNotice}</a></li>
          <li><a href={privacyPath}>{extra.privacy}</a></li>
          <li><a href={cookiesPath}>{extra.cookies}</a></li>
        </ul>
      </section>
    </div>
    <div class="footer-bottom">
      <p>&copy; {currentYear} BlancaReal. {extra.footerRights}</p>
    </div>
  </footer>

  <script
    is:inline
    define:vars={{
      contactPath,
      contactPrefillStorageKey: CONTACT_PREFILL_STORAGE_KEY,
      landingRedirectText: formCopy.redirecting,
    }}
  >
    const homeFormDisclosure = document.querySelector(".z-form-disclosure");
    const landingLeadForm = document.getElementById("landingLeadForm");
    const landingLeadStatus = document.getElementById("landingLeadStatus");
    const journalAccordion = document.querySelector(".home-journal-accordion");
    const teamCarousels = document.querySelectorAll("[data-team-carousel]");
    const BREAKPOINTS = {
      xs: 480,
      md: 768,
      lg: 1024,
    };

    const syncHomeFormDisclosure = () => {
      if (!(homeFormDisclosure instanceof HTMLDetailsElement)) return;
      if (window.innerWidth < BREAKPOINTS.md) {
        homeFormDisclosure.removeAttribute("open");
      } else {
        homeFormDisclosure.setAttribute("open", "");
      }
    };

    const syncTeamCarouselState = (carousel) => {
      const viewport = carousel.querySelector("[data-carousel-viewport]");
      const prev = carousel.querySelector("[data-carousel-prev]");
      const next = carousel.querySelector("[data-carousel-next]");

      if (!(viewport instanceof HTMLElement) || !(prev instanceof HTMLButtonElement) || !(next instanceof HTMLButtonElement)) {
        return;
      }

      const maxScrollLeft = viewport.scrollWidth - viewport.clientWidth;
      prev.disabled = viewport.scrollLeft <= 8;
      next.disabled = viewport.scrollLeft >= maxScrollLeft - 8;
    };

    const setupTeamCarousel = (carousel) => {
      const viewport = carousel.querySelector("[data-carousel-viewport]");
      const prev = carousel.querySelector("[data-carousel-prev]");
      const next = carousel.querySelector("[data-carousel-next]");

      if (!(viewport instanceof HTMLElement) || !(prev instanceof HTMLButtonElement) || !(next instanceof HTMLButtonElement)) {
        return;
      }

      const scrollStep = () => Math.max(viewport.clientWidth * 0.82, 280);

      prev.addEventListener("click", () => {
        viewport.scrollBy({ left: -scrollStep(), behavior: "smooth" });
      });

      next.addEventListener("click", () => {
        viewport.scrollBy({ left: scrollStep(), behavior: "smooth" });
      });

      viewport.addEventListener("scroll", () => syncTeamCarouselState(carousel), { passive: true });
      syncTeamCarouselState(carousel);
    };

    const syncHomeJournalAccordion = () => {
      if (!(journalAccordion instanceof HTMLDetailsElement)) {
        return;
      }

      journalAccordion.open = window.innerWidth >= BREAKPOINTS.md;
    };

    if (landingLeadForm instanceof HTMLFormElement && landingLeadStatus instanceof HTMLElement) {
      landingLeadForm.addEventListener("submit", (event) => {
        event.preventDefault();

        if (!landingLeadForm.reportValidity()) {
          return;
        }

        const formData = new FormData(landingLeadForm);
        const payload = {
          full_name: String(formData.get("name") ?? "").trim(),
          email: String(formData.get("email") ?? "").trim(),
          phone: String(formData.get("phone") ?? "").trim(),
          service: String(formData.get("service") ?? "").trim(),
          message: String(formData.get("message") ?? "").trim(),
          source: "landing_home_form",
        };

        try {
          window.sessionStorage.setItem(contactPrefillStorageKey, JSON.stringify(payload));
        } catch (error) {
          console.error(error);
        }

        landingLeadStatus.textContent = landingRedirectText;
        landingLeadStatus.classList.add("is-success");

        const targetUrl = new URL(contactPath, window.location.origin);
        if (payload.service) {
          targetUrl.searchParams.set("service", payload.service);
        }
        targetUrl.searchParams.set("from", "home");
        window.location.assign(targetUrl.toString());
      });
    }

    syncHomeFormDisclosure();
    syncHomeJournalAccordion();
    teamCarousels.forEach(setupTeamCarousel);
    window.addEventListener("resize", () => {
      teamCarousels.forEach(syncTeamCarouselState);
    });
    window.addEventListener("resize", syncHomeFormDisclosure);
    window.addEventListener("resize", syncHomeJournalAccordion);
  </script>
</BaseLayout>

