---
export const prerender = false;

import BaseLayout from "@webapp/layouts/BaseLayout.astro";
import { DEFAULT_LANG, isSupportedLang, SUPPORTED_LANGS } from "@shared/i18n/languages";
import { buildPublicNavigation } from "@webapp/navigation/publicNavigation";
import "@webapp/styles/pages/service-pages.css";

const langParam = Astro.params.lang ?? DEFAULT_LANG;

if (!isSupportedLang(langParam)) {
  return Astro.redirect(`/${DEFAULT_LANG}/contact/`, 302);
}

const lang = langParam;
const navigation = buildPublicNavigation({
  lang,
  family: "editorial",
  section: "contact",
});
const privacyPath = `/${lang}/legal/privacy/`;
const CONTACT_PREFILL_STORAGE_KEY = "blancareal-contact-prefill";
const turnstileSiteKey = String(import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "").trim();
const turnstileRequired = !import.meta.env.DEV || turnstileSiteKey.length > 0;
const OFFICE_ADDRESS = "Calle Monte Calahonda 10, Mijas Costa, Malaga";
const OFFICE_MAP_EMBED =
  "https://www.google.com/maps?q=Calle+Monte+Calahonda+10,+Mijas+Costa,+Malaga&output=embed";
const OFFICE_MAP_LINK =
  "https://www.google.com/maps/search/?api=1&query=Calle+Monte+Calahonda+10,+Mijas+Costa,+Malaga";
const OFFICE_PHONE_DISPLAY = "+34 952 599 159";
const OFFICE_PHONE_TEL = "+34952599159";
const OFFICE_WHATSAPP_LINK = "https://wa.me/601641600";

const serviceParamRaw = String(Astro.url.searchParams.get("service") ?? "").trim();
const ALLOWED_SERVICES = new Set([
  "real-estate",
  "legal-services",
  "commercialization",
  "marketing-3d",
  "agents",
]);
const selectedService = ALLOWED_SERVICES.has(serviceParamRaw) ? serviceParamRaw : "";

