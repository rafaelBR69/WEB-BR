const serviceParamRaw = String(Astro.url.searchParams.get("service") ?? "").trim();
const ALLOWED_SERVICES = new Set([
  "real-estate",
  "legal-services",
  "commercialization",
  "marketing-3d",
  "agents",
]);
const selectedService = ALLOWED_SERVICES.has(serviceParamRaw) ? serviceParamRaw : "";

