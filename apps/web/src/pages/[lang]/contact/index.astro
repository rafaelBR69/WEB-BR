const t = copyByLang[lang] ?? copyByLang.es;
const contactCopy =
  lang === "es"
    ? {
        ...t,
        heading: "Respondemos a todas sus consultas",
        intro:
          "Seleccione el departamento que necesite y nuestro equipo le responderá lo antes posible.",
        phoneLabel: "Tlf",
        officeLabel: "Dirección",
        hoursValue: "10.00H a 18.00H de Lunes a Viernes",
        channelsTitle: "Información y contacto de la oficina de BlancaReal",
        channelsIntro: "Contacto directo",
