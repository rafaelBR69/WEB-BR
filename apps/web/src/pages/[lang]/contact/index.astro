---

<BaseLayout
  title={contactCopy.title}
  description={contactCopy.description}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  {...navigation}
>
  <div class="contact-page">
    <section class="contact-hero container">
      <div class="contact-hero__shell">
        <div class="contact-hero__copy">
          <span class="service-eyebrow">{contactCopy.eyebrow}</span>
          <h1>{contactCopy.heading}</h1>
          <p>{contactCopy.intro}</p>

        </div>

        <aside class="contact-hero__aside" aria-label={contactCopy.channelsTitle}>
          <div class="contact-hero__card">
            <span class="contact-card__eyebrow">{contactCopy.channelsTitle}</span>
            <div class="contact-hero__lead">
              <p class="contact-hero__lead-label">{contactCopy.channelsIntro ?? contactCopy.channelsTitle}</p>
              <a href={`tel:${OFFICE_PHONE_TEL}`} class="contact-hero__phone">{OFFICE_PHONE_DISPLAY}</a>
              <a href="mailto:info@blancareal.com" class="contact-hero__mail">info@blancareal.com</a>
              <a
                href={OFFICE_WHATSAPP_LINK}
                class="contact-whatsapp-button"
                target="_blank"
                rel="noreferrer"
              >
                {contactCopy.whatsappCta ?? "WhatsApp"}
              </a>
            </div>
            <dl class="contact-hero__meta">
              <div>
                <dt>{contactCopy.officeLabel}</dt>
                <dd>
                  <a href={OFFICE_MAP_LINK} target="_blank" rel="noreferrer" class="contact-address-link">
                    {contactCopy.officeValue}
                  </a>
                </dd>
              </div>
              <div>
                <dt>{contactCopy.whatsappLabel ?? "WhatsApp"}</dt>
                <dd>
                  <a href={OFFICE_WHATSAPP_LINK} target="_blank" rel="noreferrer" class="contact-address-link">
                    {contactCopy.whatsappCta ?? "WhatsApp"}
                  </a>
                </dd>
              </div>
              <div>
                <dt>{contactCopy.hoursLabel}</dt>
                <dd>{contactCopy.hoursValue}</dd>
              </div>
            </dl>
          </div>
        </aside>
      </div>
    </section>

    <section class="contact-grid container">
      <article class="contact-panel contact-panel--channels">
        <div class="contact-panel__head">
          <span class="contact-card__eyebrow">{contactCopy.channelsTitle}</span>
          <h2>{contactCopy.channelsTitle}</h2>
          <p>{contactCopy.channelsIntro ?? contactCopy.channelsTitle}</p>
        </div>
        <ul class="contact-channel-grid">
          <li class="contact-channel-card">
            <span>{contactCopy.phoneLabel}</span>
            <a href={`tel:${OFFICE_PHONE_TEL}`} class="contact-channel-card__phone">{OFFICE_PHONE_DISPLAY}</a>
          </li>
          <li class="contact-channel-card">
            <span>{contactCopy.emailLabel}</span>
            <a href="mailto:info@blancareal.com">info@blancareal.com</a>
          </li>
          <li class="contact-channel-card">
            <span>{contactCopy.officeLabel}</span>
            <a href={OFFICE_MAP_LINK} target="_blank" rel="noreferrer">{contactCopy.officeValue}</a>
          </li>
          <li class="contact-channel-card">
            <span>{contactCopy.hoursLabel}</span>
            <strong>{contactCopy.hoursValue}</strong>
          </li>
        </ul>
        <a
          href={OFFICE_WHATSAPP_LINK}
          class="contact-whatsapp-button contact-whatsapp-button--panel"
          target="_blank"
          rel="noreferrer"
        >
          {contactCopy.whatsappCta ?? "WhatsApp"}
        </a>
      </article>

      <article class="contact-panel contact-panel--links">
        <div class="contact-panel__head">
          <span class="contact-card__eyebrow">{contactCopy.linksIntro ?? contactCopy.linksTitle}</span>
          <h2>{contactCopy.linksTitle}</h2>
        </div>
        <ul class="contact-links-grid">
          {contactCopy.links.map((link) => (
            <li>
              <a href={link.href} class="contact-link-card">
                <span>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </article>

      <article class="contact-panel contact-panel--form">
        <div class="contact-panel__head">
          <span class="contact-card__eyebrow">{contactCopy.formEyebrow ?? contactCopy.formTitle}</span>
          <h2>{contactCopy.formTitle}</h2>
          <p>{contactCopy.formIntro}</p>
        </div>

        <form id="contactLeadForm" class="service-form contact-form">
          <div class="service-form-grid contact-form-grid">
            <label class="service-form-field">
              <span>{contactCopy.formName}</span>
              <input type="text" name="full_name" required />
            </label>

            <label class="service-form-field">
              <span>{contactCopy.formEmail}</span>
              <input type="email" name="email" required />
            </label>

            <label class="service-form-field">
              <span>{contactCopy.formPhone}</span>
              <input type="tel" name="phone" />
            </label>

            <label class="service-form-field">
              <span>{contactCopy.formService}</span>
              <select name="service" required>
                <option value="">{contactCopy.serviceDefault}</option>
                {contactCopy.serviceOptions.map((option) => (
                  <option value={option.value} selected={option.value === selectedService}>
                    {option.label}
                  </option>
                ))}
              </select>
            </label>
          </div>

          <label class="service-form-field service-form-field-full">
            <span>{contactCopy.formMessage}</span>
            <textarea name="message" rows="5"></textarea>
          </label>

          <label class="service-form-consent service-form-field-full">
            <input type="checkbox" name="consent" required />
            <span>
              {contactCopy.formConsentPrefix}{" "}
              <a href={privacyPath}>{contactCopy.formConsentLink}</a>{" "}
              {contactCopy.formConsentSuffix}
            </span>
          </label>

          <input type="hidden" name="form_rendered_at" value="" />
          <label
            aria-hidden="true"
            style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;"
          >
            <span>Website</span>
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </label>

          {turnstileSiteKey ? <div class="service-form-field-full" id="contactLeadTurnstile"></div> : null}

          <p class="service-form-legal-note service-form-field-full">{contactCopy.formLegalNote}</p>

          <div class="service-form-actions contact-form-actions">
            <button type="submit" class="service-cta contact-submit" id="contactLeadSubmit">{contactCopy.formSubmit}</button>
            <p class="service-form-status" id="contactLeadStatus" aria-live="polite"></p>
          </div>
        </form>
      </article>

      <article class="contact-panel contact-panel--map service-panel-full">
        <div class="contact-panel__head">
          <span class="contact-card__eyebrow">{contactCopy.mapEyebrow ?? contactCopy.mapTitle}</span>
          <h2>{contactCopy.mapTitle}</h2>
          <p>{contactCopy.mapIntro}</p>
        </div>
        <div class="contact-map-shell">
          <iframe
            src={OFFICE_MAP_EMBED}
            title={contactCopy.mapTitle}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </article>
    </section>
  </div>

  {turnstileSiteKey ? (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
  ) : null}

  <script
    is:inline
    define:vars={{
      lang,
      selectedService,
      t,
      contactPrefillStorageKey: CONTACT_PREFILL_STORAGE_KEY,
      turnstileSiteKey,
      turnstileRequired,
    }}
  >
    const form = document.getElementById("contactLeadForm");
    const submitButton = document.getElementById("contactLeadSubmit");
    const statusNode = document.getElementById("contactLeadStatus");
    const turnstileContainer = document.getElementById("contactLeadTurnstile");
    let turnstileWidgetId = null;
    let turnstileToken = "";

    const setRenderedAt = () => {
      if (!(form instanceof HTMLFormElement)) return;
      const renderedAtInput = form.querySelector('input[name="form_rendered_at"]');
      if (renderedAtInput instanceof HTMLInputElement) {
        renderedAtInput.value = new Date().toISOString();
      }
    };

    const mountTurnstile = () => {
      if (!turnstileSiteKey || !turnstileContainer || turnstileWidgetId !== null) {
        return turnstileWidgetId !== null;
      }
      if (!window.turnstile || typeof window.turnstile.render !== "function") {
        return false;
      }

      turnstileWidgetId = window.turnstile.render(turnstileContainer, {
        sitekey: turnstileSiteKey,
        theme: "light",
        callback: (token) => {
          turnstileToken = String(token ?? "").trim();
        },
        "expired-callback": () => {
          turnstileToken = "";
        },
        "error-callback": () => {
          turnstileToken = "";
        },
      });

      return true;
    };

    const resetTurnstile = () => {
      turnstileToken = "";
      if (turnstileWidgetId !== null && window.turnstile && typeof window.turnstile.reset === "function") {
        window.turnstile.reset(turnstileWidgetId);
      }
    };

    try {
      const rawPrefill = window.sessionStorage.getItem(contactPrefillStorageKey);
      if (rawPrefill && form instanceof HTMLFormElement) {
        const prefill = JSON.parse(rawPrefill);
        const assignFieldValue = (selector, value) => {
          const field = form.querySelector(selector);
          if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement) {
            field.value = String(value ?? "").trim();
          }
        };

        assignFieldValue('input[name="full_name"]', prefill.full_name);
        assignFieldValue('input[name="email"]', prefill.email);
        assignFieldValue('input[name="phone"]', prefill.phone);
        assignFieldValue('textarea[name="message"]', prefill.message);
        if (prefill.service) {
          assignFieldValue('select[name="service"]', prefill.service);
        }
        window.sessionStorage.removeItem(contactPrefillStorageKey);
      }
    } catch (error) {
      console.error(error);
    }

    setRenderedAt();

    if (turnstileSiteKey) {
      const turnstilePoll = window.setInterval(() => {
        if (mountTurnstile()) {
          window.clearInterval(turnstilePoll);
        }
      }, 250);
      mountTurnstile();
      window.setTimeout(() => window.clearInterval(turnstilePoll), 10000);
    }

    if (
      form instanceof HTMLFormElement &&
      submitButton instanceof HTMLButtonElement &&
      statusNode instanceof HTMLElement
    ) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        statusNode.textContent = "";
        statusNode.classList.remove("is-error", "is-success");

        const formData = new FormData(form);
        const fullName = String(formData.get("full_name") ?? "").trim();
        const email = String(formData.get("email") ?? "").trim();
        const phone = String(formData.get("phone") ?? "").trim();
        const service = String(formData.get("service") ?? "").trim();
        const message = String(formData.get("message") ?? "").trim();
        const consent = formData.get("consent") === "on";
        const honeypot = String(formData.get("website") ?? "").trim();
        const renderedAt = String(formData.get("form_rendered_at") ?? "").trim();

        if (!consent) {
          statusNode.textContent = t.formError;
          statusNode.classList.add("is-error");
          return;
        }

        if (turnstileRequired && !turnstileToken) {
          mountTurnstile();
          statusNode.textContent = t.formError;
          statusNode.classList.add("is-error");
          return;
        }

        const payload = {
          full_name: fullName,
          email,
          phone,
          consent,
          source: "website_contact_form",
          lead_kind: service === "agents" ? "agency" : "buyer",
          operation_interest: "both",
          message: `[service:${service || "unspecified"}][lang:${lang}][consent:accepted] ${message}`.trim(),
          website_form: "contact",
          hp_field: honeypot,
          form_rendered_at: renderedAt,
          turnstile_token: turnstileToken,
        };

        submitButton.disabled = true;
        submitButton.textContent = t.formSending;

        try {
          const response = await fetch("/api/v1/leads", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            throw new Error(`lead_submit_failed_${response.status}`);
          }

          statusNode.textContent = t.formSuccess;
          statusNode.classList.add("is-success");
          form.reset();
          resetTurnstile();
          setRenderedAt();

          const serviceSelect = form.querySelector('select[name="service"]');
          if (serviceSelect instanceof HTMLSelectElement && selectedService) {
            serviceSelect.value = selectedService;
          }
        } catch (error) {
          statusNode.textContent = t.formError;
          statusNode.classList.add("is-error");
          console.error(error);
        } finally {
          resetTurnstile();
          submitButton.disabled = false;
          submitButton.textContent = t.formSubmit;
        }
      });
    }
  </script>
</BaseLayout>
