  includedServicesOverridesByLang.es;

page = {
  ...page,
  intro: commercializationOverrides.heroIntro,
  sectionNav: [
    { id: "por-que", label: sectionLabelAt(0, chrome.whyTitle) },
    { id: "trabajo", label: sectionLabelAt(1, chrome.workflowTitle) },
    { id: "proyectos", label: sectionLabelAt(2, chrome.projectsTitle) },
    { id: "ofrece-por-defecto", label: includedServicesOverrides.defaultNavLabel },
    { id: "ofrece-mas", label: sectionLabelAt(7, chrome.extraTitle) },
    { id: "encontrarnos", label: sectionLabelAt(8, chrome.locationTitle) },
  ],
  whyItems: commercializationOverrides.whyItems,
  workflow: page.workflow.map((item: Record<string, any>, index: number) => ({
    ...item,
    title: index === 0 ? commercializationOverrides.workflowMarketingTitle : item.title,
    items: commercializationOverrides.workflowItems[index] ?? item.items,
  })),
  defaultLead: includedServicesOverrides.defaultLead,
  defaultGroups: includedServicesOverrides.defaultGroups,
  brandsLead: commercializationOverrides.brandsLead,
  brands: commercializationOverrides.brands,
