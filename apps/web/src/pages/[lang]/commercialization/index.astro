const brandEcosystemRight = page.brands.slice(3);
--- 

<BaseLayout
  title={page.title}
  description={page.description}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  {...navigation}
>
  <div class="brand-page">
    <section class="brand-hero">
      <div class="container brand-hero__layout">
        <div class="brand-hero__copy">
          {page.eyebrow && <span class="service-eyebrow">{page.eyebrow}</span>}
          <h1>
            <span class="brand-hero__title-main">{page.headingLineA}</span>
            <span class="brand-hero__title-sub">{page.headingLineB}</span>
          </h1>
          <p>{page.intro}</p>
          <div class="brand-hero__actions">
            <a class="service-cta brand-hero__cta" href={`/${lang}/contact/?service=commercialization`}>
              {page.primaryCta}
            </a>
            <a class="brand-hero__link brand-hero__link--mobile-index" href={`/${lang}/projects/`}>
              <span class="brand-hero__link-text">{page.secondaryCta}</span>
              <span class="brand-hero__link-mobile" aria-hidden="true">
                <span>{chrome.mobileMore}</span>
                <span class="brand-hero__link-mobile-arrow">&darr;</span>
              </span>
            </a>
          </div>
        </div>

        <aside class="brand-hero__stats" aria-label={chrome.statsAria}>
          {page.heroStats.map((item) => (
            <article class="brand-stat">
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </article>
          ))}
        </aside>
      </div>
    </section>

    <div class="container brand-shell">
      <section class="brand-tabs">
        {page.sectionNav.map((item, index) => (
          <input
            class="brand-tab-input"
            type="radio"
            name="brand-tabs"
            id={`brand-tab-${item.id}`}
            checked={index === 0}
          />
        ))}

        <div class="brand-subnav-shell">
          <button
            class="brand-subnav-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="brand-subnav"
          >
            <span class="brand-subnav-toggle__eyebrow">{chrome.sectionIndex}</span>
            <span class="brand-subnav-toggle__value">{page.sectionNav[0]?.label}</span>
            <span class="brand-subnav-toggle__icon" aria-hidden="true">+</span>
          </button>
          <nav class="brand-subnav" id="brand-subnav" aria-label={page.navTitle}>
            {page.sectionNav.map((item) => (
              <label class="brand-subnav__label" for={`brand-tab-${item.id}`}>
                {item.label}
              </label>
            ))}
          </nav>
        </div>

        <div class="brand-panel-shell">

          <article
            class="brand-panel"
            id="panel-por-que"
            data-panel-id="por-que"
          >
            <section class="brand-section brand-section--ecosystem" aria-labelledby="ecosistema-title">
              <div class="service-section-heading">
                <span class="service-mini-eyebrow">{chrome.brandsEyebrow}</span>
                <h2 id="ecosistema-title">{chrome.brandsTitle}</h2>
                <p>{page.brandsLead}</p>
              </div>
              <div class="brand-ecosystem">
                <div class="brand-ecosystem__cluster brand-ecosystem__cluster--left">
                  {brandEcosystemLeft.map((item, index) => (
                    <article class:list={["brand-ecosystem-card", `is-${item.tone}`]}>
                      <div class="brand-ecosystem-card__head">
                        <span class="brand-ecosystem-card__icon" aria-hidden="true">
                          <svg viewBox={brandUniverseIcons[index].viewBox} focusable="false">
                            {brandUniverseIcons[index].paths.map((path) => (
                              <path d={path} />
                            ))}
                          </svg>
                        </span>
                        <span class="brand-ecosystem-card__title">{item.title}</span>
                      </div>
                      <ul>
                        {item.items.map((entry) => (
                          <li>{entry}</li>
                        ))}
                      </ul>
                    </article>
                  ))}
                </div>

                <div class="brand-ecosystem__center" aria-hidden="true">
                  <div class="brand-ecosystem__center-shell">
                    <span class="brand-ecosystem__center-icon">
                      <BrandLogo variant="icon" class="brand-ecosystem__center-mark" loading="lazy" />
                    </span>
                    <BrandLogo variant="wordmark" class="brand-ecosystem__center-logo" loading="lazy" />
                  </div>
                </div>

                <div class="brand-ecosystem__cluster brand-ecosystem__cluster--right">
                  {brandEcosystemRight.map((item, index) => (
                    <article class:list={["brand-ecosystem-card", `is-${item.tone}`]}>
                      <div class="brand-ecosystem-card__head">
                        <span class="brand-ecosystem-card__icon" aria-hidden="true">
                          <svg viewBox={brandUniverseIcons[index + brandEcosystemLeft.length].viewBox} focusable="false">
                            {brandUniverseIcons[index + brandEcosystemLeft.length].paths.map((path) => (
                              <path d={path} />
                            ))}
                          </svg>
                        </span>
                        <span class="brand-ecosystem-card__title">{item.title}</span>
                      </div>
                      <ul>
                        {item.items.map((entry) => (
                          <li>{entry}</li>
                        ))}
                      </ul>
                    </article>
                  ))}
                </div>
              </div>
            </section>

            <section class="brand-section brand-section--why" aria-labelledby="por-que-title">
              <div class="service-section-heading">
                <span class="service-mini-eyebrow">{chrome.whyEyebrow}</span>
                <h2 id="por-que-title">{chrome.whyTitle}</h2>
                <p>{page.whyLead}</p>
              </div>
              <div class="brand-values-flow" aria-label={chrome.valuesAria}>
                <article class="brand-value-card brand-value-card--top-left">
                  <h3>{whyFlowItems.topLeft.title}</h3>
                  <p>{whyFlowItems.topLeft.text}</p>
                </article>

                <article class="brand-value-card brand-value-card--top-right">
                  <h3>{whyFlowItems.topRight.title}</h3>
                  <p>{whyFlowItems.topRight.text}</p>
                </article>

                <article class="brand-value-card brand-value-card--bottom-left">
                  <h3>{whyFlowItems.bottomLeft.title}</h3>
                  <p>{whyFlowItems.bottomLeft.text}</p>
                </article>

                <article class="brand-value-card brand-value-card--bottom-right">
                  <h3>{whyFlowItems.bottomRight.title}</h3>
                  <p>{whyFlowItems.bottomRight.text}</p>
                </article>

                <div class="brand-values-flow__hub" aria-hidden="true">
                  <span class="brand-values-flow__badge">
                    <BrandLogo variant="icon" class="brand-values-flow__logo" loading="lazy" />
                  </span>
                </div>

                <svg
                  class="brand-values-flow__route"
                  viewBox="0 0 1000 620"
                  aria-hidden="true"
                  focusable="false"
                >
                  <defs>
                    <marker
                      id="brand-values-arrowhead"
                      markerWidth="10"
                      markerHeight="10"
                      refX="8"
                      refY="5"
                      orient="auto"
                    >
                      <path d="M0 0L10 5L0 10" />
                    </marker>
                  </defs>
                  <path d="M322 132H678" marker-end="url(#brand-values-arrowhead)" />
                  <path d="M808 182V438" marker-end="url(#brand-values-arrowhead)" />
                  <path d="M678 488H322" marker-end="url(#brand-values-arrowhead)" />
                  <path d="M192 438V182" marker-end="url(#brand-values-arrowhead)" />
                </svg>
              </div>
            </section>
          </article>

          <article
            class="brand-panel"
            id="panel-trabajo"
            data-panel-id="trabajo"
          >
          <section class="brand-section brand-section--workflow" aria-labelledby="trabajo-title">
            <div class="service-section-heading">
              <span class="service-mini-eyebrow">{chrome.workflowEyebrow}</span>
              <h2 id="trabajo-title">{chrome.workflowTitle}</h2>
              <p>{page.workflowLead}</p>
            </div>
            <div class="brand-workflow-journey">
              {page.workflow.map((item, index) => (
                <article class="brand-workflow-stage">
                  <div class="brand-workflow-stage__head">
                    <div class="brand-workflow-stage__meta">
                      <span class="brand-workflow-stage__icon" aria-hidden="true">
                        <svg viewBox={workflowIcons[index].viewBox} focusable="false">
                          {workflowIcons[index].paths.map((path) => (
                            <path d={path} />
                          ))}
                        </svg>
                      </span>
                      <span class="brand-workflow-stage__step">{item.step}</span>
                    </div>
                    <div class="brand-workflow-stage__title-wrap">
                      {item.tagline && <p class="brand-workflow-stage__tagline">{item.tagline}</p>}
                      <h3>{item.title}</h3>
                    </div>
                  </div>
                  <ul class="brand-workflow-stage__items">
                    {item.items.map((entry) => (
                      <li>{entry}</li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </section>
          </article>

          <article
            class="brand-panel"
            id="panel-proyectos"
            data-panel-id="proyectos"
          >
          <section class="brand-section brand-section--projects" aria-labelledby="proyectos-title">
            <div class="service-section-heading">
              <span class="service-mini-eyebrow">{chrome.projectsEyebrow}</span>
              <h2 id="proyectos-title">{chrome.projectsTitle}</h2>
              <p>{page.projectsLead}</p>
            </div>
            <div class="brand-project-grid">
              {page.portfolio.map((project, index) => (
                <a
                  class:list={[
                    "brand-project-card",
                    index === 0 && "brand-project-card--featured",
                  ]}
                  href={`/${lang}/properties/${project.slug}/`}
                  aria-label={`${project.name} - ${project.location}`}
                >
                  <img src={project.image} alt={project.name} loading="lazy" />
                  <div class="brand-project-card__overlay">
                    <div class="brand-project-card__eyebrow">
                      <span>{index === 0 ? page.projectFeaturedLabel : page.projectCollectionLabel}</span>
                      <small>{project.location}</small>
                    </div>
                    <h3>{project.name}</h3>
                    <p>{project.body}</p>
                    <div class="brand-project-card__footer">
                      <strong class="brand-project-card__cta">{page.projectCta}</strong>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
          </article>

          <article
            class="brand-panel"
            id="panel-ofrece-por-defecto"
            data-panel-id="ofrece-por-defecto"
          >
          <section class="brand-section brand-section--default" aria-labelledby="ofrece-por-defecto-title">
            <div class="service-section-heading">
              <span class="service-mini-eyebrow">{chrome.defaultEyebrow}</span>
              <h2 id="ofrece-por-defecto-title">{chrome.defaultTitle}</h2>
              <p>{page.defaultLead}</p>
            </div>
            <div class="brand-default-intro">
              <article class="brand-default-intro__panel">
                <span class="brand-default-intro__eyebrow">{chrome.defaultIntroEyebrow}</span>
                <h3>{chrome.defaultIntroTitle}</h3>
                <p>{chrome.defaultIntroText}</p>
                <div class="brand-default-timeline">
                  <span class="brand-default-timeline__title">{chrome.defaultTimelineTitle}</span>
                  <ol class="brand-default-timeline__list">
                    {includedServicesOverrides.defaultTimeline.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ol>
                </div>
              </article>

              <article class="brand-default-intro__visual">
                {page.portfolio[0] && (
                  <img
                    src={page.portfolio[0].image}
                    alt={chrome.defaultVisualAlt}
                    loading="lazy"
                  />
                )}
              </article>
            </div>

            <div class="brand-card-grid brand-card-grid--default-enhanced">
              {page.defaultGroups.map((item, index) => (
                <article class="brand-card brand-card--default-tier">
                  <div class="brand-default-card__head">
                    <div class="brand-default-card__identity">
                      <span class="brand-default-card__icon" aria-hidden="true">
                        <svg viewBox={includedServiceCardIcons[index].viewBox} focusable="false">
                          {includedServiceCardIcons[index].paths.map((path) => (
                            <path d={path} />
                          ))}
                        </svg>
                      </span>
                      <div class="brand-default-card__title-wrap">
                        <h3>{item.title}</h3>
                      </div>
                    </div>
                  </div>
                  <p class="brand-default-card__caption">{item.items[0]}</p>
                </article>
              ))}
            </div>
          </section>
          </article>

          <article
            class="brand-panel"
            id="panel-ofrece-mas"
            data-panel-id="ofrece-mas"
          >
          <section class="brand-section brand-section--extra" aria-labelledby="ofrece-mas-title">
            <div class="service-section-heading">
              <span class="service-mini-eyebrow">{chrome.extraEyebrow}</span>
              <h2 id="ofrece-mas-title">{chrome.extraTitle}</h2>
              <p>{page.extraLead}</p>
            </div>
            <div class="brand-extra-intro">
              <article class="brand-extra-intro__panel">
                <span class="brand-extra-intro__eyebrow">{chrome.extraIntroEyebrow}</span>
                <h3>{chrome.extraIntroTitle}</h3>
                <p>{chrome.extraIntroText}</p>
              </article>
            </div>
            <div class="brand-card-grid brand-card-grid--extra-enhanced">
              {page.extraGroups.map((item, index) => (
                <article class="brand-card brand-card--list brand-card--extra-tier">
                  <div class="brand-extra-card__head">
                    <div class="brand-extra-card__identity">
                      <span class="brand-extra-card__icon" aria-hidden="true">
                        <svg viewBox={extraGroupMeta[index].icon.viewBox} focusable="false">
                          {extraGroupMeta[index].icon.paths.map((path) => (
                            <path d={path} />
                          ))}
                        </svg>
                      </span>
                      <div class="brand-extra-card__title-wrap">
                        <span class="brand-extra-card__eyebrow">{extraGroupMeta[index].eyebrow}</span>
                        <h3>{item.title}</h3>
                      </div>
                    </div>
                    <strong class="brand-extra-card__stat">{extraGroupMeta[index].stat}</strong>
                  </div>
                  <p class="brand-extra-card__caption">{extraGroupMeta[index].caption}</p>
                  <ul class="brand-extra-card__items">
                    {item.items.map((entry) => (
                      <li>{entry}</li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </section>
          </article>

          <article
            class="brand-panel"
            id="panel-encontrarnos"
            data-panel-id="encontrarnos"
          >
          <section class="brand-section brand-section--location" aria-labelledby="encontrarnos-title">
            <div class="service-section-heading">
              <span class="service-mini-eyebrow">{chrome.locationEyebrow}</span>
              <h2 id="encontrarnos-title">{chrome.locationTitle}</h2>
              <p>{page.locationLead}</p>
            </div>
            <div class="brand-location">
              <div class="brand-location__grid">
                {page.locationCards.map((item) => (
                  <article class="brand-location__card">
                    <span>{item.label}</span>
                    {item.href ? <a href={item.href}>{item.value}</a> : <strong>{item.value}</strong>}
                  </article>
                ))}
              </div>
              <div class="brand-cta-band">
                <div>
                    <span class="service-mini-eyebrow">{chrome.ctaEyebrow}</span>
                    <h3>{chrome.ctaTitle}</h3>
                    <p>{chrome.ctaText}</p>
                </div>
                <a class="service-cta brand-hero__cta" href={`/${lang}/contact/?service=commercialization`}>
                  {page.locationCta}
                </a>
              </div>
            </div>
          </section>
          </article>
        </div>

        <button
          class="brand-mobile-return"
          type="button"
            aria-label={chrome.returnToIndex}
          hidden
        >
          <span aria-hidden="true">&uarr;</span>
        </button>
      </section>
    </div>
  </div>

  <script is:inline>
    (() => {
      const isMobile = window.matchMedia("(max-width: 720px)");
      const tabsRoot = document.querySelector(".brand-tabs");
      const panelShell = tabsRoot?.querySelector(".brand-panel-shell");
      const navShell = tabsRoot?.querySelector(".brand-subnav-shell");
      const navToggle = tabsRoot?.querySelector(".brand-subnav-toggle");
      const navToggleValue = tabsRoot?.querySelector(".brand-subnav-toggle__value");
      const mobileIndexLink = document.querySelector(".brand-hero__link--mobile-index");
      const labels = tabsRoot ? Array.from(tabsRoot.querySelectorAll(".brand-subnav__label")) : [];
      const radios = tabsRoot ? Array.from(tabsRoot.querySelectorAll(".brand-tab-input")) : [];
      const returnButton = tabsRoot?.querySelector(".brand-mobile-return");

      if (!tabsRoot || !panelShell || !navShell || !labels.length || !radios.length || !returnButton || !navToggle || !navToggleValue) {
        return;
      }

      const setNavOpen = (open) => {
        navShell.classList.toggle("is-open", open);
        navToggle.setAttribute("aria-expanded", String(open));
      };

      const updateActiveLabel = () => {
        const activeRadio = radios.find((radio) => radio.checked);
        const activeLabel = activeRadio
          ? labels.find((label) => label.getAttribute("for") === activeRadio.id)
          : null;

        if (activeLabel) {
          navToggleValue.textContent = activeLabel.textContent?.trim() ?? "";
        }
      };

      const getSelectedPanel = () => {
        const activeRadio = radios.find((radio) => radio.checked);
        const panelId = activeRadio?.id.replace("brand-tab-", "panel-");
        return panelId ? tabsRoot.querySelector(`#${panelId}`) : null;
      };

      const scrollToTarget = (element) => {
        const offset = 92;
        const top = element.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({
          top: Math.max(0, top),
          behavior: "smooth",
        });
      };

      const updateReturnButton = () => {
        if (!isMobile.matches) {
          setNavOpen(false);
          returnButton.hidden = true;
          returnButton.classList.remove("is-visible");
          return;
        }

        const selectedPanel = getSelectedPanel();
        if (!selectedPanel) {
          returnButton.hidden = true;
          returnButton.classList.remove("is-visible");
          return;
        }

        const rect = selectedPanel.getBoundingClientRect();
        const nearBottom = rect.bottom <= window.innerHeight + 80;
        returnButton.hidden = !nearBottom;
        returnButton.classList.toggle("is-visible", nearBottom);
      };

      labels.forEach((label) => {
        label.addEventListener("click", () => {
          if (!isMobile.matches) {
            return;
          }

          setNavOpen(false);

          window.requestAnimationFrame(() => {
            window.setTimeout(() => {
              scrollToTarget(panelShell);
              updateReturnButton();
            }, 70);
          });
        });
      });

      radios.forEach((radio) => {
        radio.addEventListener("change", () => {
          if (!radio.checked) {
            return;
          }

          updateActiveLabel();
          updateReturnButton();
        });
      });

      navToggle.addEventListener("click", () => {
        if (!isMobile.matches) {
          return;
        }

        setNavOpen(!navShell.classList.contains("is-open"));
      });

      returnButton.addEventListener("click", () => {
        scrollToTarget(navShell);
      });

      mobileIndexLink?.addEventListener("click", (event) => {
        if (!isMobile.matches) {
          return;
        }

        event.preventDefault();
        scrollToTarget(navShell);
      });

      document.addEventListener("click", (event) => {
        if (!isMobile.matches || !navShell.classList.contains("is-open")) {
          return;
        }

        const target = event.target;
        if (target instanceof Node && !navShell.contains(target)) {
          setNavOpen(false);
        }
      });

      window.addEventListener("scroll", updateReturnButton, { passive: true });
      window.addEventListener("resize", updateReturnButton);
      isMobile.addEventListener("change", () => {
        updateReturnButton();
        updateActiveLabel();
      });
      updateActiveLabel();
      updateReturnButton();
    })();
  </script>
</BaseLayout>
