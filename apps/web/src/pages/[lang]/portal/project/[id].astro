  },
  de: {
    title: "Portal | Projekt",
    description: "Projektstruktur mit visuellem Inhalt und Dokumenten.",
    eyebrow: "Projektdetail",
    heading: "Kommerzielles Material des Projekts",
    intro: "Überprüfen Sie veröffentlichtes Bildmaterial und laden Sie autorisierte Dokumente herunter.",
    heroTagsLabel: "Projektblöcke",
    heroTagContent: "Visueller Inhalt",
    heroTagDocs: "Kommerzielle Dokumente",
    heroTagUnits: "Verfügbare Einheiten",
    back: "Zurück zum Dashboard",
    projectScopeHint: "Es werden nur für dieses Konto autorisierte Projekte angezeigt.",
    contentTitle: "Veröffentlichte Inhalte",
    contentHint: "Aktive Blöcke für die kommerzielle Projektkommunikation.",
    documentsTitle: "Sichtbare Dokumente",
    documentsHint: "Veröffentlichte Dokumentbibliothek für autorisierte Benutzer.",
    unitsTitle: "Verfügbare Einheiten",
    unitsHint: "Live-Liste der verfügbaren Einheiten in diesem Projekt.",
    docsSearch: "Dokumente suchen",
    docsSearchPlaceholder: "Titel, Format",
