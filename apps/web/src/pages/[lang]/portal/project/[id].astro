  },
  fr: {
    title: "Portail | Projet",
    description: "Espace de travail du projet avec contenu visuel et documents.",
    eyebrow: "Détail du projet",
    heading: "Matériel commercial du projet",
    intro: "Consultez le matériel visuel publié et téléchargez la documentation autorisée.",
    heroTagsLabel: "Blocs de projet",
    heroTagContent: "Contenu visuel",
    heroTagDocs: "Documents commerciaux",
    heroTagUnits: "Unités disponibles",
    back: "Retour au tableau de bord",
