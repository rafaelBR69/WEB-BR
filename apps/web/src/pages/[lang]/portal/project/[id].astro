    noUnits: "Aucune unité disponible pour le moment.",
    logoutCta: "Se déconnecter",
  },
  it: {
    title: "Portale | Progetto",
    description: "Spazio di lavoro del progetto con contenuti visivi e documenti.",
    eyebrow: "Dettagli del progetto",
    heading: "Materiale commerciale del progetto",
    intro: "Consulta il materiale visivo pubblicato e scarica la documentazione autorizzata.",
    heroTagsLabel: "Blocchi del progetto",
    heroTagContent: "Contenuto visivo",
    heroTagDocs: "Documenti commerciali",
    heroTagUnits: "Unità disponibili",
    back: "Torna al dashboard",
    projectScopeHint: "Vengono mostrati solo i progetti autorizzati per questo account.",
    contentTitle: "Contenuto pubblicato",
    contentHint: "Blocchi attivi per la comunicazione commerciale del progetto.",
    documentsTitle: "Documenti visibili",
    documentsHint: "Biblioteca di documenti pubblicati per gli utenti autorizzati.",
    unitsTitle: "Unità disponibili",
    unitsHint: "Elenco in tempo reale delle unità disponibili in questo progetto.",
    docsSearch: "Cerca documenti",
    docsSearchPlaceholder: "titolo, formato",
    projectLoading: "Caricamento dati del progetto...",
    noContent: "Nessun blocco pubblicato per questa lingua/pubblico.",
    noDocuments: "Nessun documento visibile per questo progetto.",
    noUnits: "Nessuna unità disponibile al momento.",
    logoutCta: "Esci",
  },
  nl: {
    title: "Portaal | Project",
    description: "Projectwerkruimte met visuele inhoud en documenten.",
    eyebrow: "Projectdetail",
    heading: "Commercieel materiaal van het project",
    intro: "Bekijk gepubliceerd visueel materiaal en download geautoriseerde documentatie.",
    heroTagsLabel: "Projectblokken",
    heroTagContent: "Visuele inhoud",
    heroTagDocs: "Commerciële documenten",
    heroTagUnits: "Beschikbare eenheden",
    back: "Terug naar dashboard",
    projectScopeHint: "Alleen projecten die voor dit account zijn geautoriseerd, worden getoond.",
    contentTitle: "Gepubliceerde inhoud",
    contentHint: "Actieve blokken voor commerciële projectcommunicatie.",
    documentsTitle: "Zichtbare documenten",
    documentsHint: "Gepubliceerde documentenbibliotheek voor geautoriseerde gebruikers.",
    unitsTitle: "Beschikbare eenheden",
    unitsHint: "Live overzicht van beschikbare eenheden in dit project.",
    docsSearch: "Documenten zoeken",
    docsSearchPlaceholder: "titel, formaat",
    projectLoading: "Projectgegevens laden...",
    noContent: "Geen gepubliceerde blokken voor deze taal/doelgroep.",
    noDocuments: "Geen zichtbare documenten voor dit project.",
    noUnits: "Geen beschikbare eenheden op dit moment.",
    logoutCta: "Uitloggen",
  },
};

const t = (copyByLang as any)[lang] || copyByLang.en;
---

<BaseLayout
  title={`${t.title} | BlancaReal`}
  description={t.description}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  showMobileStickyCta={false}
>
  <div id="portal-auth-loading" class="portal-auth-loading" role="status" aria-live="polite">
    <div class="portal-auth-loading-card">
      <div class="portal-auth-loading-ring" aria-hidden="true"></div>
      <p class="portal-auth-loading-label">{t.heading}</p>
      <p class="portal-auth-loading-copy" data-portal-loading-text>{t.projectLoading}</p>
    </div>
  </div>

  <div id="portal-private-shell" hidden>
  <div class="portal-scene">
    <!-- SIDEBAR (Consistent with Dashboard) -->
    <aside class="portal-sidebar desktop-only">
      <div class="sidebar-brand">
        <BrandLogo variant="wordmark" href={`/${lang}/`} />
      </div>
      
      <nav class="sidebar-nav">
        <a href={`/${lang}/portal/`} class="nav-item active">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
          Dashboard
        </a>
        <a href={`/${lang}/properties/`} class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          Properties
        </a>
        <a href="#" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          Documents
        </a>
      </nav>

      <div class="sidebar-footer">
        <button id="portal-dashboard-logout" class="logout-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          {t.logoutCta || 'Sign out'}
        </button>
      </div>
    </aside>

    <!-- CONTENT AREA -->
    <main class="portal-main">
      <header class="portal-header">
        <div class="header-welcome">
          <a class="luxury-back-link" href={`/${lang}/portal/`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            {t.back}
          </a>
          <h1 id="portal-project-title-heading">{t.heading}</h1>
          <div id="portal-project-header" class="project-meta-stats">
            <p>{t.intro}</p>
          </div>
        </div>
      </header>

      <div class="portal-content-grid">
        <div class="project-sections-layout">
          <div class="main-sections">
            <section class="luxury-card">
              <div class="card-head">
                <div class="icon-box luxury-blue">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                </div>
                <h3>{t.contentTitle}</h3>
              </div>
              <p class="card-desc">{t.contentHint}</p>
              <ul id="portal-project-content" class="portal-list dynamic-content-list">
                <li class="portal-empty">{t.noContent}</li>
              </ul>
            </section>

            <section class="luxury-card">
              <div class="card-head">
                <div class="icon-box luxury-gold">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </div>
                <h3>{t.documentsTitle}</h3>
              </div>
              <div class="search-filter-box">
                <input
                  id="portal-documents-search"
                  type="search"
                  placeholder={t.docsSearchPlaceholder}
                  class="luxury-search-input"
                />
              </div>
              <ul id="portal-project-documents" class="portal-list dynamic-docs-list">
                <li class="portal-empty">{t.noDocuments}</li>
              </ul>
            </section>
          </div>

          <aside class="project-side-column">
            <section class="luxury-card compact">
              <div class="card-head">
                <div class="icon-box luxury-red">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                </div>
                <h3>{t.unitsTitle}</h3>
              </div>
              <ul id="portal-project-units" class="portal-list compact-list">
                <li class="portal-empty">{t.noUnits}</li>
              </ul>
            </section>
          </aside>
        </div>
      </div>

      <footer class="portal-footer">
        <p id="portal-project-feedback" class="status-indicator" role="status" aria-live="polite">
          {t.projectLoading}
        </p>
      </footer>
    </main>
  </div>
  </div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap');

    #portal-auth-loading[hidden],
    #portal-private-shell[hidden] {
      display: none !important;
    }

    .portal-auth-loading {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 32px 20px;
      background:
        radial-gradient(circle at top, rgba(222, 31, 56, 0.08), transparent 32%),
        linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
    }

    .portal-auth-loading-card {
      width: min(100%, 420px);
      padding: 32px 28px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(15, 23, 42, 0.08);
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
      text-align: center;
    }

    .portal-auth-loading-ring {
      width: 44px;
      height: 44px;
      margin: 0 auto 18px;
      border-radius: 999px;
      border: 3px solid rgba(15, 23, 42, 0.12);
      border-top-color: #de1f38;
      animation: portal-auth-spin 0.85s linear infinite;
    }

    .portal-auth-loading-label {
      margin: 0;
      font-size: 1rem;
      font-weight: 600;
      color: #0f172a;
    }

    .portal-auth-loading-copy {
      margin: 8px 0 0;
      color: #475569;
      font-size: 0.95rem;
    }

    @keyframes portal-auth-spin {
      to { transform: rotate(360deg); }
    }

    .portal-scene {
      display: flex;
      min-height: 100vh;
      background: #f8fafc;
      font-family: 'Outfit', sans-serif;
      color: #0f172a;
    }

    /* SIDEBAR (SHARED) */
    .portal-sidebar {
      width: 260px;
      background: #00152e;
      color: white;
      display: flex;
      flex-direction: column;
      padding: 40px 0;
      position: sticky;
      top: 0;
      height: 100vh;
      border-right: 1px solid rgba(255,255,255,0.05);
    }

    .sidebar-brand {
      padding: 0 32px 40px;
    }

    .sidebar-brand a {
      font-size: 1.4rem;
      font-weight: 700;
      color: white;
      text-decoration: none;
      letter-spacing: -0.5px;
    }

    .sidebar-brand span { color: #de1f38; }

    .sidebar-nav {
      display: flex;
      flex-direction: column;
      gap: 4px;
      flex-grow: 1;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px 32px;
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      font-weight: 500;
      font-size: 0.9rem;
      border-left: 3px solid transparent;
      letter-spacing: 0.3px;
    }

    .nav-item:hover {
      color: white;
      background: rgba(255,255,255,0.03);
    }

    .nav-item.active {
      color: white;
      background: rgba(212, 175, 55, 0.05);
      border-left-color: #D4AF37;
    }

    .nav-item svg {
      width: 18px;
      height: 18px;
      transition: transform 0.3s;
    }

    .nav-item:hover svg {
      transform: translateX(2px);
    }

    .sidebar-footer {
      padding: 24px 32px;
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    .logout-link {
      display: flex; align-items: center; gap: 10px; background: transparent;
      border: 0; color: rgba(255,255,255,0.6); cursor: pointer; font-family: inherit;
    }

    /* PROJECT DETAIL SPECIFIC */
    .portal-main { flex-grow: 1; padding: 40px 60px; max-width: 1400px; margin: 0 auto; width: 100%; min-width: 0; }

    .luxury-back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #64748b;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 20px;
      transition: color 0.3s;
    }
    .luxury-back-link:hover { color: #001E44; }

    .header-welcome h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem;
      color: #001E44;
      margin: 0 0 0.5rem;
    }

    .project-meta-stats {
      color: #64748b;
      font-size: 1.1rem;
      font-weight: 300;
      display: flex;
      gap: 15px;
      align-items: center;
      flex-wrap: wrap;
    }
    .project-meta-stats strong { color: #001E44; font-weight: 600; }

    .project-sections-layout {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 40px;
      min-width: 0;
    }

    .main-sections,
    .project-side-column,
    .luxury-card {
      min-width: 0;
    }

    .main-sections { display: grid; gap: 30px; }

    .luxury-card {
      background: white;
      border-radius: 12px;
      padding: 32px;
      border: 1px solid rgba(0,30,68,0.05);
      box-shadow: 0 4px 20px rgba(0,30,68,0.02);
    }

    .luxury-card.compact { padding: 24px; }

    .card-head { display: flex; align-items: center; gap: 15px; margin-bottom: 1.5rem; }
    .card-head h3 { font-size: 1.25rem; font-weight: 600; color: #001E44; margin: 0; }

    .icon-box {
      width: 40px; height: 40px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
    }
    .luxury-blue { background: rgba(0, 30, 68, 0.05); color: #001E44; }
    .luxury-gold { background: rgba(212, 175, 55, 0.1); color: #D4AF37; }
    .luxury-red { background: rgba(222, 31, 56, 0.05); color: #de1f38; }

    .card-desc { color: #94a3b8; font-size: 0.9rem; margin-bottom: 20px; }

    .luxury-search-input {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      margin-bottom: 20px;
      font-family: inherit;
      outline: none;
      transition: border-color 0.3s;
      min-width: 0;
    }
    .luxury-search-input:focus { border-color: #001E44; }

    /* DYNAMIC CONTENT STYLES */
    :global(.dynamic-content-list), :global(.dynamic-docs-list) {
      list-style: none; padding: 0; display: grid; gap: 15px;
    }

    :global(.portal-item) {
      background: #f8fafc;
      border-radius: 8px;
      padding: 20px;
      border: 1px solid #f1f5f9;
    }

    :global(.portal-item-title) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 600;
      color: #001E44;
      margin-bottom: 5px;
      line-height: 1.05;
      overflow-wrap: anywhere;
    }

    :global(.status-indicator) { font-size: 0.8rem; color: #94a3b8; text-align: right; margin-top: 40px; }

    @media (max-width: 1100px) {
      .project-sections-layout { grid-template-columns: 1fr; }
    }
    @media (max-width: 900px) {
      .portal-sidebar { display: none; }
      .portal-main { padding: 30px 20px; }
      .header-welcome h1 { font-size: 2.2rem; }
      .project-meta-stats { font-size: 1rem; }
      .project-sections-layout { gap: 24px; }
      .main-sections { gap: 20px; }
      .luxury-card { padding: 24px; }
    }
    @media (max-width: 640px) {
      .portal-main { padding: 22px 14px 28px; }
      .luxury-back-link { margin-bottom: 14px; }
      .header-welcome h1 { font-size: 1.85rem; }
      .project-meta-stats { font-size: 0.95rem; gap: 10px; }
      .luxury-card,
      .luxury-card.compact { padding: 18px; border-radius: 10px; }
      .card-head { align-items: flex-start; gap: 12px; margin-bottom: 1rem; }
      .card-head h3 { font-size: 1.08rem; line-height: 1.2; }
      .card-desc { margin-bottom: 14px; }
      .luxury-search-input { margin-bottom: 14px; min-height: 46px; }
      :global(.portal-list) { gap: 12px; }
      :global(.portal-item) { padding: 16px; }
