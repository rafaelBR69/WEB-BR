---
export const prerender = false;

import BaseLayout from "@webapp/layouts/BaseLayout.astro";
import { DEFAULT_LANG, SUPPORTED_LANGS, isSupportedLang } from "@shared/i18n/languages";
import BrandLogo from "@webapp/components/BrandLogo.astro";
import "@webapp/styles/pages/portal.css";

const langParam = Astro.params.lang ?? DEFAULT_LANG;
if (!isSupportedLang(langParam)) {
  return Astro.redirect(`/${DEFAULT_LANG}/portal/activate/`, 302);
}

const lang = langParam;
const defaultOrganizationId = String(
  import.meta.env.PUBLIC_CRM_ORGANIZATION_ID ?? import.meta.env.CRM_ORGANIZATION_ID ?? ""
).trim();

const copyByLang = {
  es: {
    title: "Portal | Activacion",
    description: "Activa una cuenta portal con email, codigo e password.",
    eyebrow: "Activacion de cuenta",
    heading: "Alta inicial del portal",
    intro:
      "Valida el codigo de invitacion y crea credenciales para acceder al dashboard del portal.",
    formTitle: "Formulario de activacion",
    emailLabel: "Email invitado",
    codeLabel: "Codigo de invitacion",
    passwordLabel: "Contraseña (min 8)",
    nameLabel: "Nombre completo",
    validateCta: "Validar codigo",
    activateCta: "Activar cuenta",
    resultTitle: "Resultado",
    loginHint: "¿Ya tienes cuenta activa?",
    loginLink: "Ir a login",
    logoutCta: "Cerrar sesión",
  },
  en: {
    title: "Portal | Activation",
    description: "Activate a portal account with email, code and password.",
    eyebrow: "Account activation",
    heading: "Initial portal onboarding",
    intro:
      "Validate invitation code and create credentials to access the portal dashboard.",
    formTitle: "Activation form",
    emailLabel: "Invited email",
    codeLabel: "Invitation code",
    passwordLabel: "Password (min 8)",
    nameLabel: "Full name",
    validateCta: "Validate code",
    activateCta: "Activate account",
    resultTitle: "Result",
    loginHint: "Already have an active account?",
    loginLink: "Go to login",
    logoutCta: "Sign out",
  },
  de: {
    title: "Portal | Aktivierung",
    description: "Aktivieren Sie ein Portal-Konto mit E-Mail, Code und Passwort.",
    eyebrow: "Kontoaktywierung",
    heading: "Erste Portal-Anmeldung",
    intro: "Validieren Sie den Einladungscode und erstellen Sie Zugangsdaten für das Portal-Dashboard.",
    formTitle: "Aktivierungsformular",
    emailLabel: "Eingeladene E-Mail",
    codeLabel: "Einladungscode",
    passwordLabel: "Passwort (min. 8)",
    nameLabel: "Vollständiger Name",
    validateCta: "Code validieren",
    activateCta: "Konto aktivieren",
    resultTitle: "Ergebnis",
    loginHint: "Haben Sie bereits ein aktives Konto?",
    loginLink: "Zum Login",
    logoutCta: "Abmelden",
  },
  fr: {
    title: "Portail | Activation",
    description: "Activez un compte portail avec e-mail, code et mot de passe.",
    eyebrow: "Activation de compte",
    heading: "Intégration initiale au portail",
    intro: "Validez le code d'invitation et créez des identifiants pour accéder au tableau de bord du portail.",
    formTitle: "Formulaire d'activation",
    emailLabel: "E-mail invité",
    codeLabel: "Code d'invitation",
    passwordLabel: "Mot de passe (min 8)",
    nameLabel: "Nom complet",
    validateCta: "Valider le code",
    activateCta: "Activer le compte",
    resultTitle: "Résultat",
    loginHint: "Vous avez déjà un compte actif ?",
    loginLink: "Aller au login",
    logoutCta: "Se déconnecter",
  },
  it: {
    title: "Portale | Attivazione",
    description: "Attiva un account portale con email, codice e password.",
    eyebrow: "Attivazione dell'account",
    heading: "Onboarding iniziale del portale",
    intro: "Valida il codice di invito e crea le credenziali per accedere al dashboard del portale.",
    formTitle: "Modulo di attivazione",
    emailLabel: "Email invitata",
    codeLabel: "Codice di invito",
    passwordLabel: "Password (min 8)",
    nameLabel: "Nome completo",
    validateCta: "Valida codice",
    activateCta: "Attiva account",
    resultTitle: "Risultato",
    loginHint: "Hai già un account attivo?",
    loginLink: "Vai al login",
    logoutCta: "Esci",
  },
  nl: {
    title: "Portaal | Activatie",
    description: "Activeer een portaalaccount met e-mail, code en wachtwoord.",
    eyebrow: "Accountactivatie",
    heading: "Initiële portaal-onboarding",
    intro: "Valideer de uitnodigingscode en maak inloggegevens aan om toegang te krijgen tot het portaal-dashboard.",
    formTitle: "Activatieformulier",
    emailLabel: "Uitgenodigde e-mail",
    codeLabel: "Uitnodigingscode",
    passwordLabel: "Wachtwoord (min 8)",
    nameLabel: "Volledige naam",
    validateCta: "Code valideren",
    activateCta: "Account activeren",
    resultTitle: "Resultaat",
    loginHint: "Heeft u al een actief account?",
    loginLink: "Ga naar login",
    logoutCta: "Uitloggen",
  },
};

const t = (copyByLang as any)[lang] || copyByLang.en;
---

<BaseLayout
  title={`${t.title} | BlancaReal`}
  description={t.description}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  showMobileStickyCta={false}
>
  <div class="portal-scene">
    <!-- SIDEBAR -->
    <aside class="portal-sidebar desktop-only">
      <div class="sidebar-brand">
        <BrandLogo variant="wordmark" href={`/${lang}/`} />
      </div>
      
      <nav class="sidebar-nav">
        <a href={`/${lang}/portal/`} class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
          Dashboard
        </a>
        <a href={`/${lang}/portal/properties/`} class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          Properties
        </a>
      </nav>

      <div class="sidebar-footer">
        <button id="portal-dashboard-logout" class="logout-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          {t.logoutCta}
        </button>
      </div>
    </aside>

    <!-- CONTENT AREA -->
    <main class="portal-main">
      <header class="portal-header">
        <div class="header-welcome">
          <h1>{t.heading}</h1>
          <p>{t.intro}</p>
        </div>
      </header>

      <div class="portal-content-grid">
        <div class="content-columns">
          <div class="main-column">
            <section class="luxury-card">
              <div class="card-head">
                <div class="icon-box luxury-blue">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><polyline points="17 11 19 13 23 9"></polyline></svg>
                </div>
                <h3>{t.formTitle}</h3>
              </div>
              
              <form id="portal-activate-form" class="luxury-activation-form">
                <div class="form-row">
                  <div class="input-field">
                    <label>{t.emailLabel}</label>
                    <input id="portal-activate-email" name="email" type="email" placeholder="tu@email.com" required />
                  </div>
                  <div class="input-field">
                    <label>{t.codeLabel}</label>
                    <input id="portal-activate-code" name="code" type="text" placeholder="ABC12345" required />
                  </div>
                </div>

                <div class="form-row">
                  <div class="input-field">
                    <label>{t.passwordLabel}</label>
                    <input id="portal-activate-password" name="password" type="password" minlength="8" required />
                  </div>
                  <div class="input-field">
                    <label>{t.nameLabel}</label>
                    <input id="portal-activate-name" name="full_name" type="text" required />
                  </div>
                </div>

                <div class="form-btns">
                  <button id="portal-activate-validate" type="button" class="btn-activate-soft">{t.validateCta}</button>
                  <button type="submit" class="btn-activate-primary">{t.activateCta}</button>
                </div>
              </form>

              <div id="portal-activate-feedback" class="activation-feedback">
                Completa los campos para activar.
              </div>
            </section>
          </div>

          <aside class="side-column">
            <section class="luxury-card compact">
              <h3>{t.loginHint}</h3>
              <a class="btn-goto-login" href={`/${lang}/portal/login/`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h4"></path><polyline points="10 17 15 12 10 7"></polyline><line x1="15" y1="12" x2="3" y2="12"></line></svg>
                {t.loginLink}
              </a>
            </section>

            <section class="luxury-card compact">
              <h3>{t.resultTitle}</h3>
              <div id="portal-activate-result" class="result-placeholder">
                Aqui se mostraran los datos tras la activación.
              </div>
            </section>
          </aside>
        </div>
      </div>
    </main>
  </div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap');

    .portal-scene {
      display: flex;
      min-height: 100vh;
      background: #f8fafc;
      font-family: 'Outfit', sans-serif;
      color: #0f172a;
    }

    /* SIDEBAR (SHARED) */
    .portal-sidebar {
      width: 260px;
      background: #00152e;
      color: white;
      display: flex;
      flex-direction: column;
      padding: 40px 0;
      position: sticky;
      top: 0;
      height: 100vh;
      border-right: 1px solid rgba(255,255,255,0.05);
    }

    .sidebar-brand {
      padding: 0 32px 40px;
    }

    .sidebar-brand a {
      font-size: 1.4rem;
      font-weight: 700;
      color: white;
      text-decoration: none;
      letter-spacing: -0.5px;
    }

    .sidebar-brand span { color: #de1f38; }

    .sidebar-nav {
      display: flex;
      flex-direction: column;
      gap: 4px;
      flex-grow: 1;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px 32px;
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      font-weight: 500;
      font-size: 0.9rem;
      border-left: 3px solid transparent;
      letter-spacing: 0.3px;
    }

    .nav-item:hover {
      color: white;
      background: rgba(255,255,255,0.03);
    }

    .nav-item.active {
      color: white;
      background: rgba(212, 175, 55, 0.05);
      border-left-color: #D4AF37;
    }

    .nav-item svg {
      width: 18px;
      height: 18px;
      transition: transform 0.3s;
    }

    .nav-item:hover svg {
      transform: translateX(2px);
    }

    .sidebar-footer {
      padding: 24px 32px;
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    .logout-link { display: flex; align-items: center; gap: 10px; background: transparent; border: 0; color: rgba(255,255,255,0.6); cursor: pointer; font-family: inherit; }

    /* CONTENT AREA */
    .portal-main { flex-grow: 1; padding: 40px 60px; max-width: 1400px; margin: 0 auto; width: 100%; min-width: 0; }
    .header-welcome h1 { font-family: 'Cormorant Garamond', serif; font-size: 3rem; color: #001E44; margin: 0 0 0.5rem; }
    .header-welcome p { color: #64748b; font-size: 1.1rem; font-weight: 300; }

    .content-columns { display: grid; grid-template-columns: 1fr 340px; gap: 40px; min-width: 0; }
    .main-column, .side-column, .luxury-card { min-width: 0; }

    .luxury-card { background: white; border-radius: 12px; padding: 32px; border: 1px solid rgba(0,30,68,0.05); box-shadow: 0 4px 20px rgba(0,30,68,0.02); }
    .luxury-card.compact { padding: 24px; }
    .luxury-card h3 { font-size: 1.1rem; font-weight: 600; color: #001E44; margin-bottom: 1.2rem; }

    .card-head { display: flex; align-items: center; gap: 15px; margin-bottom: 2rem; }
    .card-head h3 { margin: 0; font-size: 1.3rem; }
    .icon-box { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; }
    .luxury-blue { background: rgba(0, 30, 68, 0.05); color: #001E44; }

    /* FORM STYLES */
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    .input-field label { display: block; font-size: 0.85rem; font-weight: 600; color: #475569; margin-bottom: 8px; }
    .input-field input { width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 8px; outline: none; transition: border-color 0.3s; min-width: 0; }
    .input-field input:focus { border-color: #001E44; }

    .form-btns { display: flex; gap: 12px; margin-top: 10px; }
    .btn-activate-primary { flex: 1; background: #001E44; color: white; border: 0; padding: 14px; border-radius: 8px; font-weight: 600; cursor: pointer; transition: background 0.3s; }
    .btn-activate-primary:hover { background: #de1f38; }
    .btn-activate-soft { background: #f1f5f9; color: #475569; border: 0; padding: 14px 20px; border-radius: 8px; font-weight: 600; cursor: pointer; transition: background 0.3s; }
    .btn-activate-soft:hover { background: #e2e8f0; }

    .activation-feedback { margin-top: 20px; font-size: 0.9rem; color: #64748b; padding: 12px; background: #f8fafc; border-radius: 8px; border: 1px solid #f1f5f9; }

    .btn-goto-login { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 12px; background: #001E44; color: white; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 0.9rem; transition: background 0.3s; }
    .btn-goto-login:hover { background: #de1f38; }

    .result-placeholder { font-size: 0.85rem; color: #94a3b8; line-height: 1.6; }

    @media (max-width: 1100px) { .content-columns { grid-template-columns: 1fr; } }
    @media (max-width: 900px) {
      .portal-sidebar { display: none; }
      .portal-main { padding: 30px 20px; }
      .header-welcome h1 { font-size: 2.15rem; }
      .header-welcome p { font-size: 1rem; }
      .content-columns { gap: 24px; }
      .luxury-card { padding: 24px; }
      .card-head { margin-bottom: 1.4rem; }
      .form-row { grid-template-columns: 1fr; gap: 16px; margin-bottom: 16px; }
      .form-btns { flex-direction: column; }
      .btn-activate-primary,
      .btn-activate-soft,
      .btn-goto-login { width: 100%; min-height: 46px; }
    }
    @media (max-width: 560px) {
      .portal-main { padding: 22px 14px 26px; }
      .header-welcome h1 { font-size: 1.8rem; }
      .luxury-card,
      .luxury-card.compact { padding: 18px; border-radius: 10px; }
      .card-head { gap: 12px; align-items: flex-start; }
      .card-head h3 { font-size: 1.12rem; line-height: 1.2; }
      .icon-box { width: 40px; height: 40px; }
      .activation-feedback,
      .result-placeholder { font-size: 0.88rem; overflow-wrap: anywhere; }
    }
  </style>

  <script is:inline define:vars={{ defaultOrganizationId, lang }}>
    window.__portalBootstrap = {
      ...(window.__portalBootstrap || {}),
      lang,
      defaultOrganizationId,
    };
  </script>
  <script type="module" src="/portal/activate.js"></script>
</BaseLayout>
