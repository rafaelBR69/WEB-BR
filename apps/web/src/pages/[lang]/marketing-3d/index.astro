---
export const prerender = false;

import BaseLayout from "@webapp/layouts/BaseLayout.astro";
import { DEFAULT_LANG, isSupportedLang, SUPPORTED_LANGS } from "@shared/i18n/languages";
import { buildPublicNavigation } from "@webapp/navigation/publicNavigation";
import marketing3dPageContent from "@shared/data/pages/marketing-3d.json";
import "@webapp/styles/pages/marketing-3d.css";

const langParam = Astro.params.lang ?? DEFAULT_LANG;

if (!isSupportedLang(langParam)) {
  return Astro.redirect(`/${DEFAULT_LANG}/marketing-3d/`, 302);
}

const lang = langParam;
const navigation = buildPublicNavigation({
  lang,
  family: "section-landing",
  section: "marketing-3d",
});

const marketing3dContent = marketing3dPageContent as Record<string, any>;
const page = marketing3dContent.pageByLang[lang] ?? marketing3dContent.pageByLang.en ?? marketing3dContent.pageByLang.es;
const chrome = marketing3dContent.chromeByLang[lang] ?? marketing3dContent.chromeByLang.en ?? marketing3dContent.chromeByLang.es;

const sectionNav = [
  { id: "solutions", label: page.sections.solutionsEyebrow },
  { id: "flow", label: page.sections.flowEyebrow },
  { id: "results", label: page.sections.resultsEyebrow },
  { id: "contact", label: chrome.contactLabel },
];

const icons = {
  photo: ["M13 22h38v24H13z", "M20 22l4-6h16l4 6", "M32 41a8 8 0 1 0 0-16a8 8 0 0 0 0 16Z", "M44 28h4"],
  drone: ["M24 28h16v8H24z", "M18 18l8 8", "M46 18l-8 8", "M18 46l8-8", "M46 46l-8-8", "M12 16h10", "M42 16h10", "M12 48h10", "M42 48h10"],
  render: ["M32 12l18 10v20L32 52L14 42V22l18-10Z", "M32 12v20", "M50 22L32 32L14 22", "M32 32v20"],
  launch: ["M18 42h18l10-10V18l-8-8H24l-10 10v14Z", "M18 42l8-8", "M28 24h14", "M28 31h10", "M24 48l-6 6", "M18 54l-8-8"],
};
---

<BaseLayout
  title={page.title}
  description={page.description}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  {...navigation}
  showMobileStickyCta={false}
>
  <div class="marketing3d-page">
    <section class="marketing3d-hero container">
      <div class="marketing3d-copy">
        <span class="marketing3d-kicker">{page.eyebrow}</span>
        <h1>
          <span class="marketing3d-title-main">{page.headingMain}</span>
          <span class="marketing3d-title-sub">{page.headingSub}</span>
        </h1>
        <p>{page.intro}</p>

        <div class="marketing3d-actions">
          <a class="marketing3d-button marketing3d-button--primary" href={`/${lang}/contact/?service=marketing-3d`}>{page.primaryCta}</a>
          <a class="marketing3d-button marketing3d-button--ghost" href={`/${lang}/contact/`}>{page.secondaryCta}</a>
        </div>

        <div class="marketing3d-stats">
          {page.stats.map((stat) => (
            <article class="marketing3d-stat">
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </article>
          ))}
        </div>
      </div>

      <div class="marketing3d-console">
        <article class="marketing3d-console-panel">
          <span class="marketing3d-kicker">{page.consoleLabel}</span>
          <h2>{page.consoleTitle}</h2>
          <p>{page.consoleText}</p>
          <div class="marketing3d-console-signals">
            {chrome.consoleSignals.map((signal: string) => (
              <span>{signal}</span>
            ))}
          </div>
        </article>
        <article class="marketing3d-radar" aria-hidden="true">
          <span class="marketing3d-radar-ring marketing3d-radar-ring--one"></span>
          <span class="marketing3d-radar-ring marketing3d-radar-ring--two"></span>
          <span class="marketing3d-radar-sweep"></span>
          <span class="marketing3d-radar-dot marketing3d-radar-dot--one"></span>
          <span class="marketing3d-radar-dot marketing3d-radar-dot--two"></span>
          <span class="marketing3d-radar-dot marketing3d-radar-dot--three"></span>
          <span class="marketing3d-radar-dot marketing3d-radar-dot--four"></span>
        </article>
      </div>
    </section>

    <div class="container marketing3d-section-nav-shell">
      <button
        class="marketing3d-section-nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="marketing3d-section-nav"
      >
        <span class="marketing3d-section-nav-toggle__eyebrow">{chrome.sectionIndexEyebrow}</span>
        <span class="marketing3d-section-nav-toggle__value">{sectionNav[0]?.label}</span>
        <span class="marketing3d-section-nav-toggle__icon" aria-hidden="true">+</span>
      </button>
      <nav id="marketing3d-section-nav" class="marketing3d-section-nav" aria-label={chrome.sectionIndexAria}>
        {sectionNav.map((item, index) => (
          <a
            class:list={["marketing3d-section-nav__link", index === 0 && "is-active"]}
            href={`#${item.id}`}
            data-marketing-nav-link
          >
            <span>{item.label}</span>
          </a>
        ))}
      </nav>
    </div>

    <section id="solutions" class="marketing3d-section container">
      <div class="marketing3d-section-heading">
        <span>{page.sections.solutionsEyebrow}</span>
        <h2>{page.sections.solutionsHeading}</h2>
        <p>{page.sections.solutionsIntro}</p>
      </div>
      <div class="marketing3d-card-grid">
        {page.solutions.map((solution) => (
          <article class={`marketing3d-card marketing3d-card--${solution.id}`}>
            <div class="marketing3d-card-hud">
              <span>{solution.kicker}</span>
              <span>{chrome.solutionHudLabel}</span>
            </div>
            <div class="marketing3d-icon" aria-hidden="true">
              <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                {icons[solution.id].map((path) => (
                  <path d={path}></path>
                ))}
              </svg>
            </div>
            <h3>{solution.title}</h3>
            <p>{solution.text}</p>
            <footer>{solution.note}</footer>
          </article>
        ))}
      </div>
    </section>

    <section id="flow" class="marketing3d-section marketing3d-section--flow">
      <div class="container">
        <div class="marketing3d-section-heading">
          <span>{page.sections.flowEyebrow}</span>
          <h2>{page.sections.flowHeading}</h2>
          <p>{page.sections.flowIntro}</p>
        </div>
        <div class="marketing3d-flow">
          {page.flow.map((item) => (
            <article class="marketing3d-flow-step">
              <strong>{item.step}</strong>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="results" class="marketing3d-section container">
      <div class="marketing3d-section-heading">
        <span>{page.sections.resultsEyebrow}</span>
        <h2>{page.sections.resultsHeading}</h2>
        <p>{page.sections.resultsIntro}</p>
      </div>
      <div class="marketing3d-results">
        <div class="marketing3d-results-stats">
          {page.resultStats.map((stat) => (
            <article class="marketing3d-result-card">
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </article>
          ))}
        </div>
        <article class="marketing3d-panel">
          <h3>{page.checklistTitle}</h3>
          <ul>
            {page.checklist.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
        <article class="marketing3d-panel">
          <h3>{page.channelsTitle}</h3>
          <div class="marketing3d-chip-list">
            {page.channels.map((channel) => (
              <span>{channel}</span>
            ))}
          </div>
        </article>
      </div>
    </section>

    <section id="contact" class="marketing3d-cta container">
      <div class="marketing3d-cta-panel">
        <div>
          <span class="marketing3d-kicker">{chrome.closingEyebrow}</span>
          <h2>{page.closingTitle}</h2>
        </div>
        <p>{page.closingIntro}</p>
        <div class="marketing3d-actions">
          <a class="marketing3d-button marketing3d-button--primary" href={`/${lang}/contact/?service=marketing-3d`}>{page.closingPrimary}</a>
          <a class="marketing3d-button marketing3d-button--ghost" href={`/${lang}/commercialization/`}>{page.closingSecondary}</a>
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    (() => {
      const isMobile = window.matchMedia("(max-width: 760px)");
      const navShell = document.querySelector(".marketing3d-section-nav-shell");
      const navToggle = document.querySelector(".marketing3d-section-nav-toggle");
      const navToggleValue = document.querySelector(".marketing3d-section-nav-toggle__value");
      const links = Array.from(document.querySelectorAll("[data-marketing-nav-link]"));
      const items = links
        .map((link) => {
          const id = link.getAttribute("href")?.replace("#", "");
          const section = id ? document.getElementById(id) : null;
          return section ? { link, section } : null;
        })
        .filter(Boolean);

      if (!items.length || !navShell || !navToggle || !navToggleValue) {
        return;
      }

      const setNavOpen = (open) => {
        navShell.classList.toggle("is-open", open);
        navToggle.setAttribute("aria-expanded", String(open));
      };

      const setActive = (activeId) => {
        items.forEach(({ link, section }) => {
          link.classList.toggle("is-active", section.id === activeId);
        });

        const active = items.find(({ section }) => section.id === activeId);
        if (active) {
          navToggleValue.textContent = active.link.textContent?.trim() ?? "";
        }
      };

      const updateActiveFromScroll = () => {
        const offset = window.innerWidth <= 760 ? 148 : 160;
        const current =
          [...items].reverse().find(({ section }) => window.scrollY + offset >= section.offsetTop) ?? items[0];

        setActive(current.section.id);
      };

      links.forEach((link) => {
        link.addEventListener("click", (event) => {
          const id = link.getAttribute("href")?.replace("#", "");
          const section = id ? document.getElementById(id) : null;

          if (!section) {
            return;
          }

          event.preventDefault();
          const offset = window.innerWidth <= 760 ? 122 : 136;
          const top = section.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top: Math.max(0, top), behavior: "smooth" });
          setActive(section.id);
          if (isMobile.matches) {
            setNavOpen(false);
          }
        });
      });

      navToggle.addEventListener("click", () => {
        if (!isMobile.matches) {
          return;
        }

        setNavOpen(!navShell.classList.contains("is-open"));
      });

      document.addEventListener("click", (event) => {
        if (!isMobile.matches || !navShell.classList.contains("is-open")) {
          return;
        }

        const target = event.target;
        if (target instanceof Node && !navShell.contains(target)) {
          setNavOpen(false);
        }
      });

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

          if (visible?.target?.id) {
            setActive(visible.target.id);
          }
        },
        {
          rootMargin: "-20% 0px -55% 0px",
          threshold: [0.2, 0.45, 0.7],
        }
      );

      items.forEach(({ section }) => observer.observe(section));
      window.addEventListener("scroll", updateActiveFromScroll, { passive: true });
      window.addEventListener("resize", updateActiveFromScroll);
      isMobile.addEventListener("change", () => setNavOpen(false));
      updateActiveFromScroll();
    })();
  </script>
</BaseLayout>
