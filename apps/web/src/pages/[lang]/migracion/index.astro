---
export const prerender = false;

import BaseLayout from "@webapp/layouts/BaseLayout.astro";
import { getSeoMigrationDashboardData } from "@webapp/lib/seoMigrationDashboard";
import { buildPublicNavigation } from "@webapp/navigation/publicNavigation";
import { DEFAULT_LANG, isSupportedLang } from "@shared/i18n/languages";
import "@webapp/styles/pages/migracion.css";

const langParam = Astro.params.lang ?? DEFAULT_LANG;

if (!isSupportedLang(langParam) || langParam !== "es") {
  return Astro.redirect("/es/migracion/", 302);
}

const lang = "es";
const navigation = buildPublicNavigation({
  lang,
  family: "editorial",
  section: "legal",
});
const dashboard = await getSeoMigrationDashboardData();
const { summary } = dashboard;

const quickLinks = [
  { href: "#resumen", label: "Resumen" },
  { href: "#cockpit", label: "Cockpit" },
  { href: "#tareas", label: "Plan" },
  { href: "#redirects", label: "Redirects" },
  { href: "#gaps", label: "Gaps" },
  { href: "#auditoria", label: "Auditoria" },
  { href: "#checklists", label: "Checklists" },
];

const phaseNotes = {
  "00-discovery": "Congelar baseline y validar universo legacy antes de tocar nada.",
  "01-safe-redirects": "Mover solo el bucket seguro y separar merges dudosos.",
  "02-content-gaps": "Resolver indexabilidad y equivalencias de contenido.",
  "03-redirect-build": "Construir, revisar y documentar el mapa final de 301.",
  "04-internal-seo": "Refuerzo interno: enlazado, canonicals, sitemap y signals.",
  "05-prelaunch-qa": "QA tecnico y funcional antes de salir a produccion.",
  "06-launch": "Activacion, monitorizacion y seguimiento post-lanzamiento.",
};

const prettyNumber = (value: number) => value.toLocaleString("es-ES");
const humanize = (value: string) =>
  String(value ?? "")
    .replace(/[_-]+/g, " ")
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
const slugify = (value: string) =>
  String(value ?? "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
const badgeClass = (value: string, prefix = "tone") => `${prefix}-${slugify(value) || "default"}`;
const maxCount = (items: Array<{ count: number }>) => Math.max(1, ...items.map((item) => item.count));

const taskPhaseMax = maxCount(dashboard.taskPhaseCounts);
const redirectTypeMax = maxCount(dashboard.redirectTypeCounts);
const ownerMax = maxCount(dashboard.gapActionOwnerCounts ?? []);
const actionTypeMax = maxCount(dashboard.gapActionTypeCounts ?? []);
const noindexMax = maxCount(dashboard.auditNoindexUrlTypeCounts ?? []);

const indexabilityBlockers =
  dashboard.gapTypeCounts.find((item) => item.key === "target_currently_noindex")?.count ?? 0;
const missingEquivalents =
  dashboard.gapTypeCounts.find((item) => item.key === "content_missing_exact_equivalent")?.count ?? 0;
const manualQueueTotal = summary.mergeToParentCount + summary.manualDecisionCount;
const auditIndexable =
  dashboard.auditIndexStatusCounts.find((item) => item.key === "indexable")?.count ?? 0;
const auditNoindex =
  dashboard.auditIndexStatusCounts.find((item) => item.key === "noindex")?.count ?? 0;

const cockpitCards = [
  {
    title: "Ola 1",
    value: prettyNumber(summary.safeRedirectCount),
    hint: "redirects seguros listos para validar y mover",
    tone: "safe",
  },
  {
    title: "Cola manual",
    value: prettyNumber(manualQueueTotal),
    hint: "URLs que no se deben aprobar por lote",
    tone: "manual",
  },
  {
    title: "Bloqueo de indexacion",
    value: prettyNumber(indexabilityBlockers),
    hint: "targets existentes que siguen en noindex",
    tone: "risk",
  },
  {
    title: "Contenido a recrear",
    value: prettyNumber(missingEquivalents),
    hint: "URLs legacy sin equivalente exacto actual",
    tone: "content",
  },
];

const manualPreview = dashboard.manualReviewRows.slice(0, 6);
const priorityGapPreview = [...dashboard.datasets.gapActions.rows]
  .sort((left, right) => {
    const leftWeight = left.priority_band === "P1" ? 0 : 1;
    const rightWeight = right.priority_band === "P1" ? 0 : 1;
    return leftWeight - rightWeight || left.old_url.localeCompare(right.old_url);
  })
  .slice(0, 6);

const legendItems = [
  { title: "indexable", text: "URL publica y lista para captar trafico organico." },
  { title: "noindex", text: "Existe, pero no deberia capturar SEO tal y como esta ahora." },
  { title: "excluded_public", text: "Soporte, plantilla o fila no publica dentro del inventario." },
  { title: "canonical_redirect", text: "Consolidacion via canonical o redireccion, no compite sola." },
];
---

<BaseLayout
  title="Panel de control de migracion SEO | BlancaReal"
  description="Centro de mando interno para revisar redirects, gaps de contenido, indexabilidad y checklists de migracion SEO."
  lang={lang}
  availableLangs={["es"]}
  noindex={true}
  {...navigation}
>
  <div class="migration-page">
    <div class="migration-shell">
      <section class="migration-hero">
        <div class="migration-hero__copy">
          <p class="migration-eyebrow">Control interno SEO</p>
          <h1>Panel de control de migracion SEO</h1>
          <p class="migration-lead">
            No vamos a migrar 1.869 URLs una por una en bruto. Este panel convierte el inventario
            en olas de trabajo, colas de decision y bloques accionables para que sepas que hacer
            primero, que revisar con cuidado y que controlar en launch.
          </p>
          <div class="migration-meta">
            <span>Pagina interna, fuera de navegacion y no indexable</span>
            <span>
              {dashboard.sourceMode === "snapshot" ? "Snapshot desplegado" : "Lectura live de CSV"}
            </span>
            <span>Leido el {dashboard.generatedAt}</span>
          </div>
        </div>

        <aside class="migration-hero__panel">
          <h2>Estado de carga</h2>
          <div class="migration-source-mode">
            <strong>{dashboard.sourceMode === "snapshot" ? "Produccion estable" : "Modo local"}</strong>
            <p>
              {dashboard.sourceMode === "snapshot"
                ? "La pagina usa un snapshot versionado para no depender de CSV privados en el servidor."
                : "Los datos se estan leyendo desde los CSV locales del repositorio."}
            </p>
          </div>
          <ul class="migration-source-list">
            {dashboard.availableDatasets.map((fileName) => (
              <li>
                <code>{fileName}</code>
              </li>
            ))}
          </ul>
        </aside>
      </section>

      <nav class="migration-anchor-nav" aria-label="Navegacion rapida">
        {quickLinks.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>

      <section class="migration-section" id="resumen">
        <div class="migration-section__head">
          <div>
            <p class="migration-eyebrow">Resumen ejecutivo</p>
            <h2>La migracion real, convertida en volumen manejable</h2>
          </div>
          <p>
            La foto correcta no es “hay 1.869 URLs”. La foto correcta es cuantas entran en ola 1,
            cuantas bloquean indexacion, cuantas requieren decision manual y donde esta la mayor
            presion de noindex dentro del nuevo site.
          </p>
        </div>

        <div class="migration-kpi-grid">
          <article class="migration-kpi-card migration-kpi-card--hero">
            <span class="migration-kpi-card__value">{prettyNumber(summary.tasksTotal)}</span>
            <h3>Tareas</h3>
            <p>Plan maestro de ejecucion</p>
          </article>
          <article class="migration-kpi-card">
            <span class="migration-kpi-card__value">{prettyNumber(summary.phasesTotal)}</span>
            <h3>Fases</h3>
            <p>Bloques operativos de trabajo</p>
          </article>
          <article class="migration-kpi-card">
            <span class="migration-kpi-card__value">{prettyNumber(summary.criticalTasks)}</span>
            <h3>Criticas</h3>
            <p>Prioridad maxima antes de launch</p>
          </article>
          <article class="migration-kpi-card">
            <span class="migration-kpi-card__value">{prettyNumber(summary.legacyUrlCount)}</span>
            <h3>Legacy URLs</h3>
            <p>Universo legacy bajo decision</p>
          </article>
          <article class="migration-kpi-card">
            <span class="migration-kpi-card__value">{prettyNumber(summary.gapActionCount)}</span>
            <h3>Gaps</h3>
            <p>Bloqueos de contenido e indexacion</p>
          </article>
          <article class="migration-kpi-card">
            <span class="migration-kpi-card__value">{prettyNumber(summary.auditUrlCount)}</span>
            <h3>URLs auditadas</h3>
            <p>Inventario nuevo ya clasificado</p>
          </article>
        </div>
      </section>

      <section class="migration-section" id="cockpit">
        <div class="migration-section__head">
          <div>
            <p class="migration-eyebrow">Cockpit de decision</p>
            <h2>Que hacer primero y donde se atasca la migracion</h2>
          </div>
          <p>
            Estas cuatro cifras son la sala de mando. Si esto no se mueve, la migracion no avanza
            aunque el inventario este perfectamente auditado.
          </p>
        </div>

        <div class="migration-cockpit-grid">
          {cockpitCards.map((card) => (
            <article class:list={["migration-cockpit-card", `migration-cockpit-card--${card.tone}`]}>
              <p>{card.title}</p>
              <strong>{card.value}</strong>
              <span>{card.hint}</span>
            </article>
          ))}
        </div>

        <div class="migration-dual-grid">
          <article class="migration-card">
            <h3>Fases de trabajo</h3>
            <div class="migration-bar-list">
              {dashboard.taskPhaseCounts.map((item) => (
                <div class="migration-bar-item">
                  <div class="migration-bar-item__head">
                    <span>{item.label}</span>
                    <strong>{prettyNumber(item.count)}</strong>
                  </div>
                  <div class="migration-bar">
                    <span style={`width:${(item.count / taskPhaseMax) * 100}%`}></span>
                  </div>
                  <p>{phaseNotes[item.key] ?? "Bloque operativo de la migracion."}</p>
                </div>
              ))}
            </div>
          </article>

          <article class="migration-card">
            <h3>Radar de riesgo inmediato</h3>
            <div class="migration-bar-list">
              {dashboard.redirectTypeCounts.map((item) => (
                <div class="migration-bar-item">
                  <div class="migration-bar-item__head">
                    <span class:list={["migration-badge", badgeClass(item.key)]}>{item.label}</span>
                    <strong>{prettyNumber(item.count)}</strong>
                  </div>
                  <div class="migration-bar">
                    <span style={`width:${(item.count / redirectTypeMax) * 100}%`}></span>
                  </div>
                </div>
              ))}
            </div>
          </article>
        </div>

        <div class="migration-preview-grid">
          <article class="migration-card">
            <h3>Primeras URLs que requieren decision manual</h3>
            <div class="migration-preview-list">
              {manualPreview.map((row) => (
                <div class="migration-preview-item">
                  <span class:list={["migration-badge", badgeClass(row.migration_status)]}>
                    {humanize(row.migration_status)}
                  </span>
                  <a href={row.old_url} target="_blank" rel="noreferrer">{row.old_url}</a>
                  <p>{row.notes}</p>
                </div>
              ))}
            </div>
          </article>

          <article class="migration-card">
            <h3>Primer backlog de gaps a cerrar</h3>
            <div class="migration-preview-list">
              {priorityGapPreview.map((row) => (
                <div class="migration-preview-item">
                  <span class:list={["migration-badge", badgeClass(row.priority_band)]}>{row.priority_band}</span>
                  <a href={row.old_url} target="_blank" rel="noreferrer">{row.old_url}</a>
                  <p>{row.action_type}</p>
                </div>
              ))}
            </div>
          </article>
        </div>
      </section>

      <section class="migration-section" id="tareas">
        <div class="migration-section__head">
          <div>
            <p class="migration-eyebrow">Plan maestro</p>
            <h2>Tabla maestra de tareas</h2>
          </div>
          <p>
            Mantiene el orden de ejecucion real. La tabla completa sigue aqui, pero ya no es la
            unica forma de leer el proyecto.
          </p>
        </div>

        <details class="migration-disclosure" open>
          <summary>
            <span>Ver tabla completa de tareas</span>
            <strong>{prettyNumber(summary.tasksTotal)} filas</strong>
          </summary>
          <div class="migration-table-wrap">
            <table class="migration-table migration-table--dense">
              <thead>
                <tr>
                  <th>Seq</th>
                  <th>Phase</th>
                  <th>Task ID</th>
                  <th>Workstream</th>
                  <th>Priority</th>
                  <th>Status</th>
                  <th>Tarea</th>
                  <th>Por que importa</th>
                  <th>Depends on</th>
                  <th>Owner</th>
                  <th>Success criteria</th>
                </tr>
              </thead>
              <tbody>
                {dashboard.datasets.tasks.rows.map((row) => (
                  <tr>
                    <td>{row.sequence}</td>
                    <td>{row.phase}</td>
                    <td><code>{row.task_id}</code></td>
                    <td>{row.workstream}</td>
                    <td><span class:list={["migration-badge", badgeClass(row.priority)]}>{humanize(row.priority)}</span></td>
                    <td><span class:list={["migration-badge", badgeClass(row.status)]}>{humanize(row.status)}</span></td>
                    <td>{row.task}</td>
                    <td>{row.why_it_matters}</td>
                    <td>{row.depends_on}</td>
                    <td>{row.owner}</td>
                    <td>{row.success_criteria}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </details>
      </section>

      <section class="migration-section" id="redirects">
        <div class="migration-section__head">
          <div>
            <p class="migration-eyebrow">Redirects</p>
            <h2>Separar la ola segura de la cola delicada</h2>
          </div>
          <p>
            Los 100 seguros son una cosa. Los 50 <code>merge_to_parent</code> y la 1 decision
            manual son otra. Si mezclas ambos, pierdes claridad y calidad.
          </p>
        </div>

        <div class="migration-kpi-grid migration-kpi-grid--compact">
          {dashboard.redirectTypeCounts.map((item) => (
            <article class="migration-kpi-card migration-kpi-card--compact">
              <span class="migration-kpi-card__value">{prettyNumber(item.count)}</span>
              <h3>{item.label}</h3>
            </article>
          ))}
        </div>

        <div class="migration-dual-grid">
          <article class="migration-card">
            <h3>De que tipo son las legacy URLs</h3>
            <div class="migration-bar-list">
              {(dashboard.redirectOldTypeCounts ?? []).map((item) => (
                <div class="migration-bar-item">
                  <div class="migration-bar-item__head">
                    <span>{item.label}</span>
                    <strong>{prettyNumber(item.count)}</strong>
                  </div>
                  <div class="migration-bar">
                    <span style={`width:${(item.count / maxCount(dashboard.redirectOldTypeCounts ?? [])) * 100}%`}></span>
                  </div>
                </div>
              ))}
            </div>
          </article>

          <article class="migration-card">
            <h3>Primera ola aprobable</h3>
            <p>
              <strong>{prettyNumber(summary.safeRedirectCount)}</strong> URLs ya caen en buckets de
              bajo riesgo. Esto es lo primero que conviene revisar para implementacion real.
            </p>
            <div class="migration-safe-grid">
              {dashboard.safeRedirectBuckets.map((item) => (
                <div class="migration-safe-card">
                  <span class:list={["migration-badge", badgeClass(item.key)]}>{item.label}</span>
                  <strong>{prettyNumber(item.count)}</strong>
                </div>
              ))}
            </div>
          </article>
        </div>

        <details class="migration-disclosure">
          <summary>
            <span>Ver cola completa de revision manual</span>
            <strong>{prettyNumber(manualQueueTotal)} URLs</strong>
          </summary>
          <div class="migration-table-wrap">
            <table class="migration-table migration-table--dense">
              <thead>
                <tr>
                  <th>Legacy URL</th>
                  <th>Tipo</th>
                  <th>Destino actual</th>
                  <th>HTTP redirect</th>
                  <th>Migration bucket</th>
                  <th>Confidence</th>
                  <th>Notas</th>
                </tr>
              </thead>
              <tbody>
                {dashboard.manualReviewRows.map((row) => (
                  <tr>
                    <td class="migration-url-cell"><a href={row.old_url} target="_blank" rel="noreferrer">{row.old_url}</a></td>
                    <td>{row.old_type}</td>
                    <td class="migration-url-cell">
                      {row.matched_new_url ? (
                        <a href={row.matched_new_url} target="_blank" rel="noreferrer">{row.matched_new_url}</a>
                      ) : (
                        <span>Sin destino confirmado</span>
                      )}
                    </td>
                    <td><span class:list={["migration-badge", badgeClass(row.redirect_type)]}>{row.redirect_type || "N/A"}</span></td>
                    <td><span class:list={["migration-badge", badgeClass(row.migration_status)]}>{humanize(row.migration_status)}</span></td>
                    <td>{humanize(row.confidence)}</td>
                    <td>{row.notes}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </details>
      </section>

      <section class="migration-section" id="gaps">
        <div class="migration-section__head">
          <div>
            <p class="migration-eyebrow">Gaps prioritarios</p>
            <h2>Donde se atasca el valor SEO</h2>
          </div>
          <p>
            Aqui no hay que pensar en “filas”. Hay que pensar en propietarios del problema,
            tipo de accion y cola de resolucion.
          </p>
        </div>

        <div class="migration-kpi-grid migration-kpi-grid--compact">
          {dashboard.gapTypeCounts.map((item) => (
            <article class="migration-kpi-card migration-kpi-card--compact">
              <span class="migration-kpi-card__value">{prettyNumber(item.count)}</span>
              <h3>{item.label}</h3>
            </article>
          ))}
        </div>

        <div class="migration-dual-grid">
          <article class="migration-card">
            <h3>Owners de la cola</h3>
            <div class="migration-bar-list">
              {(dashboard.gapActionOwnerCounts ?? []).map((item) => (
                <div class="migration-bar-item">
                  <div class="migration-bar-item__head">
                    <span>{item.label}</span>
                    <strong>{prettyNumber(item.count)}</strong>
                  </div>
                  <div class="migration-bar">
                    <span style={`width:${(item.count / ownerMax) * 100}%`}></span>
                  </div>
                </div>
              ))}
            </div>
          </article>

          <article class="migration-card">
            <h3>Tipo de accion requerida</h3>
            <div class="migration-bar-list">
              {(dashboard.gapActionTypeCounts ?? []).map((item) => (
                <div class="migration-bar-item">
                  <div class="migration-bar-item__head">
                    <span>{humanize(item.key)}</span>
                    <strong>{prettyNumber(item.count)}</strong>
                  </div>
                  <div class="migration-bar">
                    <span style={`width:${(item.count / actionTypeMax) * 100}%`}></span>
                  </div>
                </div>
              ))}
            </div>
          </article>
        </div>

        <details class="migration-disclosure">
          <summary>
            <span>Ver tabla completa de gaps accionables</span>
            <strong>{prettyNumber(summary.gapActionCount)} filas</strong>
          </summary>
          <div class="migration-table-wrap">
            <table class="migration-table migration-table--dense">
              <thead>
                <tr>
                  <th>Legacy URL</th>
                  <th>Old type</th>
                  <th>Current target</th>
                  <th>Target type</th>
                  <th>Gap type</th>
                  <th>Priority band</th>
                  <th>Action owner</th>
                  <th>Action type</th>
                  <th>Implementation decision</th>
                  <th>SEO risk</th>
                  <th>Rationale</th>
                </tr>
              </thead>
              <tbody>
                {dashboard.datasets.gapActions.rows.map((row) => (
                  <tr>
                    <td class="migration-url-cell"><a href={row.old_url} target="_blank" rel="noreferrer">{row.old_url}</a></td>
                    <td>{row.old_type}</td>
                    <td class="migration-url-cell"><a href={row.current_target} target="_blank" rel="noreferrer">{row.current_target}</a></td>
                    <td>{humanize(row.current_target_type)}</td>
                    <td><span class:list={["migration-badge", badgeClass(row.gap_type)]}>{humanize(row.gap_type)}</span></td>
                    <td><span class:list={["migration-badge", badgeClass(row.priority_band)]}>{row.priority_band}</span></td>
                    <td>{row.action_owner}</td>
                    <td>{row.action_type}</td>
                    <td>{row.implementation_decision}</td>
                    <td><span class:list={["migration-badge", badgeClass(row.seo_risk)]}>{humanize(row.seo_risk)}</span></td>
                    <td>{row.rationale}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </details>

        <details class="migration-disclosure">
          <summary>
            <span>Ver diagnostico de contenido</span>
            <strong>{prettyNumber(dashboard.datasets.contentGaps.rows.length)} filas</strong>
          </summary>
          <div class="migration-table-wrap">
            <table class="migration-table migration-table--dense">
              <thead>
                <tr>
                  <th>Legacy URL</th>
                  <th>Old type</th>
                  <th>Current target</th>
                  <th>Target index status</th>
                  <th>Gap type</th>
                  <th>Recommended action</th>
                </tr>
              </thead>
              <tbody>
                {dashboard.datasets.contentGaps.rows.map((row) => (
                  <tr>
                    <td class="migration-url-cell"><a href={row.old_url} target="_blank" rel="noreferrer">{row.old_url}</a></td>
                    <td>{row.old_type}</td>
                    <td class="migration-url-cell"><a href={row.current_target} target="_blank" rel="noreferrer">{row.current_target}</a></td>
                    <td><span class:list={["migration-badge", badgeClass(row.target_index_status)]}>{humanize(row.target_index_status)}</span></td>
                    <td><span class:list={["migration-badge", badgeClass(row.gap_type)]}>{humanize(row.gap_type)}</span></td>
                    <td>{row.recommended_action}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </details>
      </section>

      <section class="migration-section" id="auditoria">
        <div class="migration-section__head">
          <div>
            <p class="migration-eyebrow">Auditoria del nuevo site</p>
            <h2>Como atacar 1.869 URLs sin morir en una tabla gigante</h2>
          </div>
          <p>
            La auditoria no se trabaja fila a fila. Se trabaja por clusters: idiomas, tipos de URL
            y bolsas de noindex. El problema principal esta concentrado en propiedades y landings.
          </p>
        </div>

        <div class="migration-cockpit-grid migration-cockpit-grid--audit">
          <article class="migration-cockpit-card migration-cockpit-card--safe">
            <p>Indexables ahora</p>
            <strong>{prettyNumber(auditIndexable)}</strong>
            <span>URLs ya listas para competir</span>
          </article>
          <article class="migration-cockpit-card migration-cockpit-card--manual">
            <p>Noindex ahora</p>
            <strong>{prettyNumber(auditNoindex)}</strong>
            <span>Bolsa principal a entender y filtrar</span>
          </article>
          <article class="migration-cockpit-card migration-cockpit-card--risk">
            <p>Presion property + landing</p>
            <strong>
              {prettyNumber(
                (dashboard.auditNoindexUrlTypeCounts?.find((item) => item.key === "property")?.count ?? 0) +
                  (dashboard.auditNoindexUrlTypeCounts?.find((item) => item.key === "property_landing")?.count ?? 0),
              )}
            </strong>
            <span>Noindex concentrado en inventario inmobiliario</span>
          </article>
        </div>

        <div class="migration-dual-grid">
          <article class="migration-card">
            <h3>Presion noindex por tipo de URL</h3>
            <div class="migration-bar-list">
              {(dashboard.auditNoindexUrlTypeCounts ?? []).map((item) => (
                <div class="migration-bar-item">
                  <div class="migration-bar-item__head">
                    <span>{item.label}</span>
                    <strong>{prettyNumber(item.count)}</strong>
                  </div>
                  <div class="migration-bar">
                    <span style={`width:${(item.count / noindexMax) * 100}%`}></span>
                  </div>
                </div>
              ))}
            </div>
          </article>

          <article class="migration-card">
            <h3>Distribucion por idioma</h3>
            <div class="migration-bar-list">
              {dashboard.auditLangCounts.map((item) => (
                <div class="migration-bar-item">
                  <div class="migration-bar-item__head">
                    <span>{item.label}</span>
                    <strong>{prettyNumber(item.count)}</strong>
                  </div>
                  <div class="migration-bar">
                    <span style={`width:${(item.count / maxCount(dashboard.auditLangCounts)) * 100}%`}></span>
                  </div>
                </div>
              ))}
            </div>
          </article>
        </div>

        <div class="migration-table-wrap">
          <table class="migration-table">
            <thead>
              <tr>
                <th>URL type</th>
                <th>Indexable</th>
                <th>Noindex</th>
                <th>Excluded public</th>
                <th>Canonical redirect</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              {(dashboard.auditMatrix ?? []).map((row) => (
                <tr>
                  <td>{row.label}</td>
                  <td>{prettyNumber(row.indexable)}</td>
                  <td>{prettyNumber(row.noindex)}</td>
                  <td>{prettyNumber(row.excluded_public)}</td>
                  <td>{prettyNumber(row.canonical_redirect)}</td>
                  <td><strong>{prettyNumber(row.total)}</strong></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="migration-legend-grid">
          {legendItems.map((item) => (
            <article class="migration-card migration-card--legend">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="migration-section" id="checklists">
        <div class="migration-section__head">
          <div>
            <p class="migration-eyebrow">Checklists finales</p>
            <h2>Control antes y despues de tocar produccion</h2>
          </div>
          <p>
            Estos bloques son la red de seguridad para que la migracion no se convierta en una
            suma de decisiones sueltas sin cierre.
          </p>
        </div>

        <div class="migration-checklists">
          <article class="migration-card">
            <h3>Antes de aprobar redirects</h3>
            <ul class="migration-checklist">
              <li>Confirmar que el destino conserva la misma intencion de busqueda.</li>
              <li>Separar bucket seguro y cola manual en dos aprobaciones distintas.</li>
              <li>Evitar cadenas, dobles 301 y redirecciones de conveniencia sin justificacion.</li>
              <li>Documentar cada merge_to_parent aceptado.</li>
            </ul>
          </article>

          <article class="migration-card">
            <h3>Antes de indexar targets hoy en noindex</h3>
            <ul class="migration-checklist">
              <li>Validar contenido suficiente, canonical correcta y ausencia de duplicado util.</li>
              <li>Confirmar que la pagina debe formar parte del inventario publico indexable.</li>
              <li>Revisar enlazado interno, metadatos y coherencia de plantilla.</li>
              <li>Relacionar el cambio con una fila concreta del gap backlog.</li>
            </ul>
          </article>

          <article class="migration-card">
            <h3>Antes del launch</h3>
            <ul class="migration-checklist">
              <li>Subir mapa final de 301 y validarlo con muestreo real.</li>
              <li>Comprobar robots, sitemap, canonicals y cobertura minima esperada.</li>
              <li>Congelar version operativa de datos y decisiones.</li>
              <li>Preparar monitorizacion de 404s y Search Console.</li>
            </ul>
          </article>

          <article class="migration-card">
            <h3>Despues del launch</h3>
            <ul class="migration-checklist">
              <li>Seguir 404s, cobertura e impresiones de las URLs legacy sensibles.</li>
              <li>Revisar clusters con mayor peso noindex en el inventario nuevo.</li>
              <li>Actualizar backlog resuelto vs pendiente con criterio SEO real.</li>
              <li>Corregir rapido cualquier redirect ciego o consolidacion dudosa.</li>
            </ul>
          </article>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
