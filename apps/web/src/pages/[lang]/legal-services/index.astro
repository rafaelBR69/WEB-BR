        points: [
          "Registry encumbrance review",
          "Ownership verification",
          "Planning status: licences, infringements and permitted use",
          "Debt review: council tax, community fees and utilities",
        ],
      },
      {
        id: "tax",
        label: "03",
        title: "Tax advice",
        text: "We frame the tax effect of each purchase, sale or rental situation and the declarations linked to it.",
        points: [
          "Transfer tax, VAT, stamp duty, municipal plusvalia and income tax",
          "Taxes linked to purchase or sale",
          "Returns related to rental activity",
          "Tourist rental licences and rental registration number",
        ],
      },
      {
        id: "docs",
        label: "04",
        title: "Documentation and formalities",
