        points: [
          "Contratos de compraventa",
          "Contratos de arras",
          "Contratos de alquiler: vivienda, temporada y local",
          "Contratos de opcion de compra",
          "Contratos de obra o reforma",
        ],
      },
      {
        id: "due",
        label: "02",
        title: "Due diligence legal del inmueble",
        text: "Verificamos la situacion juridica y documental del activo antes de avanzar en compra, venta o regularizacion.",
        points: [
          "Verificacion de cargas en el Registro de la Propiedad",
          "Comprobacion de titularidad",
          "Situacion urbanistica: licencias, infracciones y uso permitido",
          "Revision de deudas: IBI, comunidad y suministros",
