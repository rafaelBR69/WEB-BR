    closingSecondary: "View commercialization",
  },
};

const page = copyByLang[lang] ?? copyByLang.en ?? copyByLang.es;

const sectionNav = [
  { id: "coverage", label: page.sections.coverageEyebrow },
  { id: "method", label: page.sections.methodEyebrow },
  { id: "dossiers", label: page.sections.dossiersEyebrow },
  { id: "control", label: page.sections.controlEyebrow },
  { id: "contact", label: lang === "es" ? "Contacto" : "Contact" },
];

const icons = {
  sale: ["M14 20h36", "M14 28h36", "M14 36h22", "M42 36h8", "M18 14h28v36H18z"],
  due: ["M20 18h24v28H20z", "M26 14h12", "M26 50h12", "M32 22v20", "M24 30h16"],
  intl: ["M32 12c11 0 20 9 20 20s-9 20-20 20-20-9-20-20 9-20 20-20Z", "M12 32h40", "M32 12c5 6 8 12 8 20s-3 14-8 20", "M32 12c-5 6-8 12-8 20s3 14 8 20"],
  close: ["M18 22l10 10 18-18", "M16 44h32", "M18 16h28v32H18z"],
};
---

<BaseLayout
  title={page.title}
  description={page.description}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  headerVariant="landing"
  landingNavItems={landingNavItems}
  showMobileStickyCta={false}
>
  <div class="legal-page">
    <section class="legal-hero">
      <div class="container legal-hero__layout">
        <div class="legal-hero__copy">
          <span class="legal-kicker">{page.eyebrow}</span>
          <h1>
            <span class="legal-title-main">{page.headingMain}</span>
            <span class="legal-title-sub">{page.headingSub}</span>
          </h1>
          <p>{page.intro}</p>

          <div class="legal-actions">
            <a class="legal-button legal-button--primary" href={`/${lang}/contact/?service=legal-services`}>{page.primaryCta}</a>
            <a class="legal-button legal-button--ghost" href={`/${lang}/contact/`}>{page.secondaryCta}</a>
          </div>

          <div class="legal-stats" aria-label={page.eyebrow}>
            {page.heroStats.map((stat) => (
              <article class="legal-stat">
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </article>
            ))}
          </div>
        </div>

        <aside class="legal-desk">
          <span class="legal-kicker legal-kicker--soft">{page.deskEyebrow}</span>
          <h2>{page.deskTitle}</h2>
          <p>{page.deskText}</p>
          <div class="legal-tags">
            {page.deskTags.map((tag) => <span>{tag}</span>)}
          </div>
        </aside>
      </div>
    </section>

    <div class="container legal-section-nav-shell">
      <button
        class="legal-section-nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="legal-section-nav"
      >
        <span class="legal-section-nav-toggle__eyebrow">{lang === "es" ? "Indice de secciones" : "Section index"}</span>
        <span class="legal-section-nav-toggle__value">{sectionNav[0]?.label}</span>
        <span class="legal-section-nav-toggle__icon" aria-hidden="true">+</span>
      </button>
      <nav id="legal-section-nav" class="legal-section-nav" aria-label={lang === "es" ? "Indice legal" : "Legal index"}>
        {sectionNav.map((item, index) => (
          <a
            class:list={["legal-section-nav__link", index === 0 && "is-active"]}
            href={`#${item.id}`}
            data-legal-nav-link
          >
            <span>{item.label}</span>
          </a>
        ))}
      </nav>
    </div>

    <section id="coverage" class="legal-section container">
      <div class="legal-section-heading">
        <span>{page.sections.coverageEyebrow}</span>
        <h2>{page.sections.coverageHeading}</h2>
        <p>{page.sections.coverageIntro}</p>
      </div>

      <div class="legal-coverage-grid">
        {page.coverage.map((item) => (
          <article class={`legal-card legal-card--${item.id}`}>
            <div class="legal-card__head">
              <span class="legal-card__index">{item.label}</span>
              <span class="legal-card__icon" aria-hidden="true">
                <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  {icons[item.id].map((path) => <path d={path}></path>)}
                </svg>
              </span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <ul>
              {item.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section id="method" class="legal-section legal-section--tint">
      <div class="container">
        <div class="legal-section-heading">
          <span>{page.sections.methodEyebrow}</span>
          <h2>{page.sections.methodHeading}</h2>
          <p>{page.sections.methodIntro}</p>
        </div>

        <div class="legal-method">
          {page.method.map((step) => (
            <article class="legal-method-step">
              <strong>{step.step}</strong>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="dossiers" class="legal-section container">
      <div class="legal-section-heading">
        <span>{page.sections.dossiersEyebrow}</span>
        <h2>{page.sections.dossiersHeading}</h2>
        <p>{page.sections.dossiersIntro}</p>
      </div>

      <div class="legal-dossier-grid">
        {page.dossiers.map((dossier) => (
          <article class="legal-dossier">
            <h3>{dossier.title}</h3>
            <p>{dossier.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="control" class="legal-section container">
      <div class="legal-control">
        <article class="legal-control-panel">
          <div class="legal-section-heading legal-section-heading--compact">
            <span>{page.sections.controlEyebrow}</span>
            <h2>{page.sections.controlHeading}</h2>
            <p>{page.sections.controlIntro}</p>
          </div>
          <h3>{page.controlTitle}</h3>
          <ul>
            {page.controlList.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="legal-matrix">
          <h3>{page.matrixTitle}</h3>
          <dl>
            {page.matrix.map((item) => (
              <div>
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        </article>
      </div>
    </section>

    <section id="contact" class="legal-cta">
      <div class="container">
        <article class="legal-cta__panel">
          <div>
            <span class="legal-kicker">{page.eyebrow}</span>
            <h2>{page.closingTitle}</h2>
            <p>{page.closingIntro}</p>
          </div>
          <div class="legal-actions legal-actions--end">
            <a class="legal-button legal-button--primary" href={`/${lang}/contact/?service=legal-services`}>{page.closingPrimary}</a>
            <a class="legal-button legal-button--ghost" href={`/${lang}/commercialization/`}>{page.closingSecondary}</a>
          </div>
        </article>
      </div>
    </section>
  </div>

  <script is:inline>
    (() => {
      const isMobile = window.matchMedia("(max-width: 760px)");
      const navShell = document.querySelector(".legal-section-nav-shell");
      const navToggle = document.querySelector(".legal-section-nav-toggle");
      const navToggleValue = document.querySelector(".legal-section-nav-toggle__value");
      const nav = document.querySelector(".legal-section-nav");
      const links = Array.from(document.querySelectorAll("[data-legal-nav-link]"));
      const sections = links
        .map((link) => {
          const id = link.getAttribute("href")?.replace("#", "");
          const section = id ? document.getElementById(id) : null;
          return section ? { link, section } : null;
        })
        .filter(Boolean);

      if (!nav || !sections.length || !navShell || !navToggle || !navToggleValue) {
        return;
      }

      const setNavOpen = (open) => {
        navShell.classList.toggle("is-open", open);
        navToggle.setAttribute("aria-expanded", String(open));
      };

      const setActive = (activeId) => {
        sections.forEach(({ link, section }) => {
          link.classList.toggle("is-active", section.id === activeId);
        });

        const active = sections.find(({ section }) => section.id === activeId);
        if (active) {
          navToggleValue.textContent = active.link.textContent?.trim() ?? "";
        }
      };

      links.forEach((link) => {
        link.addEventListener("click", (event) => {
          const id = link.getAttribute("href")?.replace("#", "");
          const section = id ? document.getElementById(id) : null;

          if (!section) {
            return;
          }

          event.preventDefault();
          const offset = window.innerWidth <= 760 ? 122 : 136;
          const top = section.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top: Math.max(0, top), behavior: "smooth" });
          setActive(section.id);
          if (isMobile.matches) {
            setNavOpen(false);
          }
        });
      });

      navToggle.addEventListener("click", () => {
        if (!isMobile.matches) {
          return;
        }

        setNavOpen(!navShell.classList.contains("is-open"));
      });

      document.addEventListener("click", (event) => {
        if (!isMobile.matches || !navShell.classList.contains("is-open")) {
          return;
        }

        const target = event.target;
        if (target instanceof Node && !navShell.contains(target)) {
          setNavOpen(false);
        }
      });

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

          if (visible?.target?.id) {
            setActive(visible.target.id);
          }
        },
        {
          rootMargin: "-20% 0px -55% 0px",
          threshold: [0.2, 0.45, 0.7],
        }
      );

      sections.forEach(({ section }) => observer.observe(section));
      isMobile.addEventListener("change", () => setNavOpen(false));
      setActive(sections[0].section.id);
    })();
  </script>
</BaseLayout>
