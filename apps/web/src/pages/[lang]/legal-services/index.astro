---
export const prerender = false;

import BaseLayout from "@webapp/layouts/BaseLayout.astro";
import { DEFAULT_LANG, isSupportedLang, SUPPORTED_LANGS } from "@shared/i18n/languages";
import { buildPublicNavigation } from "@webapp/navigation/publicNavigation";
import "@webapp/styles/pages/legal-services.css";

const langParam = Astro.params.lang ?? DEFAULT_LANG;

if (!isSupportedLang(langParam)) {
  return Astro.redirect(`/${DEFAULT_LANG}/legal-services/`, 302);
}

const lang = langParam;
const navigation = buildPublicNavigation({
  lang,
  family: "section-landing",
  section: "legal-services",
});

const copyByLang = {
  es: {
    title: "Servicios legales | BlancaReal",
    description:
      "Servicios legales inmobiliarios en la Costa del Sol para contratos, due diligence, fiscalidad, tramites, representacion y apoyo a compradores, vendedores, arrendadores e inversores extranjeros.",
    eyebrow: "Servicios legales",
    headingMain: "Servicios legales inmobiliarios en la Costa del Sol",
    headingSub: "Contratos, due diligence, fiscalidad, tramites, representacion y asistencia internacional",
    intro:
      "Adaptamos el soporte legal a cada operacion inmobiliaria: compra, venta, alquiler, regularizacion, cierre notarial y defensa posterior si surge cualquier conflicto sobre el inmueble o el contrato.",
