    sections: {
      coverageEyebrow: "Coverage",
      coverageHeading: "Legal areas we structure inside a transaction",
      coverageIntro:
        "The page is intentionally organized in clear blocks so we can deepen each service later without rebuilding the structure.",
      methodEyebrow: "Method",
      methodHeading: "How a legal file is structured with BlancaReal",
      methodIntro:
        "The approach is not theoretical. Each phase has a direct role within deal progress and client protection.",
      dossiersEyebrow: "Case files",
      dossiersHeading: "Types of matters this landing can expand later",
      dossiersIntro:
        "The architecture is ready to grow around sales, international clients, developers and transactions with document-heavy risk layers.",
      controlEyebrow: "Document control",
      controlHeading: "What should always stay under legal review",
      controlIntro:
        "Until the final content arrives, the structure already prioritizes the areas where real estate legal support adds the most value.",
    },
    coverage: [
      {
        id: "sale",
        label: "01",
        title: "Sales and contracts",
        text: "Contract review and structure so the transaction can advance with clear rules, defined milestones and lower exposure.",
        points: ["Reservations", "Deposits", "Private sale agreement", "Annexes and conditions"],
      },
      {
        id: "due",
        label: "02",
        title: "Real estate due diligence",
        text: "Reading of encumbrances, title position, registry consistency and critical documentation before financial commitment.",
        points: ["Registry notes", "Charges", "Ownership", "Document consistency"],
      },
      {
        id: "intl",
        label: "03",
