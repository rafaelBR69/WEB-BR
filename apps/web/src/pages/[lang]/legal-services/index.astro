    ],
    matrixTitle: "Layers this page can expand",
    matrix: [
      { label: "Transaction", value: "Purchase, sale or mixed structure" },
      { label: "Asset", value: "Residential, development or singular unit" },
      { label: "Profile", value: "Private client, developer or international buyer" },
