---
const { lang } = Astro.props;
import homePageContent from "@shared/data/pages/home.json";

const homeContent = homePageContent as Record<string, any>;
const t = homeContent.featuredServicesByLang[lang] ?? homeContent.featuredServicesByLang.es;
const cards = t.cards.map((card: Record<string, string>) => ({
  ...card,
  href: String(card.href).replace("__LANG__", lang),
}));
---

<section class="home-featured-services" aria-labelledby="homeFeaturedServicesTitle">
  <div class="container">
    <div class="home-editorial-section-head">
      <p class="home-editorial-section-kicker">{t.eyebrow}</p>
      <h2 id="homeFeaturedServicesTitle" class="home-editorial-section-title">{t.title}</h2>
      <p class="home-editorial-section-text">{t.intro}</p>
    </div>

    <div class="home-services-grid">
      {cards.map((card) => (
        <article class="home-service-card">
          <a href={card.href} class="home-service-link">
            <img src={card.image} alt={card.title} loading="lazy" decoding="async" />
            <div class="home-service-overlay"></div>
            <div class="home-service-copy">
              <h3>{card.title}</h3>
              <p>{card.text}</p>
              <span>{card.cta}</span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
