---
const props = Astro.props as {
  variant?: "wordmark" | "stacked" | "icon";
  tone?: "default" | "light";
  href?: string | null;
  alt?: string;
  class?: string;
  loading?: "eager" | "lazy" | "auto";
};

const variant = props.variant ?? "wordmark";
const tone = props.tone ?? "default";
const href = props.href ?? null;
const alt = props.alt ?? "BlancaReal";
const className = props.class ?? "";
const loading = props.loading ?? "eager";
const classList = ["brand-logo-element", `brand-logo-${variant}`, className].filter(Boolean).join(" ");

const srcByToneAndVariant: Record<string, Record<string, string>> = {
  default: {
    wordmark: "/logos/blanca_real_logo_principal.png",
    stacked: "/logos/blanca_real_logo_secundario.png",
    icon: "/logos/blanca_real_icono.png",
  },
  light: {
    wordmark: "/logos/blancareal_logo_principal_blanco.png",
    stacked: "/logos/blanca_real_logo_secundario_blanco.png",
    icon: "/logos/blanca_real_icono.png",
  },
};

const sizeByVariant: Record<string, { width: number; height: number }> = {
  wordmark: { width: 182, height: 44 },
  stacked: { width: 118, height: 114 },
  icon: { width: 42, height: 42 },
};

const imageSrc =
  srcByToneAndVariant[tone]?.[variant] ??
  srcByToneAndVariant.default[variant] ??
  srcByToneAndVariant.default.wordmark;
const { width, height } = sizeByVariant[variant] ?? sizeByVariant.wordmark;
---
{
  href === null || href === undefined ? (
    <span class={classList} aria-label={alt} data-logo-variant={variant}>
      <img src={imageSrc} alt={alt} width={width} height={height} loading={loading} />
    </span>
  ) : (
    <a href={href} class={classList} aria-label={alt} data-logo-variant={variant}>
      <img src={imageSrc} alt={alt} width={width} height={height} loading={loading} />
    </a>
  )
}
