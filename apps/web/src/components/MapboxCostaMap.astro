---
const {
  token,
  styleUrl = "mapbox://styles/mapbox/standard",
  features = [],
  featuresUrl = "",
  poisUrl = "/data/pois.geojson",
  zonesUrl = "/data/zones.geojson",
  poiFilters = [
    { id: "restaurant", label: "Restaurantes" },
    { id: "hospital", label: "Hospitales" },
    { id: "school", label: "Colegios" },
    { id: "pharmacy", label: "Farmacias" },
    { id: "airport", label: "Aeropuertos" },
    { id: "leisure", label: "Ocio" },
  ],
  emptyMessage = "No hay ubicaciones disponibles en el mapa.",
  poiLabel = "Puntos de interes",
  routePlannerTitle = "Ruta",
  routeStartLabel = "Iniciar ruta",
  routeClearLabel = "Limpiar ruta",
  routeDistanceLabel = "Distancia",
  routeDurationLabel = "Tiempo estimado",
  routeSelectionHint = "Selecciona una vivienda para comenzar la ruta.",
  openDetailLabel = "Ver ficha",
  resetViewLabel = "Reiniciar mapa",
  exploreAreaLabel = "Explorar zona",
  compact = false,
  fitToFeaturesOnLoad = false,
  mode = "listing",
  loadStrategy = "visible",
  allowExtrasLoad = mode === "detail",
  showPois = mode === "detail",
  showZones = mode === "detail",
  enableRouting = mode === "detail",
} = Astro.props;

const featureCollection = {
  type: "FeatureCollection",
  features,
};
const serializedFeatureCollection = featureCollection.features.length
  ? JSON.stringify(featureCollection)
  : "";

const shouldRenderExploreButton =
  allowExtrasLoad && !(showPois && showZones && enableRouting);
---

<section class:list={["map-layout", compact && "is-compact", mode === "listing" && "is-listing"]}>
  <div
    class="map-shell"
    data-mapbox-root
    data-token={token}
    data-style={styleUrl}
    data-mode={mode}
    data-load-strategy={loadStrategy}
    data-fit-to-features={fitToFeaturesOnLoad ? "true" : "false"}
    data-features={serializedFeatureCollection || undefined}
    data-features-url={featuresUrl || undefined}
    data-pois-url={poisUrl}
    data-zones-url={zonesUrl}
    data-poi-filters={JSON.stringify(poiFilters)}
    data-empty={emptyMessage}
    data-open-detail-label={openDetailLabel}
    data-route-start-label={routeStartLabel}
    data-route-clear-label={routeClearLabel}
    data-route-distance-label={routeDistanceLabel}
    data-route-duration-label={routeDurationLabel}
    data-route-selection-hint={routeSelectionHint}
    data-show-pois={showPois ? "true" : "false"}
    data-show-zones={showZones ? "true" : "false"}
    data-enable-routing={enableRouting ? "true" : "false"}
    data-can-load-extras={allowExtrasLoad ? "true" : "false"}
  >
    <div class="map-toolbar">
      <button type="button" class="map-action map-action-alt" data-map-reset>
        {resetViewLabel}
      </button>
      {shouldRenderExploreButton && (
        <button type="button" class="map-action" data-map-load-extras>
          {exploreAreaLabel}
        </button>
      )}
    </div>

    <div class="map-viewport">
      <div class="costa-map" data-mapbox-canvas></div>
      <div class="map-overlay-card" data-mapbox-overlay>
        <p class="map-overlay-eyebrow">{mode === "listing" ? "Vista interactiva" : "Mapa"}</p>
        <p class="map-overlay-text">
          {mode === "listing"
            ? "Preparando la vista del mapa."
            : "Preparando el mapa y su entorno interactivo."}
        </p>
      </div>

      <div class="map-route-panel" data-map-route-panel hidden>
        <p class="map-route-title">{routePlannerTitle}</p>
        <button type="button" class="map-action map-action-alt" data-map-route-clear>
          {routeClearLabel}
        </button>
        <p class="map-route-status" data-map-route-status>{routeSelectionHint}</p>
        <div class="map-route-metrics" data-map-route-metrics hidden>
          <p><strong>{routeDistanceLabel}:</strong> <span data-map-route-distance></span></p>
          <p><strong>{routeDurationLabel}:</strong> <span data-map-route-duration></span></p>
        </div>
      </div>
    </div>

    <div class="map-poi-panel" data-map-poi-panel hidden>
      <p class="map-poi-panel-title">{poiLabel}</p>
      <div class="poi-filters" data-map-poi-filters></div>
    </div>
  </div>
</section>

<script>
  import "@webapp/scripts/mapbox-public";
</script>

<style>
  .map-layout {
    position: relative;
  }

  .map-shell {
    --map-brand: #202f4e;
    --map-accent: #d32c43;
    --map-border: rgba(32, 47, 78, 0.14);
    --map-shadow: 0 18px 34px rgba(15, 23, 42, 0.1);
    display: grid;
    gap: 0.9rem;
  }

  .map-toolbar {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .map-viewport {
    position: relative;
    padding: 0.42rem;
    border-radius: 22px;
    border: 1px solid var(--map-border);
    background:
      radial-gradient(120% 100% at 100% -20%, rgba(29, 78, 216, 0.1), transparent 58%),
      linear-gradient(180deg, #ffffff, #f6f9ff);
    box-shadow: var(--map-shadow);
    overflow: hidden;
  }

  .costa-map {
    width: 100%;
    min-height: 560px;
    height: min(70vh, 720px);
    border-radius: 16px;
    border: 1px solid rgba(32, 47, 78, 0.18);
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(32, 47, 78, 0.08), rgba(29, 78, 216, 0.1)),
      #e9eef5;
  }

  .is-compact .map-toolbar {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 5;
  }

  .is-compact .map-viewport {
    padding: 0.3rem;
    border-radius: 18px;
  }

  .is-compact .costa-map {
    min-height: clamp(420px, 42vw, 560px);
    height: clamp(420px, 42vw, 560px);
  }

  .map-overlay-card,
  .map-route-panel {
    position: absolute;
    z-index: 4;
    border-radius: 16px;
    backdrop-filter: blur(8px);
  }

  .map-overlay-card {
    left: 1rem;
    bottom: 1rem;
    width: min(340px, calc(100% - 2rem));
    padding: 0.95rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 14px 26px rgba(15, 23, 42, 0.16);
  }

  .map-overlay-card[hidden],
  .map-poi-panel[hidden],
  .map-route-panel[hidden] {
    display: none;
  }

  .map-overlay-eyebrow,
  .map-poi-panel-title,
  .map-route-title {
    margin: 0 0 0.35rem;
    color: var(--map-brand);
    font-size: 0.74rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.13em;
  }

  .map-overlay-text,
  .map-route-status {
    margin: 0 0 0.85rem;
    color: rgba(32, 47, 78, 0.82);
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .map-action {
    border: 0;
    background: linear-gradient(135deg, #202f4e, #1d4ed8);
    color: #fff;
    padding: 0.7rem 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font-size: 0.72rem;
    line-height: 1;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    font-family: "Manrope", sans-serif;
  }

  .map-action-alt {
    background: rgba(255, 255, 255, 0.94);
    color: var(--map-brand);
    border: 1px solid rgba(32, 47, 78, 0.14);
    box-shadow: 0 8px 14px rgba(15, 23, 42, 0.12);
  }

  .map-poi-panel {
    display: grid;
    gap: 0.7rem;
    padding: 1rem 1.05rem 1.05rem;
    border: 1px solid var(--map-border);
    border-radius: 18px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(246, 249, 255, 0.96));
    box-shadow: 0 14px 28px rgba(15, 23, 42, 0.08);
  }

  .poi-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .poi-chip {
    border: 1px solid rgba(32, 47, 78, 0.14);
    background: rgba(255, 255, 255, 0.84);
    color: var(--map-brand);
    border-radius: 999px;
    padding: 0.62rem 0.95rem;
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    text-align: center;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
  }

  .poi-chip:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 16px rgba(15, 23, 42, 0.08);
  }

  .poi-chip.is-active {
    background: linear-gradient(135deg, rgba(32, 47, 78, 0.94), rgba(29, 78, 216, 0.9));
    color: #fff;
    border-color: transparent;
  }

  .map-route-panel {
    right: 1rem;
    bottom: 1rem;
    width: min(320px, calc(100% - 2rem));
    display: grid;
    gap: 0.45rem;
    padding: 0.82rem 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(15, 23, 42, 0.78);
    box-shadow: 0 14px 28px rgba(2, 6, 23, 0.28);
  }

  .map-route-title,
  .map-route-status,
  .map-route-metrics strong,
  .map-route-metrics span,
  .map-route-metrics p {
    color: #fff;
  }

  .map-route-metrics p {
    margin: 0;
    font-size: 0.82rem;
  }

  .map-empty {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    padding: 2rem;
    text-align: center;
    color: rgba(32, 47, 78, 0.78);
    font-weight: 600;
  }

  :global(.mapboxgl-popup-content) {
    padding: 0;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.22);
  }

  :global(.map-popup) {
    display: grid;
    min-width: 240px;
    max-width: 280px;
  }

  :global(.map-popup-cover) {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
  }

  :global(.map-popup-body) {
    display: grid;
    gap: 0.45rem;
    padding: 0.9rem 1rem 1rem;
  }

  :global(.map-popup-body h3),
  :global(.map-popup-body p) {
    margin: 0;
  }

  :global(.map-popup-body p) {
    color: rgba(32, 47, 78, 0.76);
    font-size: 0.9rem;
  }

  :global(.map-popup-actions) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.15rem;
  }

  :global(.map-popup-actions a),
  :global(.map-popup-actions button) {
    border: 0;
    background: linear-gradient(135deg, #202f4e, #1d4ed8);
    color: #fff;
    border-radius: 999px;
    padding: 0.58rem 0.88rem;
    font-size: 0.76rem;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
  }

  :global(.map-popup-actions button) {
    background: rgba(32, 47, 78, 0.1);
    color: var(--map-brand);
  }

  @media (max-width: 900px) {
    .map-toolbar {
      justify-content: flex-start;
    }

    .costa-map {
      min-height: 440px;
      height: 58vh;
    }

    .map-overlay-card,
    .map-route-panel {
      width: min(100%, calc(100% - 2rem));
    }

    .map-poi-panel {
      padding: 0.9rem;
    }

    .poi-filters {
      gap: 0.45rem;
    }

    .poi-chip {
      flex: 1 1 calc(50% - 0.45rem);
      min-width: 132px;
      padding-inline: 0.8rem;
    }
  }
</style>
