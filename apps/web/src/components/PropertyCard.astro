---
import "@webapp/styles/components/property-card.css";
import { formatPrice } from "@shared/presentation/common";
import { formatArea } from "@shared/presentation/common";
import FeatureBadge from "@webapp/components/FeatureBadge.astro";
import { buildSupabaseImageUrl, buildSupabaseSrcSet } from "@shared/media/supabaseImage";
import { getUiCopy } from "@shared/i18n/ui";

const { data, lang, maxGallerySlides, compact = false, disableSrcSet = false } = Astro.props;
const galleryLimit =
  typeof maxGallerySlides === "number" && Number.isFinite(maxGallerySlides)
    ? Math.max(1, Math.floor(maxGallerySlides))
    : null;
const galleryItems = Array.isArray(data.galleryPreview) && data.galleryPreview.length
  ? data.galleryPreview
  : data.cover
    ? [data.cover]
    : [];
const visibleGalleryItems = galleryLimit ? galleryItems.slice(0, galleryLimit) : galleryItems;

const gallerySlides = visibleGalleryItems
  .map((item) => {
    const url = typeof item === "string" ? item : item?.url;
    if (!url) return null;
    const alt =
      (typeof item === "object" ? item?.alt?.[lang] : null) ||
      (typeof item === "object" ? item?.alt?.es : null) ||
      data.title;
    return {
      url,
      alt,
      src: buildSupabaseImageUrl(url, { width: compact ? 560 : 720, quality: 72 }) ?? url,
      srcSet: disableSrcSet
        ? ""
        : buildSupabaseSrcSet(url, compact ? [320, 480, 560] : [320, 480, 640, 720], {
            quality: 72,
          }) || "",
    };
  })
  .filter(Boolean);

const hasGalleryControls = gallerySlides.length > 1;
const areaValue = formatArea(data.details.area_m2, lang);

const ui = getUiCopy(lang);
const label = ui.propertyCard.viewDetails;
const galleryCopyByLang = {
  es: { prev: "Imagen anterior", next: "Imagen siguiente" },
  en: { prev: "Previous image", next: "Next image" },
  de: { prev: "Vorheriges Bild", next: "Naechstes Bild" },
  fr: { prev: "Image precedente", next: "Image suivante" },
  it: { prev: "Immagine precedente", next: "Immagine successiva" },
  nl: { prev: "Vorige afbeelding", next: "Volgende afbeelding" },
};
const galleryUi = galleryCopyByLang[lang] ?? galleryCopyByLang.es;
const compactLabelsByLang = {
  es: { bedrooms: "dorm.", bathrooms: "baños" },
  en: { bedrooms: "beds", bathrooms: "baths" },
  de: { bedrooms: "sz.", bathrooms: "bader" },
  fr: { bedrooms: "ch.", bathrooms: "sdb" },
  it: { bedrooms: "cam.", bathrooms: "bagni" },
  nl: { bedrooms: "slk.", bathrooms: "baden" },
};
const compactLabels = compactLabelsByLang[lang] ?? compactLabelsByLang.es;
const scarcityCopyByLang = {
  es: { one: "\u00DAltima unidad", many: "Quedan {count} unidades" },
  en: { one: "Last unit", many: "{count} units left" },
  de: { one: "Letzte Einheit", many: "Nur noch {count} Einheiten" },
  fr: { one: "Derniere unite", many: "Plus que {count} unites" },
  it: { one: "Ultima unita", many: "Restano {count} unita" },
  nl: { one: "Laatste unit", many: "Nog {count} units beschikbaar" },
};
const scarcityUi = scarcityCopyByLang[lang] ?? scarcityCopyByLang.es;
const compactSummary = [
  data.details.bedrooms ? `${data.details.bedrooms} ${compactLabels.bedrooms}` : null,
  data.details.bathrooms ? `${data.details.bathrooms} ${compactLabels.bathrooms}` : null,
  areaValue ? areaValue : null,
]
  .filter(Boolean)
  .join(" \u00B7 ");
const scarcityLabel =
  data.shouldHighlightScarcity && typeof data.availableUnitsCount === "number"
    ? data.availableUnitsCount === 1
      ? scarcityUi.one
      : scarcityUi.many.replace("{count}", String(data.availableUnitsCount))
    : "";
---

<article
  class:list={["property-card", compact && "is-compact", data.shouldHighlightScarcity && "is-scarcity"]}
  data-map-property-id={String(data.id ?? "")}
  data-map-property-slug={String(data.slug ?? "")}
  data-map-property-href={`/${lang}/property/${data.slug}/`}
>
  <div class="card-image" data-gallery-size={gallerySlides.length}>
    {gallerySlides.length > 0 ? (
      <div class="card-gallery" data-gallery-index="0">
        <div class="card-gallery-track">
          {gallerySlides.map((slide) => (
            <a href={`/${lang}/property/${data.slug}`} aria-label={data.title} class="card-gallery-slide">
              <img
                src={slide.src}
                srcset={slide.srcSet || undefined}
                sizes={compact ? "(max-width: 768px) 88vw, (max-width: 1200px) 32vw, 280px" : "(max-width: 768px) 92vw, (max-width: 1200px) 46vw, 380px"}
                width="720"
                height="540"
                data-fallback-src={slide.url}
                onerror="if(!this.dataset.fallbackApplied){this.dataset.fallbackApplied='1';this.src=this.dataset.fallbackSrc||this.src;this.srcset='';}"
                alt={slide.alt}
                loading="lazy"
                decoding="async"
              />
            </a>
          ))}
        </div>

        {hasGalleryControls && (
          <>
            <button
              type="button"
              class="card-gallery-nav is-prev"
              aria-label={galleryUi.prev}
              onclick="window.__advancePropertyCard?.(this.closest('.card-gallery'), -1); return false;"
            >
              <span aria-hidden="true">&#8249;</span>
            </button>
            <button
              type="button"
              class="card-gallery-nav is-next"
              aria-label={galleryUi.next}
              onclick="window.__advancePropertyCard?.(this.closest('.card-gallery'), 1); return false;"
            >
              <span aria-hidden="true">&#8250;</span>
            </button>
            <div class="card-gallery-dots" aria-hidden="true">
              {gallerySlides.map((_, index) => (
                <span class:list={["card-gallery-dot", index === 0 && "is-active"]}></span>
              ))}
            </div>
          </>
        )}
      </div>
    ) : (
      <div class="no-image-placeholder"></div>
    )}

    {data.isPromotion && (
      <span class="badge-promotion">
        {ui.propertyCard.newBuild}
      </span>
    )}

    {scarcityLabel && (
      <span class="badge-scarcity">
        {scarcityLabel}
      </span>
    )}
  </div>

  <div class="card-content">
    <header class="header">
      <h3 class="title">
        <a href={`/${lang}/property/${data.slug}`}>
          {data.title}
        </a>
      </h3>

      {data.location?.line && <p class="card-location">{data.location.line}</p>}

      <div class="price-row">
        {data.isPromotion ? (
          data.priceFrom && (
            <p class="price">
              {ui.propertyCard.fromPrice} {formatPrice(data.priceFrom, data.currency, lang)}
            </p>
          )
        ) : (
          data.price && (
            <p class="price">
              {formatPrice(data.price, data.currency, lang)}
            </p>
          )
        )}
      </div>
    </header>

    {!compact && !data.isPromotion && (
      <ul class="meta">
        {data.details.bedrooms && (
          <li class="meta-item">
            <span class="meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M3 12h18v6H3z" />
                <path d="M7 12V9a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3" />
                <path d="M3 18v3M21 18v3" />
              </svg>
            </span>
            <span class="meta-value">{data.details.bedrooms}</span>
          </li>
        )}

        {data.details.bathrooms && (
          <li class="meta-item">
            <span class="meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M4 12h16v3a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4v-3z" />
                <path d="M8 12V8a2 2 0 0 1 4 0v4" />
              </svg>
            </span>
            <span class="meta-value">{data.details.bathrooms}</span>
          </li>
        )}

        {areaValue && (
          <li class="meta-item">
            <span class="meta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M5 5h5M5 5v5M19 5h-5M19 5v5M5 19h5M5 19v-5M19 19h-5M19 19v-5" />
              </svg>
            </span>
            <span class="meta-value">{areaValue}</span>
          </li>
        )}
      </ul>
    )}

    {compact && compactSummary && <p class="compact-meta">{compactSummary}</p>}

    {!compact && data.features.length > 0 && (
      <div class="features">
        {data.features.slice(0, 3).map((f) => (
          <FeatureBadge icon={f.icon} label={f.label} />
        ))}
        {data.features.length > 3 && (
          <span class="more-features">+{data.features.length - 3}</span>
        )}
      </div>
    )}

    <div class="card-actions">
      <a href={`/${lang}/property/${data.slug}`} class="btn-card">{label}</a>
    </div>
  </div>
</article>

<script>
  import "@webapp/scripts/property-card";
</script>
