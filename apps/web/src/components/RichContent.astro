---
const { blocks } = Astro.props;
---

{Array.isArray(blocks) &&
  blocks.map((block, index) => {
    if (!block || !block.type) {
      return null;
    }

    if (block.type === "heading" && block.content) {
      if (block.level === 2) {
        return <h2 key={index} set:html={block.content}></h2>;
      }
      return <h3 key={index} set:html={block.content}></h3>;
    }

    if (block.type === "paragraph" && block.content) {
      return <p key={index} set:html={block.content}></p>;
    }

    if (block.type === "list") {
      if (!Array.isArray(block.items)) {
        return (
          <pre key={index} style="color:red">
            LIST MAL FORMADA EN BLOQUE {index}
          </pre>
        );
      }

      return (
        <ul key={index}>
          {block.items.map((text, i) => (
            <li key={`${index}-${i}`} set:html={text}></li>
          ))}
        </ul>
      );
    }

    if (block.type === "table" && Array.isArray(block.headers) && Array.isArray(block.rows)) {
      return (
        <div key={index} class="rich-content-table-wrap">
          <table class="rich-content-table">
            <thead>
              <tr>
                {block.headers.map((header, i) => (
                  <th key={`${index}-head-${i}`} set:html={header}></th>
                ))}
              </tr>
            </thead>
            <tbody>
              {block.rows.map((row, rowIndex) => (
                <tr key={`${index}-row-${rowIndex}`}>
                  {Array.isArray(row) &&
                    row.map((cell, cellIndex) => (
                      <td key={`${index}-cell-${rowIndex}-${cellIndex}`} set:html={cell}></td>
                    ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      );
    }

    if (block.type === "links" && Array.isArray(block.items)) {
      return (
        <ul key={index} class="rich-content-links">
          {block.items.map((item, i) => (
            <li key={`${index}-${i}`}>
              <a href={item.url} target="_blank" rel="noreferrer">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      );
    }

    if (block.type === "image" && block.url) {
      return (
        <figure key={index} class="rich-content-figure">
          <img src={block.url} alt={block.alt ?? ""} loading="lazy" />
        </figure>
      );
    }

    if (block.type === "caption" && block.content) {
      return <p key={index} class="rich-content-caption" set:html={block.content}></p>;
    }

    return null;
  })}
