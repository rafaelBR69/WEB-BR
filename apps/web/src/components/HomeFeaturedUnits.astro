---
import PropertyCard from "@webapp/components/PropertyCard.astro";
import homePageContent from "@shared/data/pages/home.json";

const {
  lang,
  cards = [],
  viewAllHref = "",
  viewAllLabel = "",
  disableAutoplayOnMobile = false,
} = Astro.props;
const homeContent = homePageContent as Record<string, any>;
const t = homeContent.featuredUnitsByLang[lang] ?? homeContent.featuredUnitsByLang.es;
---

{cards.length > 0 && (
  <section class="home-featured-units" aria-labelledby="homeFeaturedUnitsTitle">
    <div class="container">
      <div class="home-units-section-head">
        <div class="home-editorial-section-head">
          <p class="home-editorial-section-kicker">{t.eyebrow}</p>
          <h2 id="homeFeaturedUnitsTitle" class="home-editorial-section-title">{t.title}</h2>
          <p class="home-editorial-section-text">{t.intro}</p>
        </div>
        {viewAllHref && viewAllLabel && (
          <a href={viewAllHref} class="home-units-view-all">
            {viewAllLabel}
          </a>
        )}
      </div>

      <div
        class="home-units-carousel"
        data-home-units-carousel
        data-disable-autoplay-on-mobile={disableAutoplayOnMobile ? "true" : "false"}
      >
        <div class="home-units-stage">
          <button
            type="button"
            class="home-units-arrow"
            data-home-units-prev
            aria-label={t.prev}
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
              <path d="M14.5 5.5 8 12l6.5 6.5"></path>
            </svg>
          </button>
          <button
            type="button"
            class="home-units-arrow"
            data-home-units-next
            aria-label={t.next}
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
              <path d="M9.5 5.5 16 12l-6.5 6.5"></path>
            </svg>
          </button>

          <div class="home-units-viewport" data-home-units-viewport tabindex="0">
            <div class="home-units-track" data-home-units-track>
              {cards.map((card) => (
                <div class="home-units-slide">
                  <PropertyCard
                    data={card}
                    lang={lang}
                    maxGallerySlides={1}
                    compact={true}
                    disableSrcSet={true}
                  />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<script is:inline>
  (() => {
    const carousel = document.querySelector("[data-home-units-carousel]");
    if (!(carousel instanceof HTMLElement) || carousel.dataset.bound === "true") return;
    carousel.dataset.bound = "true";

    const viewport = carousel.querySelector("[data-home-units-viewport]");
    const track = carousel.querySelector("[data-home-units-track]");
    const prevButton = carousel.querySelector("[data-home-units-prev]");
    const nextButton = carousel.querySelector("[data-home-units-next]");
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const BREAKPOINTS = {
      xs: 480,
      md: 768,
      lg: 1024,
      xl: 1280,
    };
    const SWIPE_THRESHOLD = 48;
    const mobileViewport = window.matchMedia(`(max-width: ${BREAKPOINTS.md - 1}px)`);
    const disableAutoplayOnMobile = carousel.dataset.disableAutoplayOnMobile === "true";
    const CONTINUOUS_SPEED = 28;
    const MANUAL_RESUME_DELAY = 1400;

    if (!(viewport instanceof HTMLElement) || !(track instanceof HTMLElement)) return;

    let originalSlides = Array.from(track.children).filter((node) =>
      node instanceof HTMLElement && node.classList.contains("home-units-slide")
    );
    if (originalSlides.length <= 1) return;

    let rafId = 0;
    let lastTimestamp = 0;
    let loopWidth = 0;
    let paused = false;
    let manualResumeTimer = 0;
    let touchStartX = 0;
    let touchStartY = 0;

    const getPageSize = () => {
      if (window.innerWidth >= BREAKPOINTS.xl) return 5;
      if (window.innerWidth >= BREAKPOINTS.lg) return 4;
      if (window.innerWidth >= BREAKPOINTS.md) return 3;
      if (window.innerWidth >= BREAKPOINTS.xs) return 2;
      return 1;
    };

    const shouldLoop = () =>
      !prefersReducedMotion.matches &&
      originalSlides.length > getPageSize() &&
      !(disableAutoplayOnMobile && mobileViewport.matches);

    const syncButtons = () => {
      const disabled = originalSlides.length <= getPageSize();
      if (prevButton instanceof HTMLButtonElement) prevButton.disabled = disabled;
      if (nextButton instanceof HTMLButtonElement) nextButton.disabled = disabled;
    };

    const clearClones = () => {
      Array.from(track.querySelectorAll("[data-home-units-clone='true']")).forEach((node) => node.remove());
    };

    const buildClones = () => {
      clearClones();
      if (!shouldLoop()) {
        loopWidth = 0;
        carousel.classList.remove("is-marquee");
        return;
      }

      originalSlides.forEach((slide) => {
        if (!(slide instanceof HTMLElement)) return;
        const clone = slide.cloneNode(true);
        if (!(clone instanceof HTMLElement)) return;
        clone.dataset.homeUnitsClone = "true";
        clone.classList.add("is-clone");
        clone.setAttribute("aria-hidden", "true");
        clone.setAttribute("inert", "");
        track.appendChild(clone);
      });

      carousel.classList.add("is-marquee");
      loopWidth = track.scrollWidth / 2;
      if (loopWidth > 0) {
        viewport.scrollLeft = viewport.scrollLeft % loopWidth;
      }
    };

    const normalizeScroll = () => {
      if (!loopWidth) return;
      if (viewport.scrollLeft >= loopWidth) {
        viewport.scrollLeft -= loopWidth;
      } else if (viewport.scrollLeft < 0) {
        viewport.scrollLeft += loopWidth;
      }
    };

    const getStepSize = () => {
      const first = originalSlides[0];
      const second = originalSlides[1];
      if (first instanceof HTMLElement && second instanceof HTMLElement) {
        return second.offsetLeft - first.offsetLeft;
      }
      if (first instanceof HTMLElement) {
        return first.getBoundingClientRect().width;
      }
      return viewport.clientWidth * 0.72;
    };

    const stopAnimation = () => {
      if (rafId) {
        window.cancelAnimationFrame(rafId);
        rafId = 0;
      }
      lastTimestamp = 0;
    };

    const tick = (timestamp) => {
      if (!shouldLoop() || paused) {
        lastTimestamp = timestamp;
        rafId = window.requestAnimationFrame(tick);
        return;
      }

      if (!lastTimestamp) lastTimestamp = timestamp;
      const delta = Math.min(48, timestamp - lastTimestamp);
      lastTimestamp = timestamp;
      viewport.scrollLeft += (CONTINUOUS_SPEED * delta) / 1000;
      normalizeScroll();
      rafId = window.requestAnimationFrame(tick);
    };

    const startAnimation = () => {
      stopAnimation();
      if (!shouldLoop()) return;
      rafId = window.requestAnimationFrame(tick);
    };

    const pause = () => {
      paused = true;
      window.clearTimeout(manualResumeTimer);
    };

    const resume = () => {
      paused = false;
      window.clearTimeout(manualResumeTimer);
    };

    const resumeAfterManualInteraction = () => {
      pause();
      window.clearTimeout(manualResumeTimer);
      if (!shouldLoop()) return;
      manualResumeTimer = window.setTimeout(() => {
        paused = false;
      }, MANUAL_RESUME_DELAY);
    };

    const scrollByStep = (direction) => {
      const step = getStepSize();
      viewport.scrollBy({
        left: step * direction,
        behavior: "smooth",
      });
      window.setTimeout(normalizeScroll, 420);
    };

    const refreshLoop = () => {
      originalSlides = Array.from(track.children).filter((node) =>
        node instanceof HTMLElement &&
        node.classList.contains("home-units-slide") &&
        node.dataset.homeUnitsClone !== "true"
      );
      buildClones();
      syncButtons();
      startAnimation();
    };

    if (prevButton instanceof HTMLButtonElement) {
      prevButton.addEventListener("click", () => {
        scrollByStep(-1);
        resumeAfterManualInteraction();
      });
    }

    if (nextButton instanceof HTMLButtonElement) {
      nextButton.addEventListener("click", () => {
        scrollByStep(1);
        resumeAfterManualInteraction();
      });
    }

    carousel.addEventListener("mouseenter", pause);
    carousel.addEventListener("mouseleave", resume);
    carousel.addEventListener("focusin", pause);
    carousel.addEventListener("focusout", (event) => {
      const nextTarget = event.relatedTarget;
      if (!(nextTarget instanceof Node) || !carousel.contains(nextTarget)) {
        resume();
      }
    });

    viewport.addEventListener("touchstart", (event) => {
      const touch = event.changedTouches?.[0];
      if (!touch) return;
      touchStartX = touch.clientX;
      touchStartY = touch.clientY;
    }, { passive: true });

    viewport.addEventListener("touchend", (event) => {
      const touch = event.changedTouches?.[0];
      if (!touch) return;
      const deltaX = touch.clientX - touchStartX;
      const deltaY = touch.clientY - touchStartY;
      if (Math.abs(deltaX) <= SWIPE_THRESHOLD || Math.abs(deltaX) <= Math.abs(deltaY)) return;
      scrollByStep(deltaX < 0 ? 1 : -1);
      resumeAfterManualInteraction();
    }, { passive: true });

    window.addEventListener("resize", () => {
      refreshLoop();
    });
    mobileViewport.addEventListener?.("change", refreshLoop);
    prefersReducedMotion.addEventListener?.("change", refreshLoop);

    refreshLoop();
  })();
</script>
