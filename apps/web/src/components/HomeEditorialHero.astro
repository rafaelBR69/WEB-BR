    availableLabel: "Disponibles",
    soldLabel: "Vendidas",
    progressLabel: "Seleccionar proyecto destacado",
    detailLabel: "Promocion activa",
    prev: "Proyecto anterior",
    next: "Proyecto siguiente",
  },
