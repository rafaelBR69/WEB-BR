    detailLabel: "Active development",
    prev: "Previous project",
    next: "Next project",
  },
  de: {
    eyebrow: "BlancaReal Group",
    heading: "Der Luxus-Marktplatz der Costa del Sol",
    text:
      "Eigene Projekte, Premium-Vermarktung und integrierte Rechtsbegleitung fuer Kaeufer und Investoren.",
    primaryCta: "Projekt ansehen",
