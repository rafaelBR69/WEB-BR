---
import "@webapp/styles/base.css";
import "@webapp/styles/layout.css";
import { DEFAULT_LANG, LANG_LABELS, SUPPORTED_LANGS } from "@shared/i18n/languages";
import { getUiCopy } from "@shared/i18n/ui";
import BrandLogo from "@webapp/components/BrandLogo.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import manropeRegularFontUrl from "@fontsource/manrope/files/manrope-latin-400-normal.woff2?url";
import manropeSemiboldFontUrl from "@fontsource/manrope/files/manrope-latin-600-normal.woff2?url";
import cormorantSemiboldFontUrl from "@fontsource/cormorant-garamond/files/cormorant-garamond-latin-600-normal.woff2?url";

const {
  title = "BlancaReal",
  description = "",
  noindex = false,
  lang = DEFAULT_LANG,
  og = {},
  preloadImageUrl = "",
  preloadImageType = "",
  structuredData = [],
  availableLangs,
  headerVariant = "default",
  landingNavItems = [],
  landingNavGroups = [],
  headerNavItems = [],
  sideMenuSections: sideMenuSectionsProp = [],
  showMobileStickyCta = true,
  mobileStickyCta,
  landingHeaderOverlay = false,
  landingHeaderSolid = false,
  enableLightbox = false,
  enablePublicRealtime = false,
  preloadSmoothyFont = false,
} = Astro.props;

const SITE_URL = "https://blancareal.com";
const DEFAULT_OG_IMAGE =
  "https://gslfgcqwmcircqaslzij.supabase.co/storage/v1/object/public/properties/PM0079/cover/1.webp";
const localizedDefaultDescriptionByLang = {
  es: "BlancaReal: inmobiliaria, asesoramiento legal y comercialización en Costa del Sol.",
  en: "BlancaReal: real estate, legal advisory and commercialization on Costa del Sol.",
  de: "BlancaReal: Immobilien, Rechtsberatung und Vermarktung an der Costa del Sol.",
  fr: "BlancaReal : immobilier, conseil juridique et commercialisation sur la Costa del Sol.",
  it: "BlancaReal: real estate, consulenza legale e commercializzazione in Costa del Sol.",
  nl: "BlancaReal: vastgoed, juridisch advies en commercialisatie aan de Costa del Sol.",
};
const langFlagSrcByCode = {
  es: "/flags/es.svg",
  en: "/flags/gb.svg",
  de: "/flags/de.svg",
  fr: "/flags/fr.svg",
  it: "/flags/it.svg",
  nl: "/flags/nl.svg",
};

const currentUrl = Astro.url;
const canonicalPath = currentUrl.pathname;

const canonicalUrl = `${SITE_URL}${canonicalPath}`;

const resolveLangs = () => {
  const list = Array.isArray(availableLangs) && availableLangs.length
    ? availableLangs
    : [lang];
  const unique = Array.from(new Set(list));
  if (!unique.includes(lang)) {
    unique.unshift(lang);
  }
  const sorted = SUPPORTED_LANGS.filter((code) => unique.includes(code));
  return sorted.length ? sorted : [lang];
};

const buildLangPath = (targetLang) => {
  const parts = canonicalPath.split("/").filter(Boolean);
  const hasLangPrefix = parts.length > 0 && SUPPORTED_LANGS.includes(parts[0]);
  if (hasLangPrefix) {
    parts[0] = targetLang;
    const base = `/${parts.join("/")}`;
    const suffix = canonicalPath.endsWith("/") ? "/" : "";
    return `${base}${suffix}${currentUrl.search}`;
  }
  return `/${targetLang}/`;
};

const buildLangCanonicalPath = (targetLang) => {
  const parts = canonicalPath.split("/").filter(Boolean);
  const hasLangPrefix = parts.length > 0 && SUPPORTED_LANGS.includes(parts[0]);
  if (hasLangPrefix) {
    parts[0] = targetLang;
    const base = `/${parts.join("/")}`;
    const suffix = canonicalPath.endsWith("/") ? "/" : "";
    return `${base}${suffix}`;
  }
  return `/${targetLang}/`;
};

const langLinks = resolveLangs().map((code) => ({
  code,
  label: LANG_LABELS[code] ?? String(code).toUpperCase(),
  href: buildLangPath(code),
  canonicalHref: `${SITE_URL}${buildLangCanonicalPath(code)}`,
  flagSrc: langFlagSrcByCode[code] ?? "/flags/es.svg",
  isActive: code === lang,
}));
const activeLang = langLinks.find((item) => item.isActive) ?? langLinks[0];
const ui = getUiCopy(lang);
const defaultMobileStickyCta = showMobileStickyCta
  ? {
      primary: {
        href: "tel:+34952599159",
        label: ui.layout.call,
        variant: "call",
      },
      secondary: {
        href: "#descContainer",
        label: ui.layout.contact,
        variant: "contact",
        id: "mobileContactBtn",
      },
    }
  : false;
const resolvedMobileStickyCta =
  mobileStickyCta === false
    ? false
    : mobileStickyCta && typeof mobileStickyCta === "object"
      ? mobileStickyCta
      : defaultMobileStickyCta;
const hasMobileStickyCta = Boolean(resolvedMobileStickyCta);
const langAlternateLinks = resolveLangs().map((code) => ({
  code,
  href: `${SITE_URL}${buildLangCanonicalPath(code)}`,
}));
const defaultLangAlternateHref = `${SITE_URL}${buildLangCanonicalPath(DEFAULT_LANG)}`;
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData.filter(Boolean)
  : structuredData
    ? [structuredData]
    : [];
const resolvedDescription =
  String(description ?? "").trim() ||
  localizedDefaultDescriptionByLang[lang as keyof typeof localizedDefaultDescriptionByLang] ||
  localizedDefaultDescriptionByLang.es;
const resolvedOgImage = og.image ?? DEFAULT_OG_IMAGE;

const ogLocaleMap = {
  es: "es_ES",
  en: "en_GB",
  fr: "fr_FR",
  it: "it_IT",
  de: "de_DE",
  nl: "nl_NL",
};

const isLandingHeader = headerVariant === "landing";

const normalizePath = (value) => {
  const path = String(value ?? "");
  if (!path) return "/";
  return path.endsWith("/") ? path : `${path}/`;
};

const isActiveHref = (href) => {
  if (typeof href !== "string" || !href.startsWith("/")) return false;
  const current = normalizePath(canonicalPath);
  const cleanHref = href.split("?")[0]?.split("#")[0] ?? href;
  const target = normalizePath(cleanHref);
  const propertiesPath = normalizePath(`/${lang}/properties/`);
  const propertyDetailPath = normalizePath(`/${lang}/property/`);
  const postsPath = normalizePath(`/${lang}/posts/`);
  const postDetailPath = normalizePath(`/${lang}/post/`);
  const aboutPath = normalizePath(`/${lang}/about/`);
  const agentsPath = normalizePath(`/${lang}/agents/`);
  const legalServicesPath = normalizePath(`/${lang}/legal-services/`);
  const legalDocsPath = normalizePath(`/${lang}/legal/`);
  if (target === `/${lang}/`) {
    return current === target;
  }
  if (target === propertiesPath && current.startsWith(propertyDetailPath)) {
    return true;
  }
  if (target === postsPath && current.startsWith(postDetailPath)) {
    return true;
  }
  if (target === aboutPath && current.startsWith(agentsPath)) {
    return true;
  }
  if (target === legalServicesPath && current.startsWith(legalDocsPath)) {
    return true;
  }
  return current.startsWith(target);
};

const isMenuItemActive = (item) =>
  isActiveHref(item.href) ||
  (Array.isArray(item.children) && item.children.some((child) => isActiveHref(child.href))) ||
  (Array.isArray(item.sections) &&
    item.sections.some(
      (section) => Array.isArray(section.items) && section.items.some((entry) => isActiveHref(entry.href))
    ));

const defaultLandingNavItems = [
  { href: `/${lang}/portal/`, label: ui.layout.navForAgents },
  { href: `/${lang}/commercialization/`, label: ui.layout.navPromoters },
];

const utilityNavItems = [
  { href: `/${lang}/sell-with-us/`, label: ui.layout.navSellWithUs },
  { href: `/${lang}/portal/`, label: ui.layout.navForAgents },
  { href: `/${lang}/contact/`, label: ui.layout.navContact },
];

const resolvedLandingNavItems =
  Array.isArray(landingNavItems) && landingNavItems.length
    ? landingNavItems
    : defaultLandingNavItems;
const resolvedLandingNavGroups = Array.isArray(landingNavGroups) ? landingNavGroups : [];

const defaultHeaderNavItems = [
  { href: `/${lang}/properties/`, label: ui.layout.navRealEstate },
  { href: `/${lang}/commercialization/`, label: ui.layout.navCommercialization },
  { href: `/${lang}/legal-services/`, label: ui.layout.navLegalServices },
  { href: `/${lang}/contact/`, label: ui.layout.navContact },
];

const resolvedHeaderNavItems =
  Array.isArray(headerNavItems) && headerNavItems.length
    ? headerNavItems
    : defaultHeaderNavItems;

const realEstateSubmenuCopyByLang = {
  es: {
    allProperties: "Todas las propiedades",
    exclusiveProjects: "Proyectos exclusivos de BlancaReal",
    resale: "Segunda mano",
    sellWithUs: "Vende con nosotros",
  },
  en: {
    allProperties: "All properties",
    exclusiveProjects: "BlancaReal exclusive projects",
    resale: "Resale",
    sellWithUs: "Sell with us",
  },
  de: {
    allProperties: "Alle Immobilien",
    exclusiveProjects: "Exklusive BlancaReal-Projekte",
    resale: "Bestand",
    sellWithUs: "Mit uns verkaufen",
  },
  fr: {
    allProperties: "Toutes les proprietes",
    exclusiveProjects: "Programmes exclusifs de BlancaReal",
    resale: "Revente",
    sellWithUs: "Vendez avec nous",
  },
  it: {
    allProperties: "Tutte le proprieta",
    exclusiveProjects: "Progetti esclusivi di BlancaReal",
    resale: "Usato",
    sellWithUs: "Vendi con noi",
  },
  nl: {
    allProperties: "Alle woningen",
    exclusiveProjects: "Exclusieve projecten van BlancaReal",
    resale: "Bestaande bouw",
    sellWithUs: "Verkoop met ons",
  },
} as const;

const realEstateSubmenuCopy =
  realEstateSubmenuCopyByLang[lang as keyof typeof realEstateSubmenuCopyByLang] ??
  realEstateSubmenuCopyByLang.es;

const realEstateSubmenuItems = [
  { href: `/${lang}/properties/`, label: realEstateSubmenuCopy.allProperties },
  { href: `/${lang}/projects/`, label: realEstateSubmenuCopy.exclusiveProjects },
  { href: `/${lang}/properties/?market=segunda_mano`, label: realEstateSubmenuCopy.resale },
  { href: `/${lang}/sell-with-us/`, label: realEstateSubmenuCopy.sellWithUs },
];

const resolvedHeaderDesktopItems = resolvedHeaderNavItems.map((item) =>
  item.href === `/${lang}/properties/`
    ? {
        ...item,
        sections: [
          {
            title: "",
            items: realEstateSubmenuItems,
          },
        ],
      }
    : item,
);

const menuSectionCopyByLang = {
  es: {
    relationshipTitle: "Para agentes y clientes particulares",
    contentTitle: "Revista BlancaReal",
    socialLabel: "Nuestras redes sociales",
    socialHint: "Instagram, LinkedIn y contenidos de BlancaReal",
  },
  en: {
    relationshipTitle: "For agents and private clients",
    contentTitle: "BlancaReal Magazine",
    socialLabel: "Our social networks",
    socialHint: "Instagram, LinkedIn and BlancaReal content",
  },
  de: {
    relationshipTitle: "Fuer Agenten und Privatkunden",
    contentTitle: "BlancaReal Magazin",
    socialLabel: "Unsere sozialen Netzwerke",
    socialHint: "Instagram, LinkedIn und Inhalte von BlancaReal",
  },
  fr: {
    relationshipTitle: "Pour agents et clients particuliers",
    contentTitle: "Magazine BlancaReal",
    socialLabel: "Nos reseaux sociaux",
    socialHint: "Instagram, LinkedIn et contenus BlancaReal",
  },
  it: {
    relationshipTitle: "Per agenti e clienti privati",
    contentTitle: "Rivista BlancaReal",
    socialLabel: "I nostri social",
    socialHint: "Instagram, LinkedIn e contenuti BlancaReal",
  },
  nl: {
    relationshipTitle: "Voor agenten en particuliere klanten",
    contentTitle: "BlancaReal Magazine",
    socialLabel: "Onze sociale netwerken",
    socialHint: "Instagram, LinkedIn en BlancaReal-content",
  },
} as const;

const menuSectionCopy =
  menuSectionCopyByLang[lang as keyof typeof menuSectionCopyByLang] ?? menuSectionCopyByLang.es;

const defaultSideMenuSections = [
  {
    title: ui.layout.menuMain,
    items: [
      { href: `/${lang}/`, label: ui.layout.navHome },
      {
        href: `/${lang}/properties/`,
        label: ui.layout.navRealEstate,
        description: ui.layout.menuRealEstateHint,
        children: realEstateSubmenuItems,
      },
    ],
  },
  {
    title: ui.layout.menuServices,
    items: [
      { href: `/${lang}/commercialization/`, label: ui.layout.navCommercialization, description: ui.layout.menuPromotersHint },
      { href: `/${lang}/legal-services/`, label: ui.layout.navLegalServices, description: ui.layout.menuLegalHint },
      { href: `/${lang}/marketing-3d/`, label: "Marketing 3D", description: ui.layout.menuMarketingHint },
    ],
  },
  {
    title: menuSectionCopy.relationshipTitle,
    items: [
      { href: `/${lang}/sell-with-us/`, label: ui.layout.navSellWithUs, description: ui.layout.menuSellWithUsHint },
      { href: `/${lang}/portal/`, label: ui.layout.navForAgents, description: ui.layout.menuAgentsHint },
      { href: `/${lang}/contact/`, label: ui.layout.navContact, description: ui.layout.menuContactHint },
    ],
  },
  {
    title: menuSectionCopy.contentTitle,
    items: [
      { href: `/${lang}/posts/`, label: ui.layout.navPosts, description: ui.layout.menuBlogHint },
      { href: `/${lang}/#home-social-hub`, label: menuSectionCopy.socialLabel, description: menuSectionCopy.socialHint },
      { href: `/${lang}/about/`, label: ui.layout.navAbout, description: ui.layout.menuAboutHint },
    ],
  },
];

const resolvedSideMenuSections =
  Array.isArray(sideMenuSectionsProp) && sideMenuSectionsProp.length
    ? sideMenuSectionsProp
    : defaultSideMenuSections;

const realtimeOrganizationId =
  String(import.meta.env.PUBLIC_CRM_ORGANIZATION_ID ?? import.meta.env.CRM_ORGANIZATION_ID ?? "").trim() || null;

const publicRealtimeConfig = {
  enabled: Boolean(enablePublicRealtime),
  supabaseUrl: String(import.meta.env.PUBLIC_SUPABASE_URL ?? "").trim(),
  anonKey: String(import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "").trim(),
  organizationId: realtimeOrganizationId,
  debounceMs: 900,
  refreshTimeoutMs: 10000,
};

const shouldLoadPublicRealtime =
  publicRealtimeConfig.enabled &&
  Boolean(publicRealtimeConfig.supabaseUrl) &&
  Boolean(publicRealtimeConfig.anonKey);
const cookieYesSiteId = String(
  import.meta.env.PUBLIC_COOKIEYES_SITE_ID ??
  import.meta.env.PUBLIC_COOKIEYES_ID ??
  ""
).trim();
const shouldLoadCookieYes = Boolean(cookieYesSiteId);
const cookieYesScriptUrl = shouldLoadCookieYes
  ? `https://cdn-cookieyes.com/client_data/${cookieYesSiteId}/script.js`
  : "";
const isPortalPage = /\/portal(\/|$)/.test(currentUrl.pathname);

if (!isPortalPage && !Astro.response.headers.has("Cache-Control")) {
  Astro.response.headers.set("Cache-Control", "public, max-age=0, s-maxage=300, stale-while-revalidate=86400");
}
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="preconnect" href="https://gslfgcqwmcircqaslzij.supabase.co" crossorigin />
    <link rel="dns-prefetch" href="https://gslfgcqwmcircqaslzij.supabase.co" />
    <link rel="preload" as="font" type="font/woff2" href={manropeRegularFontUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={manropeSemiboldFontUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={cormorantSemiboldFontUrl} crossorigin />
    {preloadSmoothyFont && (
      <link rel="preload" as="font" type="font/woff2" href="/fonts/smoothy-sans-regular.woff2" crossorigin />
    )}
    {shouldLoadCookieYes && (
      <>
        <link rel="preconnect" href="https://cdn-cookieyes.com" crossorigin />
        <link rel="dns-prefetch" href="https://cdn-cookieyes.com" />
      </>
    )}
    {preloadImageUrl && (
      <link
        rel="preload"
        as="image"
        href={preloadImageUrl}
        type={preloadImageType || undefined}
        fetchpriority="high"
      />
    )}
    <link rel="icon" type="image/x-icon" href="/logos/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/logos/favicon.svg" />
    <link rel="icon" type="image/png" href="/logos/favicon-96x96.png" sizes="96x96" />
    <link rel="apple-touch-icon" href="/logos/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/logos/site.webmanifest" />

    <title>{title}</title>

    <meta name="description" content={resolvedDescription} />

    {noindex && (
      <meta name="robots" content="noindex,follow" />
    )}

    {canonicalUrl && (
      <link rel="canonical" href={canonicalUrl} />
    )}
    {langAlternateLinks.map((item) => (
      <link rel="alternate" hreflang={item.code} href={item.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={defaultLangAlternateHref} />

    <meta property="og:type" content={og.type ?? "website"} />

    {title && (
      <meta property="og:title" content={title} />
    )}

    <meta property="og:description" content={resolvedDescription} />

    {canonicalUrl && (
      <meta property="og:url" content={canonicalUrl} />
    )}

    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:image" content={resolvedOgImage} />
    {title && (
      <meta name="twitter:title" content={title} />
    )}
    <meta name="twitter:description" content={resolvedDescription} />

    <meta
      property="og:locale"
      content={ogLocaleMap[lang as keyof typeof ogLocaleMap] ?? "es_ES"}
    />

    <meta name="twitter:card" content="summary_large_image" />
    {shouldLoadCookieYes && (
      <script
        id="cookieyes"
        type="text/javascript"
        src={cookieYesScriptUrl}
      ></script>
    )}
    {structuredDataItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>

  <body
    class={hasMobileStickyCta ? "has-mobile-sticky-cta" : ""}
    data-cookie-consent-provider={shouldLoadCookieYes ? "cookieyes" : "none"}
  >
    <a class="skip-link" href="#mainContent">{ui.layout.skipToContent}</a>
    <div class="page-loader" aria-hidden="true">
      <div class="loader-ring"></div>
    </div>
    <header
      class={`main-header ${isLandingHeader ? "main-header-landing" : ""} ${landingHeaderOverlay ? "main-header-overlay" : ""} ${landingHeaderSolid ? "is-scrolled" : ""}`}
      data-landing-header={isLandingHeader ? "true" : undefined}
      data-landing-header-solid={landingHeaderSolid ? "true" : undefined}
    >
      <div class={`header-container ${isLandingHeader ? "header-container-landing" : ""}`}>
        <div class="brand-logo">
          {isLandingHeader ? (
            <>
              <a
                href={`/${lang}/`}
                class="brand-logo-element brand-logo-wordmark brand-logo-main landing-brand-logo"
                aria-label="BlancaReal"
              >
                <img
                  src="/logos/blancareal_logo_principal_blanco.png"
                  alt="BlancaReal"
                  width="182"
                  height="44"
                  loading="eager"
                  data-logo-switch
                  data-logo-light-src="/logos/blancareal_logo_principal_blanco.png"
                  data-logo-dark-src="/logos/blanca_real_logo_principal.png"
                />
              </a>
              <a
                href={`/${lang}/`}
                class="brand-logo-mobile-only landing-brand-logo-mobile"
                aria-label="BlancaReal"
              >
                <img
                  src="/logos/blancareal_logo_principal_blanco.png"
                  alt="BlancaReal"
                  width="182"
                  height="44"
                  loading="eager"
                  data-logo-switch
                  data-logo-light-src="/logos/blancareal_logo_principal_blanco.png"
                  data-logo-dark-src="/logos/blanca_real_logo_principal.png"
                />
              </a>
            </>
          ) : (
            <>
              <BrandLogo variant="wordmark" href={`/${lang}/`} class="brand-logo-main" />
              <a href={`/${lang}/`} class="brand-logo-mobile-only" aria-label="BlancaReal">
                <img
                  src="/logos/blanca_real_logo_principal.png"
                  alt="BlancaReal"
                  width="182"
                  height="44"
                  loading="eager"
                />
              </a>
            </>
          )}
        </div>

        {isLandingHeader ? (
          <>
            <div class="header-actions header-actions-landing">
              <nav class="header-utility-links desktop-only" aria-label="Utility navigation">
                {utilityNavItems.map((item) => (
                  <a href={item.href} class={`header-utility-link ${isActiveHref(item.href) ? "active" : ""}`}>
                    {item.label}
                  </a>
                ))}
              </nav>

              <div class="lang-switcher desktop-only">
                <span class="lang-switcher-label">{ui.layout.language}</span>
                <div class="lang-picker" id="langPickerLanding">
                  <button
                    type="button"
                    class="lang-trigger"
                    id="langTriggerLanding"
                    aria-expanded="false"
                    aria-controls="langMenuLanding"
                  >
                    <img src={activeLang.flagSrc} alt={activeLang.label} width="18" height="12" loading="lazy" />
                    <span id="langLabelLanding">{activeLang.code.toUpperCase()}</span>
                  </button>
                  <div class="lang-menu" id="langMenuLanding" hidden>
                    {langLinks.map((item) => (
                      <button
                        type="button"
                        class={`lang-option ${item.isActive ? "is-active" : ""}`}
                        data-href={item.href}
                        data-label={item.code.toUpperCase()}
                        title={item.label}
                        lang={item.code}
                      >
                        <img src={item.flagSrc} alt={item.label} width="18" height="12" loading="lazy" />
                        <span>{item.label}</span>
                      </button>
                    ))}
                  </div>
                </div>
              </div>

              <button
                class="side-menu-toggle"
                aria-label={ui.layout.openMenu}
                aria-expanded="false"
                aria-controls="sideMenu"
                id="sideMenuToggle"
              >
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
              </button>
            </div>
          </>
        ) : (
          <>
            <nav class="main-nav desktop-only">
              <ul class="nav-links">
                {resolvedHeaderDesktopItems.map((item) => (
                  <li class={Array.isArray(item.sections) && item.sections.length > 0 ? `landing-nav-group ${isMenuItemActive(item) ? "is-active" : ""}` : undefined}>
                    <a
                      href={item.href}
                      class={Array.isArray(item.sections) && item.sections.length > 0 ? `landing-nav-group-trigger ${isMenuItemActive(item) ? "active" : ""}` : isActiveHref(item.href) ? "active" : ""}
                    >
                      {item.label}
                    </a>
                    {Array.isArray(item.sections) && item.sections.length > 0 ? (
                      <div class="landing-nav-dropdown">
                        <div class="landing-nav-dropdown-grid">
                          {item.sections.map((section) => (
                            <section class="landing-nav-dropdown-section">
                              {section.title ? <p>{section.title}</p> : null}
                              <ul>
                                {section.items.map((entry) => (
                                  <li>
                                    <a href={entry.href} class={isActiveHref(entry.href) ? "active" : ""}>
                                      {entry.label}
                                    </a>
                                  </li>
                                ))}
                              </ul>
                            </section>
                          ))}
                        </div>
                      </div>
                    ) : null}
                  </li>
                ))}
              </ul>
            </nav>

            <div class="header-actions">
              <nav class="header-utility-links desktop-only" aria-label="Utility navigation">
                {utilityNavItems.map((item) => (
                  <a href={item.href} class={`header-utility-link ${isActiveHref(item.href) ? "active" : ""}`}>
                    {item.label}
                  </a>
                ))}
              </nav>

              <div class="lang-switcher desktop-only">
                <span class="lang-switcher-label">{ui.layout.language}</span>
                <div class="lang-picker" id="langPickerDesktop">
                  <button
                    type="button"
                    class="lang-trigger"
                    id="langTriggerDesktop"
                    aria-expanded="false"
                    aria-controls="langMenuDesktop"
                  >
                    <img src={activeLang.flagSrc} alt={activeLang.label} width="18" height="12" loading="lazy" />
                    <span id="langLabelDesktop">{activeLang.code.toUpperCase()}</span>
                  </button>
                  <div class="lang-menu" id="langMenuDesktop" hidden>
                    {langLinks.map((item) => (
                      <button
                        type="button"
                        class={`lang-option ${item.isActive ? "is-active" : ""}`}
                        data-href={item.href}
                        data-label={item.code.toUpperCase()}
                        title={item.label}
                        lang={item.code}
                      >
                        <img src={item.flagSrc} alt={item.label} width="18" height="12" loading="lazy" />
                        <span>{item.label}</span>
                      </button>
                    ))}
                  </div>
                </div>
              </div>
              <button
                class="side-menu-toggle"
                aria-label={ui.layout.openMenu}
                aria-expanded="false"
                aria-controls="sideMenu"
                id="sideMenuToggle"
              >
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
              </button>
            </div>
          </>
        )}
      </div>

      {isLandingHeader ? (
        <div class="landing-subnav desktop-only">
          <div class="landing-subnav-inner">
            {resolvedLandingNavGroups.length > 0 ? (
              <nav class="main-nav main-nav-landing-subnav landing-nav-groups-nav" aria-label="Landing navigation">
                <ul class="landing-nav-groups">
                  {resolvedLandingNavGroups.map((group) => (
                    <li class={`landing-nav-group ${isMenuItemActive(group) ? "is-active" : ""}`}>
                      <a
                        href={group.href}
                        class={`landing-nav-group-trigger ${isMenuItemActive(group) ? "active" : ""}`}
                      >
                        {group.label}
                      </a>
                      {Array.isArray(group.sections) && group.sections.length > 0 ? (
                        <div class="landing-nav-dropdown">
                          <div class="landing-nav-dropdown-grid">
                            {group.sections.map((section) => (
                              <section class="landing-nav-dropdown-section">
                                {section.title ? <p>{section.title}</p> : null}
                                <ul>
                                  {section.items.map((item) => (
                                    <li>
                                      <a href={item.href} class={isActiveHref(item.href) ? "active" : ""}>
                                        {item.label}
                                      </a>
                                    </li>
                                  ))}
                                </ul>
                              </section>
                            ))}
                          </div>
                        </div>
                      ) : null}
                    </li>
                  ))}
                </ul>
              </nav>
            ) : (
              <nav class="main-nav main-nav-landing-subnav">
                <ul class="nav-links nav-links-landing">
                  {resolvedLandingNavItems.map((item) => (
                    <li>
                      <a href={item.href} class={isActiveHref(item.href) ? "active" : ""}>
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            )}
          </div>
        </div>
      ) : null}

      <div class="side-menu-backdrop" id="sideMenuBackdrop" hidden></div>
      <aside class="side-menu-drawer" id="sideMenu" aria-hidden="true">
        <div class="side-menu-brand-watermark" aria-hidden="true">
          <BrandLogo variant="stacked" />
        </div>
        <div class="side-menu-head">
          <p>{ui.layout.menu}</p>
          <button type="button" id="sideMenuClose" aria-label={ui.layout.closeMenu}>
            {ui.layout.closeMenu}
          </button>
        </div>

        <nav class="side-menu-nav" aria-label={ui.layout.menu}>
          {resolvedSideMenuSections.map((section) => (
            <section class="side-menu-section">
              <h2>{section.title}</h2>
              <ul>
                {section.items.map((item) => (
                  <li>
                    <a href={item.href} class={isMenuItemActive(item) ? "active" : ""}>
                      <strong>{item.label}</strong>
                      {item.description && <small>{item.description}</small>}
                    </a>
                    {Array.isArray(item.children) && item.children.length > 0 && (
                      <ul class="side-submenu">
                        {item.children.map((child) => (
                          <li>
                            <a href={child.href} class={isActiveHref(child.href) ? "active" : ""}>
                              <strong>{child.label}</strong>
                            </a>
                          </li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </nav>

        <div class="side-menu-lang">
          <span class="lang-switcher-label">{ui.layout.language}</span>
          <ul class="side-menu-lang-list" aria-label={ui.layout.language}>
            {langLinks.map((item) => (
              <li lang={item.code}>
                <a
                  href={item.href}
                  hreflang={item.code}
                  lang={item.code}
                  class={`side-menu-lang-link ${item.isActive ? "is-active" : ""}`}
                  aria-current={item.isActive ? "page" : undefined}
                >
                  <img src={item.flagSrc} alt={item.label} width="18" height="12" loading="lazy" />
                  <span>{item.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </header>

    {hasMobileStickyCta && (
      <div class="mobile-sticky-cta">
        {resolvedMobileStickyCta?.primary && (
          <a
            href={resolvedMobileStickyCta.primary.href}
            class={`cta-item ${resolvedMobileStickyCta.primary.variant ?? "contact"}`}
            id={resolvedMobileStickyCta.primary.id}
          >
            {(resolvedMobileStickyCta.primary.variant ?? "contact") === "call" ? (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.28-2.28a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            ) : (resolvedMobileStickyCta.primary.variant ?? "contact") === "primary" ? (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            )}
            {resolvedMobileStickyCta.primary.label}
          </a>
        )}
        {resolvedMobileStickyCta?.secondary && (
          <a
            href={resolvedMobileStickyCta.secondary.href}
            class={`cta-item ${resolvedMobileStickyCta.secondary.variant ?? "contact"}`}
            id={resolvedMobileStickyCta.secondary.id}
          >
            {(resolvedMobileStickyCta.secondary.variant ?? "contact") === "call" ? (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.28-2.28a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            )}
            {resolvedMobileStickyCta.secondary.label}
          </a>
        )}
      </div>
    )}

    <script is:inline>
      const body = document.body;
      const landingHeader = document.querySelector("[data-landing-header='true']");
      const landingHeaderIsSolid = landingHeader?.getAttribute("data-landing-header-solid") === "true";
      const sideMenuToggle = document.getElementById("sideMenuToggle");
      const switchableLogos = Array.from(document.querySelectorAll("[data-logo-switch]"));
      const sideMenu = document.getElementById("sideMenu");
      const sideMenuBackdrop = document.getElementById("sideMenuBackdrop");
      const sideMenuClose = document.getElementById("sideMenuClose");
      let sideMenuLastFocus = null;

      const getSideMenuFocusable = () => {
        if (!(sideMenu instanceof HTMLElement)) return [];
        return Array.from(
          sideMenu.querySelectorAll(
            'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
          )
        );
      };

      const closeSideMenu = () => {
        if (!(sideMenu instanceof HTMLElement)) return;
        sideMenu.classList.remove("is-open");
        sideMenu.setAttribute("aria-hidden", "true");

        if (sideMenuBackdrop instanceof HTMLElement) {
          sideMenuBackdrop.classList.remove("is-open");
          sideMenuBackdrop.setAttribute("hidden", "");
        }

        if (sideMenuToggle instanceof HTMLElement) {
          sideMenuToggle.classList.remove("is-active");
          sideMenuToggle.setAttribute("aria-expanded", "false");
        }

        body.style.overflow = "";
        document.removeEventListener("keydown", handleSideMenuKeydown);
        if (sideMenuLastFocus instanceof HTMLElement) {
          sideMenuLastFocus.focus();
        }
      };

      const openSideMenu = () => {
        if (!(sideMenu instanceof HTMLElement) || !(sideMenuToggle instanceof HTMLElement)) return;
        sideMenuLastFocus = document.activeElement;
        sideMenu.classList.add("is-open");
        sideMenu.setAttribute("aria-hidden", "false");
        sideMenuToggle.classList.add("is-active");
        sideMenuToggle.setAttribute("aria-expanded", "true");

        if (sideMenuBackdrop instanceof HTMLElement) {
          sideMenuBackdrop.removeAttribute("hidden");
          sideMenuBackdrop.classList.add("is-open");
        }

        body.style.overflow = "hidden";
        const focusable = getSideMenuFocusable();
        if (focusable[0] instanceof HTMLElement) {
          focusable[0].focus();
        }
        document.addEventListener("keydown", handleSideMenuKeydown);
      };

      const handleSideMenuKeydown = (event) => {
        if (!(sideMenu instanceof HTMLElement)) return;

        if (event.key === "Escape") {
          event.preventDefault();
          closeSideMenu();
          return;
        }

        if (event.key !== "Tab") return;

        const focusable = getSideMenuFocusable();
        if (!focusable.length) return;

        const first = focusable[0];
        const last = focusable[focusable.length - 1];

        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
          return;
        }

        if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      };

      if (sideMenuToggle instanceof HTMLElement && sideMenu instanceof HTMLElement) {
        sideMenuToggle.addEventListener("click", () => {
          const isOpen = sideMenu.classList.contains("is-open");
          if (isOpen) {
            closeSideMenu();
          } else {
            closeSideMenu();
            openSideMenu();
          }
        });
      }

      if (sideMenuClose instanceof HTMLElement) {
        sideMenuClose.addEventListener("click", closeSideMenu);
      }

      if (sideMenuBackdrop instanceof HTMLElement) {
        sideMenuBackdrop.addEventListener("click", closeSideMenu);
      }

      if (sideMenu instanceof HTMLElement) {
        sideMenu.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", closeSideMenu);
        });
      }

      document.getElementById("mobileContactBtn")?.addEventListener("click", (event) => {
        event.preventDefault();
        const target = document.querySelector(".concierge-card");
        if (target instanceof HTMLElement) {
          target.scrollIntoView({ behavior: "smooth", block: "center" });
        }
      });

      const isSameOrigin = (link) => {
        try {
          return new URL(link.href).origin === window.location.origin;
        } catch {
          return false;
        }
      };

      const normalizeNavigationHref = (value) => {
        try {
          const url = new URL(value, window.location.href);
          url.hash = "";
          return url.toString();
        } catch {
          return "";
        }
      };

      const logNavigationDebug = (...args) => {
        if (!import.meta.env.DEV) return;
        console.debug("[nav-transition]", ...args);
      };

      let pageLeavingWatchdog = null;
      let pageLeavingHref = "";

      const clearPageLeavingWatchdog = () => {
        if (pageLeavingWatchdog !== null) {
          window.clearTimeout(pageLeavingWatchdog);
          pageLeavingWatchdog = null;
        }
      };

      const shouldSkipTransition = (link) => {
        if (!link || link.hasAttribute("download")) return true;
        if (link.target && link.target !== "_self") return true;
        if (link.rel && link.rel.includes("external")) return true;
        if (link.hasAttribute("data-no-page-transition")) return true;
        const href = link.getAttribute("href") || "";
        if (!href.trim()) return true;
        if (href.startsWith("#") || href.startsWith("mailto:") || href.startsWith("tel:")) return true;
        const isPropertiesManagedLink =
          link.closest(".properties-page") &&
          (href.startsWith("?") || href.includes("/properties/"));
        if (isPropertiesManagedLink) return true;
        const nextHref = normalizeNavigationHref(link.href);
        const currentHref = normalizeNavigationHref(window.location.href);
        if (!nextHref || nextHref === currentHref) return true;
        return !isSameOrigin(link);
      };

      const initLangPicker = (pickerId, triggerId, menuId, labelId) => {
        const picker = document.getElementById(pickerId);
        const trigger = document.getElementById(triggerId);
        const menu = document.getElementById(menuId);
        const label = document.getElementById(labelId);
        if (!picker || !trigger || !menu || !label) return;

        const updateMenuDirection = () => {
          picker.classList.remove("is-dropup");
          menu.removeAttribute("hidden");

          const triggerRect = trigger.getBoundingClientRect();
          const menuRect = menu.getBoundingClientRect();
          const spaceBelow = window.innerHeight - triggerRect.bottom;
          const spaceAbove = triggerRect.top;

          if (spaceBelow < menuRect.height + 12 && spaceAbove > spaceBelow) {
            picker.classList.add("is-dropup");
          }

          if (menu.hasAttribute("hidden")) return;
        };

        trigger.addEventListener("click", () => {
          const willOpen = menu.hasAttribute("hidden");
          if (willOpen) {
            menu.removeAttribute("hidden");
            updateMenuDirection();
          } else {
            menu.setAttribute("hidden", "");
            picker.classList.remove("is-dropup");
          }
          trigger.setAttribute("aria-expanded", String(willOpen));
        });

        menu.querySelectorAll(".lang-option").forEach((option) => {
          option.addEventListener("click", () => {
            const href = option.getAttribute("data-href");
            const nextLabel = option.getAttribute("data-label");
            if (nextLabel) label.textContent = nextLabel;
            if (href) window.location.href = href;
          });
        });

        document.addEventListener("click", (event) => {
          if (picker.contains(event.target)) return;
          menu.setAttribute("hidden", "");
          picker.classList.remove("is-dropup");
          trigger.setAttribute("aria-expanded", "false");
        });

        window.addEventListener("resize", () => {
          if (menu.hasAttribute("hidden")) return;
          updateMenuDirection();
        });
      };

      const resetPageLeavingState = (reason = "reset") => {
        clearPageLeavingWatchdog();
        if (document.body.classList.contains("page-is-leaving")) {
          logNavigationDebug("reset", { reason, href: pageLeavingHref || window.location.href });
        }
        pageLeavingHref = "";
        document.body.classList.remove("page-is-leaving");
      };

      const markPageLeaving = (href) => {
        const nextHref = normalizeNavigationHref(href);
        if (!nextHref) return;

        clearPageLeavingWatchdog();
        pageLeavingHref = nextHref;
        document.body.classList.add("page-is-leaving");
        logNavigationDebug("start", { href: nextHref });

        pageLeavingWatchdog = window.setTimeout(() => {
          if (document.visibilityState === "hidden") return;
          logNavigationDebug("watchdog-reset", {
            href: nextHref,
            currentHref: window.location.href,
          });
          resetPageLeavingState("watchdog");
        }, 1800);
      };

      const syncLandingHeaderState = () => {
        if (!(landingHeader instanceof HTMLElement)) return;
        const isScrolled = landingHeaderIsSolid || window.scrollY > 24;
        landingHeader.classList.toggle("is-scrolled", isScrolled);
        switchableLogos.forEach((logo) => {
          if (!(logo instanceof HTMLImageElement)) return;
          const nextSrc = isScrolled
            ? logo.dataset.logoDarkSrc
            : logo.dataset.logoLightSrc;
          if (nextSrc && logo.getAttribute("src") !== nextSrc) {
            logo.setAttribute("src", nextSrc);
          }
        });
      };

      resetPageLeavingState();
      syncLandingHeaderState();
      window.addEventListener("pageshow", () => resetPageLeavingState("pageshow"));
      window.addEventListener("pagehide", () => clearPageLeavingWatchdog());
      window.addEventListener("beforeunload", () => clearPageLeavingWatchdog());
      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "visible") {
          resetPageLeavingState("visibilitychange");
        }
      });
      window.addEventListener("scroll", syncLandingHeaderState, { passive: true });
      initLangPicker("langPickerLanding", "langTriggerLanding", "langMenuLanding", "langLabelLanding");
      initLangPicker("langPickerDesktop", "langTriggerDesktop", "langMenuDesktop", "langLabelDesktop");

      document.addEventListener("click", (event) => {
        if (event.defaultPrevented) return;
        if (event.button !== 0) return;
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
        const link = event.target.closest("a");
        if (!link || shouldSkipTransition(link)) return;
        const href = link.href;
        if (!href) return;
        closeSideMenu();
        markPageLeaving(href);
      });
    </script>

    <main id="mainContent">
      <slot />
    </main>

    {shouldLoadPublicRealtime && (
      <>
        <script is:inline define:vars={{ publicRealtimeConfig }}>
          window.__blancarealPublicRealtime = publicRealtimeConfig;
        </script>
        <script>
          const loadPublicRealtime = () => import("@webapp/scripts/public-crm-realtime");
          if ("requestIdleCallback" in window) {
            window.requestIdleCallback(() => {
              void loadPublicRealtime();
            }, { timeout: 2200 });
          } else {
            window.setTimeout(() => {
              void loadPublicRealtime();
            }, 1200);
          }
        </script>
      </>
    )}
    {enableLightbox && (
      <script>
        import "@webapp/scripts/lightbox.js";
      </script>
    )}
    {!import.meta.env.DEV ? <SpeedInsights /> : null}
    </body>
  </html>
