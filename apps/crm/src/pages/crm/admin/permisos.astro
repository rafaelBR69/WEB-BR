---
import CrmLayout from "@crmapp/layouts/CrmLayout.astro";
---
<CrmLayout title="CRM | Admin | Permisos" section="admin">
  <div class="crm-stack" data-crm-admin-permissions-page="true">
    <section class="crm-card crm-full">
      <h2>Gestion de permisos internos</h2>
      <p>
        Como admin puedes gestionar rol, estado de membresia y permisos granulares de cada usuario interno del CRM.
      </p>
      <form id="crm-admin-org-form" class="crm-form crm-form-compact">
        <label for="crm-admin-users-q">
          Buscar usuario
          <input id="crm-admin-users-q" name="q" type="search" placeholder="email, nombre, rol o id" />
        </label>
        <label for="crm-admin-users-per-page">
          Por pagina
          <select id="crm-admin-users-per-page" name="per_page">
            <option value="10">10</option>
            <option value="25" selected>25</option>
            <option value="50">50</option>
          </select>
        </label>
        <div class="crm-actions-row crm-col-2">
          <button type="submit" class="crm-button crm-button-soft">Aplicar</button>
          <button id="crm-admin-clear" type="button" class="crm-button crm-button-soft">Limpiar</button>
        </div>
      </form>
    </section>

    <section class="crm-grid">
      <article class="crm-card crm-full">
        <h3>Crear usuario interno</h3>
        <form id="crm-admin-create-form" class="crm-form">
          <label for="crm-admin-create-email">
            Email
            <input
              id="crm-admin-create-email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="usuario@dominio.com"
              required
            />
          </label>
          <label for="crm-admin-create-password">
            Contrasena temporal
            <input
              id="crm-admin-create-password"
              name="password"
              type="password"
              minlength="8"
              placeholder="Minimo 8 caracteres"
              required
            />
          </label>
          <label for="crm-admin-create-full-name" class="crm-col-2">
            Nombre completo
            <input
              id="crm-admin-create-full-name"
              name="full_name"
              type="text"
              placeholder="Nombre visible en el CRM"
            />
          </label>
          <label for="crm-admin-create-role">
            Rol CRM
            <select id="crm-admin-create-role" name="role" data-dictionary="crm-role">
              <option value="owner">owner</option>
              <option value="admin">admin</option>
              <option value="agent">agent</option>
              <option value="finance">finance</option>
              <option value="legal">legal</option>
              <option value="viewer">viewer</option>
            </select>
          </label>
          <label class="crm-checkbox-label" for="crm-admin-create-active">
            <input id="crm-admin-create-active" name="is_active" type="checkbox" checked />
            Membresia activa en esta organizacion
          </label>
          <div class="crm-col-2 crm-actions-row">
            <button type="submit" class="crm-button">Crear usuario</button>
          </div>
        </form>
      </article>

      <article class="crm-card crm-full">
        <p id="crm-admin-users-meta" class="crm-inline-note">Cargando usuarios internos...</p>
        <div class="crm-table-wrap">
          <table class="crm-table">
            <caption class="sr-only">Usuarios internos CRM</caption>
            <thead>
              <tr>
                <th>Usuario</th>
                <th>Rol</th>
                <th>Estado</th>
                <th>Permisos efectivos</th>
                <th>Ultimo acceso</th>
                <th>Accion</th>
              </tr>
            </thead>
            <tbody id="crm-admin-users-tbody">
              <tr><td colspan="6">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </article>

      <article class="crm-card crm-full">
        <h3>Editar usuario interno</h3>
        <form id="crm-admin-permissions-form" class="crm-form">
          <input type="hidden" id="crm-admin-membership-id" name="membership_id" />
          <input type="hidden" id="crm-admin-user-id" name="user_id" />
          <label for="crm-admin-user-display" class="crm-col-2">
            Usuario seleccionado
            <input id="crm-admin-user-display" type="text" value="Selecciona un usuario de la tabla" readonly />
          </label>
          <label for="crm-admin-role">
            Rol CRM
            <select id="crm-admin-role" name="role" data-dictionary="crm-role">
              <option value="owner">owner</option>
              <option value="admin">admin</option>
              <option value="agent">agent</option>
              <option value="finance">finance</option>
              <option value="legal">legal</option>
              <option value="viewer">viewer</option>
            </select>
          </label>
          <label class="crm-checkbox-label" for="crm-admin-is-active">
            <input id="crm-admin-is-active" name="is_active" type="checkbox" checked />
            Membresia activa
          </label>
          <label for="crm-admin-full-name" class="crm-col-2">
            Nombre visible
            <input id="crm-admin-full-name" name="full_name" type="text" placeholder="Nombre completo del usuario" />
          </label>
          <div class="crm-col-2 crm-permission-block">
            <h4>Permisos extra (anadidos)</h4>
            <p class="crm-field-help">
              Estos permisos se suman a los que ya trae el rol.
            </p>
            <div id="crm-admin-granted-list" class="crm-permission-list">
              <p class="crm-inline-note">Selecciona un usuario para editar permisos.</p>
            </div>
          </div>
          <div class="crm-col-2 crm-permission-block">
            <h4>Permisos bloqueados (revocados)</h4>
            <p class="crm-field-help">
              Estos permisos se bloquean aunque el rol los incluya por defecto.
            </p>
            <div id="crm-admin-revoked-list" class="crm-permission-list">
              <p class="crm-inline-note">Selecciona un usuario para editar permisos.</p>
            </div>
          </div>
          <div class="crm-col-2 crm-actions-row">
            <button type="submit" class="crm-button">Guardar permisos</button>
          </div>
        </form>
      </article>
    </section>

    <section class="crm-card crm-full">
      <p id="crm-admin-feedback" class="crm-feedback" role="status" aria-live="polite">
        Listo para administrar permisos.
      </p>
    </section>
  </div>
  <script is:inline src="/crm/admin-permissions.js"></script>
</CrmLayout>
