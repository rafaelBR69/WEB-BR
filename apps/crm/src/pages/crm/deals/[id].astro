---
import CrmLayout from "@crmapp/layouts/CrmLayout.astro";

const dealId = String(Astro.params.id ?? "").trim();
const backUrl = `/crm/deals/${Astro.url.search}`;
---
<CrmLayout title="CRM | Ficha de deal" section="deals">
  <div class="crm-stack">
    <section class="crm-card crm-full">
      <div class="crm-actions-row" style="justify-content:space-between;align-items:flex-start">
        <div>
          <a href={backUrl} class="crm-button crm-button-soft">Volver a deals</a>
          <h2 id="deal-detail-title" style="margin:1rem 0 0.35rem">Ficha de deal</h2>
          <p id="deal-detail-subtitle" class="crm-inline-note">Cargando oportunidad...</p>
        </div>
        <div class="crm-actions-row">
          <a id="deal-open-lead" href="#" class="crm-button crm-button-soft">Abrir lead</a>
          <a id="deal-open-client" href="#" class="crm-button crm-button-soft">Abrir cliente</a>
          <a id="deal-open-property" href="#" class="crm-button crm-button-soft">Abrir propiedad</a>
        </div>
      </div>
    </section>

    <section class="crm-grid" aria-label="Resumen deal">
      <article class="crm-card">
        <small class="crm-inline-note">Stage</small>
        <strong id="deal-stage">-</strong>
      </article>
      <article class="crm-card">
        <small class="crm-inline-note">Valor esperado</small>
        <strong id="deal-value">-</strong>
      </article>
      <article class="crm-card">
        <small class="crm-inline-note">Probabilidad</small>
        <strong id="deal-probability">-</strong>
      </article>
      <article class="crm-card">
        <small class="crm-inline-note">Cierre previsto</small>
        <strong id="deal-close-date">-</strong>
      </article>
    </section>

    <section class="crm-card crm-full">
      <h3>Editar deal</h3>
      <div id="deal-stage-quick-actions" class="crm-actions-row" style="margin-bottom:1rem"></div>
      <form id="deal-edit-form" class="crm-form crm-form-compact">
        <label>Titulo
          <input name="title" type="text" />
        </label>
        <label>Stage
          <select name="stage">
            <option value="qualification">Cualificacion</option>
            <option value="visit">Visita</option>
            <option value="offer">Oferta</option>
            <option value="negotiation">Negociacion</option>
            <option value="reservation">Reserva</option>
            <option value="contract">Contrato</option>
            <option value="won">Ganada</option>
            <option value="lost">Perdida</option>
          </select>
        </label>
        <label>Fecha cierre prevista
          <input name="expected_close_date" type="date" />
        </label>
        <label>Valor esperado
          <input name="expected_value" type="number" min="0" step="0.01" />
        </label>
        <label>Probabilidad
          <input name="probability" type="number" min="0" max="100" step="1" />
        </label>
        <label>Propiedad operativa
          <input id="deal-property-search" type="text" list="deal-property-options" placeholder="Selecciona una vivienda operativa" autocomplete="off" />
          <input id="deal-property-id" name="property_id" type="hidden" />
          <datalist id="deal-property-options"></datalist>
          <small id="deal-property-helper" class="crm-inline-note">Sin propiedad vinculada.</small>
        </label>
        <div class="crm-actions-row">
          <button type="submit" class="crm-button crm-button-primary">Guardar cambios</button>
        </div>
      </form>
    </section>

    <section class="crm-grid" aria-label="Relaciones deal">
      <article class="crm-card">
        <h3>Seguimiento</h3>
        <div id="deal-notifications-summary" class="crm-inline-note">Cargando alertas...</div>
        <div id="deal-notifications-list" style="margin-top:0.85rem;display:grid;gap:0.65rem"></div>
      </article>
      <article class="crm-card">
        <h3>Lead relacionado</h3>
        <div id="deal-lead-summary" class="crm-inline-note">Sin lead vinculado.</div>
      </article>
      <article class="crm-card">
        <h3>Cliente relacionado</h3>
        <div id="deal-client-summary" class="crm-inline-note">Sin cliente vinculado.</div>
      </article>
      <article class="crm-card">
        <h3>Propiedad / promocion</h3>
        <div id="deal-property-summary" class="crm-inline-note">Sin propiedad vinculada.</div>
      </article>
      <article class="crm-card">
        <h3>Bloqueos de borrado</h3>
        <div id="deal-links-summary" class="crm-inline-note">Cargando relaciones...</div>
      </article>
    </section>

    <section class="crm-card crm-full">
      <p id="deal-detail-feedback" class="crm-feedback">Listo para operar.</p>
    </section>
  </div>
  <script is:inline define:vars={{ dealId }}>
    window.__crmDealDetailId = dealId;
  </script>
  <script is:inline src="/crm/deal-detail.js"></script>
</CrmLayout>
