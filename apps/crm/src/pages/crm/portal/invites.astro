---
import CrmLayout from "@crmapp/layouts/CrmLayout.astro";
---
<CrmLayout title="CRM | Portal | Invites" section="portal">
  <div class="crm-stack" data-portal-page="invites">
    <section class="crm-card crm-full">
      <h2>Invites y altas portal</h2>
      <p>Gestion operativa de invitaciones reales y de solicitudes de acceso recibidas desde el portal.</p>
    </section>

    <section class="crm-grid">
      <article class="crm-card crm-half">
        <h3>Crear invite</h3>
        <form id="portal-invite-form" class="crm-form">
          <label for="portal-invite-email">
            Email
            <input id="portal-invite-email" name="email" type="email" autocomplete="email" required />
          </label>
          <label for="portal-invite-type">
            Tipo invite
            <select id="portal-invite-type" name="invite_type">
              <option value="agent">Agente</option>
              <option value="client">Cliente</option>
            </select>
          </label>
          <label for="portal-invite-role">
            Rol portal
            <select id="portal-invite-role" name="role" data-dictionary="portal-role">
              <option value="portal_agent_member">portal_agent_member</option>
              <option value="portal_agent_admin">portal_agent_admin</option>
              <option value="portal_client">portal_client</option>
            </select>
          </label>
          <label for="portal-invite-project-select" class="crm-col-2">
            Promocion (opcional)
            <select id="portal-invite-project-select" name="project_property_id">
              <option value="">Sin vincular a promocion concreta</option>
            </select>
            <small class="crm-field-help">Solo promociones de Mis Propiedades.</small>
          </label>
          <label for="portal-invite-expires">
            Caduca en (horas)
            <input id="portal-invite-expires" name="expires_hours" type="number" min="1" max="720" value="72" />
          </label>
          <label for="portal-invite-attempts">
            Max intentos
            <input id="portal-invite-attempts" name="max_attempts" type="number" min="1" max="20" value="5" />
          </label>
          <div class="crm-col-2 crm-actions-row">
            <button type="submit" class="crm-button">Generar invite</button>
          </div>
        </form>
        <p id="portal-invite-code" class="crm-inline-note" role="status" aria-live="polite">
          El codigo de un solo uso aparecera aqui tras crear la invitacion.
        </p>
        <div id="portal-invite-share" class="crm-share-card" hidden>
          <p class="crm-share-title">Invite lista para enviar</p>
          <p id="portal-invite-share-summary" class="crm-inline-note">
            Genera una invitacion para desbloquear envio por WhatsApp o correo.
          </p>
          <div class="crm-actions-row">
            <a
              id="portal-invite-share-whatsapp"
              class="crm-button crm-button-soft"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
            >
              Enviar por WhatsApp
            </a>
            <a id="portal-invite-share-email" class="crm-button crm-button-soft" href="#">
              Enviar por correo
            </a>
            <button id="portal-invite-copy-message" type="button" class="crm-button crm-button-soft">
              Copiar mensaje
            </button>
            <button id="portal-invite-copy-code" type="button" class="crm-button crm-button-soft">
              Copiar codigo
            </button>
          </div>
        </div>
      </article>

      <article class="crm-card crm-half portal-registration-card">
        <h3>Solicitudes de acceso</h3>
        <p class="crm-inline-note">
          Aqui entran las peticiones enviadas desde el login del portal. Puedes aprobarlas para generar una invite real o rechazarlas.
        </p>
        <div class="crm-grid portal-registration-kpis" aria-live="polite">
          <article class="crm-card crm-kpi">
            <strong id="portal-registration-kpi-requested">-</strong>
            <p>Pendientes</p>
            <small class="crm-kpi-hint">Esperando revision.</small>
          </article>
          <article class="crm-card crm-kpi">
            <strong id="portal-registration-kpi-approved">-</strong>
            <p>Aprobadas</p>
            <small class="crm-kpi-hint">Ya convertidas en invite.</small>
          </article>
          <article class="crm-card crm-kpi">
            <strong id="portal-registration-kpi-rejected">-</strong>
            <p>Rechazadas</p>
            <small class="crm-kpi-hint">Cerradas por revision.</small>
          </article>
        </div>
        <form id="portal-registration-filter" class="crm-form">
          <label for="portal-registration-status">
            Estado revision
            <select id="portal-registration-status" name="approval_status" data-dictionary="registration-approval">
              <option value="requested">requested</option>
              <option value="approved">approved</option>
              <option value="rejected">rejected</option>
              <option value="all">all</option>
            </select>
          </label>
          <label for="portal-registration-email">
            Email
            <input id="portal-registration-email" name="email" type="search" placeholder="filtro exacto por email" />
          </label>
          <label for="portal-registration-per-page">
            Por pagina
            <select id="portal-registration-per-page" name="per_page">
              <option value="10">10</option>
              <option value="25" selected>25</option>
              <option value="50">50</option>
            </select>
          </label>
          <div class="crm-col-2 crm-actions-row">
            <button type="submit" class="crm-button crm-button-soft">Ver solicitudes</button>
            <button id="portal-registration-clear" type="button" class="crm-button crm-button-soft">Limpiar</button>
          </div>
        </form>
      </article>
    </section>

    <section class="crm-card crm-full">
      <div class="crm-row-between portal-section-head">
        <div>
          <h3>Solicitudes de acceso</h3>
          <p>Listado de altas pedidas desde el portal, separadas del historico de invites.</p>
        </div>
      </div>
      <p id="portal-registration-meta" class="crm-inline-note"></p>
      <p id="portal-registration-requests-note" class="crm-inline-note"></p>
      <div class="crm-table-wrap">
        <table class="crm-table" aria-describedby="portal-registration-meta">
          <caption class="sr-only">Listado de solicitudes de acceso portal</caption>
          <thead>
            <tr>
              <th>Solicitante</th>
              <th>Proyecto</th>
              <th>Revision</th>
              <th>Solicitud</th>
              <th>Revision final</th>
              <th>Accion</th>
            </tr>
          </thead>
          <tbody id="portal-registration-tbody">
            <tr><td colspan="6">Cargando solicitudes...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <dialog id="portal-registration-approve-dialog" class="portal-approve-dialog">
      <form id="portal-registration-approve-form" method="dialog" class="crm-form">
        <input id="portal-registration-approve-request-id" name="request_id" type="hidden" />
        <div class="portal-approve-header">
          <div>
            <h3>Configurar aprobacion</h3>
            <p id="portal-registration-approve-summary" class="crm-inline-note">Selecciona rol, acceso y promociones antes de enviar activacion.</p>
          </div>
        </div>
        <label for="portal-registration-approve-role">
          Rol final
          <select id="portal-registration-approve-role" name="role" data-dictionary="portal-role">
            <option value="portal_agent_admin">portal_agent_admin</option>
            <option value="portal_agent_member">portal_agent_member</option>
            <option value="portal_client">portal_client</option>
          </select>
        </label>
        <label for="portal-registration-approve-access-mode">
          Modo de acceso
          <select id="portal-registration-approve-access-mode" name="access_mode">
            <option value="selected">Solo promociones seleccionadas</option>
            <option value="all">Todas las promociones publicadas</option>
          </select>
          <small class="crm-field-help">Si eliges <code>portal_agent_admin</code>, se activan automaticamente todas las promociones y no hace falta seleccionar ninguna.</small>
        </label>
        <label for="portal-registration-approve-projects" class="crm-col-2">
          Promociones asignadas
          <select id="portal-registration-approve-projects" name="project_property_ids" multiple size="8"></select>
          <small class="crm-field-help">Para acceso limitado selecciona una o varias promociones. Para acceso a todas, usa el modo superior.</small>
        </label>
        <label for="portal-registration-approve-scope">
          Scope por defecto
          <select id="portal-registration-approve-scope" name="access_scope" data-dictionary="membership-scope">
            <option value="read">read</option>
            <option value="read_write">read_write</option>
            <option value="full">full</option>
          </select>
        </label>
        <label for="portal-registration-approve-status">
          Estado inicial cuenta
          <select id="portal-registration-approve-status" name="status" data-dictionary="portal-status">
            <option value="pending">pending</option>
            <option value="active">active</option>
            <option value="blocked">blocked</option>
            <option value="revoked">revoked</option>
          </select>
        </label>
        <label for="portal-registration-approve-notes" class="crm-col-2">
          Notas de revision
          <textarea id="portal-registration-approve-notes" name="review_notes" rows="3" placeholder="Visible en la traza interna"></textarea>
        </label>
        <div class="crm-col-2 crm-actions-row">
          <button type="submit" class="crm-button">Aprobar y enviar activacion</button>
          <button id="portal-registration-approve-cancel" type="button" class="crm-button crm-button-soft">Cancelar</button>
        </div>
      </form>
    </dialog>

    <section class="crm-card crm-full">
      <div class="crm-row-between portal-section-head">
        <div>
          <h3>Invites generadas</h3>
          <p>Invitaciones reales del portal, separadas de las peticiones de acceso para que la operativa sea mas limpia.</p>
        </div>
      </div>
      <form id="portal-invites-filter" class="crm-form">
        <label for="portal-invites-status">
          Estado
          <select id="portal-invites-status" name="status" data-dictionary="invite-status">
            <option value="">Todos</option>
            <option value="pending">pending</option>
            <option value="used">used</option>
            <option value="expired">expired</option>
            <option value="revoked">revoked</option>
            <option value="blocked">blocked</option>
          </select>
        </label>
        <label for="portal-invites-email">
          Email
          <input id="portal-invites-email" name="email" type="search" placeholder="filtro exacto por email" />
        </label>
        <label for="portal-invites-project-select">
          Promocion
          <select id="portal-invites-project-select" name="project_property_id">
            <option value="">Todas</option>
          </select>
        </label>
        <label for="portal-invites-per-page">
          Por pagina
          <select id="portal-invites-per-page" name="per_page">
            <option value="10">10</option>
            <option value="25" selected>25</option>
            <option value="50">50</option>
          </select>
        </label>
        <div class="crm-col-2 crm-actions-row">
          <button type="submit" class="crm-button crm-button-soft">Aplicar filtros</button>
          <button id="portal-invites-clear" type="button" class="crm-button crm-button-soft">Limpiar</button>
        </div>
      </form>
      <p id="portal-invites-meta" class="crm-inline-note"></p>
      <p class="crm-inline-note">Esta tabla muestra invites reales y oculta las solicitudes de acceso para que el historico no se mezcle.</p>
      <div class="crm-table-wrap">
        <table class="crm-table" aria-describedby="portal-invites-meta">
          <caption class="sr-only">Listado de invitaciones portal</caption>
          <thead>
            <tr>
              <th>Email</th>
              <th>Tipo/Rol</th>
              <th>Proyecto</th>
              <th>Estado</th>
              <th>Caduca</th>
              <th>Intentos</th>
              <th>Accion</th>
            </tr>
          </thead>
          <tbody id="portal-invites-tbody">
            <tr><td colspan="7">Cargando invitaciones...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="crm-card crm-full">
      <p id="crm-portal-feedback" class="crm-feedback" role="status" aria-live="polite">
        Listo para operar.
      </p>
    </section>
  </div>
  <style>
    .portal-registration-card .crm-inline-note {
      margin-bottom: 1rem;
    }

    .portal-registration-kpis {
      margin-bottom: 1rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .portal-section-head {
      gap: 1rem;
      margin-bottom: 0.75rem;
    }

    .portal-request-note {
      white-space: pre-line;
    }

    .portal-approve-dialog {
      width: min(860px, calc(100vw - 2rem));
      border: 0;
      border-radius: 1rem;
      padding: 0;
      box-shadow: 0 24px 80px rgba(8, 29, 49, 0.28);
    }

    .portal-approve-dialog::backdrop {
      background: rgba(6, 24, 43, 0.42);
    }

    .portal-approve-dialog form {
      padding: 1.25rem;
    }

    .portal-approve-header {
      margin-bottom: 0.5rem;
    }

    .portal-approve-dialog select[multiple] {
      min-height: 13rem;
    }

    @media (max-width: 900px) {
      .portal-registration-kpis {
        grid-template-columns: 1fr;
      }
    }
  </style>
  <script is:inline src="/crm/portal.js"></script>
</CrmLayout>
