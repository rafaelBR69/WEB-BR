---
import CrmLayout from "@crmapp/layouts/CrmLayout.astro";
---
<CrmLayout title="CRM | Portal | Operativa" section="portal">
  <div class="crm-stack" data-portal-operations-page="operations">
    <section class="crm-card crm-full">
      <h2>Operativa comercial del portal</h2>
      <p>Gestion diaria de solicitudes de visita y estados de comision por promocion.</p>
    </section>

    <section class="crm-grid">
      <article class="crm-card crm-half">
        <h3>Visitas: filtros</h3>
        <form id="portal-ops-visits-filter" class="crm-form">
          <label for="portal-ops-visits-project-select">
            Promocion
            <select id="portal-ops-visits-project-select" name="project_property_id">
              <option value="">Todas las promociones</option>
            </select>
          </label>
          <label for="portal-ops-visits-project-manual">
            Promocion manual (solo soporte)
            <input
              id="portal-ops-visits-project-manual"
              name="project_property_id_manual"
              type="text"
              autocomplete="off"
              spellcheck="false"
              placeholder="UUID de proyecto"
            />
          </label>
          <label for="portal-ops-visits-status">
            Estado
            <select id="portal-ops-visits-status" name="status" data-dictionary="visit-status">
              <option value="">Todos</option>
              <option value="requested">requested</option>
              <option value="confirmed">confirmed</option>
              <option value="declined">declined</option>
              <option value="done">done</option>
              <option value="no_show">no_show</option>
              <option value="cancelled">cancelled</option>
            </select>
          </label>
          <label for="portal-ops-visits-search">
            Buscar
            <input id="portal-ops-visits-search" name="q" type="search" placeholder="lead, email o estado" />
          </label>
          <label for="portal-ops-visits-per-page">
            Por pagina
            <select id="portal-ops-visits-per-page" name="per_page">
              <option value="25" selected>25</option>
              <option value="50">50</option>
              <option value="100">100</option>
            </select>
          </label>
          <div class="crm-actions-row">
            <button type="submit" class="crm-button crm-button-soft">Aplicar filtros</button>
            <button id="portal-ops-visits-clear" type="button" class="crm-button crm-button-soft">Limpiar</button>
          </div>
        </form>
      </article>

      <article class="crm-card crm-half">
        <h3>Visitas: actualizar estado</h3>
        <form id="portal-ops-visit-form" class="crm-form">
          <input id="portal-ops-visit-id" name="id" type="hidden" />
          <label for="portal-ops-visit-status">
            Estado
            <select id="portal-ops-visit-status" name="status" required data-dictionary="visit-status">
              <option value="requested">requested</option>
              <option value="confirmed">confirmed</option>
              <option value="declined">declined</option>
              <option value="done">done</option>
              <option value="no_show">no_show</option>
              <option value="cancelled">cancelled</option>
            </select>
          </label>
          <label for="portal-ops-visit-confirmed-slot">
            Slot confirmado
            <input id="portal-ops-visit-confirmed-slot" name="confirmed_slot" type="datetime-local" />
          </label>
          <label for="portal-ops-visit-notes" class="crm-col-2">
            Notas internas
            <textarea id="portal-ops-visit-notes" name="notes" rows="3" placeholder="Motivo, observaciones o seguimiento"></textarea>
          </label>
          <div class="crm-col-2 crm-actions-row">
            <button type="submit" class="crm-button">Guardar visita</button>
            <button id="portal-ops-visit-new" type="button" class="crm-button crm-button-soft">Nuevo</button>
          </div>
        </form>
      </article>
    </section>

    <section class="crm-card crm-full">
      <p id="portal-ops-visits-meta" class="crm-inline-note"></p>
      <div class="crm-table-wrap">
        <table class="crm-table" aria-describedby="portal-ops-visits-meta">
          <caption class="sr-only">Listado de solicitudes de visita portal</caption>
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Promocion</th>
              <th>Lead</th>
              <th>Estado</th>
              <th>Slot</th>
              <th>Accion</th>
            </tr>
          </thead>
          <tbody id="portal-ops-visits-tbody">
            <tr><td colspan="6">Cargando solicitudes de visita...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="crm-grid">
      <article class="crm-card crm-half">
        <h3>Comisiones: filtros</h3>
        <form id="portal-ops-commissions-filter" class="crm-form">
          <label for="portal-ops-commissions-project-select">
            Promocion
            <select id="portal-ops-commissions-project-select" name="project_property_id">
              <option value="">Todas las promociones</option>
            </select>
          </label>
          <label for="portal-ops-commissions-project-manual">
            Promocion manual (solo soporte)
            <input
              id="portal-ops-commissions-project-manual"
              name="project_property_id_manual"
              type="text"
              autocomplete="off"
              spellcheck="false"
              placeholder="UUID de proyecto"
            />
          </label>
          <label for="portal-ops-commissions-status">
            Estado
            <select id="portal-ops-commissions-status" name="status" data-dictionary="commission-status">
              <option value="">Todos</option>
              <option value="pending">pending</option>
              <option value="approved">approved</option>
              <option value="paid">paid</option>
              <option value="cancelled">cancelled</option>
            </select>
          </label>
          <label for="portal-ops-commissions-type">
            Tipo
            <select id="portal-ops-commissions-type" name="commission_type" data-dictionary="commission-type">
              <option value="">Todos</option>
              <option value="percent">percent</option>
              <option value="fixed">fixed</option>
            </select>
          </label>
          <label for="portal-ops-commissions-search">
            Buscar
            <input id="portal-ops-commissions-search" name="q" type="search" placeholder="lead, email o estado" />
          </label>
          <label for="portal-ops-commissions-per-page">
            Por pagina
            <select id="portal-ops-commissions-per-page" name="per_page">
              <option value="25" selected>25</option>
              <option value="50">50</option>
              <option value="100">100</option>
            </select>
          </label>
          <div class="crm-actions-row">
            <button type="submit" class="crm-button crm-button-soft">Aplicar filtros</button>
            <button id="portal-ops-commissions-clear" type="button" class="crm-button crm-button-soft">Limpiar</button>
          </div>
        </form>
      </article>

      <article class="crm-card crm-half">
        <h3>Comisiones: actualizar estado</h3>
        <form id="portal-ops-commission-form" class="crm-form">
          <input id="portal-ops-commission-id" name="id" type="hidden" />
          <label for="portal-ops-commission-status">
            Estado
            <select id="portal-ops-commission-status" name="status" required data-dictionary="commission-status">
              <option value="pending">pending</option>
              <option value="approved">approved</option>
              <option value="paid">paid</option>
              <option value="cancelled">cancelled</option>
            </select>
          </label>
          <label for="portal-ops-commission-type">
            Tipo
            <select id="portal-ops-commission-type" name="commission_type" data-dictionary="commission-type">
              <option value="fixed">fixed</option>
              <option value="percent">percent</option>
            </select>
          </label>
          <label for="portal-ops-commission-value">
            Importe
            <input id="portal-ops-commission-value" name="commission_value" type="number" step="0.01" min="0" />
          </label>
          <label for="portal-ops-commission-currency">
            Moneda
            <input id="portal-ops-commission-currency" name="currency" type="text" maxlength="8" value="EUR" />
          </label>
          <label for="portal-ops-commission-payment-date">
            Fecha pago
            <input id="portal-ops-commission-payment-date" name="payment_date" type="date" />
          </label>
          <label for="portal-ops-commission-notes" class="crm-col-2">
            Notas internas
            <textarea id="portal-ops-commission-notes" name="notes" rows="3" placeholder="Aprobacion, motivo o comentario"></textarea>
          </label>
          <div class="crm-col-2 crm-actions-row">
            <button type="submit" class="crm-button">Guardar comision</button>
            <button id="portal-ops-commission-new" type="button" class="crm-button crm-button-soft">Nuevo</button>
          </div>
        </form>
      </article>
    </section>

    <section class="crm-card crm-full">
      <p id="portal-ops-commissions-meta" class="crm-inline-note"></p>
      <div class="crm-table-wrap">
        <table class="crm-table" aria-describedby="portal-ops-commissions-meta">
          <caption class="sr-only">Listado de comisiones portal</caption>
          <thead>
            <tr>
              <th>Promocion</th>
              <th>Lead</th>
              <th>Tipo</th>
              <th>Importe</th>
              <th>Estado</th>
              <th>Pago</th>
              <th>Accion</th>
            </tr>
          </thead>
          <tbody id="portal-ops-commissions-tbody">
            <tr><td colspan="7">Cargando comisiones...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="crm-card crm-full">
      <p id="crm-portal-ops-feedback" class="crm-feedback" role="status" aria-live="polite">
        Listo para operar.
      </p>
    </section>
  </div>
  <script is:inline src="/crm/portal-operations.js"></script>
</CrmLayout>
