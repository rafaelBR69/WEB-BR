---
import CrmLayout from "@crmapp/layouts/CrmLayout.astro";
import "@crmapp/styles/crm/lead-ficha.css";

const leadId = String(Astro.params.id ?? "").trim();
const backUrl = `/crm/leads/${Astro.url.search}`;
---
<CrmLayout title="CRM | Ficha de Lead" section="leads">
  <div class="ld-page">

    <section class="ld-shellhead">
      <div class="ld-shellhead-main">
        <a href={backUrl} class="ld-back-btn">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M3.83 7H14a1 1 0 1 1 0 2H3.83l3.58 3.58a1 1 0 0 1-1.41 1.42l-5.3-5.29a1 1 0 0 1 0-1.42L5.99 1.99a1 1 0 1 1 1.42 1.42L3.83 7Z"/></svg>
          Volver a leads
        </a>
        <p class="ld-context-eyebrow">Lead</p>
        <h1 class="ld-shellhead-title">Ficha de lead</h1>
        <p class="ld-shellhead-copy">Vista comercial alineada con el módulo de agencias y clientes para revisar origen, estado y conversión.</p>
      </div>
      <div class="ld-shellhead-side">
        <nav class="ld-module-nav" aria-label="Navegacion modulo leads">
          <a href="/crm/leads/dashboard/">Dashboard</a>
          <a href="/crm/leads/">Listado</a>
          <a href="/crm/leads/nuevo/">Nuevo</a>
        </nav>
        <div class="ld-topbar-actions">
          <button id="lead-edit-toggle" type="button" class="ld-btn ld-btn-ghost">Editar</button>
          <button id="lead-convert-btn" type="button" class="ld-btn ld-btn-success">Convertir a Cliente</button>
          <button id="lead-delete" type="button" class="ld-btn ld-btn-danger">Eliminar</button>
        </div>
      </div>
    </section>

    <!-- HERO HEADER -->
    <div class="ld-hero">
      <div class="ld-hero-avatar" id="lead-hero-avatar">?</div>
      <div class="ld-hero-info">
        <div class="ld-hero-badges">
          <span id="lead-status-badge" class="ld-badge">Cargando...</span>
          <span id="lead-priority-badge" class="ld-badge">—</span>
          <span id="lead-kind-badge" class="ld-badge">—</span>
        </div>
        <h2 id="lead-detail-title" class="ld-hero-name">Ficha de Lead</h2>
        <p id="lead-detail-subtitle" class="ld-hero-sub">Cargando información...</p>
      </div>
      <div class="ld-hero-actions">
        <a id="action-whatsapp" href="#" class="ld-contact-btn whatsapp" target="_blank" rel="noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.29-.15-1.72-.85-1.99-.95s-.46-.15-.65.15-.75.95-.92 1.14-.34.22-.63.07a7.94 7.94 0 0 1-2.34-1.44 8.78 8.78 0 0 1-1.62-2c-.17-.29 0-.45.13-.6s.29-.34.44-.51a2 2 0 0 0 .29-.49.54.54 0 0 0 0-.52c-.07-.15-.65-1.57-.89-2.15s-.47-.49-.65-.49h-.55a1.06 1.06 0 0 0-.77.36 3.24 3.24 0 0 0-1 2.41 5.64 5.64 0 0 0 1.18 3c.15.2 2.1 3.2 5.09 4.49a17.24 17.24 0 0 0 1.7.63 4.1 4.1 0 0 0 1.88.12 3 3 0 0 0 1.95-1.38 2.41 2.41 0 0 0 .17-1.38c-.07-.12-.26-.19-.55-.34ZM12 2A10 10 0 0 0 2 12a9.89 9.89 0 0 0 1.38 5.09L2 22l5.1-1.34A10 10 0 1 0 12 2Z"/></svg>
          WhatsApp
        </a>
        <a id="action-email" href="#" class="ld-contact-btn email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
          Email
        </a>
        <a id="action-call" href="#" class="ld-contact-btn call">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.38h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.06-.9a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          Llamar
        </a>
      </div>
    </div>

    <section class="ld-signal-grid" aria-label="Resumen lead">
      <article class="ld-signal-card">
        <span class="ld-signal-label">Estado comercial</span>
        <strong id="lead-signal-status">Cargando...</strong>
        <small id="lead-signal-origin">-</small>
      </article>
      <article class="ld-signal-card">
        <span class="ld-signal-label">Prioridad y tipo</span>
        <strong id="lead-signal-priority">-</strong>
        <small id="lead-signal-kind">-</small>
      </article>
      <article class="ld-signal-card">
        <span class="ld-signal-label">Origen por agencia</span>
        <strong id="lead-signal-agency">-</strong>
        <small id="lead-signal-agency-contact">-</small>
      </article>
      <article class="ld-signal-card">
        <span class="ld-signal-label">Interes y propiedad</span>
        <strong id="lead-signal-interest">-</strong>
        <small id="lead-signal-property">-</small>
      </article>
    </section>

    <!-- MAIN GRID -->
    <div class="ld-grid">

      <!-- LEFT COLUMN -->
      <div class="ld-col-main">

        <!-- Identidad y Contacto -->
        <div class="ld-card">
          <div class="ld-card-header">
            <h3 class="ld-card-title">Identidad y Contacto</h3>
          </div>
          <div class="ld-data-grid">
            <div class="ld-data-item"><span class="ld-label">Nombre completo</span><span class="ld-value" id="d-full-name">—</span></div>
            <div class="ld-data-item"><span class="ld-label">Email</span><span class="ld-value" id="d-email">—</span></div>
            <div class="ld-data-item"><span class="ld-label">Teléfono</span><span class="ld-value" id="d-phone">—</span></div>
            <div class="ld-data-item"><span class="ld-label">Nacionalidad</span><span class="ld-value" id="d-nationality">—</span></div>
          </div>
        </div>

        <!-- Estado Comercial -->
        <div class="ld-card">
          <div class="ld-card-header">
            <h3 class="ld-card-title">Estado Comercial</h3>
          </div>
          <div class="ld-data-grid">
            <div class="ld-data-item"><span class="ld-label">Estado</span><span class="ld-value" id="d-status">—</span></div>
            <div class="ld-data-item"><span class="ld-label">Tipo de Lead</span><span class="ld-value" id="d-kind">—</span></div>
            <div class="ld-data-item"><span class="ld-label">Interés</span><span class="ld-value" id="d-interest">—</span></div>
            <div class="ld-data-item"><span class="ld-label">Prioridad</span><span class="ld-value" id="d-priority">—</span></div>
            <div class="ld-data-item"><span class="ld-label">Origen</span><span class="ld-value" id="d-origin">—</span></div>
            <div class="ld-data-item"><span class="ld-label">Canal</span><span class="ld-value" id="d-source">—</span></div>
          </div>
        </div>

        <!-- Presupuesto -->
        <div class="ld-card">
          <div class="ld-card-header">
            <h3 class="ld-card-title">Presupuesto</h3>
          </div>
          <div class="ld-budget-row">
            <div class="ld-budget-item">
              <span class="ld-label">Mínimo</span>
              <span class="ld-budget-value" id="d-budget-min">—</span>
            </div>
            <div class="ld-budget-item">
              <span class="ld-label">Máximo</span>
              <span class="ld-budget-value" id="d-budget-max">—</span>
            </div>
          </div>
        </div>

        <!-- Mensaje -->
        <div class="ld-card" id="lead-message-card">
          <div class="ld-card-header">
            <h3 class="ld-card-title">Mensaje Original</h3>
          </div>
          <p id="d-message" class="ld-message-text">—</p>
        </div>

        <!-- Formulario Edición -->
        <div class="ld-card" id="lead-edit-panel" hidden>
          <div class="ld-card-header">
            <h3 class="ld-card-title">Editar Lead</h3>
            <button id="lead-edit-cancel" type="button" class="ld-btn ld-btn-ghost">Cancelar</button>
          </div>
          <form id="lead-edit-form" class="ld-form">
            <div class="ld-form-grid">
              <label class="ld-field"><span>Nombre completo</span><input name="full_name" type="text" required /></label>
              <label class="ld-field"><span>Email</span><input name="email" type="email" /></label>
              <label class="ld-field"><span>Teléfono</span><input name="phone" type="tel" /></label>
              <label class="ld-field"><span>Nacionalidad</span><input name="nationality" type="text" /></label>
              <label class="ld-field">
                <span>Estado</span>
                <select name="status">
                  <option value="new">Nuevo</option>
                  <option value="contacted">Contactado</option>
                  <option value="qualified">Cualificado</option>
                  <option value="proposal">Propuesta</option>
                  <option value="negotiation">Negociación</option>
                  <option value="won">Ganado</option>
                  <option value="lost">Perdido</option>
                  <option value="discarded">Descartado</option>
                </select>
              </label>
              <label class="ld-field">
                <span>Tipo de Lead</span>
                <select name="lead_kind">
                  <option value="buyer">Comprador</option>
                  <option value="seller">Vendedor</option>
                  <option value="investor">Inversor</option>
                  <option value="other">Otro</option>
                </select>
              </label>
              <label class="ld-field">
                <span>Interés</span>
                <select name="operation_interest">
                  <option value="sale">Compra</option>
                  <option value="rental">Alquiler</option>
                  <option value="mixed">Mixto</option>
                </select>
              </label>
              <label class="ld-field">
                <span>Prioridad</span>
                <select name="priority">
                  <option value="1">1 — Baja</option>
                  <option value="2">2 — Media-Baja</option>
                  <option value="3">3 — Media</option>
                  <option value="4">4 — Alta</option>
                  <option value="5">5 — Crítica</option>
                </select>
              </label>
              <label class="ld-field"><span>Presupuesto Mín. (€)</span><input name="budget_min" type="number" step="1000" /></label>
              <label class="ld-field"><span>Presupuesto Máx. (€)</span><input name="budget_max" type="number" step="1000" /></label>
            </div>
            <div class="ld-form-actions">
              <button type="submit" class="ld-btn ld-btn-primary">Guardar Cambios</button>
              <button type="button" id="lead-edit-cancel2" class="ld-btn ld-btn-ghost">Cancelar</button>
            </div>
          </form>
        </div>

      </div><!-- /col-main -->

      <!-- RIGHT SIDEBAR -->
      <div class="ld-col-sidebar">

        <div class="ld-card">
          <div class="ld-card-header">
            <h3 class="ld-card-title">Seguimiento</h3>
          </div>
          <div id="lead-notifications-summary" class="ld-property-block">
            <span class="ld-empty">Cargando alertas...</span>
          </div>
          <div id="lead-notifications-list" style="margin-top:0.85rem;display:grid;gap:0.65rem"></div>
        </div>

        <div class="ld-card">
          <div class="ld-card-header">
            <h3 class="ld-card-title">Deal de oportunidad</h3>
          </div>
          <div id="lead-deal-summary" class="ld-property-block">
            <span class="ld-empty">Comprobando oportunidades...</span>
          </div>
          <div class="ld-form-actions" style="margin-top:1rem">
            <button id="lead-deal-open-btn" type="button" class="ld-btn ld-btn-primary" style="width:100%">
              Crear deal
            </button>
          </div>
        </div>

        <div class="ld-card">
          <div class="ld-card-header">
            <h3 class="ld-card-title">Origen por agencia</h3>
          </div>
          <div id="d-agency" class="ld-property-block">
            <span class="ld-empty">Comprobando origen...</span>
          </div>
        </div>

        <!-- Propiedad -->
        <div class="ld-card">
          <div class="ld-card-header">
            <h3 class="ld-card-title">Propiedad Vinculada</h3>
          </div>
          <div id="d-property" class="ld-property-block">
            <span class="ld-empty">Sin propiedad vinculada</span>
          </div>
        </div>

        <!-- Historial / Timeline -->
        <div class="ld-card">
          <div class="ld-card-header">
            <h3 class="ld-card-title">Historial</h3>
          </div>
          <div id="lead-timeline" class="ld-timeline">
            <p class="ld-empty">Cargando...</p>
          </div>
        </div>

        <!-- Feedback -->
        <p id="lead-detail-feedback" class="ld-feedback"></p>

      </div><!-- /col-sidebar -->

    </div><!-- /grid -->

  </div><!-- /ld-page -->

  <script is:inline define:vars={{ leadId }}>
    window.__crmLeadDetailId = leadId;
  </script>
  <script is:inline src="/crm/lead-detail.js"></script>
</CrmLayout>
