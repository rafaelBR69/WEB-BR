---
import CrmLayout from "@crmapp/layouts/CrmLayout.astro";
---
<CrmLayout title="CRM | Contactos de Agencia" section="agencies">
  <div class="crm-stack">
    <section class="crm-card crm-full">
      <div class="crm-row-between" style="gap:1rem;align-items:flex-start;flex-wrap:wrap">
        <div>
          <p class="crm-context-eyebrow">Agencias</p>
          <h2 style="margin:0 0 0.35rem">Contactos de agencia</h2>
          <p class="crm-inline-note">
            Ranking y seguimiento de los agentes de agencia con historico atribuido, aunque el lead acabara en baja o no entrara como lead CRM completo.
          </p>
        </div>
        <nav class="crm-links crm-subpage-links" aria-label="Navegacion modulo agencias">
          <a class="crm-link" href="/crm/agencies/">Listado</a>
          <a class="crm-link" href="/crm/agencies/dashboard/">Dashboard</a>
          <a class="crm-link is-active" href="/crm/agencies/contacts/">Contactos</a>
          <a class="crm-link" href="/crm/agencies/duplicates/">Duplicados</a>
        </nav>
      </div>
    </section>

    <section class="crm-grid crm-agencies-kpi-grid" aria-live="polite">
      <article class="crm-card crm-kpi"><strong id="agency-contacts-kpi-total">-</strong><small>Contactos activos</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-contacts-kpi-with-leads">-</strong><small>Con actividad</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-contacts-kpi-leads">-</strong><small>Registros atribuidos</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-contacts-kpi-clients">-</strong><small>Clientes atribuidos</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-contacts-kpi-reserved">-</strong><small>Clientes con reserva</small></article>
    </section>

    <section class="crm-card crm-full">
      <div class="crm-row-between" style="gap:1rem;align-items:flex-start;flex-wrap:wrap">
        <div>
          <h3 style="margin:0 0 0.35rem">Nuevo contacto de agencia</h3>
          <p class="crm-inline-note" style="margin:0">
            Alta rapida de agentes/comerciales asociados a una agencia ya existente.
          </p>
        </div>
      </div>
      <form id="agency-contacts-create-form" class="crm-form crm-form-compact" style="margin-top:1rem">
        <label>Buscar agencia
          <input id="agency-contacts-create-agency-search" name="agency_search" type="search" list="agency-contacts-create-agency-options" placeholder="Escribe nombre de agencia..." required />
          <datalist id="agency-contacts-create-agency-options"></datalist>
          <input id="agency-contacts-create-agency-id" name="agency_id" type="hidden" />
        </label>
        <label>Nombre contacto
          <input name="full_name" type="text" placeholder="Eszter Molnar" required />
        </label>
        <label>Email
          <input name="email" type="email" placeholder="agent@email.com" />
        </label>
        <label>Telefono
          <input name="phone" type="tel" placeholder="+34 ..." />
        </label>
        <label>Rol
          <select name="role">
            <option value="agent" selected>Agent</option>
            <option value="principal">Principal</option>
            <option value="assistant">Assistant</option>
            <option value="manager">Manager</option>
          </select>
        </label>
        <label>Principal
          <select name="is_primary">
            <option value="false" selected>No</option>
            <option value="true">Si</option>
          </select>
        </label>
        <label style="grid-column:1 / -1">Notas
          <textarea name="notes" rows="2" placeholder="Contexto, idiomas, mercado, observaciones..."></textarea>
        </label>
        <div class="crm-actions-row">
          <button type="submit" class="crm-button crm-button-soft">Crear contacto</button>
          <p id="agency-contacts-create-status" class="crm-inline-note"></p>
        </div>
      </form>
    </section>

    <section class="crm-card crm-full">
      <form id="agency-contacts-filter-form" class="crm-form crm-form-compact">
        <label>Buscar
          <input name="q" type="search" placeholder="Agente, email, telefono o agencia..." />
        </label>
        <label>Por pagina
          <select id="agency-contacts-per-page" name="per_page">
            <option value="10">10</option>
            <option value="25" selected>25</option>
            <option value="50">50</option>
            <option value="100">100</option>
          </select>
        </label>
        <div class="crm-actions-row">
          <button type="submit" class="crm-button crm-button-soft">Aplicar filtros</button>
          <button id="agency-contacts-filter-clear" type="button" class="crm-button crm-button-soft">Limpiar</button>
        </div>
      </form>
      <p id="agency-contacts-meta" class="crm-inline-note"></p>
      <div class="crm-table-wrap">
        <table class="crm-table">
          <thead>
            <tr>
              <th>Contacto</th>
              <th>Agencia</th>
              <th>Actividad</th>
              <th>Clientes</th>
              <th>Reserva</th>
              <th>Rendimiento</th>
            </tr>
          </thead>
          <tbody id="agency-contacts-tbody">
            <tr>
              <td colspan="6">Cargando contactos...</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div id="agency-contacts-pagination" class="crm-pagination">
        <button type="button" class="crm-button crm-button-soft" data-page-action="prev">Anterior</button>
        <p id="agency-contacts-page-info" class="crm-inline-note">Pagina 1 de 1</p>
        <button type="button" class="crm-button crm-button-soft" data-page-action="next">Siguiente</button>
      </div>
    </section>

    <section class="crm-card crm-full">
      <p id="agency-contacts-feedback" class="crm-feedback">Modulo listo.</p>
    </section>
  </div>

  <script is:inline src="/crm/agency-contacts.js"></script>
</CrmLayout>
