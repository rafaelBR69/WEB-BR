---
import CrmLayout from "@crmapp/layouts/CrmLayout.astro";
---
<CrmLayout title="CRM | Dashboard Agencias" section="agencies">
  <div class="crm-stack crm-agencies-dashboard">
    <section class="crm-card crm-full">
      <div class="crm-row-between" style="gap:1rem;align-items:flex-start;flex-wrap:wrap">
        <div>
          <p class="crm-context-eyebrow">Agencias</p>
          <h2 style="margin:0 0 0.35rem">Dashboard general</h2>
          <p class="crm-inline-note" id="agencies-dashboard-context">
            Cargando una lectura clara de aportacion, calidad y conversion real por agencia.
          </p>
        </div>
        <nav class="crm-links crm-subpage-links" aria-label="Navegacion modulo agencias">
          <a class="crm-link" href="/crm/agencies/">Listado</a>
          <a class="crm-link is-active" href="/crm/agencies/dashboard/">Dashboard</a>
          <a class="crm-link" href="/crm/agencies/contacts/">Contactos</a>
          <a class="crm-link" href="/crm/leads/nuevo/?lead_kind=agency">Nuevo lead agencia</a>
        </nav>
      </div>
    </section>

    <section class="crm-grid crm-agencies-kpi-grid" aria-live="polite">
      <article class="crm-card crm-kpi"><strong id="agencies-kpi-total">-</strong><small>Total agencias</small></article>
      <article class="crm-card crm-kpi"><strong id="agencies-kpi-active">-</strong><small>Activas</small></article>
      <article class="crm-card crm-kpi"><strong id="agencies-kpi-referral">-</strong><small>Referral source</small></article>
      <article class="crm-card crm-kpi"><strong id="agencies-kpi-attributed">-</strong><small>Registros atribuidos</small></article>
      <article class="crm-card crm-kpi"><strong id="agencies-kpi-with-identity">-</strong><small>Con identidad</small></article>
      <article class="crm-card crm-kpi"><strong id="agencies-kpi-without-identity">-</strong><small>Sin identidad</small></article>
      <article class="crm-card crm-kpi"><strong id="agencies-kpi-customer">-</strong><small>Customer / cliente</small></article>
      <article class="crm-card crm-kpi"><strong id="agencies-kpi-discarded">-</strong><small>Baja / descartado</small></article>
      <article class="crm-card crm-kpi"><strong id="agencies-kpi-crm-leads">-</strong><small>Leads CRM</small></article>
      <article class="crm-card crm-kpi"><strong id="agencies-kpi-linked-clients">-</strong><small>Clientes vinculados</small></article>
      <article class="crm-card crm-kpi"><strong id="agencies-kpi-rate">-</strong><small>% registro a cliente</small></article>
    </section>

    <section class="crm-grid">
      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Embudo real de agencias</h3>
        <p class="crm-inline-note">De registros detectados a clientes vinculados y clientes con reserva.</p>
        <div id="agencies-dashboard-funnel" class="crm-chart-surface crm-chart-surface-wide">
          <p class="crm-inline-note">Cargando embudo...</p>
        </div>
      </article>

      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Calidad de atribucion</h3>
        <p class="crm-inline-note">Cuanto del historico tiene identidad usable y cuanto queda pendiente o en baja.</p>
        <div id="agencies-dashboard-attribution-health" class="crm-chart-surface crm-chart-surface-wide">
          <p class="crm-inline-note">Cargando calidad de atribucion...</p>
        </div>
      </article>

      <article class="crm-card crm-full">
        <div class="crm-row-between" style="gap:1rem;align-items:flex-start;flex-wrap:wrap">
          <div>
            <h3 style="margin:0 0 0.35rem">Pulso mensual</h3>
            <p class="crm-inline-note">Volumen atribuido, clientes y bajas por mes para ver tendencia real.</p>
          </div>
        </div>
        <div id="agencies-dashboard-monthly" class="crm-chart-surface crm-chart-surface-wide">
          <p class="crm-inline-note">Cargando evolucion mensual...</p>
        </div>
      </article>

      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Agencias lideres</h3>
        <p class="crm-inline-note">Comparativa directa entre volumen aportado, clientes y reserva.</p>
        <div id="agencies-dashboard-top-agencies-chart" class="crm-chart-surface crm-chart-surface-wide">
          <p class="crm-inline-note">Cargando comparativa...</p>
        </div>
      </article>

      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Agentes que mas convierten</h3>
        <p class="crm-inline-note">Contactos con mejor impacto historico aunque el lead acabara en baja.</p>
        <div id="agencies-dashboard-top-contacts-chart" class="crm-chart-surface crm-chart-surface-wide">
          <p class="crm-inline-note">Cargando agentes...</p>
        </div>
      </article>
    </section>

    <section class="crm-grid crm-agencies-signal-grid">
      <article class="crm-card crm-signal-card">
        <small>Lectura rapida</small>
        <strong id="agencies-signal-main">-</strong>
        <p id="agencies-signal-main-copy" class="crm-inline-note">Preparando diagnostico.</p>
      </article>
      <article class="crm-card crm-signal-card">
        <small>Fuga principal</small>
        <strong id="agencies-signal-leak">-</strong>
        <p id="agencies-signal-leak-copy" class="crm-inline-note">Calculando cuello de botella.</p>
      </article>
      <article class="crm-card crm-signal-card">
        <small>Reserva sobre cliente</small>
        <strong id="agencies-signal-reserve">-</strong>
        <p id="agencies-signal-reserve-copy" class="crm-inline-note">Midiendo calidad comercial.</p>
      </article>
      <article class="crm-card crm-signal-card">
        <small>Historico sin identidad</small>
        <strong id="agencies-signal-identity-gap">-</strong>
        <p id="agencies-signal-identity-gap-copy" class="crm-inline-note">Midiendo deuda de datos.</p>
      </article>
    </section>

    <section class="crm-grid">
      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Top agencias por aportacion</h3>
        <div id="agencies-dashboard-top-leads" class="crm-ranking-list">
          <p class="crm-inline-note">Cargando ranking...</p>
        </div>
      </article>

      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Top agencias por clientes</h3>
        <div id="agencies-dashboard-top-clients" class="crm-ranking-list">
          <p class="crm-inline-note">Cargando ranking...</p>
        </div>
      </article>

      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Top por cliente sobre registro</h3>
        <div id="agencies-dashboard-top-conversion" class="crm-ranking-list">
          <p class="crm-inline-note">Cargando ranking...</p>
        </div>
      </article>

      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Proyectos con mas traccion de agencia</h3>
        <div id="agencies-dashboard-top-projects" class="crm-ranking-list">
          <p class="crm-inline-note">Cargando ranking...</p>
        </div>
      </article>
    </section>

    <section class="crm-card crm-full">
      <p id="agencies-dashboard-feedback" class="crm-feedback">Cargando dashboard...</p>
    </section>
  </div>

  <style>
    .crm-agencies-kpi-grid {
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    }
    .crm-mini-bar-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 0.9rem;
    }
    .crm-chart-surface {
      margin-top: 0.85rem;
      min-height: 300px;
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 18px;
      background:
        radial-gradient(circle at top left, rgba(14, 165, 233, 0.07), transparent 35%),
        linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.96));
      padding: 0.65rem;
      box-shadow: inset 0 0 0 1px rgba(18, 38, 58, 0.03);
    }
    .crm-chart-surface-wide {
      min-height: 340px;
    }
    .crm-agencies-signal-grid {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
    .crm-signal-card {
      display: grid;
      gap: 0.3rem;
      border-radius: 18px;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.98), rgba(241,245,249,0.96)),
        linear-gradient(90deg, rgba(14,165,233,0.08), rgba(249,115,22,0.08));
    }
    .crm-signal-card small {
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 700;
    }
    .crm-signal-card strong {
      font-size: 1.65rem;
      line-height: 1;
      color: #0f172a;
    }
    .crm-mini-bar-card {
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 16px;
      padding: 0.9rem;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.96));
    }
    .crm-mini-bar-head {
      display: flex;
      justify-content: space-between;
      gap: 0.6rem;
      align-items: baseline;
      margin-bottom: 0.55rem;
      font-size: 0.82rem;
      color: #475569;
    }
    .crm-mini-bar-stack {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }
    .crm-mini-bar-track {
      height: 10px;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.18);
      overflow: hidden;
    }
    .crm-mini-bar-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #0f766e, #14b8a6);
    }
    .crm-mini-bar-fill.is-soft {
      background: linear-gradient(90deg, #2563eb, #60a5fa);
    }
    .crm-mini-bar-fill.is-accent {
      background: linear-gradient(90deg, #ea580c, #fb923c);
    }
    .crm-mini-bar-fill.is-danger {
      background: linear-gradient(90deg, #b91c1c, #ef4444);
    }
    .crm-ranking-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .crm-ranking-item {
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 16px;
      padding: 0.9rem 1rem;
      background: rgba(255,255,255,0.94);
    }
    .crm-ranking-head {
      display: flex;
      justify-content: space-between;
      gap: 0.9rem;
      align-items: center;
      margin-bottom: 0.45rem;
    }
    .crm-ranking-title {
      font-weight: 700;
      color: #0f172a;
      text-decoration: none;
    }
    .crm-ranking-meta {
      color: #64748b;
      font-size: 0.84rem;
    }
    .crm-ranking-bar {
      height: 8px;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.18);
      overflow: hidden;
    }
    .crm-ranking-bar > span {
      display: block;
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #ea580c, #fb923c);
    }
  </style>

  <script is:inline src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
  <script is:inline src="/crm/agencies-dashboard.js"></script>
</CrmLayout>
