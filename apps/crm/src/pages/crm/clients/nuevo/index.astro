---
import CrmLayout from "@crmapp/layouts/CrmLayout.astro";
---
<CrmLayout title="CRM | Nuevo cliente" section="clients">
  <div class="crm-stack">
    <section class="crm-card crm-full">
      <h2>Alta manual de cliente</h2>
      <p class="crm-inline-note">
        Crea el cliente base, activa facetas de proveedor o agencia si aplica y deja una vivienda inicial solo cuando
        ya tengas contexto suficiente.
      </p>
      <div class="crm-actions-row" style="margin-top:1rem">
        <a href="/crm/clients/" class="crm-button crm-button-soft">Volver al listado</a>
        <a href="/crm/clients/dashboard/" class="crm-button crm-button-soft">Ir al dashboard KPI</a>
      </div>
    </section>

    <section class="crm-card crm-full">
      <form id="client-create-form" class="crm-form">
        <h3>Identidad y contacto</h3>
        <label>Nombre completo
          <input name="full_name" type="text" required placeholder="Nombre legal o comercial" />
        </label>
        <label>Email
          <input name="email" type="email" placeholder="cliente@dominio.com" />
        </label>
        <label>Telefono
          <input name="phone" type="tel" placeholder="+34 600 000 000" />
        </label>
        <label>Nacionalidad
          <input name="nationality" type="text" placeholder="ES, NL, UK..." />
        </label>
        <label>Fecha de alta
          <input name="intake_date" type="date" />
        </label>

        <h3>Clasificacion comercial</h3>
        <label>Tipo de cliente
          <select name="client_type">
            <option value="individual" selected>Persona fisica</option>
            <option value="company">Persona juridica</option>
          </select>
        </label>
        <label>Canal de entrada
          <select name="entry_channel">
            <option value="other" selected>Otro</option>
            <option value="website">Web</option>
            <option value="agency">Agencia</option>
            <option value="phone">Telefono</option>
            <option value="whatsapp">WhatsApp</option>
            <option value="email">Email</option>
            <option value="provider">Proveedor</option>
            <option value="walkin">Oficina</option>
            <option value="portal">Portal</option>
          </select>
        </label>
        <label>Estado inicial
          <select name="client_status">
            <option value="active" selected>Activo</option>
            <option value="inactive">Inactivo</option>
            <option value="discarded">Descartado</option>
            <option value="blacklisted">Blacklisted</option>
          </select>
        </label>
        <label>Agencia origen
          <input name="agency_name" type="text" placeholder="Nombre de agencia" />
        </label>
        <label>Agente origen
          <input name="agent_name" type="text" placeholder="Nombre del agente" />
        </label>

        <h3>Datos fiscales</h3>
        <label>Tipo de documento
          <select name="tax_id_type">
            <option value="">Sin definir</option>
            <option value="dni">DNI</option>
            <option value="nie">NIE</option>
            <option value="cif">CIF</option>
            <option value="passport">Pasaporte</option>
            <option value="other">Otro</option>
          </select>
        </label>
        <label>Numero documento
          <input name="tax_id" type="text" placeholder="DNI, NIE, CIF..." />
        </label>

        <h3>Preferencias y notas</h3>
        <label>Presupuesto (EUR)
          <input name="budget_amount" type="number" min="0" step="0.01" />
        </label>
        <label>Tipologia
          <input name="typology" type="text" placeholder="2D, chalet, inversion..." />
        </label>
        <label>Localizacion preferida
          <input name="preferred_location" type="text" placeholder="Estepona, Mijas, Marbella..." />
        </label>
        <label>Comentarios
          <textarea name="comments" rows="3" placeholder="Notas comerciales iniciales..."></textarea>
        </label>
        <label>Reporte
          <textarea name="report_notes" rows="2" placeholder="Contexto de reporting"></textarea>
        </label>
        <label>Visita
          <textarea name="visit_notes" rows="2" placeholder="Plan de visita o notas"></textarea>
        </label>
        <label>Reserva
          <textarea name="reservation_notes" rows="2" placeholder="Notas de reserva o avance"></textarea>
        </label>
        <label>Otros
          <textarea name="other_notes" rows="2" placeholder="Cualquier otra observacion"></textarea>
        </label>

        <h3>Faceta proveedor</h3>
        <label class="crm-checkbox-label">
          <input id="client-create-as-provider" name="as_provider" type="checkbox" />
          <span>Activar proveedor</span>
        </label>
        <label>Codigo proveedor
          <input name="provider_code" type="text" data-role-field="provider" />
        </label>
        <label>Tipo proveedor
          <select name="provider_type" data-role-field="provider">
            <option value="developer">Developer</option>
            <option value="promoter">Promotor</option>
            <option value="constructor">Constructor</option>
            <option value="architect">Arquitecto</option>
            <option value="agency">Agencia</option>
            <option value="owner">Propietario</option>
            <option value="other" selected>Otro</option>
          </select>
        </label>
        <label>Estado proveedor
          <select name="provider_status" data-role-field="provider">
            <option value="active" selected>Activo</option>
            <option value="inactive">Inactivo</option>
          </select>
        </label>
        <label class="crm-checkbox-label">
          <input name="provider_is_billable" type="checkbox" checked data-role-field="provider" />
          <span>Proveedor facturable</span>
        </label>
        <label>Notas proveedor
          <textarea name="provider_notes" rows="2" data-role-field="provider"></textarea>
        </label>

        <h3>Faceta agencia</h3>
        <label class="crm-checkbox-label">
          <input id="client-create-as-agency" name="as_agency" type="checkbox" />
          <span>Activar agencia</span>
        </label>
        <label>Codigo agencia
          <input name="agency_code" type="text" data-role-field="agency" />
        </label>
        <label>Scope agencia
          <select name="agency_scope" data-role-field="agency">
            <option value="buyer">Comprador</option>
            <option value="seller">Vendedor</option>
            <option value="rental">Alquiler</option>
            <option value="mixed" selected>Mixto</option>
          </select>
        </label>
        <label>Estado agencia
          <select name="agency_status" data-role-field="agency">
            <option value="active" selected>Activo</option>
            <option value="inactive">Inactivo</option>
            <option value="discarded">Descartado</option>
          </select>
        </label>
        <label class="crm-checkbox-label">
          <input name="agency_is_referral_source" type="checkbox" checked data-role-field="agency" />
          <span>Fuente de referidos</span>
        </label>
        <label>Notas agencia
          <textarea name="agency_notes" rows="2" data-role-field="agency"></textarea>
        </label>

        <h3>Asignacion inicial de vivienda</h3>
        <p class="crm-inline-note">
          Opcional. La documentacion se carga despues, dentro de la ficha del cliente.
        </p>
        <label>Vivienda inicial
          <select id="client-create-property-id" name="property_id">
            <option value="">Sin asignar</option>
          </select>
        </label>
        <label>Rol comprador
          <select name="buyer_role">
            <option value="primary" selected>Titular</option>
            <option value="co_buyer">Cotitular</option>
            <option value="legal_representative">Representante legal</option>
            <option value="other">Otro</option>
          </select>
        </label>
        <label>Notas de asignacion
          <textarea name="assignment_notes" rows="2" placeholder="Observaciones sobre la vivienda elegida"></textarea>
        </label>

        <div class="crm-actions-row">
          <button type="submit" class="crm-button crm-button-primary">Crear cliente</button>
          <a href="/crm/clients/" class="crm-button crm-button-soft">Cancelar</a>
        </div>
      </form>
    </section>

    <section class="crm-card crm-full">
      <p id="client-create-feedback" class="crm-feedback">
        Completa el formulario. Si eliges vivienda, la asignacion se aplicara justo despues de crear el cliente.
      </p>
    </section>
  </div>
  <script is:inline src="/crm/client-create.js"></script>
</CrmLayout>
