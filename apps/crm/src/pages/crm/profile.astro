---
import CrmLayout from "@crmapp/layouts/CrmLayout.astro";
---
<CrmLayout title="CRM | Perfil" section="profile">
  <div class="crm-stack">
    <section class="crm-card crm-full">
      <h2>Perfil de usuario CRM</h2>
      <p>Datos de sesion activa para tu cuenta interna del CRM.</p>
      <div class="crm-grid">
        <article class="crm-card crm-half">
          <h3>Identidad</h3>
          <ul class="crm-list">
            <li><strong>Nombre:</strong> <span id="crm-profile-page-full-name">-</span></li>
            <li><strong>Email:</strong> <span id="crm-profile-page-email">-</span></li>
            <li><strong>Rol:</strong> <span id="crm-profile-page-role">-</span></li>
          </ul>
        </article>
        <article class="crm-card crm-half">
          <h3>Sesion</h3>
          <ul class="crm-list">
            <li><strong>User ID:</strong> <span id="crm-profile-page-id">-</span></li>
            <li><strong>Ultimo acceso:</strong> <span id="crm-profile-page-last-sign-in">-</span></li>
            <li><strong>Creado:</strong> <span id="crm-profile-page-created-at">-</span></li>
          </ul>
        </article>
      </div>
      <div class="crm-actions-row">
        <button id="crm-profile-page-refresh" type="button" class="crm-button crm-button-soft">Actualizar</button>
        <button id="crm-profile-page-logout" type="button" class="crm-button crm-button-soft">Cerrar sesion</button>
      </div>
      <p id="crm-profile-page-feedback" class="crm-inline-note" role="status" aria-live="polite">
        Cargando perfil...
      </p>
    </section>
  </div>
  <script is:inline src="/crm/profile.js"></script>
</CrmLayout>
