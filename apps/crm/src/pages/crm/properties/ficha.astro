---
import CrmLayout from "@crmapp/layouts/CrmLayout.astro";
---
<CrmLayout title="CRM | Propiedades | Ruta legacy" section="properties">
  <div class="crm-stack">
    <section class="crm-card crm-full">
      <div class="crm-row-between">
        <div>
          <h2>Ruta legacy retirada del flujo principal</h2>
          <p>
            La edicion canonica ahora vive en la ficha individual de propiedad y en la vista de
            promocion. Esta URL se mantiene solo como compatibilidad.
          </p>
          <p class="crm-inline-note">Redirigiendo automaticamente...</p>
        </div>
        <nav class="crm-links crm-subpage-links" aria-label="Navegacion modulo propiedades">
          <a class="crm-link" href="/crm/properties/dashboard/">Dashboard</a>
          <a class="crm-link" href="/crm/properties/listado/">Listado</a>
          <a class="crm-link" href="/crm/properties/nueva/">Nueva propiedad</a>
        </nav>
      </div>
      <div class="crm-actions-row">
        <a id="properties-legacy-target" class="crm-link" href="/crm/properties/listado/">Ir al listado</a>
      </div>
    </section>
  </div>

  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const propertyId = String(params.get("property_id") || "").trim();
      const projectId = String(params.get("project_id") || "").trim();
      const organizationId = String(params.get("organization_id") || "").trim();
      const nextParams = new URLSearchParams();

      if (organizationId) nextParams.set("organization_id", organizationId);

      let target = "/crm/properties/listado/";
      if (propertyId) {
        target = `/crm/properties/propiedad/${encodeURIComponent(propertyId)}/`;
      } else if (projectId) {
        target = `/crm/properties/promocion/${encodeURIComponent(projectId)}/`;
      }

      const suffix = nextParams.toString();
      const destination = suffix ? `${target}?${suffix}` : target;
      const link = document.getElementById("properties-legacy-target");
      if (link instanceof HTMLAnchorElement) link.href = destination;

      window.setTimeout(() => {
        window.location.replace(destination);
      }, 160);
    })();
  </script>
</CrmLayout>
