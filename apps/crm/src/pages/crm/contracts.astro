---
import CrmLayout from "@crmapp/layouts/CrmLayout.astro";
---
<CrmLayout title="CRM | Contratos" section="contracts">
  <div class="crm-stack">
    <section class="crm-card crm-full">
      <h2>Contratos</h2>
      <p class="crm-inline-note">
        Modulo temporalmente fuera de navegacion hasta conectar CRUD real sobre <code>crm.contracts</code>.
      </p>
      <div class="crm-actions-row">
        <a class="crm-link" href="/crm/deals/">Volver a deals</a>
        <a class="crm-link" href="/crm/clients/dashboard/">Volver a clientes</a>
      </div>
    </section>
  </div>
</CrmLayout>
