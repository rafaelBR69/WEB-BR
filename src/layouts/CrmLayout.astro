---
import "@/styles/crm/base.css";

type NavItem = {
  href: string;
  label: string;
  key: string;
};

type SubNavItem = {
  href: string;
  label: string;
  exact?: boolean;
};

const {
  title = "CRM | BlancaReal",
  description = "Panel interno para gestion de clientes, propiedades y operaciones.",
  section = "dashboard",
} = Astro.props;
const defaultOrganizationId = String(
  import.meta.env.PUBLIC_CRM_ORGANIZATION_ID ?? import.meta.env.CRM_ORGANIZATION_ID ?? ""
).trim();

const navItems: NavItem[] = [
  { key: "dashboard", label: "Dashboard", href: "/crm/" },
  { key: "profile", label: "Perfil", href: "/crm/profile/" },
  { key: "admin", label: "Permisos", href: "/crm/admin/permisos/" },
  { key: "leads", label: "Leads", href: "/crm/leads/dashboard/" },
  { key: "agencies", label: "Agencias", href: "/crm/agencies/dashboard/" },
  { key: "notifications", label: "Notificaciones", href: "/crm/notifications/" },
  { key: "properties", label: "Propiedades", href: "/crm/properties/" },
  { key: "clients", label: "Clientes", href: "/crm/clients/dashboard/" },
  { key: "portal", label: "Portal", href: "/crm/portal/" },
  { key: "contracts", label: "Contratos", href: "/crm/contracts/" },
  { key: "invoices", label: "Facturacion", href: "/crm/invoices/" },
];

const propertiesSubNav: SubNavItem[] = [
  { href: "/crm/properties/dashboard/", label: "Dashboard" },
  { href: "/crm/properties/listado/", label: "Listado" },
  { href: "/crm/properties/nueva/", label: "Nueva propiedad" },
  { href: "/crm/properties/ficha/", label: "Ficha y media" },
];

const clientsSubNav: SubNavItem[] = [
  { href: "/crm/clients/dashboard/", label: "Dashboard KPI", exact: true },
  { href: "/crm/clients/", label: "Listado clientes", exact: true },
  { href: "/crm/clients/?client_role=provider", label: "Proveedores", exact: true },
  { href: "/crm/agencies/", label: "Agencias", exact: true },
];

const agenciesSubNav: SubNavItem[] = [
  { href: "/crm/agencies/dashboard/", label: "Dashboard", exact: true },
  { href: "/crm/agencies/", label: "Listado", exact: true },
  { href: "/crm/agencies/contacts/", label: "Contactos", exact: true },
  { href: "/crm/agencies/duplicates/", label: "Duplicados", exact: true },
  { href: "/crm/leads/nuevo/?lead_kind=agency", label: "Nuevo lead agencia", exact: true },
];

const portalSubNav: SubNavItem[] = [
  { href: "/crm/portal/", label: "Dashboard", exact: true },
  { href: "/crm/portal/invites/", label: "Invites", exact: true },
  { href: "/crm/portal/users/", label: "Usuarios", exact: true },
  { href: "/crm/portal/operations/", label: "Operativa", exact: true },
  { href: "/crm/portal/content/", label: "Contenido", exact: true },
  { href: "/crm/portal/documents/", label: "Documentos", exact: true },
  { href: "/crm/portal/logs/", label: "Logs", exact: true },
];

const adminSubNav: SubNavItem[] = [
  { href: "/crm/admin/permisos/", label: "Usuarios internos", exact: true },
];

const leadsSubNav: SubNavItem[] = [
  { href: "/crm/leads/dashboard/", label: "Dashboard", exact: true },
  { href: "/crm/leads/", label: "Listado y ficha", exact: true },
  { href: "/crm/leads/nuevo/", label: "Nuevo lead", exact: true },
  { href: "/crm/leads/comunicaciones/", label: "Comunicaciones", exact: true },
];

const subNavBySection: Record<string, SubNavItem[]> = {
  admin: adminSubNav,
  leads: leadsSubNav,
  agencies: agenciesSubNav,
  properties: propertiesSubNav,
  clients: clientsSubNav,
  portal: portalSubNav,
};

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const currentSearchParams = Astro.url.searchParams;

const isActive = (href: string) => {
  const normalizedHref = href.replace(/\/+$/, "") || "/";
  if (normalizedHref === "/crm") return currentPath === "/crm";
  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
};

const isTopLevelActive = (item: NavItem) => section === item.key || isActive(item.href);

const isSubActive = (item: SubNavItem) => {
  const itemUrl = new URL(item.href, Astro.url);
  const normalizedHref = itemUrl.pathname.replace(/\/+$/, "") || "/";
  const pathMatches = item.exact
    ? currentPath === normalizedHref
    : currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);

  if (!pathMatches) return false;
  if (!itemUrl.searchParams.size) return true;

  for (const [key, value] of itemUrl.searchParams.entries()) {
    if (currentSearchParams.get(key) !== value) {
      return false;
    }
  }

  return true;
};

const sectionLabel = navItems.find((item) => item.key === section)?.label ?? "CRM";
const currentPathWithSearch = `${currentPath}${Astro.url.search}`;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline src="/crm/dictionaries.js"></script>
  </head>
  <body class="crm-body">
    <div class="crm-shell">
      <aside class="crm-sidebar">
        <a class="crm-brand" href="/crm/" aria-label="Ir al inicio del CRM">
          <span class="crm-brand-mark">BR</span>
          <span class="crm-brand-text">BlancaReal CRM</span>
        </a>

        <nav aria-label="Navegacion CRM">
          <ul class="crm-nav">
            {navItems.map((item) => (
              <li>
                <a href={item.href} class={isTopLevelActive(item) ? "is-active" : ""}>
                  {item.label}
                </a>
                {(subNavBySection[item.key]?.length ?? 0) > 0 && isTopLevelActive(item) && (
                  <ul class="crm-subnav">
                    {subNavBySection[item.key].map((subItem) => (
                      <li>
                        <a href={subItem.href} class={isSubActive(subItem) ? "is-active" : ""}>
                          {subItem.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>

        <div class="crm-sidebar-footer">
          <p>Zona interna separada de la web publica.</p>
          <a href="/es/">Ir a web publica</a>
        </div>
      </aside>

      <div class="crm-main">
        <header class="crm-topbar">
          <div>
            <p class="crm-eyebrow">CRM</p>
            <h1>{sectionLabel}</h1>
          </div>
          <div class="crm-topbar-right">
            <code class="crm-path">{currentPath}/</code>
          </div>
        </header>

        <main class="crm-content">
          <slot />
        </main>
      </div>
    </div>
    <script is:inline define:vars={{ defaultOrganizationId }}>
      window.__crmDefaultOrganizationId = defaultOrganizationId;
    </script>
    <script is:inline>
      (() => {
        const key = "crm.organization_id";
        const defaultOrgId = String(window.__crmDefaultOrganizationId || "").trim();
        if (!defaultOrgId) return;
        try {
          const current = String(window.localStorage.getItem(key) || "").trim();
          if (!current) {
            window.localStorage.setItem(key, defaultOrgId);
          }
        } catch {
          // no-op
        }
      })();
    </script>
    <script is:inline>
      (() => {
        window.crmLabels?.applySelectDictionaries?.(document);
      })();
    </script>
    <script is:inline>
      (() => {
        const tables = document.querySelectorAll(".crm-table");
        tables.forEach((table) => {
          const headers = Array.from(table.querySelectorAll("thead th")).map((th) =>
            String(th.textContent || "").trim()
          );
          if (!headers.length) return;
          table.querySelectorAll("tbody tr").forEach((row) => {
            const cells = row.querySelectorAll("td");
            cells.forEach((cell, index) => {
              if (!cell.getAttribute("data-label")) {
                const label = headers[index] || `Campo ${index + 1}`;
                cell.setAttribute("data-label", label);
              }
            });
          });
        });
      })();
    </script>
  </body>
</html>
