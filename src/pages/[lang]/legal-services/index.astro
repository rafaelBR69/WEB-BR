const t = copyByLang[lang] ?? copyByLang.es;

const stepLabelByLang = {
  es: "Paso",
  en: "Step",
  de: "Schritt",
  fr: "Etape",
  it: "Fase",
  nl: "Stap",
};

const stepLabel = stepLabelByLang[lang] ?? stepLabelByLang.en;
---

<BaseLayout
  title={t.title}
  description={t.description}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
>
  <div class="legal-page">
    <section class="legal-hero">
      <div class="container legal-hero__shell">
        <div class="legal-hero__copy">
          <span class="service-eyebrow">{t.eyebrow}</span>
          <h1>{t.heading}</h1>
          <p>{t.intro}</p>
          <div class="legal-hero__meta">
            <span class="legal-seal" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M12 3l7 3v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6l7-3z" stroke="currentColor" stroke-width="1.8" />
              </svg>
            </span>
            <span class="legal-note">{t.focusTitle}</span>
          </div>
          <a class="service-cta legal-cta" href={`/${lang}/contact/?service=legal-services`}>
            {t.cta}
          </a>
        </div>

        <aside class="legal-trust" aria-label={t.blockTitleA}>
          {t.stats.map((item) => (
            <div class="legal-trust__item">
              <span class="legal-trust__value">{item.value}</span>
              <span class="legal-trust__label">{item.label}</span>
            </div>
          ))}
        </aside>
      </div>
    </section>

    <section class="legal-section container">
      <div class="service-section-heading">
        <span class="service-mini-eyebrow">{t.blockTitleA}</span>
        <h2>{t.focusTitle}</h2>
        <p>{t.focusIntro}</p>
      </div>

      <div class="legal-grid">
        <div class="legal-pillar-grid">
          {t.services.map((item, index) => (
            <article class="legal-pillar">
              <span class="legal-pillar__index">0{index + 1}</span>
              <h3>{item}</h3>
            </article>
          ))}
        </div>

        <aside class="legal-dossier">
          <h3>{t.dossierTitle}</h3>
          <p>{t.dossierIntro}</p>
          <ul>
            {t.dossier.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section class="legal-section container">
      <div class="service-section-heading">
        <span class="service-mini-eyebrow">{t.blockTitleB}</span>
        <h2>{t.blockTitleB}</h2>
        <p>{t.intro}</p>
      </div>

      <div class="legal-process">
        {t.process.map((item, index) => (
          <article class="legal-process-card">
            <span class="legal-process-card__step">{stepLabel} {index + 1}</span>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="legal-section container">
      <div class="service-section-heading">
        <span class="service-mini-eyebrow">{t.riskTitle}</span>
        <h2>{t.riskTitle}</h2>
        <p>{t.description}</p>
      </div>

      <div class="legal-risk-grid">
        {t.risks.map((risk) => (
          <article class="legal-risk-card">
            <span class="legal-risk-card__tag">{risk.label}</span>
            <h3>{risk.title}</h3>
            <p>{risk.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="legal-section container">
      <div class="legal-cta-band">
        <div class="service-section-heading">
          <span class="service-mini-eyebrow">{t.eyebrow}</span>
          <h2>{t.finalTitle}</h2>
          <p>{t.finalIntro}</p>
        </div>
        <a class="service-cta legal-cta" href={`/${lang}/contact/?service=legal-services`}>
          {t.cta}
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
