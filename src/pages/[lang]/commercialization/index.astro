---

<BaseLayout
  title={t.title}
  description={t.description}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
>
  <div class="comm-page">
    <section class="comm-hero">
      <div class="container comm-hero__layout">
        <div class="comm-hero__copy">
          <span class="service-eyebrow">{t.eyebrow}</span>
          <h1>{t.heading}</h1>
          <p>{t.intro}</p>
          <div class="comm-hero__actions">
            <a class="service-cta comm-hero__cta" href={`/${lang}/contact/?service=commercialization`}>
              {t.cta}
            </a>
            <span class="comm-hero__badge">{t.historyDesde}</span>
          </div>
        </div>

        <aside class="comm-kpis" aria-label={t.portfolioTitle}>
          {t.stats.map((item) => (
            <div class="comm-kpi">
              <span class="comm-kpi__value">{item.value}</span>
              <span class="comm-kpi__label">{item.label}</span>
            </div>
          ))}
        </aside>
      </div>
    </section>

    <div class="service-shell">
      <section class="comm-section container">
        <div class="service-section-heading">
          <span class="service-mini-eyebrow">{t.blockTitleB}</span>
          <h2>{t.blockTitleB}</h2>
          <p>{t.description}</p>
        </div>

        <div class="comm-card-grid">
          {t.process.map((step, index) => (
            <article class="comm-card">
              <span class="comm-card__index">0{index + 1}</span>
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
              {t.services[index] && (
                <ul>
                  <li>{t.services[index]}</li>
                </ul>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="comm-section container">
        <div class="comm-dual">
          <article class="comm-coverage">
            <div class="service-section-heading">
              <span class="service-mini-eyebrow">{t.blockTitleA}</span>
              <h2>{t.coverageTitle}</h2>
              <p>{t.intro}</p>
            </div>
            <div class="comm-coverage__grid">
              {t.coverageAreas.map((area) => (
                <div class:list={["comm-area", { "is-highlight": area.highlight }]}>
                  {area.name}
                </div>
              ))}
            </div>
          </article>

          <aside class="comm-service-panel">
            <h3>{t.blockTitleB}</h3>
            <p>{t.description}</p>
            <ul class="comm-check-list">
              {t.services.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </aside>
        </div>
      </section>

      <section class="comm-section container">
        <div class="service-section-heading">
          <span class="service-mini-eyebrow">{t.portfolioTitle}</span>
          <h2>{t.portfolioTitle}</h2>
          <p>{t.intro}</p>
        </div>

        <div class="comm-showcase">
          {t.portfolio.map((project) => (
            <article class="comm-property-card">
              <img src={project.image} alt={project.name} loading="lazy" />
              <div class="comm-property-card__overlay">
                <span class="comm-property-card__location">{project.location}</span>
                <h3 class="comm-property-card__title">{project.name}</h3>
                <p class="comm-property-card__body">{showcaseBody}</p>
                <a class="comm-property-card__cta" href={`/${lang}/properties/${project.slug}/`}>
                  {projectCta}
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="comm-section container">
        <div class="service-section-heading">
          <span class="service-mini-eyebrow">{t.blockTitleB}</span>
          <h2>{t.blockTitleB}</h2>
          <p>{t.intro}</p>
        </div>

        <div class="comm-flow">
          {t.process.map((step, index) => (
            <article class="comm-flow__step">
              <span class="comm-flow__num">{index + 1}</span>
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </article>
          ))}
        </div>

        <div class="comm-cta-band">
          <div class="service-section-heading">
            <span class="service-mini-eyebrow">{t.eyebrow}</span>
            <h2>{t.heading}</h2>
            <p>{t.description}</p>
          </div>
          <a class="service-cta comm-hero__cta" href={`/${lang}/contact/?service=commercialization`}>
            {t.cta}
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
