---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { DEFAULT_LANG, SUPPORTED_LANGS, isSupportedLang } from "@/i18n/languages";
import BrandLogo from "@/components/BrandLogo.astro";
import "@/styles/pages/portal.css";

const langParam = Astro.params.lang ?? DEFAULT_LANG;
if (!isSupportedLang(langParam)) {
  return Astro.redirect(`/${DEFAULT_LANG}/portal/`, 302);
}

const lang = langParam;
const defaultOrganizationId = String(
  import.meta.env.PUBLIC_CRM_ORGANIZATION_ID ?? import.meta.env.CRM_ORGANIZATION_ID ?? ""
).trim();

const copyByLang = {
  es: {
    title: "Portal | Dashboard",
    description: "Portal profesional para consultar promociones y documentacion comercial.",
    eyebrow: "Portal dashboard",
    heading: "Panel de promociones y biblioteca documental",
    intro:
      "Vista consolidada de tus promociones activas para revisar contenido visual y documentacion publicada.",
    heroTagsLabel: "Fortalezas del portal",
    heroTagPortfolio: "Promociones sincronizadas",
    heroTagDocuments: "Documentos con descarga segura",
    heroTagCompliance: "Sesion segura por rol",
    refreshCta: "Actualizar panel",
    logoutCta: "Cerrar sesion",
    activateCta: "Activar otra cuenta",
    workflowTitle: "Flujo recomendado",
    workflowHint: "Secuencia breve para operar rapido y con menos errores.",
    workflowStep1: "Valida cuenta activa y promociones autorizadas.",
    workflowStep2: "Abre la promocion para revisar material visual y comercial.",
    workflowStep3: "Descarga la documentacion necesaria para seguimiento con cliente.",
    accountTitle: "Cuenta portal",
    accountHint: "Acceso activo con permisos por rol y promociones asignadas.",
    accountLoading: "Cargando sesion...",
    kpiProjects: "Promociones autorizadas",
    kpiDocuments: "Documentos visibles",
    projectsTitle: "Promociones autorizadas",
    projectsHint: "Listado de promociones vinculadas desde Mis Propiedades.",
    projectsListLabel: "Listado de promociones autorizadas",
    noProjects: "No hay promociones activas asignadas.",
    dashboardLoading: "Cargando panel...",
  },
  en: {
    title: "Portal | Dashboard",
    description: "Professional portal to review projects and commercial documents.",
    eyebrow: "Portal dashboard",
    heading: "Projects and document library panel",
    intro:
      "Consolidated view of your active projects to review visual content and published documentation.",
    heroTagsLabel: "Portal highlights",
    heroTagPortfolio: "Projects synced from My Properties",
    heroTagDocuments: "Secure document download",
    heroTagCompliance: "Secure role-based session",
    refreshCta: "Refresh dashboard",
    logoutCta: "Sign out",
    activateCta: "Activate another account",
    workflowTitle: "Recommended flow",
    workflowHint: "Short sequence to work faster and reduce operating mistakes.",
    workflowStep1: "Validate active account and authorized projects.",
    workflowStep2: "Open the project to review visual and commercial material.",
    workflowStep3: "Download the required documentation for customer follow-up.",
    accountTitle: "Portal account",
    accountHint: "Active access with role-based permissions and assigned projects.",
    accountLoading: "Loading session...",
    kpiProjects: "Authorized projects",
    kpiDocuments: "Visible documents",
    projectsTitle: "Authorized projects",
    projectsHint: "Projects linked from My Properties.",
    projectsListLabel: "Authorized project list",
    noProjects: "No active projects assigned yet.",
    dashboardLoading: "Loading dashboard...",
  },
};

const t = copyByLang[lang] ?? copyByLang.en;
---

<BaseLayout
  title={`${t.title} | BlancaReal`}
  description={t.description}
  lang={lang}
  availableLangs={SUPPORTED_LANGS}
  showMobileStickyCta={false}
>
  <div class="portal-scene">
    <!-- SIDEBAR -->
    <aside class="portal-sidebar desktop-only">
      <div class="sidebar-brand">
        <BrandLogo variant="wordmark" href={`/${lang}/`} />
      </div>
      
      <nav class="sidebar-nav">
        <a href={`/${lang}/portal/`} class="nav-item active">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
          Dashboard
        </a>
        <a href={`/${lang}/properties/`} class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          Properties
        </a>
        <a href="#" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          Documents
        </a>
      </nav>

      <div class="sidebar-footer">
        <button id="portal-dashboard-logout" class="logout-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          {t.logoutCta}
        </button>
      </div>
    </aside>

    <!-- CONTENT AREA -->
    <main class="portal-main">
      <header class="portal-header">
        <div class="header-welcome">
          <h1>{t.heading}</h1>
          <p>{t.intro}</p>
        </div>
        <div class="header-actions">
          <button id="portal-dashboard-refresh" class="btn-refresh" title={t.refreshCta}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
          </button>
          <a class="btn-activate" href={`/${lang}/portal/activate/`}>
            {t.activateCta}
          </a>
        </div>
      </header>

      <div class="portal-content-grid">
        <!-- STAT CARDS -->
        <div class="portal-stats">
          <div class="stat-card">
            <div class="stat-icon luxury-gold">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.27 5.82 21 7 14.14l-5-4.87 6.91-1.01L12 2z"></path></svg>
            </div>
            <div class="stat-info">
              <span class="stat-label">{t.kpiProjects}</span>
              <strong id="portal-kpi-projects">0</strong>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon luxury-blue">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            </div>
            <div class="stat-info">
              <span class="stat-label">{t.kpiDocuments}</span>
              <strong id="portal-kpi-documents">0</strong>
            </div>
          </div>
        </div>

        <!-- MAIN CARDS -->
        <div class="content-columns">
          <div class="main-column">
            <section class="luxury-section">
              <div class="section-header">
                <h2>{t.projectsTitle}</h2>
                <p>{t.projectsHint}</p>
              </div>
              <div id="portal-dashboard-projects" class="project-elegant-grid">
                <div class="portal-empty">{t.noProjects}</div>
              </div>
            </section>
          </div>

          <aside class="side-column">
            <section class="account-widget">
              <h3>{t.accountTitle}</h3>
              <div id="portal-dashboard-account" class="account-status">
                <p>{t.accountLoading}</p>
              </div>
            </section>

            <section class="workflow-widget">
              <h3>{t.workflowTitle}</h3>
              <ol class="luxury-steps">
                <li><span>1</span> {t.workflowStep1}</li>
                <li><span>2</span> {t.workflowStep2}</li>
                <li><span>3</span> {t.workflowStep3}</li>
              </ol>
            </section>
          </aside>
        </div>
      </div>

      <footer class="portal-footer">
        <p id="portal-dashboard-feedback" class="status-indicator" role="status" aria-live="polite">
          {t.dashboardLoading}
        </p>
      </footer>
    </main>
  </div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap');

    .portal-scene {
      display: flex;
      min-height: 100vh;
      background: #f8fafc;
      font-family: 'Outfit', sans-serif;
      color: #0f172a;
    }

    /* SIDEBAR */
    .portal-sidebar {
      width: 260px;
      background: #00152e;
      color: white;
      display: flex;
      flex-direction: column;
      padding: 40px 0;
      position: sticky;
      top: 0;
      height: 100vh;
      border-right: 1px solid rgba(255,255,255,0.05);
    }

    .sidebar-brand {
      padding: 0 32px 40px;
    }

    .sidebar-brand a {
      font-size: 1.4rem;
      font-weight: 700;
      color: white;
      text-decoration: none;
      letter-spacing: -0.5px;
    }

    .sidebar-brand span { color: #de1f38; }

    .sidebar-nav {
      display: flex;
      flex-direction: column;
      gap: 4px;
      flex-grow: 1;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px 32px;
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      font-weight: 500;
      font-size: 0.9rem;
      border-left: 3px solid transparent;
      letter-spacing: 0.3px;
    }

    .nav-item:hover {
      color: white;
      background: rgba(255,255,255,0.03);
    }

    .nav-item.active {
      color: white;
      background: rgba(212, 175, 55, 0.05);
      border-left-color: #D4AF37;
    }

    .nav-item svg {
      width: 18px;
      height: 18px;
      transition: transform 0.3s;
    }

    .nav-item:hover svg {
      transform: translateX(2px);
    }

    .sidebar-footer {
      padding: 24px 32px;
      border-top: 1px solid rgba(255,255,255,0.05);
    }

    .logout-link {
      display: flex;
      align-items: center;
      gap: 10px;
      background: transparent;
      border: 0;
      color: rgba(255,255,255,0.4);
      cursor: pointer;
      font-family: inherit;
      font-size: 0.85rem;
      transition: all 0.3s;
    }

    .logout-link:hover { color: #de1f38; }

    /* MAIN CONTENT */
    .portal-main {
      flex-grow: 1;
      padding: 40px 60px;
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
    }

    .portal-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 40px;
    }

    .header-welcome h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem;
      color: #001E44;
      margin: 0 0 0.5rem;
    }

    .header-welcome p {
      color: #64748b;
      font-size: 1.1rem;
      font-weight: 300;
    }

    .header-actions {
      display: flex;
      gap: 12px;
    }

    .btn-refresh {
      background: white;
      border: 1px solid #e2e8f0;
      padding: 10px;
      border-radius: 8px;
      cursor: pointer;
      color: #64748b;
      transition: all 0.3s;
    }

    .btn-refresh:hover { border-color: #001E44; color: #001E44; }

    .btn-activate {
      background: #e2e8f0;
      color: #0f172a;
      text-decoration: none;
      padding: 10px 20px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.3s;
    }

    .btn-activate:hover { background: #cbd5e1; }

    /* STATS */
    .portal-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 24px;
      margin-bottom: 40px;
    }

    .stat-card {
      background: white;
      padding: 24px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      gap: 20px;
      box-shadow: 0 4px 20px rgba(0,30,68,0.03);
      border: 1px solid rgba(0,30,68,0.05);
    }

    .stat-icon {
      width: 52px;
      height: 52px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .luxury-gold { background: rgba(212, 175, 55, 0.1); color: #D4AF37; }
    .luxury-blue { background: rgba(0, 30, 68, 0.05); color: #001E44; }

    .stat-label {
      display: block;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #94a3b8;
      font-weight: 600;
    }

    .stat-info strong {
      font-size: 2rem;
      font-weight: 700;
      color: #001E44;
    }

    /* GRID COLUMNS */
    .content-columns {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 40px;
      align-items: start;
    }

    .luxury-section .section-header {
      margin-bottom: 24px;
    }

    .luxury-section h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.2rem;
      color: #001E44;
      margin-bottom: 0.5rem;
    }

    .luxury-section p { color: #94a3b8; font-size: 0.95rem; }

    /* PROJECT CARDS - These will be rendered by dashboard.js */
    .project-elegant-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 24px;
    }

    /* WIDGETS */
    .account-widget, .workflow-widget {
      background: white;
      padding: 32px;
      border-radius: 12px;
      margin-bottom: 24px;
      border: 1px solid rgba(0,30,68,0.05);
    }

    .account-widget h3, .workflow-widget h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      color: #001E44;
    }

    .luxury-steps {
      list-style: none;
      padding: 0;
      display: grid;
      gap: 1.2rem;
    }

    .luxury-steps li {
      display: flex;
      gap: 15px;
      font-size: 0.9rem;
      line-height: 1.5;
      color: #64748b;
    }

    .luxury-steps span {
      flex-shrink: 0;
      width: 24px;
      height: 24px;
      background: #001E44;
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 800;
    }

    .status-indicator {
      font-size: 0.8rem;
      color: #94a3b8;
      text-align: right;
      margin-top: 40px;
    }

    /* CUSTOM PROJECT ITEM STYLES (for dynamic content) */
    :global(.portal-item) {
      background: white;
      border: 1px solid #f1f5f9;
      border-radius: 12px;
      padding: 24px;
      transition: all 0.3s;
    }

    :global(.portal-item:hover) {
      box-shadow: 0 10px 30px rgba(0,30,68,0.06);
      border-color: #e2e8f0;
      transform: translateY(-4px);
    }

    :global(.portal-item-title) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 600;
      color: #001E44;
      margin-bottom: 10px;
    }

    :global(.portal-item-meta) {
      font-size: 0.85rem;
      color: #64748b;
      margin-bottom: 5px;
    }

    :global(.portal-badges) {
      margin: 15px 0;
      display: flex;
      gap: 8px;
    }

    :global(.portal-badge) {
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    :global(.portal-badge.role) { background: #f1f5f9; color: #475569; }
    :global(.portal-badge.ok) { background: #ecfdf5; color: #059669; }

    :global(.portal-button-soft) {
      display: inline-block;
      width: 100%;
      text-align: center;
      background: #001E44;
      color: white;
      text-decoration: none;
      padding: 12px;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 600;
      margin-top: 15px;
      transition: background 0.3s;
    }

    :global(.portal-button-soft:hover) { background: #de1f38; }

    @media (max-width: 1200px) {
      .content-columns { grid-template-columns: 1fr; }
    }

    @media (max-width: 900px) {
      .portal-sidebar { display: none; }
      .portal-main { padding: 30px 20px; }
      .header-welcome h1 { font-size: 2.2rem; }
    }
  </style>

  <script is:inline define:vars={{ defaultOrganizationId, lang }}>
    window.__portalBootstrap = {
      ...(window.__portalBootstrap || {}),
      lang,
      defaultOrganizationId,
    };
  </script>
  <script type="module" src="/portal/dashboard.js"></script>
</BaseLayout>
