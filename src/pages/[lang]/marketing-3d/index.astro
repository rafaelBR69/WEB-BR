---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { DEFAULT_LANG, isSupportedLang, SUPPORTED_LANGS } from "@/i18n/languages";
import { getUiCopy } from "@/i18n/ui";
import "@/styles/pages/marketing-3d.css";

const langParam = Astro.params.lang ?? DEFAULT_LANG;

if (!isSupportedLang(langParam)) {
  return Astro.redirect(`/${DEFAULT_LANG}/marketing-3d/`, 302);
}

const lang = langParam;
const ui = getUiCopy(lang);

const landingNavItems = [
  { href: `/${lang}/real-estate/`, label: ui.layout.navRealEstate },
  { href: `/${lang}/commercialization/`, label: ui.layout.navPromoters },
  { href: `/${lang}/legal-services/`, label: ui.layout.navLegalServices },
  { href: `/${lang}/contact/`, label: ui.layout.navContact },
];

const copyByLang = {
  es: {
    title: "Marketing 3D | BlancaReal",
