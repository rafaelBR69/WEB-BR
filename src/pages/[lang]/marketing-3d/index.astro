    closingPrimary: "Hablar con el equipo",
    closingSecondary: "Ver comercializacion",
  },
  en: {
    title: "3D Marketing | BlancaReal",
    description:
      "Real estate 3D marketing on the Costa del Sol: professional photography, drones, 3D modeling and tailored strategic campaigns.",
