    sections: {
      solutionsEyebrow: "Our visual and strategic solutions",
      solutionsHeading: "Four modules, one mission",
      solutionsIntro:
        "Each format plays a different role in the sales journey. Together they build desire, transparency and commercial speed.",
      flowEyebrow: "Launch sequence",
      flowHeading: "From first frame to ideal buyer",
      flowIntro:
        "We approach sales as progression: catch attention, elevate perception, make the future tangible and convert visibility into qualified demand.",
