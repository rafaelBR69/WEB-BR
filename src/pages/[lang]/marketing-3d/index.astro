    headingMain: "Real estate 3D marketing on the Costa del Sol",
    headingSub: "Visuals built to trigger the sale",
    intro:
      "We turn each asset into a visual and strategic stage set: we capture better light, lift perspective, build hyperreal spaces and launch campaigns designed for the right buyer.",
    primaryCta: "Request visual proposal",
    secondaryCta: "Go to contact",
    stats: [
      { value: "4 modules", label: "capture, flight, render and campaign" },
