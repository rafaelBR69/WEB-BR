---
import CrmLayout from "@/layouts/CrmLayout.astro";
import "@/styles/crm/client-ficha.css";

const clientId = String(Astro.params.id ?? "").trim();
const backUrl = `/crm/clients/${Astro.url.search}`;
---
<CrmLayout title="CRM | Ficha de Cliente" section="clients">
  <div class="cd-page">

    <section class="cd-shellhead">
      <div class="cd-shellhead-main">
        <a href={backUrl} class="cd-back-btn">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M3.83 7H14a1 1 0 1 1 0 2H3.83l3.58 3.58a1 1 0 0 1-1.41 1.42l-5.3-5.29a1 1 0 0 1 0-1.42L5.99 1.99a1 1 0 1 1 1.42 1.42L3.83 7Z"/></svg>
          Volver a clientes
        </a>
        <p class="cd-context-eyebrow">Cliente</p>
        <h1 class="cd-shellhead-title">Ficha de cliente</h1>
        <p class="cd-shellhead-copy">Vista comercial unificada con contacto, propiedad, documentación y atribución.</p>
      </div>
      <div class="cd-shellhead-side">
        <nav class="cd-module-nav" aria-label="Navegacion modulo clientes">
          <a href="/crm/clients/dashboard/">Dashboard</a>
          <a href="/crm/clients/">Listado</a>
        </nav>
        <div class="cd-topbar-actions">
          <button id="client-edit-toggle" type="button" class="cd-btn cd-btn-ghost">Editar</button>
          <button id="client-delete" type="button" class="cd-btn cd-btn-danger">Eliminar</button>
        </div>
      </div>
    </section>

    <!-- HERO HEADER -->
    <div class="cd-hero">
      <div class="cd-hero-avatar" id="client-hero-avatar">?</div>
      <div class="cd-hero-info">
        <div class="cd-hero-badges">
          <span id="client-status-badge" class="cd-badge">Cargando...</span>
          <span id="client-type-badge" class="cd-badge">—</span>
          <span id="client-channel-badge" class="cd-badge">—</span>
        </div>
        <h2 id="client-detail-title" class="cd-hero-name">Ficha de Cliente</h2>
        <p id="client-detail-subtitle" class="cd-hero-sub">Cargando información...</p>
      </div>
      <div class="cd-hero-actions">
        <a id="action-whatsapp" href="#" class="cd-contact-btn whatsapp" target="_blank" rel="noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.29-.15-1.72-.85-1.99-.95s-.46-.15-.65.15-.75.95-.92 1.14-.34.22-.63.07a7.94 7.94 0 0 1-2.34-1.44 8.78 8.78 0 0 1-1.62-2c-.17-.29 0-.45.13-.6s.29-.34.44-.51a2 2 0 0 0 .29-.49.54.54 0 0 0 0-.52c-.07-.15-.65-1.57-.89-2.15s-.47-.49-.65-.49h-.55a1.06 1.06 0 0 0-.77.36 3.24 3.24 0 0 0-1 2.41 5.64 5.64 0 0 0 1.18 3c.15.2 2.1 3.2 5.09 4.49a17.24 17.24 0 0 0 1.7.63 4.1 4.1 0 0 0 1.88.12 3 3 0 0 0 1.95-1.38 2.41 2.41 0 0 0 .17-1.38c-.07-.12-.26-.19-.55-.34ZM12 2A10 10 0 0 0 2 12a9.89 9.89 0 0 0 1.38 5.09L2 22l5.1-1.34A10 10 0 1 0 12 2Z"/></svg>
          WhatsApp
        </a>
        <a id="action-email" href="#" class="cd-contact-btn email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
          Email
        </a>
        <a id="action-call" href="#" class="cd-contact-btn call">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.38h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.06-.9a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          Llamar
        </a>
      </div>
    </div>

    <section class="cd-signal-grid" aria-label="Resumen cliente">
      <article class="cd-signal-card">
        <span class="cd-signal-label">Estado y canal</span>
        <strong id="client-signal-status">Cargando...</strong>
        <small id="client-signal-channel">-</small>
      </article>
      <article class="cd-signal-card">
        <span class="cd-signal-label">Origen comercial</span>
        <strong id="client-signal-agency">-</strong>
        <small id="client-signal-agent">-</small>
      </article>
      <article class="cd-signal-card">
        <span class="cd-signal-label">Interes comprador</span>
        <strong id="client-signal-budget">-</strong>
        <small id="client-signal-location">-</small>
      </article>
      <article class="cd-signal-card">
        <span class="cd-signal-label">Asignacion actual</span>
        <strong id="client-signal-property">-</strong>
        <small id="client-signal-docs">-</small>
      </article>
    </section>

    <!-- MAIN GRID -->
    <div class="cd-grid">

      <!-- LEFT COLUMN -->
      <div class="cd-col-main">

        <!-- Identidad -->
        <div class="cd-card">
          <div class="cd-card-header">
            <h3 class="cd-card-title">Identidad y Contacto</h3>
          </div>
          <div class="cd-data-grid">
            <div class="cd-data-item"><span class="cd-label">Nombre completo</span><span class="cd-value" id="d-full-name">—</span></div>
            <div class="cd-data-item"><span class="cd-label">Tipo de cliente</span><span class="cd-value" id="d-client-type">—</span></div>
            <div class="cd-data-item"><span class="cd-label">Email</span><span class="cd-value" id="d-email">—</span></div>
            <div class="cd-data-item"><span class="cd-label">Teléfono</span><span class="cd-value" id="d-phone">—</span></div>
            <div class="cd-data-item"><span class="cd-label">Nacionalidad</span><span class="cd-value" id="d-nationality">—</span></div>
            <div class="cd-data-item"><span class="cd-label">Fecha de alta</span><span class="cd-value" id="d-intake-date">—</span></div>
          </div>
        </div>

        <!-- Estado Comercial -->
        <div class="cd-card">
          <div class="cd-card-header">
            <h3 class="cd-card-title">Estado Comercial</h3>
          </div>
          <div class="cd-data-grid">
            <div class="cd-data-item"><span class="cd-label">Estado</span><span class="cd-value" id="d-status">—</span></div>
            <div class="cd-data-item"><span class="cd-label">Canal entrada</span><span class="cd-value" id="d-entry-channel">—</span></div>
            <div class="cd-data-item"><span class="cd-label">Agencia</span><span class="cd-value" id="d-agency-name">—</span></div>
            <div class="cd-data-item"><span class="cd-label">Agente</span><span class="cd-value" id="d-agent-name">—</span></div>
          </div>
        </div>

        <!-- Datos Fiscales -->
        <div class="cd-card">
          <div class="cd-card-header">
            <h3 class="cd-card-title">Datos Fiscales</h3>
          </div>
          <div class="cd-data-grid">
            <div class="cd-data-item"><span class="cd-label">Tipo Documento</span><span class="cd-value" id="d-tax-id-type">—</span></div>
            <div class="cd-data-item"><span class="cd-label">Número Documento</span><span class="cd-value" id="d-tax-id">—</span></div>
          </div>
        </div>

        <!-- Preferencias -->
        <div class="cd-card">
          <div class="cd-card-header">
            <h3 class="cd-card-title">Interés y Preferencias</h3>
          </div>
          <div class="cd-budget-row">
            <div class="cd-budget-item">
              <span class="cd-label">Presupuesto</span>
              <span class="cd-budget-value" id="d-budget">—</span>
            </div>
            <div class="cd-budget-item">
              <span class="cd-label">Tipología</span>
              <span class="cd-budget-value" id="d-typology" style="font-size:1rem">—</span>
            </div>
          </div>
          <div style="margin-top:1rem">
            <span class="cd-label">Localización preferida</span>
            <span class="cd-value" id="d-location" style="display:block;margin-top:0.25rem">—</span>
          </div>
        </div>

        <!-- Notas -->
        <div class="cd-card">
          <div class="cd-card-header">
            <h3 class="cd-card-title">Notas y Comentarios</h3>
          </div>
          <div style="display:flex;flex-direction:column;gap:1rem">
            <div id="notes-comments" hidden>
              <span class="cd-label">Comentarios</span>
              <p id="d-comments" class="cd-note-text">—</p>
            </div>
            <div id="notes-report" hidden>
              <span class="cd-label">Reporte</span>
              <p id="d-report-notes" class="cd-note-text">—</p>
            </div>
            <div id="notes-visit" hidden>
              <span class="cd-label">Visita</span>
              <p id="d-visit-notes" class="cd-note-text">—</p>
            </div>
            <div id="notes-reservation" hidden>
              <span class="cd-label">Reserva</span>
              <p id="d-reservation-notes" class="cd-note-text">—</p>
            </div>
            <div id="notes-other" hidden>
              <span class="cd-label">Otros</span>
              <p id="d-other-notes" class="cd-note-text">—</p>
            </div>
            <p id="d-no-notes" class="cd-empty">Sin notas registradas.</p>
          </div>
        </div>

        <!-- Edición -->
        <div class="cd-card" id="client-edit-panel" hidden>
          <div class="cd-card-header">
            <h3 class="cd-card-title">Editar Cliente</h3>
            <button id="client-edit-cancel" type="button" class="cd-btn cd-btn-ghost">Cancelar</button>
          </div>
          <form id="client-edit-form" class="cd-form">
            <div class="cd-form-grid">
              <label class="cd-field"><span>Nombre completo</span><input name="full_name" type="text" required /></label>
              <label class="cd-field"><span>Email</span><input name="email" type="email" /></label>
              <label class="cd-field"><span>Teléfono</span><input name="phone" type="tel" /></label>
              <label class="cd-field"><span>Nacionalidad</span><input name="nationality" type="text" /></label>
              <label class="cd-field"><span>Fecha de alta</span><input name="intake_date" type="date" /></label>
              <label class="cd-field">
                <span>Tipo cliente</span>
                <select name="client_type">
                  <option value="individual">Persona física</option>
                  <option value="company">Persona jurídica</option>
                </select>
              </label>
              <label class="cd-field">
                <span>Canal entrada</span>
                <select name="entry_channel">
                  <option value="website">Web</option>
                  <option value="agency">Agencia</option>
                  <option value="phone">Teléfono</option>
                  <option value="whatsapp">WhatsApp</option>
                  <option value="email">Email</option>
                  <option value="provider">Proveedor</option>
                  <option value="walkin">Oficina</option>
                  <option value="portal">Portal</option>
                  <option value="other">Otro</option>
                </select>
              </label>
              <label class="cd-field">
                <span>Estado</span>
                <select name="client_status">
                  <option value="active">Activo</option>
                  <option value="inactive">Inactivo</option>
                  <option value="discarded">Descartado</option>
                  <option value="blacklisted">Blacklisted</option>
                </select>
              </label>
              <label class="cd-field"><span>Agencia</span><input name="agency_name" type="text" /></label>
              <label class="cd-field"><span>Agente</span><input name="agent_name" type="text" /></label>
              <span class="cd-section-divider">Datos fiscales</span>
              <label class="cd-field">
                <span>Tipo documento</span>
                <select name="tax_id_type">
                  <option value="">Sin definir</option>
                  <option value="dni">DNI</option>
                  <option value="nie">NIE</option>
                  <option value="cif">CIF</option>
                  <option value="passport">Pasaporte</option>
                  <option value="other">Otro</option>
                </select>
              </label>
              <label class="cd-field"><span>Número documento</span><input name="tax_id" type="text" /></label>
              <span class="cd-section-divider">Preferencias</span>
              <label class="cd-field"><span>Presupuesto (€)</span><input name="budget_amount" type="number" min="0" step="0.01" /></label>
              <label class="cd-field"><span>Tipología</span><input name="typology" type="text" /></label>
              <label class="cd-field"><span>Localización preferida</span><input name="preferred_location" type="text" /></label>
              <label class="cd-field"><span>Descartado por</span><input name="discarded_by" type="text" /></label>
              <span class="cd-section-divider">Notas</span>
              <label class="cd-field" style="grid-column:span 2"><span>Comentarios</span><textarea name="comments" rows="3"></textarea></label>
              <label class="cd-field" style="grid-column:span 2"><span>Reporte</span><textarea name="report_notes" rows="3"></textarea></label>
              <label class="cd-field" style="grid-column:span 2"><span>Visita</span><textarea name="visit_notes" rows="3"></textarea></label>
              <label class="cd-field" style="grid-column:span 2"><span>Reserva</span><textarea name="reservation_notes" rows="3"></textarea></label>
              <label class="cd-field" style="grid-column:span 2"><span>Otros</span><textarea name="other_notes" rows="3"></textarea></label>
              <span class="cd-section-divider">Roles</span>
              <label class="cd-checkbox-label"><input name="as_provider" type="checkbox" /> Marcar como proveedor</label>
              <label class="cd-checkbox-label"><input name="as_agency" type="checkbox" /> Marcar como agencia</label>
              <label class="cd-field"><span>Código proveedor</span><input name="provider_code" type="text" /></label>
              <label class="cd-field">
                <span>Tipo proveedor</span>
                <select name="provider_type">
                  <option value="developer">Developer</option>
                  <option value="promoter">Promotor</option>
                  <option value="constructor">Constructor</option>
                  <option value="architect">Arquitecto</option>
                  <option value="agency">Agencia</option>
                  <option value="owner">Propietario</option>
                  <option value="other">Otro</option>
                </select>
              </label>
              <label class="cd-field">
                <span>Estado proveedor</span>
                <select name="provider_status">
                  <option value="active">Activo</option>
                  <option value="inactive">Inactivo</option>
                </select>
              </label>
              <label class="cd-checkbox-label"><input name="provider_is_billable" type="checkbox" /> Proveedor facturable</label>
              <label class="cd-field" style="grid-column:span 2"><span>Notas proveedor</span><textarea name="provider_notes" rows="2"></textarea></label>
              <label class="cd-field"><span>Código agencia</span><input name="agency_code" type="text" /></label>
              <label class="cd-field">
                <span>Scope agencia</span>
                <select name="agency_scope">
                  <option value="buyer">Comprador</option>
                  <option value="seller">Vendedor</option>
                  <option value="rental">Alquiler</option>
                  <option value="mixed">Mixto</option>
                </select>
              </label>
              <label class="cd-field">
                <span>Estado agencia</span>
                <select name="agency_status">
                  <option value="active">Activo</option>
                  <option value="inactive">Inactivo</option>
                  <option value="discarded">Descartado</option>
                </select>
              </label>
              <label class="cd-checkbox-label"><input name="agency_is_referral_source" type="checkbox" /> Fuente de referidos</label>
              <label class="cd-field" style="grid-column:span 2"><span>Notas agencia</span><textarea name="agency_notes" rows="2"></textarea></label>
            </div>
            <div class="cd-form-actions">
              <button type="submit" class="cd-btn cd-btn-primary">Guardar Cambios</button>
              <button type="button" id="client-edit-cancel2" class="cd-btn cd-btn-ghost">Cancelar</button>
            </div>
          </form>
        </div>

      </div><!-- /col-main -->

      <!-- RIGHT SIDEBAR -->
      <div class="cd-col-sidebar">

        <!-- Propiedad asignada -->
        <div class="cd-card">
          <div class="cd-card-header">
            <h3 class="cd-card-title">Propiedad Asignada</h3>
          </div>
          <p id="client-assignment-summary" class="cd-empty">Cargando...</p>
          <div id="client-linked-projects-block" style="margin-top:0.75rem" hidden>
            <span class="cd-label">Promociones vinculadas</span>
            <ul id="client-linked-projects" style="margin:0.5rem 0 0;padding-left:1.25rem;list-style:disc;font-size:0.875rem;color:#14324d;line-height:1.6"></ul>
          </div>
          <form id="client-property-form" class="cd-form" style="margin-top:1.25rem">
            <label class="cd-field">
              <span>Vivienda asignada</span>
              <select id="client-property-id" name="property_id">
                <option value="">Sin asignar</option>
              </select>
            </label>
            <label class="cd-field">
              <span>Rol comprador</span>
              <select name="buyer_role">
                <option value="primary">Titular</option>
                <option value="co_buyer">Cotitular</option>
                <option value="legal_representative">Representante legal</option>
                <option value="other">Otro</option>
              </select>
            </label>
            <label class="cd-field">
              <span>Notas de asignación</span>
              <textarea name="notes" rows="2" placeholder="Observaciones..."></textarea>
            </label>
            <div class="cd-form-actions">
              <button type="submit" class="cd-btn cd-btn-primary" style="flex:1">Guardar asignación</button>
              <button id="client-property-clear" type="button" class="cd-btn cd-btn-ghost">Quitar</button>
            </div>
          </form>
        </div>

        <!-- Documentación -->
        <div class="cd-card">
          <div class="cd-card-header">
            <h3 class="cd-card-title">Documentación</h3>
          </div>
          <div id="client-docs-list" style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:1.25rem">
            <p class="cd-empty">Cargando documentos...</p>
          </div>
          <form id="client-doc-form" class="cd-form">
            <label class="cd-field">
              <span>Tipo de documento</span>
              <select name="document_kind">
                <option value="dni_front">DNI anverso</option>
                <option value="dni_back">DNI reverso</option>
                <option value="nie_front">NIE anverso</option>
                <option value="nie_back">NIE reverso</option>
                <option value="passport">Pasaporte</option>
                <option value="cif">CIF</option>
                <option value="bank_proof">Justificante bancario</option>
                <option value="reservation">Reserva</option>
                <option value="contract">Contrato</option>
                <option value="authorization">Autorización</option>
                <option value="other">Otro</option>
              </select>
            </label>
            <label class="cd-field">
              <span>Contexto</span>
              <select name="subject_type">
                <option value="client">Cliente</option>
                <option value="provider">Proveedor</option>
                <option value="agency">Agencia</option>
                <option value="other">Otro</option>
              </select>
            </label>
            <label class="cd-field"><span>Título</span><input name="title" type="text" placeholder="DNI cliente - marzo 2026" /></label>
            <label class="cd-checkbox-label"><input name="is_private" type="checkbox" checked /> Documento privado</label>
            <label class="cd-field"><span>Archivo</span><input name="file" type="file" accept=".pdf,.png,.jpg,.jpeg,.webp,.doc,.docx" style="height:auto;padding:0.4rem" /></label>
            <button type="submit" class="cd-btn cd-btn-primary" style="width:100%;justify-content:center">Subir documento</button>
          </form>
        </div>

        <!-- Timeline -->
        <div class="cd-card">
          <div class="cd-card-header">
            <h3 class="cd-card-title">Historial</h3>
          </div>
          <div id="client-timeline" class="cd-timeline">
            <p class="cd-empty">Cargando...</p>
          </div>
        </div>

        <!-- Feedback -->
        <p id="client-detail-feedback" class="cd-feedback"></p>

      </div><!-- /col-sidebar -->

    </div><!-- /grid -->

  </div><!-- /cd-page -->

  <script is:inline define:vars={{ clientId }}>
    window.__crmClientDetailId = clientId;
  </script>
  <script is:inline src="/crm/client-detail.js"></script>
</CrmLayout>
