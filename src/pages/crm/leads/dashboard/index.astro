---
import CrmLayout from "@/layouts/CrmLayout.astro";
---
<CrmLayout title="CRM | Leads | Dashboard" section="leads">
  <div class="crm-stack crm-leads-dashboard">
    <header class="crm-dashboard-header">
      <h1>Dashboard KPI de leads</h1>
      <p>
        Vista ejecutiva de captacion: volumen, calidad de tratamiento y mezcla por promocion, canal y nacionalidad.
      </p>
      <form id="leads-dashboard-filters" class="crm-dashboard-filters">
        <label>Ambito
          <select id="leads-dashboard-project-select">
            <option value="">Todas las promociones</option>
          </select>
        </label>
        <label>Origen
          <select id="leads-dashboard-origin-select">
            <option value="">Todos los origenes</option>
          </select>
        </label>
        <label>Canal detallado
          <select id="leads-dashboard-source-select">
            <option value="">Todos los canales</option>
          </select>
        </label>
        <label>Nacionalidad
          <select id="leads-dashboard-nationality-select">
            <option value="">Todas las nacionalidades</option>
          </select>
        </label>
        <div class="crm-filter-actions">
          <button type="submit" class="crm-button crm-button-primary">Aplicar filtros</button>
          <button id="leads-dashboard-reset" type="button" class="crm-button crm-button-soft">
            Ver todo
          </button>
          <button id="leads-dashboard-customize-toggle" type="button" class="crm-button crm-button-soft">
            Personalizar
          </button>
        </div>
      </form>
    </header>
      <p id="leads-dashboard-context" class="crm-inline-note">Preparando filtros...</p>
      <section id="leads-dashboard-layout-panel" class="crm-layout-panel">
        <div class="crm-layout-panel-head">
          <div>
            <h3>Vista personal del dashboard</h3>
            <p class="crm-inline-note">
              Los cambios se guardan por usuario y organizacion. Puedes ocultar, reordenar y crear widgets guiados.
            </p>
          </div>
          <button id="leads-dashboard-customize-close" type="button" class="crm-button crm-button-soft">
            Cerrar
          </button>
        </div>

        <div class="crm-layout-panel-grid">
          <article class="crm-layout-panel-card">
            <h4>KPIs fijos</h4>
            <div id="leads-dashboard-kpi-layout-list" class="crm-layout-list">
              <p class="crm-inline-note">Cargando widgets KPI...</p>
            </div>
          </article>

          <article class="crm-layout-panel-card">
            <h4>Graficos fijos</h4>
            <div id="leads-dashboard-chart-layout-list" class="crm-layout-list">
              <p class="crm-inline-note">Cargando widgets de grafico...</p>
            </div>
          </article>
        </div>

        <article class="crm-layout-panel-card crm-layout-panel-card-wide">
          <h4>Crear widget personalizado</h4>
          <form id="leads-dashboard-custom-widget-form" class="crm-form crm-form-compact">
            <label>Titulo
              <input
                id="leads-dashboard-custom-widget-title"
                name="title"
                type="text"
                placeholder="Ej. Top canales por volumen"
              />
            </label>
            <label>Dimension
              <select id="leads-dashboard-custom-widget-dataset" name="dataset">
                <option value="source">Canal detallado</option>
                <option value="origin_type">Familia de origen</option>
                <option value="status">Estado comercial</option>
                <option value="project">Promocion</option>
                <option value="nationality">Nacionalidad</option>
              </select>
            </label>
            <label>Tipo de grafico
              <select id="leads-dashboard-custom-widget-chart-type" name="chart_type"></select>
            </label>
            <div class="crm-actions-row">
              <button type="submit" class="crm-button crm-button-soft">Crear widget</button>
            </div>
          </form>
          <p id="leads-dashboard-custom-widget-help" class="crm-inline-note">
            Elige una dimension y el tipo de visualizacion disponible para ese dataset.
          </p>
        </article>

        <article class="crm-layout-panel-card crm-layout-panel-card-wide">
          <h4>Widgets personalizados</h4>
          <div id="leads-dashboard-custom-layout-list" class="crm-layout-list">
            <p class="crm-inline-note">Todavia no hay widgets personalizados.</p>
          </div>
        </article>
      </section>
    </section>

    <section class="crm-grid crm-leads-kpi-grid" aria-live="polite">
      <article class="crm-card crm-kpi crm-kpi-highlight" data-dashboard-section="kpis" data-widget-id="total">
        <div class="crm-kpi-head">
          <p>Total leads</p>
          <button
            class="crm-kpi-help"
            type="button"
            data-help="Total de leads visibles en el filtro actual."
          >
            ?
          </button>
        </div>
        <strong id="leads-kpi-total">0</strong>
        <small class="crm-kpi-sub">Volumen global de captacion</small>
      </article>

      <article class="crm-card crm-kpi" data-dashboard-section="kpis" data-widget-id="new">
        <div class="crm-kpi-head">
          <p>Nuevos</p>
          <button
            class="crm-kpi-help"
            type="button"
            data-help="Leads en estado Nuevo sin gestion comercial iniciada."
          >
            ?
          </button>
        </div>
        <strong id="leads-kpi-new">0</strong>
        <small class="crm-kpi-sub">Pendientes de primer contacto</small>
      </article>

      <article class="crm-card crm-kpi" data-dashboard-section="kpis" data-widget-id="treated">
        <div class="crm-kpi-head">
          <p>Tratados</p>
          <button
            class="crm-kpi-help"
            type="button"
            data-help="Leads en cualquier estado distinto de Nuevo."
          >
            ?
          </button>
        </div>
        <strong id="leads-kpi-treated">0</strong>
        <small class="crm-kpi-sub">Con actividad comercial</small>
      </article>

      <article class="crm-card crm-kpi" data-dashboard-section="kpis" data-widget-id="untreated">
        <div class="crm-kpi-head">
          <p>No tratados</p>
          <button
            class="crm-kpi-help"
            type="button"
            data-help="Leads sin tratar: estado Nuevo."
          >
            ?
          </button>
        </div>
        <strong id="leads-kpi-untreated">0</strong>
        <small class="crm-kpi-sub">Backlog de gestion comercial</small>
      </article>

      <article class="crm-card crm-kpi" data-dashboard-section="kpis" data-widget-id="treated_rate">
        <div class="crm-kpi-head">
          <p>% tratamiento</p>
          <button
            class="crm-kpi-help"
            type="button"
            data-help="Porcentaje de leads tratados sobre el total visible."
          >
            ?
          </button>
        </div>
        <strong id="leads-kpi-treated-rate">0%</strong>
        <small class="crm-kpi-sub">Nivel de cobertura comercial</small>
      </article>

      <article class="crm-card crm-kpi" data-dashboard-section="kpis" data-widget-id="top_origin">
        <div class="crm-kpi-head">
          <p>Canal lider</p>
          <button
            class="crm-kpi-help"
            type="button"
            data-help="Canal detallado de entrada con mayor volumen de leads."
          >
            ?
          </button>
        </div>
        <strong id="leads-kpi-top-origin">-</strong>
        <small class="crm-kpi-sub">Principal canal real de captacion</small>
      </article>
    </section>

    <section class="crm-grid">
      <article class="crm-card crm-half" data-dashboard-section="charts" data-widget-id="origin_donut">
        <h3>Canales de entrada</h3>
        <p class="crm-inline-note">Distribucion porcentual por canal detallado real del lead.</p>
        <div class="crm-channel-layout">
          <div class="crm-chart-wrap">
            <div id="leads-chart-origin-donut" class="crm-chart-surface crm-chart-surface-compact">
              <p class="crm-inline-note">Cargando grafico de canales...</p>
            </div>
          </div>
          <ul id="leads-chart-origin-legend" class="crm-metric-list">
            <li>Sin datos</li>
          </ul>
        </div>
      </article>

      <article class="crm-card crm-half" data-dashboard-section="charts" data-widget-id="treated_bars">
        <h3>Tratados vs no tratados</h3>
        <p class="crm-inline-note">Comparativa operativa del estado de gestion.</p>
        <div id="leads-chart-treated-bars" class="crm-chart-surface">
          <p class="crm-inline-note">Sin datos de gestion.</p>
        </div>
      </article>

      <article class="crm-card crm-half" data-dashboard-section="charts" data-widget-id="projects_3d">
        <h3>Top promociones (3D)</h3>
        <p class="crm-inline-note">Ranking de volumen por promocion (visualizacion 3D).</p>
        <div id="leads-chart-projects-3d" class="crm-chart-list"></div>
      </article>

      <article class="crm-card crm-half" data-dashboard-section="charts" data-widget-id="sources_treemap">
        <h3>Familias de origen</h3>
        <p class="crm-inline-note">Mapa de peso relativo por familia agregada de canal.</p>
        <div id="leads-chart-sources-treemap" class="crm-chart-surface">
          <p class="crm-inline-note">Sin fuentes registradas.</p>
        </div>
      </article>

      <article class="crm-card crm-full" data-dashboard-section="charts" data-widget-id="status_funnel">
        <h3>Embudo por estado</h3>
        <p class="crm-inline-note">Distribucion de leads por etapa comercial.</p>
        <div id="leads-chart-status-funnel" class="crm-chart-surface crm-chart-surface-wide">
          <p class="crm-inline-note">Sin estados disponibles.</p>
        </div>
      </article>

      <article class="crm-card crm-full" data-dashboard-section="charts" data-widget-id="nationalities_radar">
        <h3>Radar de nacionalidades</h3>
        <p class="crm-inline-note">Comparativa de volumen entre las nacionalidades dominantes.</p>
        <div id="leads-chart-nationalities-radar" class="crm-chart-surface crm-chart-surface-wide">
          <p class="crm-inline-note">Sin nacionalidades registradas.</p>
        </div>
      </article>
    </section>

    <section id="leads-dashboard-custom-grid" class="crm-grid" hidden></section>

    <section class="crm-card crm-full">
      <p id="leads-dashboard-feedback" class="crm-feedback">Cargando dashboard...</p>
    </section>
  </div>
  <style>
    .crm-leads-dashboard .crm-form.crm-form-compact {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      align-items: end;
      margin-top: 0.9rem;
    }

    .crm-layout-panel {
      margin-top: 1.5rem;
      border: 1px solid rgba(255, 255, 255, 0.4);
      border-radius: 24px;
      padding: 2rem;
      display: none;
      gap: 1.5rem;
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(20px) saturate(180%);
      box-shadow: 
        0 20px 40px -15px rgba(0, 0, 0, 0.1),
        0 0 0 1px rgba(18, 38, 58, 0.05),
        inset 0 0 0 1px rgba(255, 255, 255, 0.4);
      animation: crmFadeSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes crmFadeSlideUp {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .crm-layout-panel.is-visible {
      display: grid;
    }

    .crm-layout-panel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(18, 38, 58, 0.05);
    }

    .crm-layout-panel-head h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--crm-primary);
      margin: 0;
    }

    .crm-layout-panel-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.2rem;
    }

    .crm-layout-panel-card {
      border: 1px solid rgba(18, 38, 58, 0.05);
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.5);
      padding: 1.2rem;
      display: grid;
      gap: 1rem;
    }

    .crm-layout-panel-card-wide {
      grid-column: 1 / -1;
    }

    .crm-layout-panel-card h4 {
      margin: 0;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 600;
      color: #64748b;
    }

    .crm-layout-list {
      display: grid;
      gap: 0.75rem;
    }

    .crm-layout-item {
      border: 1px solid rgba(18, 38, 58, 0.08);
      border-radius: 12px;
      background: #fff;
      padding: 1rem 1.25rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      cursor: grab;
    }

    .crm-layout-item:active {
      cursor: grabbing;
    }

    .crm-layout-item:hover {
      border-color: var(--crm-primary);
      box-shadow: 0 10px 20px -5px rgba(15, 31, 51, 0.08);
      transform: translateY(-2px);
    }

    .crm-layout-item-top {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      flex: 1;
    }

    .crm-layout-item-label {
      font-weight: 600;
      color: var(--crm-primary);
      margin: 0;
      font-size: 0.95rem;
    }

    .crm-layout-item-meta {
      font-size: 0.8rem;
      color: #64748b;
      margin: 0;
    }

    .crm-layout-item-actions {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .crm-layout-item-actions .crm-button {
      width: 34px;
      height: 34px;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 9px;
      background: transparent;
      border: 1px solid transparent;
      color: #64748b;
      transition: all 0.2s;
    }

    .crm-layout-item-actions .crm-button svg {
      width: 18px;
      height: 18px;
    }

    .crm-layout-item-actions .crm-button:hover {
      background: var(--crm-primary-soft);
      color: var(--crm-primary);
      border-color: rgba(var(--crm-primary-rgb), 0.1);
    }

    .crm-layout-item-actions .crm-button[data-layout-action="toggle"].is-hidden {
      color: #cbd5e1;
    }

    .crm-custom-widget-grid {
      display: grid;
      gap: 0.75rem;
    }

    .crm-custom-widget-grid .crm-chart-surface {
      margin-top: 0;
    }

    .crm-custom-widget-title {
      margin: 0;
    }

    .crm-custom-widget-subtitle {
      margin: 0;
      color: var(--crm-muted);
      font-size: 0.78rem;
      font-weight: 600;
    }

    .crm-leads-dashboard .crm-leads-kpi-grid {
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 0.62rem;
    }

    .crm-leads-dashboard .crm-leads-kpi-grid .crm-kpi {
      grid-column: span 1;
      min-height: 110px;
      padding: 1rem 1.25rem;
      background: linear-gradient(180deg, #fff 0%, #f9fbff 100%);
      border: 1px solid rgba(18, 38, 58, 0.08);
      border-radius: 16px;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
      transition: all 0.3s ease;
    }

    .crm-leads-dashboard .crm-leads-kpi-grid .crm-kpi:hover {
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04);
      border-color: rgba(59, 130, 246, 0.15);
    }

    .crm-leads-dashboard .crm-leads-kpi-grid .crm-kpi-highlight {
      background: linear-gradient(180deg, #f0f7ff 0%, #e0efff 100%);
      border-color: rgba(59, 130, 246, 0.2);
    }

    .crm-leads-dashboard .crm-leads-kpi-grid .crm-kpi strong {
      font-size: 1.5rem;
      margin-bottom: 0.25rem;
      line-height: 1;
      color: var(--crm-primary);
      letter-spacing: -0.02em;
    }

    .crm-kpi-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.55rem;
      margin-bottom: 0.34rem;
    }

    .crm-kpi-head p {
      margin: 0;
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--crm-muted);
      font-weight: 700;
      line-height: 1.2;
    }

    .crm-kpi-help {
      width: 1.3rem;
      height: 1.3rem;
      border: 1px solid #c4d3e7;
      border-radius: 999px;
      background: #f2f6fd;
      color: var(--crm-primary);
      font-size: 0.8rem;
      font-weight: 800;
      line-height: 1;
      cursor: help;
      position: relative;
      flex: 0 0 auto;
    }

    .crm-kpi-help:focus-visible {
      outline: none;
      box-shadow: 0 0 0 3px rgba(20, 50, 77, 0.18);
    }

    .crm-kpi-help::before {
      content: "";
      position: absolute;
      top: calc(100% + 0.18rem);
      right: 0.34rem;
      border-width: 0.3rem;
      border-style: solid;
      border-color: transparent transparent #0f1f33 transparent;
      opacity: 0;
      transform: translateY(-4px);
      transition: opacity 0.15s ease, transform 0.15s ease;
      pointer-events: none;
      z-index: 15;
    }

    .crm-kpi-help::after {
      content: attr(data-help);
      position: absolute;
      top: calc(100% + 0.75rem);
      right: 0;
      width: min(320px, 78vw);
      padding: 0.55rem 0.64rem;
      border-radius: 9px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: #0f1f33;
      color: #f5f8ff;
      font-size: 0.74rem;
      font-weight: 600;
      line-height: 1.35;
      text-align: left;
      opacity: 0;
      transform: translateY(-4px);
      transition: opacity 0.15s ease, transform 0.15s ease;
      pointer-events: none;
      z-index: 14;
      white-space: normal;
    }

    .crm-kpi-help:hover::before,
    .crm-kpi-help:hover::after,
    .crm-kpi-help:focus-visible::before,
    .crm-kpi-help:focus-visible::after {
      opacity: 1;
      transform: translateY(0);
    }

    .crm-kpi-sub {
      color: var(--crm-muted);
      font-size: 0.7rem;
      font-weight: 600;
    }

    .crm-channel-layout {
      margin-top: 0.85rem;
      display: grid;
      grid-template-columns: minmax(280px, 1fr) minmax(260px, 1fr);
      gap: 1rem;
      align-items: stretch;
    }

    .crm-chart-wrap {
      min-width: 0;
    }

    .crm-dashboard-header {
      background: linear-gradient(135deg, #ffffff 0%, #f8faff 100%);
      border: 1px solid rgba(18, 38, 58, 0.08);
      border-radius: 20px;
      padding: 2.5rem;
      margin-bottom: 2rem;
      box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04);
      position: relative;
      overflow: hidden;
    }

    .crm-dashboard-header::before {
      content: "";
      position: absolute;
      top: -50%;
      right: -10%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(59, 130, 246, 0.03) 0%, transparent 70%);
      pointer-events: none;
    }

    .crm-dashboard-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      color: var(--crm-primary);
      margin: 0 0 0.5rem 0;
      letter-spacing: -0.025em;
    }

    .crm-dashboard-header p {
      font-size: 1.1rem;
      color: #64748b;
      margin: 0;
      max-width: 600px;
      line-height: 1.6;
    }

    .crm-dashboard-filters {
      margin-top: 2rem;
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      gap: 1.5rem;
      background: rgba(255, 255, 255, 0.5);
      backdrop-filter: blur(8px);
      padding: 1.5rem;
      border-radius: 16px;
      border: 1px solid rgba(18, 38, 58, 0.05);
    }

    .crm-dashboard-filters label {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.025em;
    }

    .crm-dashboard-filters select {
      min-width: 200px;
      height: 44px;
      padding: 0 1rem;
      border-radius: 10px;
      border: 1px solid rgba(18, 38, 58, 0.1);
      background: #fff;
      font-weight: 500;
      color: var(--crm-primary);
      transition: all 0.2s;
      cursor: pointer;
    }

    .crm-dashboard-filters select:hover {
      border-color: var(--crm-primary-soft);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .crm-dashboard-filters select:focus {
      outline: none;
      border-color: var(--crm-primary);
      box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
    }

    .crm-filter-actions {
      display: flex;
      gap: 0.75rem;
      margin-left: auto;
    }

    .crm-filter-actions .crm-button {
      height: 44px;
      padding: 0 1.5rem;
      border-radius: 10px;
      font-weight: 600;
      transition: all 0.2s;
    }

    .crm-filter-actions .crm-button-primary {
      background: var(--crm-primary);
      color: #white;
      box-shadow: 0 4px 12px rgba(13, 31, 48, 0.15);
    }

    .crm-filter-actions .crm-button-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgba(13, 31, 48, 0.2);
    }

    .crm-dashboard-meta {
      margin-top: 1rem;
      font-size: 0.85rem;
      color: #94a3b8;
      font-weight: 500;
      padding-left: 0.5rem;
    }

    .crm-chart-surface {
      margin-top: 0.85rem;
      min-height: 290px;
      border: 1px solid var(--crm-border);
      border-radius: 12px;
      background: var(--crm-surface-soft);
      padding: 0.65rem;
      box-shadow: inset 0 0 0 1px rgba(18, 38, 58, 0.04);
    }

    .crm-chart-surface-compact {
      min-height: 250px;
    }

    .crm-chart-surface-wide {
      min-height: 320px;
    }

    .crm-metric-list {
      margin: 0;
