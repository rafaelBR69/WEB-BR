---
import CrmLayout from "@/layouts/CrmLayout.astro";

const agencyId = String(Astro.params.id ?? "").trim();
const backUrl = `/crm/agencies/${Astro.url.search}`;
---
<CrmLayout title="CRM | Ficha de Agencia" section="agencies">
  <div class="crm-stack crm-agency-detail">
    <section class="crm-card crm-full">
      <div class="crm-row-between" style="gap:1rem;align-items:flex-start;flex-wrap:wrap">
        <div>
          <a href={backUrl} class="crm-link">&larr; Volver al listado</a>
          <p class="crm-context-eyebrow" style="margin-top:0.5rem">Agencia</p>
          <h2 id="agency-detail-title" style="margin:0 0 0.35rem">Cargando agencia...</h2>
          <p id="agency-detail-meta" class="crm-inline-note">Preparando contexto comercial.</p>
        </div>
        <nav class="crm-links crm-subpage-links" aria-label="Navegacion modulo agencias">
          <a class="crm-link" href="/crm/agencies/">Listado</a>
          <a class="crm-link" href="/crm/agencies/dashboard/">Dashboard</a>
          <a class="crm-link" href="/crm/agencies/contacts/">Contactos</a>
        </nav>
      </div>
    </section>

    <section class="crm-card crm-full">
      <div class="crm-row-between" style="gap:1rem;align-items:flex-start;flex-wrap:wrap">
        <div>
          <h3 style="margin:0 0 0.35rem">Gestion de agencia</h3>
          <p class="crm-inline-note" style="margin:0">Edita la agencia base, su contacto principal y el estado comercial.</p>
        </div>
      </div>
      <form id="agency-edit-form" class="crm-form crm-form-compact" style="margin-top:1rem">
        <label>Nombre agencia
          <input name="full_name" type="text" required />
        </label>
        <label>Agente principal
          <input name="agent_name" type="text" />
        </label>
        <label>Email base
          <input name="email" type="email" />
        </label>
        <label>Telefono base
          <input name="phone" type="tel" />
        </label>
        <label>Estado cliente
          <select name="client_status">
            <option value="active">Activo</option>
            <option value="inactive">Inactivo</option>
            <option value="discarded">Descartado</option>
            <option value="blacklisted">Blacklisted</option>
          </select>
        </label>
        <label>Estado agencia
          <select name="agency_status">
            <option value="active">Activa</option>
            <option value="inactive">Inactiva</option>
            <option value="discarded">Descartada</option>
          </select>
        </label>
        <label>Scope
          <select name="agency_scope">
            <option value="mixed">Mixto</option>
            <option value="buyer">Comprador</option>
            <option value="seller">Vendedor</option>
            <option value="rental">Alquiler</option>
          </select>
        </label>
        <label>Referral source
          <select name="agency_is_referral_source">
            <option value="true">Si</option>
            <option value="false">No</option>
          </select>
        </label>
        <label style="grid-column:1 / -1">Notas
          <textarea name="agency_notes" rows="3"></textarea>
        </label>
        <div class="crm-actions-row">
          <button type="submit" class="crm-button">Guardar cambios</button>
          <button id="agency-archive-button" type="button" class="crm-button crm-button-soft">Archivar agencia</button>
          <p id="agency-edit-status" class="crm-inline-note"></p>
        </div>
      </form>
    </section>

    <section class="crm-card crm-full">
      <div class="crm-row-between" style="gap:1rem;align-items:flex-start;flex-wrap:wrap">
        <div>
          <h3 style="margin:0 0 0.35rem">Nuevo contacto de agencia</h3>
          <p class="crm-inline-note" style="margin:0">Crea agentes/comerciales asociados a esta agencia para poder atribuirles actividad.</p>
        </div>
      </div>
      <form id="agency-contact-create-form" class="crm-form crm-form-compact" style="margin-top:1rem">
        <label>Nombre
          <input name="full_name" type="text" required />
        </label>
        <label>Email
          <input name="email" type="email" />
        </label>
        <label>Telefono
          <input name="phone" type="tel" />
        </label>
        <label>Rol
          <select name="role">
            <option value="agent" selected>Agent</option>
            <option value="principal">Principal</option>
            <option value="assistant">Assistant</option>
            <option value="manager">Manager</option>
          </select>
        </label>
        <label>Principal
          <select name="is_primary">
            <option value="false" selected>No</option>
            <option value="true">Si</option>
          </select>
        </label>
        <label style="grid-column:1 / -1">Notas
          <textarea name="notes" rows="2"></textarea>
        </label>
        <div class="crm-actions-row">
          <button type="submit" class="crm-button crm-button-soft">Crear contacto</button>
          <p id="agency-contact-create-status" class="crm-inline-note"></p>
        </div>
      </form>
    </section>

    <section class="crm-grid crm-agencies-kpi-grid" aria-live="polite">
      <article class="crm-card crm-kpi"><strong id="agency-kpi-attributed">-</strong><small>Registros atribuidos</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-kpi-crm-leads">-</strong><small>Leads CRM</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-kpi-with-identity">-</strong><small>Con identidad</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-kpi-without-identity">-</strong><small>Sin identidad</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-kpi-customer">-</strong><small>Customer / cliente</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-kpi-discarded">-</strong><small>Baja / descartado</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-kpi-converted-clients">-</strong><small>Clientes desde lead</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-kpi-clients">-</strong><small>Clientes vinculados</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-kpi-reserved">-</strong><small>Clientes con reserva</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-kpi-rate">-</strong><small>% registro a cliente</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-kpi-projects">-</strong><small>Proyectos detectados</small></article>
    </section>

    <section class="crm-grid">
      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Pulso mensual</h3>
        <div id="agency-detail-monthly" class="crm-mini-bar-grid">
          <p class="crm-inline-note">Cargando...</p>
        </div>
      </article>

      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Estado de registros</h3>
        <div id="agency-detail-status" class="crm-ranking-list">
          <p class="crm-inline-note">Cargando...</p>
        </div>
      </article>

      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Proyectos relacionados</h3>
        <div id="agency-detail-projects" class="crm-ranking-list">
          <p class="crm-inline-note">Cargando...</p>
        </div>
      </article>

      <article class="crm-card crm-half">
        <div class="crm-row-between" style="gap:1rem;align-items:center;flex-wrap:wrap">
          <h3 style="margin:0">Contactos de la agencia</h3>
          <a class="crm-link" id="agency-detail-contacts-link" href="/crm/agencies/contacts/">Ver todos</a>
        </div>
        <div id="agency-detail-contacts" class="crm-ranking-list" style="margin-top:0.9rem">
          <p class="crm-inline-note">Cargando...</p>
        </div>
      </article>

      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Leads que ha traido</h3>
        <div id="agency-detail-leads" class="crm-ranking-list">
          <p class="crm-inline-note">Cargando...</p>
        </div>
      </article>
    </section>

    <section class="crm-grid">
      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Clientes que ha traido</h3>
        <div id="agency-detail-clients" class="crm-ranking-list">
          <p class="crm-inline-note">Cargando...</p>
        </div>
      </article>

      <article class="crm-card crm-half">
        <h3 style="margin-top:0">Historico atribuido sin ficha CRM</h3>
        <div id="agency-detail-attributed-leads" class="crm-ranking-list">
          <p class="crm-inline-note">Cargando...</p>
        </div>
      </article>
    </section>

    <section class="crm-card crm-full">
      <p id="agency-detail-feedback" class="crm-feedback">Cargando ficha...</p>
    </section>
  </div>

  <style>
    .crm-agencies-kpi-grid {
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    }
    .crm-mini-bar-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 0.9rem;
    }
    .crm-mini-bar-card {
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 16px;
      padding: 0.9rem;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.96));
    }
    .crm-mini-bar-head {
      display: flex;
      justify-content: space-between;
      gap: 0.6rem;
      align-items: baseline;
      margin-bottom: 0.55rem;
      font-size: 0.82rem;
      color: #475569;
    }
    .crm-mini-bar-stack {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }
    .crm-mini-bar-track {
      height: 10px;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.18);
      overflow: hidden;
    }
    .crm-mini-bar-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #0f766e, #14b8a6);
    }
    .crm-mini-bar-fill.is-soft {
      background: linear-gradient(90deg, #2563eb, #60a5fa);
    }
    .crm-mini-bar-fill.is-accent {
      background: linear-gradient(90deg, #ea580c, #fb923c);
    }
    .crm-ranking-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .crm-ranking-item {
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 16px;
      padding: 0.9rem 1rem;
      background: rgba(255,255,255,0.94);
    }
    .crm-ranking-head {
      display: flex;
      justify-content: space-between;
      gap: 0.9rem;
      align-items: center;
      margin-bottom: 0.45rem;
    }
    .crm-ranking-title {
      font-weight: 700;
      color: #0f172a;
      text-decoration: none;
    }
    .crm-ranking-meta {
      color: #64748b;
      font-size: 0.84rem;
    }
    .crm-ranking-bar {
      height: 8px;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.18);
      overflow: hidden;
    }
    .crm-ranking-bar > span {
      display: block;
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #2563eb, #60a5fa);
    }
  </style>

  <script is:inline define:vars={{ agencyId }}>
    window.__crmAgencyId = agencyId;
  </script>
  <script is:inline src="/crm/agency-detail.js"></script>
</CrmLayout>
