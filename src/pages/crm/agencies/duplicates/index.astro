---
import CrmLayout from "@/layouts/CrmLayout.astro";
---
<CrmLayout title="CRM | Duplicados de Agencias" section="agencies">
  <div class="crm-stack">
    <section class="crm-card crm-full">
      <div class="crm-row-between" style="gap:1rem;align-items:flex-start;flex-wrap:wrap">
        <div>
          <p class="crm-context-eyebrow">Agencias</p>
          <h2 style="margin:0 0 0.35rem">Fusion de duplicados</h2>
          <p class="crm-inline-note">
            Cola manual para unificar agencias y contactos duplicados sin depender de scripts. El merge mueve referencias a la canónica antes de borrar la duplicada.
          </p>
        </div>
        <nav class="crm-links crm-subpage-links" aria-label="Navegacion modulo agencias">
          <a class="crm-link" href="/crm/agencies/">Listado</a>
          <a class="crm-link" href="/crm/agencies/dashboard/">Dashboard</a>
          <a class="crm-link" href="/crm/agencies/contacts/">Contactos</a>
          <a class="crm-link is-active" href="/crm/agencies/duplicates/">Duplicados</a>
        </nav>
      </div>
    </section>

    <section class="crm-grid crm-agencies-kpi-grid" aria-live="polite">
      <article class="crm-card crm-kpi"><strong id="agency-duplicates-kpi-agencies">-</strong><small>Grupos agencia</small></article>
      <article class="crm-card crm-kpi"><strong id="agency-duplicates-kpi-contacts">-</strong><small>Grupos contacto</small></article>
    </section>

    <section class="crm-card crm-full">
      <div class="crm-row-between" style="gap:1rem;align-items:flex-start;flex-wrap:wrap">
        <div>
          <h3 style="margin:0 0 0.35rem">Agencias duplicadas</h3>
          <p class="crm-inline-note" id="agency-duplicates-agencies-meta">Cargando grupos de agencias...</p>
        </div>
        <button id="agency-duplicates-refresh" type="button" class="crm-button crm-button-soft">Actualizar</button>
      </div>
      <div id="agency-duplicates-agencies-list" class="crm-stack" style="margin-top:1rem"></div>
    </section>

    <section class="crm-card crm-full">
      <div>
        <h3 style="margin:0 0 0.35rem">Contactos duplicados</h3>
        <p class="crm-inline-note" id="agency-duplicates-contacts-meta">Cargando grupos de contactos...</p>
      </div>
      <div id="agency-duplicates-contacts-list" class="crm-stack" style="margin-top:1rem"></div>
    </section>

    <section class="crm-card crm-full">
      <p id="agency-duplicates-feedback" class="crm-feedback">Modulo listo.</p>
    </section>
  </div>

  <script is:inline src="/crm/agencies-duplicates.js"></script>
</CrmLayout>
